{
  "name": "terraform",
  "version": "0.1.0",
  "description": "Terraform CLI plugin for dcli",
  "source": "https://developer.hashicorp.com/terraform/cli",
  "checks": [
    {
      "type": "binary",
      "name": "terraform"
    }
  ],
  "commands": [
    {
      "namespace": "terraform",
      "resource": "cli",
      "action": "version",
      "description": "Show Terraform CLI version information",
      "adapter": "process",
      "adapterConfig": {
        "command": "terraform",
        "baseArgs": ["version", "-json"],
        "parseJson": true,
        "missingDependencyHelp": "Please install Terraform CLI to use this command."
      },
      "args": []
    },
    {
      "namespace": "terraform",
      "resource": "_",
      "action": "_",
      "description": "Passthrough command to execute any Terraform CLI command",
      "adapter": "process",
      "adapterConfig": {
        "command": "terraform",
        "passthrough": true,
        "parseJson": true,
        "missingDependencyHelp": "Please install Terraform CLI to use this command."
      },
      "args": []
    }
  ]
}
