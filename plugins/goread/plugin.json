{
  "name": "goread",
  "version": "0.1.0",
  "description": "Command line ePub reader for Go",
  "source": "https://github.com/Ray-D-Song/goread",
  "checks": [
    {
      "type": "binary",
      "name": "goread"
    }
  ],
  "install_guidance": {
    "plugin": "goread",
    "binary": "goread",
    "check": "which goread",
    "install_steps": [
      "go install github.com/Ray-D-Song/goread@latest",
      "Verify: goread --version",
      "supercli plugins install ./plugins/goread --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "goread",
      "resource": "self",
      "action": "version",
      "description": "Print goread version",
      "adapter": "process",
      "adapterConfig": {
        "command": "goread",
        "missingDependencyHelp": "Install goread: go install github.com/Ray-D-Song/goread@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "goread",
      "resource": "book",
      "action": "read",
      "description": "read book via goread",
      "adapter": "process",
      "adapterConfig": {
        "command": "goread",
        "missingDependencyHelp": "Install goread: go install github.com/Ray-D-Song/goread@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "goread",
      "resource": "_",
      "action": "_",
      "description": "_ _ via goread",
      "adapter": "process",
      "adapterConfig": {
        "command": "goread",
        "missingDependencyHelp": "Install goread: go install github.com/Ray-D-Song/goread@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}