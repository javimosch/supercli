      "adapter": "process",
      "adapterConfig": {
        "command": "quien",
        "baseArgs": ["dns"],
        "passthrough": true,
        "missingDependencyHelp": "Install quien: brew install retlehs/tap/quien"
      },
      "args": [
        { "name": "domain", "type": "string", "description": "Domain for DNS query", "required": true }
      ]
    },
    {
