{
  "name": "quien",
  "version": "0.1.0",
  "description": "A better WHOIS lookup tool with JSON output and scripting subcommands",
  "source": "https://github.com/retlehs/quien",
  "checks": [
    { "type": "binary", "name": "quien" }
  ],
  "install_guidance": {
    "plugin": "quien",
    "binary": "quien",
    "check": "which quien",
    "install_steps": [
      "brew tap retlehs/tap",
      "brew install retlehs/tap/quien",
      "Verify: quien --version",
      "supercli plugins install ./plugins/quien --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "quien",
      "resource": "self",
      "action": "version",
      "description": "Print quien version",
      "adapter": "process",
      "adapterConfig": {
        "command": "quien",
        "baseArgs": ["--version"],
        "missingDependencyHelp": "Install quien: brew install retlehs/tap/quien"
      },
      "args": []
    },
    {
      "namespace": "quien",
      "resource": "domain",
      "action": "lookup",
      "description": "Domain WHOIS lookup (interactive TUI)",
      "adapter": "process",
      "adapterConfig": {
        "command": "quien",
        "passthrough": true,
        "missingDependencyHelp": "Install quien: brew install retlehs/tap/quien"
      },
      "args": [
        { "name": "domain", "type": "string", "description": "Domain to lookup", "required": true }
      ]
    },
    {
      "namespace": "quien",
      "resource": "ip",
      "action": "lookup",
      "description": "IP address lookup with reverse DNS, ASN, and abuse contacts",
      "adapter": "process",
      "adapterConfig": {
        "command": "quien",
        "passthrough": true,
        "missingDependencyHelp": "Install quien: brew install retlehs/tap/quien"
