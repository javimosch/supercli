{
  "name": "evans",
  "version": "0.1.0",
  "description": "Evans is an expressive, universal gRPC client. More expressive than curl for interacting with gRPC services. Supports reflection, streaming, and more.",
  "source": "https://github.com/ktr0731/evans",
  "checks": [
    { "type": "binary", "name": "evans" }
  ],
  "install_guidance": {
    "plugin": "evans",
    "binary": "evans",
    "check": "which evans",
    "install_steps": [
      "brew install evans",
      "Verify: evans --version",
      "supercli plugins install ./plugins/evans --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "evans",
      "resource": "grpc",
      "action": "call",
      "description": "Call a gRPC method",
      "adapter": "process",
      "adapterConfig": {
        "command": "evans",
        "baseArgs": ["cli"],
        "passthrough": true,
        "missingDependencyHelp": "Install evans: brew install evans"
      },
      "args": [
        { "name": "host", "type": "string", "description": "gRPC server host" },
        { "name": "--port", "type": "integer", "description": "Server port" },
        { "name": "--reflection", "type": "boolean", "description": "Use reflection" },
        { "name": "--proto", "type": "string", "description": "Proto file path" }
      ]
    },
    {
      "namespace": "evans",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to evans CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "evans",
        "passthrough": true,
        "missingDependencyHelp": "Install evans: brew install evans"
      },
      "args": []
    }
  ]
}
