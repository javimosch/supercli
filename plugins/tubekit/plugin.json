{
  "name": "tubekit",
  "version": "0.1.0",
  "description": "kubectl alternative with quick context switching",
  "source": "https://github.com/reconquest/tubekit",
  "checks": [
    {
      "type": "binary",
      "name": "tk"
    }
  ],
  "install_guidance": {
    "plugin": "tubekit",
    "binary": "tk",
    "check": "which tk",
    "install_steps": [
      "go install github.com/reconquest/tubekit@latest",
      "Verify: tk --version",
      "supercli plugins install ./plugins/tubekit --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "tubekit",
      "resource": "self",
      "action": "version",
      "description": "Print tubekit version",
      "adapter": "process",
      "adapterConfig": {
        "command": "tk",
        "missingDependencyHelp": "Install tubekit: go install github.com/reconquest/tubekit@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "tubekit",
      "resource": "context",
      "action": "switch",
      "description": "switch context via tk",
      "adapter": "process",
      "adapterConfig": {
        "command": "tk",
        "missingDependencyHelp": "Install tubekit: go install github.com/reconquest/tubekit@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
