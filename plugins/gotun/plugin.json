{
  "name": "gotun",
  "version": "0.1.0",
  "description": "Create VPN tunnels with ease",
  "source": "https://github.com/Sesame2/gotun",
  "checks": [
    {
      "type": "binary",
      "name": "gotun"
    }
  ],
  "install_guidance": {
    "plugin": "gotun",
    "binary": "gotun",
    "check": "which gotun",
    "install_steps": [
      "go install github.com/Sesame2/gotun@latest",
      "Verify: gotun --version",
      "supercli plugins install ./plugins/gotun --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "gotun",
      "resource": "self",
      "action": "version",
      "description": "Print gotun version",
      "adapter": "process",
      "adapterConfig": {
        "command": "gotun",
        "missingDependencyHelp": "Install gotun: go install github.com/Sesame2/gotun@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "gotun",
      "resource": "tunnel",
      "action": "create",
      "description": "create tunnel via gotun",
      "adapter": "process",
      "adapterConfig": {
        "command": "gotun",
        "missingDependencyHelp": "Install gotun: go install github.com/Sesame2/gotun@latest",
        "baseArgs": [
          "create"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "gotun",
      "resource": "tunnel",
      "action": "list",
      "description": "list tunnel via gotun",
      "adapter": "process",
      "adapterConfig": {
        "command": "gotun",
        "missingDependencyHelp": "Install gotun: go install github.com/Sesame2/gotun@latest",
        "baseArgs": [
          "list"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "gotun",
      "resource": "tunnel",
      "action": "destroy",
      "description": "destroy tunnel via gotun",
      "adapter": "process",
      "adapterConfig": {
        "command": "gotun",
        "missingDependencyHelp": "Install gotun: go install github.com/Sesame2/gotun@latest",
        "baseArgs": [
          "destroy"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "gotun",
      "resource": "_",
      "action": "_",
      "description": "_ _ via gotun",
      "adapter": "process",
      "adapterConfig": {
        "command": "gotun",
        "missingDependencyHelp": "Install gotun: go install github.com/Sesame2/gotun@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}