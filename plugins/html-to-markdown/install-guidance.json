{
  "plugin": "html-to-markdown",
  "binary": "html-to-markdown",
  "check": "which html-to-markdown",
  "install_steps": [
    "go install github.com/JohannesKaufmann/html-to-markdown/cmd/html-to-markdown@latest",
    "Verify: html-to-markdown --version",
    "supercli plugins install ./plugins/html-to-markdown --on-conflict replace --json"
  ]
}