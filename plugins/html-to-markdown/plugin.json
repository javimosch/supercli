{
  "name": "html-to-markdown",
  "version": "0.1.0",
  "description": "Convert HTML to Markdown from the command line",
  "source": "https://github.com/JohannesKaufmann/html-to-markdown",
  "checks": [
    {
      "type": "binary",
      "name": "html-to-markdown"
    }
  ],
  "install_guidance": {
    "plugin": "html-to-markdown",
    "binary": "html-to-markdown",
    "check": "which html-to-markdown",
    "install_steps": [
      "go install github.com/JohannesKaufmann/html-to-markdown/cmd/html-to-markdown@latest",
      "Verify: html-to-markdown --version",
      "supercli plugins install ./plugins/html-to-markdown --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "html-to-markdown",
      "resource": "self",
      "action": "version",
      "description": "Print html-to-markdown version",
      "adapter": "process",
      "adapterConfig": {
        "command": "html-to-markdown",
        "missingDependencyHelp": "Install html-to-markdown: go install github.com/JohannesKaufmann/html-to-markdown/cmd/html-to-markdown@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "html-to-markdown",
      "resource": "file",
      "action": "convert",
      "description": "convert file via html-to-markdown",
      "adapter": "process",
      "adapterConfig": {
        "command": "html-to-markdown",
        "missingDependencyHelp": "Install html-to-markdown: go install github.com/JohannesKaufmann/html-to-markdown/cmd/html-to-markdown@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "html-to-markdown",
      "resource": "_",
      "action": "_",
      "description": "_ _ via html-to-markdown",
      "adapter": "process",
      "adapterConfig": {
        "command": "html-to-markdown",
        "missingDependencyHelp": "Install html-to-markdown: go install github.com/JohannesKaufmann/html-to-markdown/cmd/html-to-markdown@latest",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}