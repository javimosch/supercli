      "description": "install node via snm",
      "adapter": "process",
      "adapterConfig": {
        "command": "snm",
        "missingDependencyHelp": "Install snm: cargo install snm",
        "baseArgs": [
          "install"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
