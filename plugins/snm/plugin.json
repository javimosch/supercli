{
  "name": "snm",
  "version": "0.1.0",
  "description": "Smol and simple Node.js version manager written in Rust",
  "source": "https://github.com/numToStr/snm",
  "checks": [
    {
      "type": "binary",
      "name": "snm"
    }
  ],
  "install_guidance": {
    "plugin": "snm",
    "binary": "snm",
    "check": "which snm",
    "install_steps": [
      "cargo install snm",
      "Verify: snm --version",
      "supercli plugins install ./plugins/snm --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "snm",
      "resource": "self",
      "action": "version",
      "description": "Print snm version",
      "adapter": "process",
      "adapterConfig": {
        "command": "snm",
        "missingDependencyHelp": "Install snm: cargo install snm",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
