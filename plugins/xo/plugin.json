{
  "name": "xo",
  "version": "0.1.0",
  "description": "Command line utility that composes regular expression matches",
  "source": "https://github.com/ezekg/xo",
  "checks": [
    {
      "type": "binary",
      "name": "xo"
    }
  ],
  "install_guidance": {
    "plugin": "xo",
    "binary": "xo",
    "check": "which xo",
    "install_steps": [
      "go install github.com/ezekg/xo@latest",
      "Verify: xo --version",
      "supercli plugins install ./plugins/xo --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "xo",
      "resource": "self",
      "action": "version",
      "description": "Print xo version",
      "adapter": "process",
      "adapterConfig": {
        "command": "xo",
        "missingDependencyHelp": "Install xo: go install github.com/ezekg/xo@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "xo",
      "resource": "pattern",
      "action": "match",
      "description": "match pattern via xo",
      "adapter": "process",
      "adapterConfig": {
        "command": "xo",
        "missingDependencyHelp": "Install xo: go install github.com/ezekg/xo@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "xo",
      "resource": "pattern",
      "action": "replace",
      "description": "replace pattern via xo",
      "adapter": "process",
      "adapterConfig": {
        "command": "xo",
        "missingDependencyHelp": "Install xo: go install github.com/ezekg/xo@latest",
        "baseArgs": [
          "--replace"
        ],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "xo",
      "resource": "_",
      "action": "_",
      "description": "_ _ via xo",
      "adapter": "process",
      "adapterConfig": {
        "command": "xo",
        "missingDependencyHelp": "Install xo: go install github.com/ezekg/xo@latest",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}