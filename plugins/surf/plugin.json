{
  "name": "surf",
  "version": "1.0.0",
  "description": "CLI for AI agents to control Chrome",
  "commands": [
    {
      "name": "version",
      "description": "Get surf CLI version",
      "command": "surf --version"
    },
    {
      "name": "browse",
      "description": "Navigate to a URL",
      "command": "surf browse <url>"
    },
    {
      "name": "screenshot",
      "description": "Take a screenshot of the current page",
      "command": "surf screenshot"
    },
    {
      "name": "evaluate",
      "description": "Execute JavaScript in the browser",
      "command": "surf evaluate <script>"
    }
  ]
}
