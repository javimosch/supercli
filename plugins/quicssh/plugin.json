{
  "name": "quicssh",
  "version": "0.1.0",
  "description": "SSH over QUIC protocol",
  "source": "https://github.com/moul/quicssh",
  "checks": [
    { "type": "binary", "name": "quicssh" }
  ],
  "install_guidance": {
    "plugin": "quicssh",
    "binary": "quicssh",
    "check": "which quicssh",
    "install_steps": [
      "go install github.com/moul/quicssh/cmd/quicssh@latest",
      "Verify: quicssh --help",
      "supercli plugins install ./plugins/quicssh --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "quicssh",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to quicssh CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "quicssh",
        "cwd": "invoke_cwd",
        "passthrough": true,
        "missingDependencyHelp": "Install quicssh: go install github.com/moul/quicssh/cmd/quicssh@latest"
      },
      "args": []
    }
  ]
}
