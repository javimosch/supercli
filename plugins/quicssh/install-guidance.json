{
  "plugin": "quicssh",
  "binary": "quicssh",
  "check": "which quicssh",
  "install_steps": [
    "go install github.com/moul/quicssh/cmd/quicssh@latest",
    "Verify: quicssh --help",
    "supercli plugins install ./plugins/quicssh --on-conflict replace --json"
  ],
  "note": "quicssh provides SSH over QUIC protocol"
}
