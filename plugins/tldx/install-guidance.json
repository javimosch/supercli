{
  "plugin": "tldx",
  "binary": "tldx",
  "check": "which tldx",
  "install_steps": [
    "go install github.com/brandonyoungdev/tldx@latest",
    "Verify: tldx --help",
    "supercli plugins install ./plugins/tldx --on-conflict replace --json"
  ],
  "note": "tldx checks domain availability with RDAP and supports multiple output formats"
}
