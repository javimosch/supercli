{
  "name": "yaml-convert",
  "version": "0.1.0",
  "description": "Command-line utility for converting between YAML and JSON",
  "source": "https://github.com/eemeli/yaml-convert",
  "checks": [
    { "type": "binary", "name": "yaml-convert" }
  ],
  "install_guidance": {
    "plugin": "yaml-convert",
    "binary": "yaml-convert",
    "check": "which yaml-convert",
    "install_steps": [
      "npm install -g yaml-convert",
      "Verify: yaml-convert --help",
      "supercli plugins install ./plugins/yaml-convert --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "yaml-convert",
      "resource": "file",
      "action": "convert",
      "description": "Convert between YAML and JSON",
      "adapter": "process",
      "adapterConfig": {
        "command": "yaml-convert",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 60000,
        "missingDependencyHelp": "Install yaml-convert: npm install -g yaml-convert"
      },
      "args": [
        { "name": "input", "type": "string", "required": false, "description": "Input file (use - for stdin)" },
        { "name": "output", "type": "string", "required": false, "description": "Output file (use - for stdout)" },
        { "name": "json", "type": "boolean", "required": false, "description": "Convert to JSON" },
        { "name": "yaml", "type": "boolean", "required": false, "description": "Convert to YAML" },
        { "name": "pretty", "type": "boolean", "required": false, "description": "Pretty print output" }
      ]
    },
    {
      "namespace": "yaml-convert",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to yaml-convert CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "yaml-convert",
        "passthrough": true,
        "missingDependencyHelp": "Install yaml-convert: npm install -g yaml-convert"
      },
      "args": []
    }
  ]
}
