{
  "name": "calendarheatmap",
  "version": "0.1.0",
  "description": "Generate calendar heatmap visualizations from data",
  "source": "https://github.com/nikolaydubina/calendarheatmap",
  "checks": [
    {
      "type": "binary",
      "name": "calendarheatmap"
    }
  ],
  "install_guidance": {
    "plugin": "calendarheatmap",
    "binary": "calendarheatmap",
    "check": "which calendarheatmap",
    "install_steps": [
      "go install github.com/nikolaydubina/calendarheatmap@latest",
      "Verify: calendarheatmap --version",
      "supercli plugins install ./plugins/calendarheatmap --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "calendarheatmap",
      "resource": "self",
      "action": "version",
      "description": "Print calendarheatmap version",
      "adapter": "process",
      "adapterConfig": {
        "command": "calendarheatmap",
        "missingDependencyHelp": "Install calendarheatmap: go install github.com/nikolaydubina/calendarheatmap@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "calendarheatmap",
      "resource": "data",
      "action": "visualize",
      "description": "visualize data via calendarheatmap",
      "adapter": "process",
      "adapterConfig": {
        "command": "calendarheatmap",
        "missingDependencyHelp": "Install calendarheatmap: go install github.com/nikolaydubina/calendarheatmap@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "calendarheatmap",
      "resource": "_",
      "action": "_",
      "description": "_ _ via calendarheatmap",
      "adapter": "process",
      "adapterConfig": {
        "command": "calendarheatmap",
        "missingDependencyHelp": "Install calendarheatmap: go install github.com/nikolaydubina/calendarheatmap@latest",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}