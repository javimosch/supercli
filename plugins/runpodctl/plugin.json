{
  "name": "runpodctl",
  "version": "0.1.0",
  "description": "Command line tool for managing RunPod serverless GPUs",
  "source": "https://github.com/runpod/runpodctl",
  "checks": [
    {
      "type": "binary",
      "name": "runpodctl"
    }
  ],
  "install_guidance": {
    "plugin": "runpodctl",
    "binary": "runpodctl",
    "check": "which runpodctl",
    "install_steps": [
      "brew install runpod/runpodctl/runpodctl",
      "Verify: runpodctl --version",
      "supercli plugins install ./plugins/runpodctl --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "runpodctl",
      "resource": "self",
      "action": "version",
      "description": "Print runpodctl version",
      "adapter": "process",
      "adapterConfig": {
        "command": "runpodctl",
        "missingDependencyHelp": "Install runpodctl: brew install runpod/runpodctl/runpodctl",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "runpodctl",
      "resource": "pod",
      "action": "create",
      "description": "create pod via runpodctl",
      "adapter": "process",
      "adapterConfig": {
        "command": "runpodctl",
        "missingDependencyHelp": "Install runpodctl: brew install runpod/runpodctl/runpodctl",
        "baseArgs": [
          "create",
          "pod"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "runpodctl",
      "resource": "pod",
      "action": "list",
      "description": "list pod via runpodctl",
      "adapter": "process",
      "adapterConfig": {
        "command": "runpodctl",
        "missingDependencyHelp": "Install runpodctl: brew install runpod/runpodctl/runpodctl",
        "baseArgs": [
          "get",
          "pod"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "runpodctl",
      "resource": "pod",
      "action": "stop",
      "description": "stop pod via runpodctl",
      "adapter": "process",
      "adapterConfig": {
        "command": "runpodctl",
        "missingDependencyHelp": "Install runpodctl: brew install runpod/runpodctl/runpodctl",
        "baseArgs": [
          "stop",
          "pod"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "runpodctl",
      "resource": "_",
      "action": "_",
      "description": "_ _ via runpodctl",
      "adapter": "process",
      "adapterConfig": {
        "command": "runpodctl",
        "missingDependencyHelp": "Install runpodctl: brew install runpod/runpodctl/runpodctl",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}