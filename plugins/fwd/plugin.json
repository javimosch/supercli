{
  "name": "fwd",
  "version": "0.1.0",
  "description": "The little forwarder that could - port forwarding CLI",
  "source": "https://github.com/kintoandar/fwd",
  "checks": [
    {
      "type": "binary",
      "name": "fwd"
    }
  ],
  "install_guidance": {
    "plugin": "fwd",
    "binary": "fwd",
    "check": "which fwd",
    "install_steps": [
      "go install github.com/kintoandar/fwd@latest",
      "Verify: fwd --version",
      "supercli plugins install ./plugins/fwd --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "fwd",
      "resource": "self",
      "action": "version",
      "description": "Print fwd version",
      "adapter": "process",
      "adapterConfig": {
        "command": "fwd",
        "missingDependencyHelp": "Install fwd: go install github.com/kintoandar/fwd@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "fwd",
      "resource": "tunnel",
      "action": "create",
      "description": "create tunnel via fwd",
      "adapter": "process",
      "adapterConfig": {
        "command": "fwd",
        "missingDependencyHelp": "Install fwd: go install github.com/kintoandar/fwd@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "fwd",
