{
  "name": "goWAPT",
  "version": "0.1.0",
  "description": "Web application vulnerability scanner and fuzzer",
  "source": "https://github.com/dzonerzy/goWAPT",
  "checks": [
    {
      "type": "binary",
      "name": "goWAPT"
    }
  ],
  "install_guidance": {
    "plugin": "goWAPT",
    "binary": "goWAPT",
    "check": "which goWAPT",
    "install_steps": [
      "go install github.com/dzonerzy/goWAPT@latest",
      "Verify: goWAPT --version",
      "supercli plugins install ./plugins/goWAPT --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "goWAPT",
      "resource": "self",
      "action": "version",
      "description": "Print goWAPT version",
      "adapter": "process",
      "adapterConfig": {
        "command": "goWAPT",
        "missingDependencyHelp": "Install goWAPT: go install github.com/dzonerzy/goWAPT@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "goWAPT",
      "resource": "target",
      "action": "scan",
      "description": "scan target via goWAPT",
      "adapter": "process",
      "adapterConfig": {
        "command": "goWAPT",
        "missingDependencyHelp": "Install goWAPT: go install github.com/dzonerzy/goWAPT@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "goWAPT",
      "resource": "_",
      "action": "_",
      "description": "_ _ via goWAPT",
      "adapter": "process",
      "adapterConfig": {
        "command": "goWAPT",
        "missingDependencyHelp": "Install goWAPT: go install github.com/dzonerzy/goWAPT@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}