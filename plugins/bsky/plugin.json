{
  "name": "bsky",
  "version": "0.1.0",
  "description": "Bluesky CLI client for posting and interacting",
  "source": "https://github.com/mattn/bsky",
  "checks": [
    {
      "type": "binary",
      "name": "bsky"
    }
  ],
  "install_guidance": {
    "plugin": "bsky",
    "binary": "bsky",
    "check": "which bsky",
    "install_steps": [
      "go install github.com/mattn/bsky@latest",
      "Verify: bsky --version",
      "supercli plugins install ./plugins/bsky --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "bsky",
      "resource": "self",
      "action": "version",
      "description": "Print bsky version",
      "adapter": "process",
      "adapterConfig": {
        "command": "bsky",
        "missingDependencyHelp": "Install bsky: go install github.com/mattn/bsky@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "bsky",
      "resource": "post",
      "action": "create",
      "description": "create post via bsky",
      "adapter": "process",
      "adapterConfig": {
        "command": "bsky",
        "missingDependencyHelp": "Install bsky: go install github.com/mattn/bsky@latest",
        "baseArgs": [
          "post"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "bsky",
      "resource": "timeline",
      "action": "show",
      "description": "show timeline via bsky",
      "adapter": "process",
      "adapterConfig": {
        "command": "bsky",
        "missingDependencyHelp": "Install bsky: go install github.com/mattn/bsky@latest",
        "baseArgs": [
          "timeline"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "bsky",
      "resource": "user",
      "action": "show",
      "description": "show user via bsky",
      "adapter": "process",
      "adapterConfig": {
        "command": "bsky",
        "missingDependencyHelp": "Install bsky: go install github.com/mattn/bsky@latest",
        "baseArgs": [
          "user"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "bsky",
      "resource": "_",
      "action": "_",
      "description": "_ _ via bsky",
      "adapter": "process",
      "adapterConfig": {
        "command": "bsky",
        "missingDependencyHelp": "Install bsky: go install github.com/mattn/bsky@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}