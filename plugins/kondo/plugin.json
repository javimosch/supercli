{
  "name": "kondo",
  "version": "0.1.0",
  "description": "Clean up project artifacts and dependencies. Identify and delete unnecessary build artifacts, caches, and dependencies from your projects to free up disk space.",
  "source": "https://github.com/tbillington/kondo",
  "checks": [
    { "type": "binary", "name": "kondo" }
  ],
  "install_guidance": {
    "plugin": "kondo",
    "binary": "kondo",
    "check": "which kondo",
    "install_steps": [
      "brew install kondo",
      "Verify: kondo --version",
      "supercli plugins install ./plugins/kondo --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "kondo",
      "resource": "project",
      "action": "clean",
      "description": "Clean up project artifacts",
      "adapter": "process",
      "adapterConfig": {
        "command": "kondo",
        "passthrough": true,
        "missingDependencyHelp": "Install kondo: brew install kondo"
      },
      "args": [
        { "name": "path", "type": "string", "description": "Project path" },
        { "name": "--all", "type": "boolean", "description": "Clean all artifacts" },
        { "name": "--dry-run", "type": "boolean", "description": "Show what would be deleted" }
      ]
    },
    {
      "namespace": "kondo",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to kondo CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "kondo",
        "passthrough": true,
        "missingDependencyHelp": "Install kondo: brew install kondo"
      },
      "args": []
    }
  ]
}
