{
  "name": "lazygit",
  "version": "0.1.0",
  "description": "A terminal UI for git commands",
  "source": "https://github.com/jesseduffield/lazygit",
  "checks": [
    { "type": "binary", "name": "lazygit" }
  ],
  "install_guidance": {
    "plugin": "lazygit",
    "binary": "lazygit",
    "check": "which lazygit",
    "install_steps": [
      "curl https://raw.githubusercontent.com/jesseduffield/lazygit/master/scripts/install_update_linux.sh | bash",
      "Or: brew install lazygit",
      "supercli plugins install ./plugins/lazygit --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "lazygit",
      "resource": "self",
      "action": "version",
      "description": "Print lazygit version",
      "adapter": "process",
      "adapterConfig": {
        "command": "lazygit",
        "baseArgs": ["--version"],
        "cwd": "invoke_cwd",
        "missingDependencyHelp": "Install lazygit: curl https://raw.githubusercontent.com/jesseduffield/lazygit/master/scripts/install_update_linux.sh | bash"
      },
      "args": []
    },
    {
      "namespace": "lazygit",
      "resource": "ui",
      "action": "open",
      "description": "Open lazygit terminal UI",
      "adapter": "process",
      "adapterConfig": {
        "command": "lazygit",
        "cwd": "invoke_cwd",
        "missingDependencyHelp": "Install lazygit: curl https://raw.githubusercontent.com/jesseduffield/lazygit/master/scripts/install_update_linux.sh | bash"
      },
      "args": [
        { "name": "--path", "type": "string", "required": false, "description": "Path to git repository" },
        { "name": "--filter", "type": "string", "required": false, "description": "Path filter for files" },
        { "name": "--worktree", "type": "string", "required": false, "description": "Path to worktree" }
      ]
    },
    {
      "namespace": "lazygit",
      "resource": "log",
      "action": "view",
      "description": "View git log in lazygit",
      "adapter": "process",
      "adapterConfig": {
        "command": "lazygit",
        "baseArgs": ["log"],
        "cwd": "invoke_cwd",
        "missingDependencyHelp": "Install lazygit: curl https://raw.githubusercontent.com/jesseduffield/lazygit/master/scripts/install_update_linux.sh | bash"
      },
      "args": [
        { "name": "--path", "type": "string", "required": false, "description": "Path to git repository" }
      ]
    },
    {
      "namespace": "lazygit",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to lazygit CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "lazygit",
        "cwd": "invoke_cwd",
        "passthrough": true,
        "missingDependencyHelp": "Install lazygit: curl https://raw.githubusercontent.com/jesseduffield/lazygit/master/scripts/install_update_linux.sh | bash"
      },
      "args": []
    }
  ]
}
