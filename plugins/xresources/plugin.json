{
  "name": "xresources",
  "version": "0.1.0",
  "description": "Manage and query X11 Xresources from the command line",
  "source": "https://github.com/nordtheme/xresources",
  "checks": [
    {
      "type": "binary",
      "name": "xresources"
    }
  ],
  "install_guidance": {
    "plugin": "xresources",
    "binary": "xresources",
    "check": "which xresources",
    "install_steps": [
      "npm install -g xresources",
      "Verify: xresources --version",
      "supercli plugins install ./plugins/xresources --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "xresources",
      "resource": "self",
      "action": "version",
      "description": "Print xresources version",
      "adapter": "process",
      "adapterConfig": {
        "command": "xresources",
        "missingDependencyHelp": "Install xresources: npm install -g xresources",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "xresources",
      "resource": "resource",
      "action": "query",
      "description": "query resource via xresources",
      "adapter": "process",
      "adapterConfig": {
        "command": "xresources",
        "missingDependencyHelp": "Install xresources: npm install -g xresources",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "xresources",
      "resource": "_",
      "action": "_",
      "description": "_ _ via xresources",
      "adapter": "process",
      "adapterConfig": {
        "command": "xresources",
        "missingDependencyHelp": "Install xresources: npm install -g xresources",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}