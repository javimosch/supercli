{
  "name": "typeshare",
  "version": "0.1.0",
  "description": "Typeshare is the ultimate tool for synchronizing your type definitions between Rust and other languages for seamless FFI. Share types across languages easily.",
  "source": "https://github.com/1Password/typeshare",
  "checks": [
    { "type": "binary", "name": "typeshare" }
  ],
  "install_guidance": {
    "plugin": "typeshare",
    "binary": "typeshare",
    "check": "which typeshare",
    "install_steps": [
      "brew install typeshare",
      "Verify: typeshare --version",
      "supercli plugins install ./plugins/typeshare --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "typeshare",
      "resource": "type",
      "action": "sync",
      "description": "Synchronize type definitions",
      "adapter": "process",
      "adapterConfig": {
        "command": "typeshare",
        "passthrough": true,
        "missingDependencyHelp": "Install typeshare: brew install typeshare"
      },
      "args": [
        { "name": "language", "type": "string", "description": "Target language" },
        { "name": "file", "type": "string", "description": "Type definition file" },
        { "name": "--output", "type": "string", "description": "Output directory" }
      ]
    },
    {
      "namespace": "typeshare",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to typeshare CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "typeshare",
        "passthrough": true,
        "missingDependencyHelp": "Install typeshare: brew install typeshare"
      },
      "args": []
    }
  ]
}
