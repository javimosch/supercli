{
  "name": "slack-cli",
  "version": "0.1.0",
  "description": "Create develop and deploy Slack apps from the command line",
  "source": "https://github.com/slackapi/slack-cli",
  "checks": [
    {
      "type": "binary",
      "name": "slack"
    }
  ],
  "install_guidance": {
    "plugin": "slack-cli",
    "binary": "slack",
    "check": "which slack",
    "install_steps": [
      "brew install slack",
      "Verify: slack --version",
      "supercli plugins install ./plugins/slack-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "slack-cli",
      "resource": "self",
      "action": "version",
      "description": "Print slack-cli version",
      "adapter": "process",
      "adapterConfig": {
        "command": "slack",
        "missingDependencyHelp": "Install slack-cli: brew install slack",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "slack-cli",
      "resource": "app",
      "action": "create",
      "description": "create app via slack",
      "adapter": "process",
      "adapterConfig": {
        "command": "slack",
        "missingDependencyHelp": "Install slack-cli: brew install slack",
        "baseArgs": [
          "app",
          "create"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "slack-cli",
      "resource": "app",
      "action": "deploy",
      "description": "deploy app via slack",
      "adapter": "process",
      "adapterConfig": {
        "command": "slack",
