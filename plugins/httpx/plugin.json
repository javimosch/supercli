{
  "name": "httpx",
  "version": "0.1.0",
  "description": "A fast and multi-purpose HTTP toolkit. Run multiple probes using the retryablehttp library. Discover subdomains, detect technologies, and analyze HTTP responses.",
  "source": "https://github.com/projectdiscovery/httpx",
  "checks": [
    { "type": "binary", "name": "httpx" }
  ],
  "install_guidance": {
    "plugin": "httpx",
    "binary": "httpx",
    "check": "which httpx",
    "install_steps": [
      "brew install httpx",
      "Verify: httpx -version",
      "supercli plugins install ./plugins/httpx --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "httpx",
      "resource": "probe",
      "action": "run",
      "description": "Run HTTP probes on targets",
      "adapter": "process",
      "adapterConfig": {
        "command": "httpx",
        "passthrough": true,
        "missingDependencyHelp": "Install httpx: brew install httpx"
      },
      "args": [
        { "name": "-u", "type": "string", "description": "Target URLs" },
        { "name": "-l", "type": "string", "description": "File with target URLs" },
        { "name": "--status-code", "type": "boolean", "description": "Show status codes" },
        { "name": "--title", "type": "boolean", "description": "Show page titles" },
        { "name": "--tech-detect", "type": "boolean", "description": "Detect technologies" },
        { "name": "--json", "type": "boolean", "description": "JSON output" },
        { "name": "--silent", "type": "boolean", "description": "Silent mode" },
        { "name": "--timeout", "type": "integer", "description": "Request timeout" },
        { "name": "--threads", "type": "integer", "description": "Number of threads" }
      ]
    },
    {
      "namespace": "httpx",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to httpx CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "httpx",
        "passthrough": true,
        "missingDependencyHelp": "Install httpx: brew install httpx"
      },
      "args": []
    }
  ]
}
