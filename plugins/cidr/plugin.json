{
  "name": "cidr",
  "version": "0.1.0",
  "description": "CIDR range calculator and IP subnet utility",
  "source": "https://github.com/bschaatsbergen/cidr",
  "checks": [
    {
      "type": "binary",
      "name": "cidr"
    }
  ],
  "install_guidance": {
    "plugin": "cidr",
    "binary": "cidr",
    "check": "which cidr",
    "install_steps": [
      "brew install cidr",
      "Verify: cidr --version",
      "supercli plugins install ./plugins/cidr --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "cidr",
      "resource": "self",
      "action": "version",
      "description": "Print cidr version",
      "adapter": "process",
      "adapterConfig": {
        "command": "cidr",
        "missingDependencyHelp": "Install cidr: brew install cidr",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "cidr",
      "resource": "ip",
      "action": "calculate",
      "description": "calculate ip via cidr",
      "adapter": "process",
      "adapterConfig": {
        "command": "cidr",
        "missingDependencyHelp": "Install cidr: brew install cidr",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "cidr",
      "resource": "_",
      "action": "_",
      "description": "_ _ via cidr",
      "adapter": "process",
      "adapterConfig": {
        "command": "cidr",
        "missingDependencyHelp": "Install cidr: brew install cidr",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}