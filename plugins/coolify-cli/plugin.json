{
  "name": "coolify-cli",
  "version": "0.1.0",
  "description": "Self-hostable Heroku/Netlify alternative CLI",
  "source": "https://github.com/coollabsio/coolify-cli",
  "checks": [
    {
      "type": "binary",
      "name": "coolify"
    }
  ],
  "install_guidance": {
    "plugin": "coolify-cli",
    "binary": "coolify",
    "check": "which coolify",
    "install_steps": [
      "npm install -g coolify-cli",
      "Verify: coolify --version",
      "supercli plugins install ./plugins/coolify-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "coolify-cli",
      "resource": "self",
      "action": "version",
      "description": "Print coolify-cli version",
      "adapter": "process",
      "adapterConfig": {
        "command": "coolify",
        "missingDependencyHelp": "Install coolify-cli: npm install -g coolify-cli",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "coolify-cli",
      "resource": "project",
      "action": "deploy",
      "description": "deploy project via coolify",
      "adapter": "process",
      "adapterConfig": {
        "command": "coolify",
        "missingDependencyHelp": "Install coolify-cli: npm install -g coolify-cli",
        "baseArgs": [
          "deploy"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "coolify-cli",
      "resource": "project",
      "action": "init",
      "description": "init project via coolify",
      "adapter": "process",
      "adapterConfig": {
        "command": "coolify",
        "missingDependencyHelp": "Install coolify-cli: npm install -g coolify-cli",
        "baseArgs": [
          "init"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "coolify-cli",
      "resource": "server",
      "action": "setup",
      "description": "setup server via coolify",
      "adapter": "process",
      "adapterConfig": {
        "command": "coolify",
        "missingDependencyHelp": "Install coolify-cli: npm install -g coolify-cli",
        "baseArgs": [
          "server"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "coolify-cli",
      "resource": "_",
      "action": "_",
      "description": "_ _ via coolify",
      "adapter": "process",
      "adapterConfig": {
        "command": "coolify",
        "missingDependencyHelp": "Install coolify-cli: npm install -g coolify-cli",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}