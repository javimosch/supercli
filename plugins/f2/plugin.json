{
  "name": "f2",
  "version": "0.1.0",
  "description": "Cross-platform command-line tool for batch renaming files and directories quickly and safely",
  "source": "https://github.com/ayoisaiah/f2",
  "checks": [
    {
      "type": "binary",
      "name": "f2"
    }
  ],
  "install_guidance": {
    "plugin": "f2",
    "binary": "f2",
    "check": "which f2",
    "install_steps": [
      "go install github.com/ayoisaiah/f2@latest",
      "Verify: f2 --version",
      "supercli plugins install ./plugins/f2 --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "f2",
      "resource": "self",
      "action": "version",
      "description": "Print f2 version",
      "adapter": "process",
      "adapterConfig": {
        "command": "f2",
        "missingDependencyHelp": "Install f2: go install github.com/ayoisaiah/f2@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "f2",
      "resource": "file",
      "action": "rename",
      "description": "rename file via f2",
      "adapter": "process",
      "adapterConfig": {
        "command": "f2",
        "missingDependencyHelp": "Install f2: go install github.com/ayoisaiah/f2@latest",
        "passthrough": true,
        "timeout_ms": 60000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "f2",
      "resource": "_",
      "action": "_",
      "description": "_ _ via f2",
      "adapter": "process",
      "adapterConfig": {
        "command": "f2",
        "missingDependencyHelp": "Install f2: go install github.com/ayoisaiah/f2@latest",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}