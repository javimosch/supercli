{
  "name": "apizza",
  "version": "0.1.0",
  "description": "Order pizza from the command line",
  "source": "https://github.com/harrybrwn/apizza",
  "checks": [
    {
      "type": "binary",
      "name": "apizza"
    }
  ],
  "install_guidance": {
    "plugin": "apizza",
    "binary": "apizza",
    "check": "which apizza",
    "install_steps": [
      "go install github.com/harrybrwn/apizza@latest",
      "Verify: apizza --version",
      "supercli plugins install ./plugins/apizza --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "apizza",
      "resource": "self",
      "action": "version",
      "description": "Print apizza version",
      "adapter": "process",
      "adapterConfig": {
        "command": "apizza",
        "missingDependencyHelp": "Install apizza: go install github.com/harrybrwn/apizza@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "apizza",
      "resource": "order",
      "action": "place",
      "description": "place order via apizza",
      "adapter": "process",
      "adapterConfig": {
        "command": "apizza",
        "missingDependencyHelp": "Install apizza: go install github.com/harrybrwn/apizza@latest",
        "baseArgs": [
          "order"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "apizza",
      "resource": "menu",
      "action": "show",
      "description": "show menu via apizza",
      "adapter": "process",
      "adapterConfig": {
        "command": "apizza",
        "missingDependencyHelp": "Install apizza: go install github.com/harrybrwn/apizza@latest",
        "baseArgs": [
          "menu"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "apizza",
      "resource": "history",
      "action": "show",
      "description": "show history via apizza",
      "adapter": "process",
      "adapterConfig": {
        "command": "apizza",
        "missingDependencyHelp": "Install apizza: go install github.com/harrybrwn/apizza@latest",
        "baseArgs": [
          "history"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "apizza",
      "resource": "_",
      "action": "_",
      "description": "_ _ via apizza",
      "adapter": "process",
      "adapterConfig": {
        "command": "apizza",
        "missingDependencyHelp": "Install apizza: go install github.com/harrybrwn/apizza@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}