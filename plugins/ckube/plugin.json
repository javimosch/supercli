{
  "name": "ckube",
  "version": "0.1.0",
  "description": "Compact Kubernetes dashboard in terminal",
  "source": "https://github.com/CanopyTax/ckube",
  "checks": [
    {
      "type": "binary",
      "name": "ckube"
    }
  ],
  "install_guidance": {
    "plugin": "ckube",
    "binary": "ckube",
    "check": "which ckube",
    "install_steps": [
      "go install github.com/CanopyTax/ckube@latest",
      "Verify: ckube --version",
      "supercli plugins install ./plugins/ckube --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "ckube",
      "resource": "self",
      "action": "version",
      "description": "Print ckube version",
      "adapter": "process",
      "adapterConfig": {
        "command": "ckube",
        "missingDependencyHelp": "Install ckube: go install github.com/CanopyTax/ckube@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "ckube",
      "resource": "cluster",
      "action": "status",
      "description": "status cluster via ckube",
      "adapter": "process",
      "adapterConfig": {
        "command": "ckube",
        "missingDependencyHelp": "Install ckube: go install github.com/CanopyTax/ckube@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "ckube",
      "resource": "pod",
      "action": "list",
      "description": "list pod via ckube",
      "adapter": "process",
      "adapterConfig": {
        "command": "ckube",
        "missingDependencyHelp": "Install ckube: go install github.com/CanopyTax/ckube@latest",
        "baseArgs": [
          "pods"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "ckube",
      "resource": "deployment",
      "action": "list",
      "description": "list deployment via ckube",
      "adapter": "process",
      "adapterConfig": {
        "command": "ckube",
        "missingDependencyHelp": "Install ckube: go install github.com/CanopyTax/ckube@latest",
        "baseArgs": [
          "deployments"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "ckube",
      "resource": "_",
      "action": "_",
      "description": "_ _ via ckube",
      "adapter": "process",
      "adapterConfig": {
        "command": "ckube",
        "missingDependencyHelp": "Install ckube: go install github.com/CanopyTax/ckube@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}