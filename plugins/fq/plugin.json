{
  "name": "fq",
  "version": "0.1.0",
  "description": "jq for binary formats. A tool, language, and decoders for working with binary and text formats. Query, decode, and transform binary data with a jq-like syntax.",
  "source": "https://github.com/wader/fq",
  "checks": [
    { "type": "binary", "name": "fq" }
  ],
  "install_guidance": {
    "plugin": "fq",
    "binary": "fq",
    "check": "which fq",
    "install_steps": [
      "brew install fq",
      "Verify: fq --version",
      "supercli plugins install ./plugins/fq --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "fq",
      "resource": "data",
      "action": "query",
      "description": "Query binary data with jq-like syntax",
      "adapter": "process",
      "adapterConfig": {
        "command": "fq",
        "passthrough": true,
        "missingDependencyHelp": "Install fq: brew install fq"
      },
      "args": [
        { "name": "file", "type": "string", "description": "Binary file to query" },
        { "name": "--output", "type": "string", "description": "Output format (json, compact)" },
        { "name": "--depth", "type": "integer", "description": "Query depth limit" },
        { "name": "--repl", "type": "boolean", "description": "Start REPL mode" }
      ]
    },
    {
      "namespace": "fq",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to fq CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "fq",
        "passthrough": true,
        "missingDependencyHelp": "Install fq: brew install fq"
      },
      "args": []
    }
  ]
}
