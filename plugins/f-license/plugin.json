{
  "name": "f-license",
  "version": "0.1.0",
  "description": "License checker and validator for open-source projects",
  "source": "https://github.com/furkansenharputlu/f-license",
  "checks": [
    {
      "type": "binary",
      "name": "f-license"
    }
  ],
  "install_guidance": {
    "plugin": "f-license",
    "binary": "f-license",
    "check": "which f-license",
    "install_steps": [
      "go install github.com/furkansenharputlu/f-license@latest",
      "Verify: f-license --version",
      "supercli plugins install ./plugins/f-license --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "f-license",
      "resource": "self",
      "action": "version",
      "description": "Print f-license version",
      "adapter": "process",
      "adapterConfig": {
        "command": "f-license",
        "missingDependencyHelp": "Install f-license: go install github.com/furkansenharputlu/f-license@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "f-license",
      "resource": "license",
      "action": "check",
      "description": "check license via f-license",
      "adapter": "process",
      "adapterConfig": {
        "command": "f-license",
        "missingDependencyHelp": "Install f-license: go install github.com/furkansenharputlu/f-license@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "f-license",
      "resource": "_",
      "action": "_",
      "description": "_ _ via f-license",
      "adapter": "process",
      "adapterConfig": {
        "command": "f-license",
        "missingDependencyHelp": "Install f-license: go install github.com/furkansenharputlu/f-license@latest",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}