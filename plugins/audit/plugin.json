{
  "name": "audit",
  "version": "0.1.0",
  "description": "Audit collaborators hooks and deploy keys on GitHub repositories",
  "source": "https://github.com/genuinetools/audit",
  "checks": [
    {
      "type": "binary",
      "name": "audit"
    }
  ],
  "install_guidance": {
    "plugin": "audit",
    "binary": "audit",
    "check": "which audit",
    "install_steps": [
      "go install github.com/genuinetools/audit@latest",
      "Verify: audit --version",
      "supercli plugins install ./plugins/audit --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "audit",
      "resource": "self",
      "action": "version",
      "description": "Print audit version",
      "adapter": "process",
      "adapterConfig": {
        "command": "audit",
        "missingDependencyHelp": "Install audit: go install github.com/genuinetools/audit@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "audit",
      "resource": "repo",
      "action": "audit",
      "description": "audit repo via audit",
      "adapter": "process",
      "adapterConfig": {
        "command": "audit",
        "missingDependencyHelp": "Install audit: go install github.com/genuinetools/audit@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "audit",
      "resource": "user",
