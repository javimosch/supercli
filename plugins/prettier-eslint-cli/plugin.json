{
  "name": "prettier-eslint-cli",
  "version": "0.1.0",
  "description": "Format with Prettier and lint with ESLint",
  "source": "https://github.com/prettier/prettier-eslint-cli",
  "checks": [
    {
      "type": "binary",
      "name": "prettier-eslint"
    }
  ],
  "install_guidance": {
    "plugin": "prettier-eslint-cli",
    "binary": "prettier-eslint",
    "check": "which prettier-eslint",
    "install_steps": [
      "npm install -g prettier-eslint-cli",
      "Verify: prettier-eslint --version",
      "supercli plugins install ./plugins/prettier-eslint-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "prettier-eslint-cli",
      "resource": "self",
      "action": "version",
      "description": "Print prettier-eslint-cli version",
      "adapter": "process",
      "adapterConfig": {
        "command": "prettier-eslint",
        "missingDependencyHelp": "Install prettier-eslint-cli: npm install -g prettier-eslint-cli",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "prettier-eslint-cli",
      "resource": "file",
      "action": "format",
      "description": "format file via prettier-eslint",
      "adapter": "process",
      "adapterConfig": {
        "command": "prettier-eslint",
        "missingDependencyHelp": "Install prettier-eslint-cli: npm install -g prettier-eslint-cli",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "prettier-eslint-cli",
      "resource": "_",
      "action": "_",
      "description": "_ _ via prettier-eslint",
      "adapter": "process",
      "adapterConfig": {
        "command": "prettier-eslint",
        "missingDependencyHelp": "Install prettier-eslint-cli: npm install -g prettier-eslint-cli",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}