{
  "plugin": "prettier-eslint-cli",
  "binary": "prettier-eslint",
  "check": "which prettier-eslint",
  "install_steps": [
    "npm install -g prettier-eslint-cli",
    "Verify: prettier-eslint --version",
    "supercli plugins install ./plugins/prettier-eslint-cli --on-conflict replace --json"
  ]
}