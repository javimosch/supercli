{
  "name": "muffet",
  "version": "0.1.0",
  "description": "Fast website link checker with recursion support",
  "source": "https://github.com/raviqqe/muffet",
  "checks": [
    {
      "type": "binary",
      "name": "muffet"
    }
  ],
  "install_guidance": {
    "plugin": "muffet",
    "binary": "muffet",
    "check": "which muffet",
    "install_steps": [
      "brew install muffet",
      "Verify: muffet --version",
      "supercli plugins install ./plugins/muffet --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "muffet",
      "resource": "self",
      "action": "version",
      "description": "Print muffet version",
      "adapter": "process",
      "adapterConfig": {
        "command": "muffet",
        "missingDependencyHelp": "Install muffet: brew install muffet",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "muffet",
      "resource": "url",
      "action": "check",
      "description": "check url via muffet",
      "adapter": "process",
      "adapterConfig": {
        "command": "muffet",
        "missingDependencyHelp": "Install muffet: brew install muffet",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "muffet",
      "resource": "_",
      "action": "_",
      "description": "_ _ via muffet",
      "adapter": "process",
      "adapterConfig": {
        "command": "muffet",
        "missingDependencyHelp": "Install muffet: brew install muffet",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}