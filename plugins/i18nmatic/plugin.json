{
  "name": "i18nmatic",
  "version": "0.1.0",
  "description": "CLI tool to automate internationalization for React and Next.js projects",
  "source": "https://github.com/seonghunYang/i18nmatic",
  "checks": [
    {
      "type": "binary",
      "name": "i18nmatic"
    }
  ],
  "install_guidance": {
    "plugin": "i18nmatic",
    "binary": "i18nmatic",
    "check": "which i18nmatic",
    "install_steps": [
      "npm install -g i18nmatic",
      "Verify: i18nmatic --version",
      "supercli plugins install ./plugins/i18nmatic --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "i18nmatic",
      "resource": "self",
      "action": "version",
      "description": "Print i18nmatic version",
      "adapter": "process",
      "adapterConfig": {
        "command": "i18nmatic",
        "missingDependencyHelp": "Install i18nmatic: npm install -g i18nmatic",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "i18nmatic",
      "resource": "project",
      "action": "init",
      "description": "init project via i18nmatic",
      "adapter": "process",
      "adapterConfig": {
        "command": "i18nmatic",
        "missingDependencyHelp": "Install i18nmatic: npm install -g i18nmatic",
        "baseArgs": [
          "init"
        ],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "i18nmatic",
      "resource": "strings",
      "action": "extract",
      "description": "extract strings via i18nmatic",
      "adapter": "process",
      "adapterConfig": {
        "command": "i18nmatic",
        "missingDependencyHelp": "Install i18nmatic: npm install -g i18nmatic",
        "baseArgs": [
          "extract"
        ],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
