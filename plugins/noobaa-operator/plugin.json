{
  "name": "noobaa-operator",
  "version": "0.1.0",
  "description": "Operator CLI for managing NooBaa object storage",
  "source": "https://github.com/noobaa/noobaa-operator",
  "checks": [
    {
      "type": "binary",
      "name": "noobaa"
    }
  ],
  "install_guidance": {
    "plugin": "noobaa-operator",
    "binary": "noobaa",
    "check": "which noobaa",
    "install_steps": [
      "brew install noobaa/noobaa-operator/noobaa-cli",
      "Verify: noobaa --version",
      "supercli plugins install ./plugins/noobaa-operator --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "noobaa-operator",
      "resource": "self",
      "action": "version",
      "description": "Print noobaa-operator version",
      "adapter": "process",
      "adapterConfig": {
        "command": "noobaa",
        "missingDependencyHelp": "Install noobaa-operator: brew install noobaa/noobaa-operator/noobaa-cli",
        "baseArgs": [
          "version"
        ]
      },
      "args": []
    },
    {
      "namespace": "noobaa-operator",
      "resource": "system",
      "action": "install",
      "description": "install system via noobaa",
      "adapter": "process",
      "adapterConfig": {
        "command": "noobaa",
        "missingDependencyHelp": "Install noobaa-operator: brew install noobaa/noobaa-operator/noobaa-cli",
        "baseArgs": [
          "install"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "noobaa-operator",
      "resource": "bucket",
      "action": "list",
      "description": "list bucket via noobaa",
      "adapter": "process",
      "adapterConfig": {
        "command": "noobaa",
        "missingDependencyHelp": "Install noobaa-operator: brew install noobaa/noobaa-operator/noobaa-cli",
        "baseArgs": [
          "bucket",
          "list"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "noobaa-operator",
      "resource": "backingstore",
      "action": "list",
      "description": "list backingstore via noobaa",
      "adapter": "process",
      "adapterConfig": {
        "command": "noobaa",
        "missingDependencyHelp": "Install noobaa-operator: brew install noobaa/noobaa-operator/noobaa-cli",
        "baseArgs": [
          "backingstore",
          "list"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "noobaa-operator",
      "resource": "_",
      "action": "_",
      "description": "_ _ via noobaa",
      "adapter": "process",
      "adapterConfig": {
        "command": "noobaa",
        "missingDependencyHelp": "Install noobaa-operator: brew install noobaa/noobaa-operator/noobaa-cli",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}