{
  "name": "lune",
  "version": "0.1.0",
  "description": "Standalone Luau runtime for running Luau scripts from the command line",
  "source": "https://github.com/lune-org/lune",
  "checks": [
    {
      "type": "binary",
      "name": "lune"
    }
  ],
  "install_guidance": {
    "plugin": "lune",
    "binary": "lune",
    "check": "which lune",
    "install_steps": [
      "cargo install lune",
      "Verify: lune --version",
      "supercli plugins install ./plugins/lune --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "lune",
      "resource": "self",
      "action": "version",
      "description": "Print lune version",
      "adapter": "process",
      "adapterConfig": {
        "command": "lune",
        "missingDependencyHelp": "Install lune: cargo install lune",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "lune",
      "resource": "script",
      "action": "run",
      "description": "run script via lune",
      "adapter": "process",
      "adapterConfig": {
        "command": "lune",
        "missingDependencyHelp": "Install lune: cargo install lune",
        "baseArgs": [
          "run"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
