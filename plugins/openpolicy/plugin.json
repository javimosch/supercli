{
  "name": "openpolicy",
  "version": "0.1.0",
  "description": "Framework for building privacy-first applications from the command line",
  "source": "https://github.com/jamiedavenport/openpolicy",
  "checks": [
    {
      "type": "binary",
      "name": "openpolicy"
    }
  ],
  "install_guidance": {
    "plugin": "openpolicy",
    "binary": "openpolicy",
    "check": "which openpolicy",
    "install_steps": [
      "npm install -g openpolicy",
      "Verify: openpolicy --version",
      "supercli plugins install ./plugins/openpolicy --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "openpolicy",
      "resource": "self",
      "action": "version",
      "description": "Print openpolicy version",
      "adapter": "process",
      "adapterConfig": {
        "command": "openpolicy",
        "missingDependencyHelp": "Install openpolicy: npm install -g openpolicy",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "openpolicy",
      "resource": "policy",
      "action": "init",
      "description": "init policy via openpolicy",
      "adapter": "process",
      "adapterConfig": {
        "command": "openpolicy",
        "missingDependencyHelp": "Install openpolicy: npm install -g openpolicy",
        "baseArgs": [
          "init"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "openpolicy",
      "resource": "policy",
      "action": "validate",
