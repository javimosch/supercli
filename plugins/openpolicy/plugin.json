      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "openpolicy",
      "resource": "policy",
      "action": "list",
      "description": "list policy via openpolicy",
      "adapter": "process",
      "adapterConfig": {
        "command": "openpolicy",
