{
  "name": "fresh",
  "version": "0.1.0",
  "description": "Build and (re)start Go web apps after saving source files",
  "source": "https://github.com/gravityblast/fresh",
  "checks": [
    {
      "type": "binary",
      "name": "fresh"
    }
  ],
  "install_guidance": {
    "plugin": "fresh",
    "binary": "fresh",
    "check": "which fresh",
    "install_steps": [
      "go install github.com/gravityblast/fresh@latest",
      "Verify: fresh --version",
      "supercli plugins install ./plugins/fresh --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "fresh",
      "resource": "self",
      "action": "version",
      "description": "Print fresh version",
      "adapter": "process",
      "adapterConfig": {
        "command": "fresh",
        "missingDependencyHelp": "Install fresh: go install github.com/gravityblast/fresh@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "fresh",
      "resource": "watch",
      "action": "start",
      "description": "start watch via fresh",
      "adapter": "process",
      "adapterConfig": {
        "command": "fresh",
        "missingDependencyHelp": "Install fresh: go install github.com/gravityblast/fresh@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "fresh",
      "resource": "_",
      "action": "_",
      "description": "_ _ via fresh",
      "adapter": "process",
      "adapterConfig": {
        "command": "fresh",
        "missingDependencyHelp": "Install fresh: go install github.com/gravityblast/fresh@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}