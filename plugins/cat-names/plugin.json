{
  "name": "cat-names",
  "version": "0.1.0",
  "description": "Get popular cat names from the command line",
  "source": "https://github.com/sindresorhus/cat-names",
  "checks": [
    {
      "type": "binary",
      "name": "cat-names"
    }
  ],
  "install_guidance": {
    "plugin": "cat-names",
    "binary": "cat-names",
    "check": "which cat-names",
    "install_steps": [
      "npm install -g cat-names",
      "Verify: cat-names --version",
      "supercli plugins install ./plugins/cat-names --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "cat-names",
      "resource": "self",
      "action": "version",
      "description": "Print cat-names version",
      "adapter": "process",
      "adapterConfig": {
        "command": "cat-names",
        "missingDependencyHelp": "Install cat-names: npm install -g cat-names",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "cat-names",
      "resource": "name",
      "action": "random",
      "description": "random name via cat-names",
      "adapter": "process",
      "adapterConfig": {
        "command": "cat-names",
        "missingDependencyHelp": "Install cat-names: npm install -g cat-names",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "cat-names",
      "resource": "_",
      "action": "_",
      "description": "_ _ via cat-names",
      "adapter": "process",
      "adapterConfig": {
        "command": "cat-names",
        "missingDependencyHelp": "Install cat-names: npm install -g cat-names",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}