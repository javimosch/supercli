{
  "plugin": "lutgen-rs",
  "binary": "lutgen",
  "check": "which lutgen",
  "install_steps": [
    "cargo install lutgen-cli",
    "Verify: lutgen --help",
    "supercli plugins install ./plugins/lutgen-rs --on-conflict replace --json"
  ],
  "note": "lutgen generates and applies color grading LUTs to images"
}
