{
  "name": "fkill",
  "version": "0.1.0",
  "description": "Fabulously kill processes. Cross-platform",
  "source": "https://github.com/sindresorhus/fkill-cli",
  "checks": [
    {
      "type": "binary",
      "name": "fkill"
    }
  ],
  "install_guidance": {
    "plugin": "fkill",
    "binary": "fkill",
    "check": "which fkill",
    "install_steps": [
      "npm install -g fkill-cli",
      "Verify: fkill --version",
      "supercli plugins install ./plugins/fkill --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "fkill",
      "resource": "self",
      "action": "version",
      "description": "Print fkill version",
      "adapter": "process",
      "adapterConfig": {
        "command": "fkill",
        "missingDependencyHelp": "Install fkill: npm install -g fkill-cli",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "fkill",
      "resource": "process",
      "action": "kill",
      "description": "kill process via fkill",
      "adapter": "process",
      "adapterConfig": {
        "command": "fkill",
        "missingDependencyHelp": "Install fkill: npm install -g fkill-cli",
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "fkill",
      "resource": "_",
      "action": "_",
      "description": "_ _ via fkill",
      "adapter": "process",
      "adapterConfig": {
        "command": "fkill",
        "missingDependencyHelp": "Install fkill: npm install -g fkill-cli",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}