{
  "name": "opa",
  "version": "0.1.0",
  "description": "Open Policy Agent command line for policy evaluation",
  "source": "https://github.com/open-policy-agent/opa",
  "checks": [
    {
      "type": "binary",
      "name": "opa"
    }
  ],
  "install_guidance": {
    "plugin": "opa",
    "binary": "opa",
    "check": "which opa",
    "install_steps": [
      "brew install opa",
      "Verify: opa --version",
      "supercli plugins install ./plugins/opa --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "opa",
      "resource": "self",
      "action": "version",
      "description": "Print opa version",
      "adapter": "process",
      "adapterConfig": {
        "command": "opa",
        "missingDependencyHelp": "Install opa: brew install opa",
        "baseArgs": [
          "version"
        ]
      },
      "args": []
    },
    {
      "namespace": "opa",
      "resource": "policy",
      "action": "eval",
      "description": "eval policy via opa",
      "adapter": "process",
      "adapterConfig": {
        "command": "opa",
        "missingDependencyHelp": "Install opa: brew install opa",
        "baseArgs": [
          "eval"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "opa",
      "resource": "policy",
      "action": "test",
      "description": "test policy via opa",
      "adapter": "process",
      "adapterConfig": {
        "command": "opa",
        "missingDependencyHelp": "Install opa: brew install opa",
        "baseArgs": [
          "test"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "opa",
      "resource": "policy",
      "action": "build",
      "description": "build policy via opa",
      "adapter": "process",
      "adapterConfig": {
        "command": "opa",
        "missingDependencyHelp": "Install opa: brew install opa",
        "baseArgs": [
          "build"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "opa",
      "resource": "_",
      "action": "_",
      "description": "_ _ via opa",
      "adapter": "process",
      "adapterConfig": {
        "command": "opa",
        "missingDependencyHelp": "Install opa: brew install opa",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}