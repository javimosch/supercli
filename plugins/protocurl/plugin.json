{
  "name": "protocurl",
  "version": "0.1.0",
  "description": "cURL for Protobuf: interact with Protobuf over HTTP REST endpoints",
  "source": "https://github.com/qaware/protocurl",
  "checks": [
    {
      "type": "binary",
      "name": "protocurl"
    }
  ],
  "install_guidance": {
    "plugin": "protocurl",
    "binary": "protocurl",
    "check": "which protocurl",
    "install_steps": [
      "brew install qaware/tap/protocurl",
      "Verify: protocurl --version",
      "supercli plugins install ./plugins/protocurl --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "protocurl",
      "resource": "self",
      "action": "version",
      "description": "Print protocurl version",
      "adapter": "process",
      "adapterConfig": {
        "command": "protocurl",
        "missingDependencyHelp": "Install protocurl: brew install qaware/tap/protocurl",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "protocurl",
      "resource": "request",
      "action": "send",
      "description": "send request via protocurl",
      "adapter": "process",
      "adapterConfig": {
        "command": "protocurl",
        "missingDependencyHelp": "Install protocurl: brew install qaware/tap/protocurl",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "protocurl",
      "resource": "proto",
      "action": "describe",
      "description": "describe proto via protocurl",
      "adapter": "process",
      "adapterConfig": {
        "command": "protocurl",
        "missingDependencyHelp": "Install protocurl: brew install qaware/tap/protocurl",
        "baseArgs": [
          "--describe"
        ],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "protocurl",
      "resource": "config",
      "action": "show",
      "description": "show config via protocurl",
      "adapter": "process",
      "adapterConfig": {
        "command": "protocurl",
        "missingDependencyHelp": "Install protocurl: brew install qaware/tap/protocurl",
        "baseArgs": [
          "--config"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "protocurl",
      "resource": "_",
      "action": "_",
      "description": "_ _ via protocurl",
      "adapter": "process",
      "adapterConfig": {
        "command": "protocurl",
        "missingDependencyHelp": "Install protocurl: brew install qaware/tap/protocurl",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}