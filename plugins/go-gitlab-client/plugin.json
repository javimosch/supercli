{
  "name": "go-gitlab-client",
  "version": "0.1.0",
  "description": "Command line tool for interacting with GitLab repositories",
  "source": "https://github.com/plouc/go-gitlab-client",
  "checks": [
    {
      "type": "binary",
      "name": "glab"
    }
  ],
  "install_guidance": {
    "plugin": "go-gitlab-client",
    "binary": "glab",
    "check": "which glab",
    "install_steps": [
      "go install github.com/plouc/go-gitlab-client@latest",
      "Verify: glab --version",
      "supercli plugins install ./plugins/go-gitlab-client --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "go-gitlab-client",
      "resource": "self",
      "action": "version",
      "description": "Print go-gitlab-client version",
      "adapter": "process",
      "adapterConfig": {
        "command": "glab",
        "missingDependencyHelp": "Install go-gitlab-client: go install github.com/plouc/go-gitlab-client@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "go-gitlab-client",
      "resource": "project",
      "action": "list",
      "description": "list project via glab",
      "adapter": "process",
      "adapterConfig": {
        "command": "glab",
        "missingDependencyHelp": "Install go-gitlab-client: go install github.com/plouc/go-gitlab-client@latest",
        "baseArgs": [
          "projects"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "go-gitlab-client",
      "resource": "issue",
      "action": "list",
      "description": "list issue via glab",
      "adapter": "process",
      "adapterConfig": {
        "command": "glab",
        "missingDependencyHelp": "Install go-gitlab-client: go install github.com/plouc/go-gitlab-client@latest",
        "baseArgs": [
          "issues"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "go-gitlab-client",
      "resource": "mr",
      "action": "list",
      "description": "list mr via glab",
      "adapter": "process",
      "adapterConfig": {
        "command": "glab",
        "missingDependencyHelp": "Install go-gitlab-client: go install github.com/plouc/go-gitlab-client@latest",
        "baseArgs": [
          "merge-requests"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "go-gitlab-client",
      "resource": "_",
      "action": "_",
      "description": "_ _ via glab",
      "adapter": "process",
      "adapterConfig": {
        "command": "glab",
        "missingDependencyHelp": "Install go-gitlab-client: go install github.com/plouc/go-gitlab-client@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}