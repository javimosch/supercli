{
  "name": "cli-kenai",
  "version": "0.1.0",
  "description": "CLI tools for JavaScript projects with code generation and scaffolding",
  "source": "https://github.com/kenai/cli-kenai",
  "checks": [
    {
      "type": "binary",
      "name": "kenai"
    }
  ],
  "install_guidance": {
    "plugin": "cli-kenai",
    "binary": "kenai",
    "check": "which kenai",
    "install_steps": [
      "npm install -g cli-kenai",
      "Verify: kenai --version",
      "supercli plugins install ./plugins/cli-kenai --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "cli-kenai",
      "resource": "self",
      "action": "version",
      "description": "Print cli-kenai version",
      "adapter": "process",
      "adapterConfig": {
        "command": "kenai",
        "missingDependencyHelp": "Install cli-kenai: npm install -g cli-kenai",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "cli-kenai",
      "resource": "project",
      "action": "scaffold",
      "description": "scaffold project via kenai",
      "adapter": "process",
      "adapterConfig": {
        "command": "kenai",
        "missingDependencyHelp": "Install cli-kenai: npm install -g cli-kenai",
        "baseArgs": [
          "scaffold"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "cli-kenai",
      "resource": "component",
      "action": "generate",
      "description": "generate component via kenai",
      "adapter": "process",
      "adapterConfig": {
        "command": "kenai",
        "missingDependencyHelp": "Install cli-kenai: npm install -g cli-kenai",
        "baseArgs": [
          "generate"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "cli-kenai",
      "resource": "config",
      "action": "init",
      "description": "init config via kenai",
      "adapter": "process",
      "adapterConfig": {
        "command": "kenai",
        "missingDependencyHelp": "Install cli-kenai: npm install -g cli-kenai",
        "baseArgs": [
          "init"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "cli-kenai",
      "resource": "config",
      "action": "show",
      "description": "show config via kenai",
      "adapter": "process",
      "adapterConfig": {
        "command": "kenai",
        "missingDependencyHelp": "Install cli-kenai: npm install -g cli-kenai",
        "baseArgs": [
          "--config"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "cli-kenai",
      "resource": "template",
      "action": "list",
      "description": "list template via kenai",
      "adapter": "process",
      "adapterConfig": {
        "command": "kenai",
        "missingDependencyHelp": "Install cli-kenai: npm install -g cli-kenai",
        "baseArgs": [
          "templates"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "cli-kenai",
      "resource": "template",
      "action": "add",
      "description": "add template via kenai",
      "adapter": "process",
      "adapterConfig": {
        "command": "kenai",
        "missingDependencyHelp": "Install cli-kenai: npm install -g cli-kenai",
        "baseArgs": [
          "--add-template"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "cli-kenai",
      "resource": "_",
      "action": "_",
      "description": "_ _ via kenai",
      "adapter": "process",
      "adapterConfig": {
        "command": "kenai",
        "missingDependencyHelp": "Install cli-kenai: npm install -g cli-kenai",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}