{
  "name": "supervizer",
  "version": "0.1.0",
  "description": "Process manager and supervisor CLI",
  "source": "https://github.com/oOthkOo/supervizer",
  "checks": [
    {
      "type": "binary",
      "name": "supervizer"
    }
  ],
  "install_guidance": {
    "plugin": "supervizer",
    "binary": "supervizer",
    "check": "which supervizer",
    "install_steps": [
      "npm install -g supervizer",
      "Verify: supervizer --version",
      "supercli plugins install ./plugins/supervizer --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "supervizer",
      "resource": "self",
      "action": "version",
      "description": "Print supervizer version",
      "adapter": "process",
      "adapterConfig": {
        "command": "supervizer",
        "missingDependencyHelp": "Install supervizer: npm install -g supervizer",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "supervizer",
      "resource": "process",
      "action": "manage",
      "description": "manage process via supervizer",
      "adapter": "process",
      "adapterConfig": {
        "command": "supervizer",
        "missingDependencyHelp": "Install supervizer: npm install -g supervizer",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "supervizer",
      "resource": "_",
      "action": "_",
      "description": "_ _ via supervizer",
      "adapter": "process",
      "adapterConfig": {
        "command": "supervizer",
        "missingDependencyHelp": "Install supervizer: npm install -g supervizer",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}