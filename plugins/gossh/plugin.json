{
  "name": "gossh",
  "version": "0.1.0",
  "description": "High-performance and high-concurrency SSH tool written in Go",
  "source": "https://github.com/windvalley/gossh",
  "checks": [
    {
      "type": "binary",
      "name": "gossh"
    }
  ],
  "install_guidance": {
    "plugin": "gossh",
    "binary": "gossh",
    "check": "which gossh",
    "install_steps": [
      "go install github.com/windvalley/gossh@latest",
      "Verify: gossh --version",
      "supercli plugins install ./plugins/gossh --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "gossh",
      "resource": "self",
      "action": "version",
      "description": "Print gossh version",
      "adapter": "process",
      "adapterConfig": {
        "command": "gossh",
        "missingDependencyHelp": "Install gossh: go install github.com/windvalley/gossh@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "gossh",
      "resource": "command",
      "action": "run",
      "description": "run command via gossh",
      "adapter": "process",
      "adapterConfig": {
        "command": "gossh",
        "missingDependencyHelp": "Install gossh: go install github.com/windvalley/gossh@latest",
        "baseArgs": [
