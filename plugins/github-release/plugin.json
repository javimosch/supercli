{
  "name": "github-release",
  "version": "0.1.0",
  "description": "Simple GitHub release command line tool",
  "source": "https://github.com/c4milo/github-release",
  "checks": [
    {
      "type": "binary",
      "name": "github-release"
    }
  ],
  "install_guidance": {
    "plugin": "github-release",
    "binary": "github-release",
    "check": "which github-release",
    "install_steps": [
      "go install github.com/c4milo/github-release@latest",
      "Verify: github-release --version",
      "supercli plugins install ./plugins/github-release --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "github-release",
      "resource": "self",
      "action": "version",
      "description": "Print github-release version",
      "adapter": "process",
      "adapterConfig": {
        "command": "github-release",
        "missingDependencyHelp": "Install github-release: go install github.com/c4milo/github-release@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "github-release",
      "resource": "release",
      "action": "create",
      "description": "create release via github-release",
      "adapter": "process",
      "adapterConfig": {
        "command": "github-release",
        "missingDependencyHelp": "Install github-release: go install github.com/c4milo/github-release@latest",
        "baseArgs": [
          "create"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "github-release",
      "resource": "release",
      "action": "delete",
      "description": "delete release via github-release",
      "adapter": "process",
      "adapterConfig": {
        "command": "github-release",
        "missingDependencyHelp": "Install github-release: go install github.com/c4milo/github-release@latest",
        "baseArgs": [
          "delete"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "github-release",
      "resource": "release",
      "action": "list",
      "description": "list release via github-release",
      "adapter": "process",
      "adapterConfig": {
        "command": "github-release",
        "missingDependencyHelp": "Install github-release: go install github.com/c4milo/github-release@latest",
        "baseArgs": [
          "list"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "github-release",
      "resource": "asset",
      "action": "upload",
      "description": "upload asset via github-release",
      "adapter": "process",
      "adapterConfig": {
        "command": "github-release",
        "missingDependencyHelp": "Install github-release: go install github.com/c4milo/github-release@latest",
        "baseArgs": [
          "upload"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "github-release",
      "resource": "_",
      "action": "_",
      "description": "_ _ via github-release",
      "adapter": "process",
      "adapterConfig": {
        "command": "github-release",
        "missingDependencyHelp": "Install github-release: go install github.com/c4milo/github-release@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}