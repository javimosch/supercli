{
  "plugin": "github-release",
  "binary": "github-release",
  "check": "which github-release",
  "install_steps": [
    "go install github.com/c4milo/github-release@latest",
    "Verify: github-release --version",
    "supercli plugins install ./plugins/github-release --on-conflict replace --json"
  ]
}