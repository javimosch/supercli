{
  "name": "pluto",
  "version": "0.1.0",
  "description": "Finds deprecated Kubernetes API versions in your cluster",
  "source": "https://github.com/FairwindsOps/pluto",
  "checks": [
    {
      "type": "binary",
      "name": "pluto"
    }
  ],
  "install_guidance": {
    "plugin": "pluto",
    "binary": "pluto",
    "check": "which pluto",
    "install_steps": [
      "brew install FairwindsOps/tap/pluto",
      "Verify: pluto --version",
      "supercli plugins install ./plugins/pluto --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "pluto",
      "resource": "self",
      "action": "version",
      "description": "Print pluto version",
      "adapter": "process",
      "adapterConfig": {
        "command": "pluto",
        "missingDependencyHelp": "Install pluto: brew install FairwindsOps/tap/pluto",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "pluto",
      "resource": "cluster",
      "action": "detect",
      "description": "detect cluster via pluto",
      "adapter": "process",
      "adapterConfig": {
        "command": "pluto",
        "missingDependencyHelp": "Install pluto: brew install FairwindsOps/tap/pluto",
        "baseArgs": [
          "detect"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "pluto",
      "resource": "files",
      "action": "detect",
      "description": "detect files via pluto",
      "adapter": "process",
      "adapterConfig": {
        "command": "pluto",
        "missingDependencyHelp": "Install pluto: brew install FairwindsOps/tap/pluto",
        "baseArgs": [
          "detect-files"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "pluto",
      "resource": "_",
      "action": "_",
      "description": "_ _ via pluto",
      "adapter": "process",
      "adapterConfig": {
        "command": "pluto",
        "missingDependencyHelp": "Install pluto: brew install FairwindsOps/tap/pluto",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}