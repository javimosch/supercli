  "install_guidance": {
    "plugin": "do-latency",
    "binary": "do-latency",
    "check": "which do-latency",
    "install_steps": [
      "pip install do-latency",
      "Verify: do-latency --version",
      "supercli plugins install ./plugins/do-latency --on-conflict replace --json"
    ]
