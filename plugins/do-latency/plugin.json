{
  "name": "do-latency",
  "version": "0.1.0",
  "description": "Digital Ocean regions latency checker to find the fastest region for your needs",
  "source": "https://github.com/dizballanze/do-latency",
  "checks": [
    {
      "type": "binary",
      "name": "do-latency"
    }
