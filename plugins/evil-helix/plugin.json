{
  "name": "evil-helix",
  "version": "0.1.0",
  "description": "Vim-inspired modal editing for Helix editor. A compatibility layer adding Vim keybindings and modes to the Helix terminal editor.",
  "source": "https://github.com/usagi-flow/evil-helix",
  "checks": [
    { "type": "binary", "name": "hx" }
  ],
  "install_guidance": {
    "plugin": "evil-helix",
    "binary": "hx",
    "check": "which hx",
    "install_steps": [
      "brew install evil-helix",
      "Verify: hx --version",
      "supercli plugins install ./plugins/evil-helix --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "evil-helix",
      "resource": "file",
      "action": "edit",
      "description": "Open file with evil-helix editor",
      "adapter": "process",
      "adapterConfig": {
        "command": "hx",
        "baseArgs": [],
        "passthrough": true,
        "missingDependencyHelp": "Install evil-helix: brew install evil-helix"
      },
      "args": [
        { "name": "path", "type": "string", "description": "File or directory to open" },
        { "name": "--health", "type": "string", "description": "Check health for language" }
      ]
    },
    {
      "namespace": "evil-helix",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to evil-helix CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "hx",
        "passthrough": true,
        "missingDependencyHelp": "Install evil-helix: brew install evil-helix"
      },
      "args": []
    }
  ]
}
