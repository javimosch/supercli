{
  "name": "Appfairy",
  "version": "0.1.0",
  "description": "Web application development and deployment CLI tool",
  "source": "https://github.com/DAB0mB/Appfairy",
  "checks": [
    {
      "type": "binary",
      "name": "appfairy"
    }
  ],
  "install_guidance": {
    "plugin": "Appfairy",
    "binary": "appfairy",
    "check": "which appfairy",
    "install_steps": [
      "npm install -g appfairy",
      "Verify: appfairy --version",
      "supercli plugins install ./plugins/Appfairy --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "Appfairy",
      "resource": "self",
      "action": "version",
      "description": "Print Appfairy version",
      "adapter": "process",
      "adapterConfig": {
        "command": "appfairy",
        "missingDependencyHelp": "Install Appfairy: npm install -g appfairy",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "Appfairy",
      "resource": "app",
      "action": "build",
      "description": "build app via appfairy",
      "adapter": "process",
      "adapterConfig": {
        "command": "appfairy",
        "missingDependencyHelp": "Install Appfairy: npm install -g appfairy",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "Appfairy",
      "resource": "app",
      "action": "deploy",
      "description": "deploy app via appfairy",
      "adapter": "process",
      "adapterConfig": {
        "command": "appfairy",
        "missingDependencyHelp": "Install Appfairy: npm install -g appfairy",
        "baseArgs": [
          "deploy"
        ],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "Appfairy",
      "resource": "_",
      "action": "_",
      "description": "_ _ via appfairy",
      "adapter": "process",
      "adapterConfig": {
        "command": "appfairy",
        "missingDependencyHelp": "Install Appfairy: npm install -g appfairy",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}