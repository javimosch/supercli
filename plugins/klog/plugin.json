{
  "name": "klog",
  "version": "0.1.0",
  "description": "Command-line tool for time tracking in a human-readable, plain-text file format",
  "source": "https://github.com/jotaen/klog",
  "checks": [
    {
      "type": "binary",
      "name": "klog"
    }
  ],
  "install_guidance": {
    "plugin": "klog",
    "binary": "klog",
    "check": "which klog",
    "install_steps": [
      "brew install klog",
      "Verify: klog --version",
      "supercli plugins install ./plugins/klog --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "klog",
      "resource": "self",
      "action": "version",
      "description": "Print klog version",
      "adapter": "process",
      "adapterConfig": {
        "command": "klog",
        "missingDependencyHelp": "Install klog: brew install klog",
        "baseArgs": [
          "version"
        ]
      },
      "args": []
    },
    {
      "namespace": "klog",
      "resource": "time",
      "action": "track",
      "description": "track time via klog",
      "adapter": "process",
      "adapterConfig": {
        "command": "klog",
        "missingDependencyHelp": "Install klog: brew install klog",
        "baseArgs": [
          "track"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "klog",
      "resource": "report",
      "action": "generate",
      "description": "generate report via klog",
      "adapter": "process",
      "adapterConfig": {
        "command": "klog",
        "missingDependencyHelp": "Install klog: brew install klog",
        "baseArgs": [
          "total"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "klog",
      "resource": "_",
      "action": "_",
      "description": "_ _ via klog",
      "adapter": "process",
      "adapterConfig": {
        "command": "klog",
        "missingDependencyHelp": "Install klog: brew install klog",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}