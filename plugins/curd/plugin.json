{
  "name": "curd",
  "version": "0.1.0",
  "description": "Anime episode manager and scraper CLI",
  "source": "https://github.com/Wraient/curd",
  "checks": [
    {
      "type": "binary",
      "name": "curd"
    }
  ],
  "install_guidance": {
    "plugin": "curd",
    "binary": "curd",
    "check": "which curd",
    "install_steps": [
      "go install github.com/Wraient/curd@latest",
      "Verify: curd --version",
      "supercli plugins install ./plugins/curd --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "curd",
      "resource": "self",
      "action": "version",
      "description": "Print curd version",
      "adapter": "process",
      "adapterConfig": {
        "command": "curd",
        "missingDependencyHelp": "Install curd: go install github.com/Wraient/curd@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "curd",
      "resource": "episode",
      "action": "manage",
      "description": "manage episode via curd",
      "adapter": "process",
      "adapterConfig": {
        "command": "curd",
        "missingDependencyHelp": "Install curd: go install github.com/Wraient/curd@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "curd",
      "resource": "_",
      "action": "_",
      "description": "_ _ via curd",
      "adapter": "process",
      "adapterConfig": {
        "command": "curd",
        "missingDependencyHelp": "Install curd: go install github.com/Wraient/curd@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}