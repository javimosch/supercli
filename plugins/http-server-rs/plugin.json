{
  "name": "http-server-rs",
  "version": "0.1.0",
  "description": "Simple and configurable command-line HTTP server written in Rust",
  "source": "https://github.com/http-server-rs/http-server",
  "checks": [
    {
      "type": "binary",
      "name": "http-server"
    }
  ],
  "install_guidance": {
    "plugin": "http-server-rs",
    "binary": "http-server",
    "check": "which http-server",
    "install_steps": [
      "cargo install http-server",
      "Verify: http-server --version",
      "supercli plugins install ./plugins/http-server-rs --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "http-server-rs",
      "resource": "self",
      "action": "version",
      "description": "Print http-server-rs version",
      "adapter": "process",
      "adapterConfig": {
        "command": "http-server",
        "missingDependencyHelp": "Install http-server-rs: cargo install http-server",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "http-server-rs",
      "resource": "server",
      "action": "start",
      "description": "start server via http-server",
      "adapter": "process",
      "adapterConfig": {
        "command": "http-server",
        "missingDependencyHelp": "Install http-server-rs: cargo install http-server",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "http-server-rs",
      "resource": "config",
      "action": "show",
      "description": "show config via http-server",
      "adapter": "process",
      "adapterConfig": {
        "command": "http-server",
        "missingDependencyHelp": "Install http-server-rs: cargo install http-server",
        "baseArgs": [
          "--config"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "http-server-rs",
      "resource": "port",
      "action": "set",
      "description": "set port via http-server",
      "adapter": "process",
      "adapterConfig": {
        "command": "http-server",
        "missingDependencyHelp": "Install http-server-rs: cargo install http-server",
        "baseArgs": [
          "--port"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "http-server-rs",
      "resource": "directory",
      "action": "serve",
      "description": "serve directory via http-server",
      "adapter": "process",
      "adapterConfig": {
        "command": "http-server",
        "missingDependencyHelp": "Install http-server-rs: cargo install http-server",
        "baseArgs": [
          "--directory"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "http-server-rs",
      "resource": "tls",
      "action": "enable",
      "description": "enable tls via http-server",
      "adapter": "process",
      "adapterConfig": {
        "command": "http-server",
        "missingDependencyHelp": "Install http-server-rs: cargo install http-server",
        "baseArgs": [
          "--tls"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "http-server-rs",
      "resource": "cors",
      "action": "enable",
      "description": "enable cors via http-server",
      "adapter": "process",
      "adapterConfig": {
        "command": "http-server",
        "missingDependencyHelp": "Install http-server-rs: cargo install http-server",
        "baseArgs": [
          "--cors"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "http-server-rs",
      "resource": "_",
      "action": "_",
      "description": "_ _ via http-server",
      "adapter": "process",
      "adapterConfig": {
        "command": "http-server",
        "missingDependencyHelp": "Install http-server-rs: cargo install http-server",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}