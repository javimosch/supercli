{
  "name": "wuzz",
  "version": "0.1.0",
  "description": "Interactive HTTP inspection and testing tool",
  "source": "https://github.com/asciimoo/wuzz",
  "checks": [
    {
      "type": "binary",
      "name": "wuzz"
    }
  ],
  "install_guidance": {
    "plugin": "wuzz",
    "binary": "wuzz",
    "check": "which wuzz",
    "install_steps": [
      "brew install wuzz",
      "Verify: wuzz --version",
      "supercli plugins install ./plugins/wuzz --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "wuzz",
      "resource": "self",
      "action": "version",
      "description": "Print wuzz version",
      "adapter": "process",
      "adapterConfig": {
        "command": "wuzz",
        "missingDependencyHelp": "Install wuzz: brew install wuzz",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "wuzz",
      "resource": "request",
      "action": "test",
      "description": "test request via wuzz",
      "adapter": "process",
      "adapterConfig": {
        "command": "wuzz",
        "missingDependencyHelp": "Install wuzz: brew install wuzz",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "wuzz",
      "resource": "_",
      "action": "_",
      "description": "_ _ via wuzz",
      "adapter": "process",
      "adapterConfig": {
        "command": "wuzz",
        "missingDependencyHelp": "Install wuzz: brew install wuzz",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}