{
  "plugin": "diagram",
  "binary": "diagram",
  "check": "which diagram",
  "install_steps": [
    "go install github.com/esimov/diagram/cmd/diagram@latest",
    "Verify: diagram --help",
    "supercli plugins install ./plugins/diagram --on-conflict replace --json"
  ],
  "note": "diagram converts ASCII art to hand-drawn style images"
}
