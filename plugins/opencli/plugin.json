{
  "name": "opencli",
  "version": "0.1.0",
  "description": "Make Any Website & Tool Your CLI. A universal CLI Hub and AI-native runtime.",
  "source": "https://github.com/jackwener/OpenCLI",
  "checks": [
    { "type": "binary", "name": "opencli" }
  ],
  "commands": [
    {
      "namespace": "opencli",
      "resource": "cli",
      "action": "version",
      "description": "Show opencli version information",
      "adapter": "process",
      "adapterConfig": {
        "command": "opencli",
        "baseArgs": ["--version"],
        "timeout_ms": 15000,
        "missingDependencyHelp": "Please install opencli to use this command."
      },
      "args": []
    },
    {
      "namespace": "opencli",
      "resource": "cli",
      "action": "run",
      "description": "Run a command through opencli",
      "adapter": "process",
      "adapterConfig": {
        "command": "opencli",
        "positionalArgs": ["cmd"],
        "timeout_ms": 30000,
        "missingDependencyHelp": "Please install opencli to use this command."
      },
      "args": [
        { "name": "cmd", "type": "string", "required": true, "description": "Command to run through opencli" }
      ]
    },
    {
      "namespace": "opencli",
      "resource": "tool",
      "action": "convert",
      "description": "Convert a website or tool to CLI interface",
      "adapter": "process",
      "adapterConfig": {
        "command": "opencli",
        "baseArgs": ["convert"],
        "positionalArgs": ["target"],
        "timeout_ms": 60000,
        "missingDependencyHelp": "Please install opencli to use this command."
      },
      "args": [
        { "name": "target", "type": "string", "required": true, "description": "Website URL or tool to convert" }
      ]
    },
    {
      "namespace": "opencli",
      "resource": "registry",
      "action": "list",
      "description": "List available CLI conversions in registry",
      "adapter": "process",
      "adapterConfig": {
        "command": "opencli",
        "baseArgs": ["list"],
        "timeout_ms": 15000,
        "missingDependencyHelp": "Please install opencli to use this command."
      },
      "args": []
    }
  ]
}