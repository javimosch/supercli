{
  "name": "nat",
  "version": "0.1.0",
  "description": "nat - the 'ls' replacement you never knew you needed. A beautifully formatted file and directory listing tool with icons, colors, and git integration.",
  "source": "https://github.com/willdoescode/nat",
  "checks": [
    { "type": "binary", "name": "nat" }
  ],
  "install_guidance": {
    "plugin": "nat",
    "binary": "nat",
    "check": "which nat",
    "install_steps": [
      "brew install nat",
      "Verify: nat --version",
      "supercli plugins install ./plugins/nat --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "nat",
      "resource": "dir",
      "action": "list",
      "description": "List directory contents beautifully",
      "adapter": "process",
      "adapterConfig": {
        "command": "nat",
        "baseArgs": [],
        "passthrough": true,
        "missingDependencyHelp": "Install nat: brew install nat"
      },
      "args": [
        { "name": "path", "type": "string", "description": "Directory path to list" },
        { "name": "--all", "type": "boolean", "description": "Show hidden files" },
        { "name": "--long", "type": "boolean", "description": "Long format listing" },
        { "name": "--icons", "type": "boolean", "description": "Show file icons" }
      ]
    },
    {
      "namespace": "nat",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to nat CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "nat",
        "passthrough": true,
        "missingDependencyHelp": "Install nat: brew install nat"
      },
      "args": []
    }
  ]
}
