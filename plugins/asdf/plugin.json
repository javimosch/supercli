{
  "name": "asdf",
  "version": "0.1.0",
  "description": "Manage multiple runtime versions with a single CLI tool. Extendable version manager for Node.js, Ruby, Python, Elixir, and hundreds more.",
  "source": "https://github.com/asdf-vm/asdf",
  "checks": [
    { "type": "binary", "name": "asdf" }
  ],
  "install_guidance": {
    "plugin": "asdf",
    "binary": "asdf",
    "check": "which asdf",
    "install_steps": [
      "brew install asdf",
      "Verify: asdf --version",
      "supercli plugins install ./plugins/asdf --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "asdf",
      "resource": "tool",
      "action": "install",
      "description": "Install a tool version",
      "adapter": "process",
      "adapterConfig": {
        "command": "asdf",
        "baseArgs": ["install"],
        "passthrough": true,
        "missingDependencyHelp": "Install asdf: brew install asdf"
      },
      "args": [
        { "name": "name", "type": "string", "description": "Tool name" },
        { "name": "version", "type": "string", "description": "Version to install" }
      ]
    },
    {
      "namespace": "asdf",
      "resource": "tool",
      "action": "list",
      "description": "List installed tool versions",
      "adapter": "process",
      "adapterConfig": {
        "command": "asdf",
        "baseArgs": ["list"],
        "passthrough": true,
        "missingDependencyHelp": "Install asdf: brew install asdf"
      },
      "args": [
        { "name": "name", "type": "string", "description": "Tool name" }
      ]
    },
    {
      "namespace": "asdf",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to asdf CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "asdf",
        "passthrough": true,
        "missingDependencyHelp": "Install asdf: brew install asdf"
      },
      "args": []
    }
  ]
}
