{
  "name": "python-cfonts",
  "version": "0.1.0",
  "description": "Sexy fonts for the console with ASCII art and styling",
  "source": "https://github.com/frostming/python-cfonts",
  "checks": [
    {
      "type": "binary",
      "name": "cfonts"
    }
  ],
  "install_guidance": {
    "plugin": "python-cfonts",
    "binary": "cfonts",
    "check": "which cfonts",
    "install_steps": [
      "pip install python-cfonts",
      "Verify: cfonts --version",
      "supercli plugins install ./plugins/python-cfonts --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
