      "namespace": "python-cfonts",
      "resource": "self",
      "action": "version",
      "description": "Print python-cfonts version",
      "adapter": "process",
      "adapterConfig": {
        "command": "cfonts",
        "missingDependencyHelp": "Install python-cfonts: pip install python-cfonts",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
