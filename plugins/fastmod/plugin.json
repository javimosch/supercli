{
  "name": "fastmod",
  "version": "0.1.0",
  "description": "A fast partial replacement for codemod. Interactive tool for making fast, semi-automated substitutions across a codebase.",
  "source": "https://github.com/facebookincubator/fastmod",
  "checks": [
    { "type": "binary", "name": "fastmod" }
  ],
  "install_guidance": {
    "plugin": "fastmod",
    "binary": "fastmod",
    "check": "which fastmod",
    "install_steps": [
      "brew install fastmod",
      "Verify: fastmod --version",
      "supercli plugins install ./plugins/fastmod --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "fastmod",
      "resource": "code",
      "action": "replace",
      "description": "Search and replace across codebase",
      "adapter": "process",
      "adapterConfig": {
        "command": "fastmod",
        "baseArgs": [],
        "passthrough": true,
        "missingDependencyHelp": "Install fastmod: brew install fastmod"
      },
      "args": [
        { "name": "search", "type": "string", "description": "Search pattern" },
        { "name": "replace", "type": "string", "description": "Replacement text" },
        { "name": "--accept-all", "type": "boolean", "description": "Accept all changes without prompt" },
        { "name": "--dir", "type": "string", "description": "Directory to search" }
      ]
    },
    {
      "namespace": "fastmod",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to fastmod CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "fastmod",
        "passthrough": true,
        "missingDependencyHelp": "Install fastmod: brew install fastmod"
      },
      "args": []
    }
  ]
}
