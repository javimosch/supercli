{
  "name": "goplaces",
  "version": "0.1.0",
  "description": "Modern Google Places command line tool in Go",
  "source": "https://github.com/steipete/goplaces",
  "checks": [
    {
      "type": "binary",
      "name": "goplaces"
    }
  ],
  "install_guidance": {
    "plugin": "goplaces",
    "binary": "goplaces",
    "check": "which goplaces",
    "install_steps": [
      "go install github.com/steipete/goplaces@latest",
      "Verify: goplaces --version",
      "supercli plugins install ./plugins/goplaces --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "goplaces",
      "resource": "self",
      "action": "version",
      "description": "Print goplaces version",
      "adapter": "process",
      "adapterConfig": {
        "command": "goplaces",
        "missingDependencyHelp": "Install goplaces: go install github.com/steipete/goplaces@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "goplaces",
      "resource": "place",
      "action": "search",
      "description": "search place via goplaces",
      "adapter": "process",
      "adapterConfig": {
        "command": "goplaces",
        "missingDependencyHelp": "Install goplaces: go install github.com/steipete/goplaces@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "goplaces",
      "resource": "place",
      "action": "details",
      "description": "details place via goplaces",
      "adapter": "process",
      "adapterConfig": {
        "command": "goplaces",
        "missingDependencyHelp": "Install goplaces: go install github.com/steipete/goplaces@latest",
        "baseArgs": [
          "--details"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "goplaces",
      "resource": "nearby",
      "action": "find",
      "description": "find nearby via goplaces",
      "adapter": "process",
      "adapterConfig": {
        "command": "goplaces",
        "missingDependencyHelp": "Install goplaces: go install github.com/steipete/goplaces@latest",
        "baseArgs": [
          "--nearby"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "goplaces",
      "resource": "_",
      "action": "_",
      "description": "_ _ via goplaces",
      "adapter": "process",
      "adapterConfig": {
        "command": "goplaces",
        "missingDependencyHelp": "Install goplaces: go install github.com/steipete/goplaces@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}