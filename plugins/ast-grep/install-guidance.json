{
  "plugin": "ast-grep",
  "binary": "ast-grep",
  "check": "which ast-grep",
  "install_steps": [
    "npm install --global @ast-grep/cli",
    "Verify: ast-grep --version",
    "supercli plugins install ./plugins/ast-grep --on-conflict replace --json"
  ],
  "note": "Also available via: cargo install ast-grep, brew install ast-grep, pip install ast-grep-cli"
}