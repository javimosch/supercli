{
  "name": "covermyass",
  "version": "0.1.0",
  "description": "Remove sensitive information from logs and files",
  "source": "https://github.com/sundowndev/covermyass",
  "checks": [
    {
      "type": "binary",
      "name": "covermyass"
    }
  ],
  "install_guidance": {
    "plugin": "covermyass",
    "binary": "covermyass",
    "check": "which covermyass",
    "install_steps": [
      "go install github.com/sundowndev/covermyass@latest",
      "Verify: covermyass --version",
      "supercli plugins install ./plugins/covermyass --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "covermyass",
      "resource": "self",
      "action": "version",
      "description": "Print covermyass version",
      "adapter": "process",
      "adapterConfig": {
        "command": "covermyass",
        "missingDependencyHelp": "Install covermyass: go install github.com/sundowndev/covermyass@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "covermyass",
      "resource": "file",
      "action": "clean",
      "description": "clean file via covermyass",
      "adapter": "process",
      "adapterConfig": {
        "command": "covermyass",
        "missingDependencyHelp": "Install covermyass: go install github.com/sundowndev/covermyass@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "covermyass",
      "resource": "_",
      "action": "_",
      "description": "_ _ via covermyass",
      "adapter": "process",
      "adapterConfig": {
        "command": "covermyass",
        "missingDependencyHelp": "Install covermyass: go install github.com/sundowndev/covermyass@latest",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}