{
  "name": "grpcdebug",
  "version": "0.1.0",
  "description": "CLI for simplifying gRPC application debugging",
  "source": "https://github.com/grpc-ecosystem/grpcdebug",
  "checks": [
    {
      "type": "binary",
      "name": "grpcdebug"
    }
  ],
  "install_guidance": {
    "plugin": "grpcdebug",
    "binary": "grpcdebug",
    "check": "which grpcdebug",
    "install_steps": [
      "go install github.com/grpc-ecosystem/grpcdebug@latest",
      "Verify: grpcdebug --version",
      "supercli plugins install ./plugins/grpcdebug --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "grpcdebug",
      "resource": "self",
      "action": "version",
      "description": "Print grpcdebug version",
      "adapter": "process",
      "adapterConfig": {
        "command": "grpcdebug",
        "missingDependencyHelp": "Install grpcdebug: go install github.com/grpc-ecosystem/grpcdebug@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "grpcdebug",
      "resource": "service",
      "action": "health",
      "description": "health service via grpcdebug",
      "adapter": "process",
      "adapterConfig": {
        "command": "grpcdebug",
        "missingDependencyHelp": "Install grpcdebug: go install github.com/grpc-ecosystem/grpcdebug@latest",
        "baseArgs": [
          "health"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "grpcdebug",
      "resource": "channel",
      "action": "list",
      "description": "list channel via grpcdebug",
      "adapter": "process",
      "adapterConfig": {
        "command": "grpcdebug",
        "missingDependencyHelp": "Install grpcdebug: go install github.com/grpc-ecosystem/grpcdebug@latest",
        "baseArgs": [
          "channels"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "grpcdebug",
      "resource": "server",
      "action": "stats",
      "description": "stats server via grpcdebug",
      "adapter": "process",
      "adapterConfig": {
        "command": "grpcdebug",
        "missingDependencyHelp": "Install grpcdebug: go install github.com/grpc-ecosystem/grpcdebug@latest",
        "baseArgs": [
          "server-stats"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "grpcdebug",
      "resource": "xds",
      "action": "config",
      "description": "config xds via grpcdebug",
      "adapter": "process",
      "adapterConfig": {
        "command": "grpcdebug",
        "missingDependencyHelp": "Install grpcdebug: go install github.com/grpc-ecosystem/grpcdebug@latest",
        "baseArgs": [
          "xds"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "grpcdebug",
      "resource": "_",
      "action": "_",
      "description": "_ _ via grpcdebug",
      "adapter": "process",
      "adapterConfig": {
        "command": "grpcdebug",
        "missingDependencyHelp": "Install grpcdebug: go install github.com/grpc-ecosystem/grpcdebug@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}