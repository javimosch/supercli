{
  "name": "chroma",
  "version": "0.1.0",
  "description": "A general-purpose syntax highlighter in pure Go",
  "source": "https://github.com/alecthomas/chroma",
  "checks": [
    {
      "type": "binary",
      "name": "chroma"
    }
  ],
  "install_guidance": {
    "plugin": "chroma",
    "binary": "chroma",
    "check": "which chroma",
    "install_steps": [
      "go install github.com/alecthomas/chroma/cmd/chroma@latest",
      "Verify: chroma --version",
      "supercli plugins install ./plugins/chroma --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "chroma",
      "resource": "self",
      "action": "version",
      "description": "Print chroma version",
      "adapter": "process",
      "adapterConfig": {
        "command": "chroma",
        "missingDependencyHelp": "Install chroma: go install github.com/alecthomas/chroma/cmd/chroma@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "chroma",
      "resource": "file",
      "action": "highlight",
      "description": "highlight file via chroma",
      "adapter": "process",
      "adapterConfig": {
        "command": "chroma",
        "missingDependencyHelp": "Install chroma: go install github.com/alecthomas/chroma/cmd/chroma@latest",
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "chroma",
      "resource": "_",
      "action": "_",
      "description": "_ _ via chroma",
      "adapter": "process",
      "adapterConfig": {
        "command": "chroma",
        "missingDependencyHelp": "Install chroma: go install github.com/alecthomas/chroma/cmd/chroma@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}