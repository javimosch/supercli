{
  "name": "fclones",
  "version": "0.1.0",
  "description": "Efficient duplicate file finder",
  "source": "https://github.com/pkolaczk/fclones",
  "checks": [
    {
      "type": "binary",
      "name": "fclones"
    }
  ],
  "install_guidance": {
    "plugin": "fclones",
    "binary": "fclones",
    "check": "which fclones",
    "install_steps": [
      "cargo install fclones",
      "Verify: fclones --version",
      "supercli plugins install ./plugins/fclones --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "fclones",
      "resource": "self",
      "action": "version",
      "description": "Print fclones version",
      "adapter": "process",
      "adapterConfig": {
        "command": "fclones",
        "missingDependencyHelp": "Install fclones: cargo install fclones",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "fclones",
      "resource": "duplicates",
      "action": "find",
      "description": "find duplicates via fclones",
      "adapter": "process",
      "adapterConfig": {
        "command": "fclones",
        "missingDependencyHelp": "Install fclones: cargo install fclones",
        "baseArgs": [
          "find"
        ],
        "passthrough": true,
        "timeout_ms": 120000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "fclones",
      "resource": "group",
      "action": "list",
      "description": "list group via fclones",
      "adapter": "process",
      "adapterConfig": {
        "command": "fclones",
        "missingDependencyHelp": "Install fclones: cargo install fclones",
        "baseArgs": [
          "group"
        ],
        "passthrough": true,
        "timeout_ms": 120000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "fclones",
      "resource": "_",
      "action": "_",
      "description": "_ _ via fclones",
      "adapter": "process",
      "adapterConfig": {
        "command": "fclones",
        "missingDependencyHelp": "Install fclones: cargo install fclones",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}