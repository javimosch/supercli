    "plugin": "zksync-cli",
    "binary": "zksync-cli",
    "check": "which zksync-cli",
    "install_steps": [
      "npm install -g zksync-cli",
      "Verify: zksync-cli --version",
      "supercli plugins install ./plugins/zksync-cli --on-conflict replace --json"
    ]
