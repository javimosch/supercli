{
  "name": "hopp-cli",
  "version": "0.1.0",
  "description": "HTTP CLI client for Hoppscotch API testing",
  "source": "https://github.com/hoppscotch/hopp-cli",
  "checks": [
    {
      "type": "binary",
      "name": "hopp"
    }
  ],
  "install_guidance": {
    "plugin": "hopp-cli",
    "binary": "hopp",
    "check": "which hopp",
    "install_steps": [
      "go install github.com/hoppscotch/hopp-cli@latest",
      "Verify: hopp --version",
      "supercli plugins install ./plugins/hopp-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "hopp-cli",
      "resource": "self",
      "action": "version",
      "description": "Print hopp-cli version",
      "adapter": "process",
      "adapterConfig": {
        "command": "hopp",
        "missingDependencyHelp": "Install hopp-cli: go install github.com/hoppscotch/hopp-cli@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "hopp-cli",
      "resource": "request",
      "action": "send",
      "description": "send request via hopp",
      "adapter": "process",
      "adapterConfig": {
        "command": "hopp",
        "missingDependencyHelp": "Install hopp-cli: go install github.com/hoppscotch/hopp-cli@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "hopp-cli",
      "resource": "collection",
      "action": "run",
      "description": "run collection via hopp",
      "adapter": "process",
      "adapterConfig": {
        "command": "hopp",
        "missingDependencyHelp": "Install hopp-cli: go install github.com/hoppscotch/hopp-cli@latest",
        "baseArgs": [
          "--collection"
        ],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "hopp-cli",
      "resource": "environment",
      "action": "list",
      "description": "list environment via hopp",
      "adapter": "process",
      "adapterConfig": {
        "command": "hopp",
        "missingDependencyHelp": "Install hopp-cli: go install github.com/hoppscotch/hopp-cli@latest",
        "baseArgs": [
          "--env-list"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "hopp-cli",
      "resource": "_",
      "action": "_",
      "description": "_ _ via hopp",
      "adapter": "process",
      "adapterConfig": {
        "command": "hopp",
        "missingDependencyHelp": "Install hopp-cli: go install github.com/hoppscotch/hopp-cli@latest",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}