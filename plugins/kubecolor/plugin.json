{
  "name": "kubecolor",
  "version": "0.1.0",
  "description": "Colorize your kubectl output. A kubectl wrapper that adds syntax highlighting and color coding to Kubernetes command output for better readability.",
  "source": "https://github.com/kubecolor/kubecolor",
  "checks": [
    { "type": "binary", "name": "kubecolor" }
  ],
  "install_guidance": {
    "plugin": "kubecolor",
    "binary": "kubecolor",
    "check": "which kubecolor",
    "install_steps": [
      "brew install kubecolor",
      "Verify: kubecolor --version",
      "supercli plugins install ./plugins/kubecolor --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "kubecolor",
      "resource": "k8s",
      "action": "run",
      "description": "Run kubectl command with colorized output",
      "adapter": "process",
      "adapterConfig": {
        "command": "kubecolor",
        "passthrough": true,
        "missingDependencyHelp": "Install kubecolor: brew install kubecolor"
      },
      "args": [
        { "name": "kubectl-args", "type": "string", "description": "kubectl subcommand and arguments" }
      ]
    },
    {
      "namespace": "kubecolor",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to kubecolor CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "kubecolor",
        "passthrough": true,
        "missingDependencyHelp": "Install kubecolor: brew install kubecolor"
      },
      "args": []
    }
  ]
}
