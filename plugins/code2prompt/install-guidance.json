{
  "plugin": "code2prompt",
  "binary": "code2prompt",
  "check": "which code2prompt",
  "install_steps": [
    "cargo install code2prompt",
    "Verify: code2prompt --version",
    "supercli plugins install ./plugins/code2prompt --on-conflict replace --json"
