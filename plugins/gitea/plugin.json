{
  "name": "gitea",
  "version": "0.1.0",
  "description": "Painless self-hosted Git service with CLI administration",
  "source": "https://github.com/go-gitea/gitea",
  "checks": [
    {
      "type": "binary",
      "name": "gitea"
    }
  ],
  "install_guidance": {
    "plugin": "gitea",
    "binary": "gitea",
    "check": "which gitea",
    "install_steps": [
      "brew install gitea",
      "Verify: gitea --version",
      "supercli plugins install ./plugins/gitea --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "gitea",
      "resource": "self",
      "action": "version",
      "description": "Print gitea version",
      "adapter": "process",
      "adapterConfig": {
        "command": "gitea",
        "missingDependencyHelp": "Install gitea: brew install gitea",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "gitea",
      "resource": "admin",
      "action": "create-user",
      "description": "create-user admin via gitea",
      "adapter": "process",
      "adapterConfig": {
        "command": "gitea",
        "missingDependencyHelp": "Install gitea: brew install gitea",
        "baseArgs": [
          "admin",
          "user",
          "create"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "gitea",
      "resource": "admin",
      "action": "delete-user",
      "description": "delete-user admin via gitea",
      "adapter": "process",
      "adapterConfig": {
        "command": "gitea",
        "missingDependencyHelp": "Install gitea: brew install gitea",
        "baseArgs": [
          "admin",
          "user",
          "delete"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "gitea",
      "resource": "migrate",
      "action": "list",
      "description": "list migrate via gitea",
      "adapter": "process",
      "adapterConfig": {
        "command": "gitea",
        "missingDependencyHelp": "Install gitea: brew install gitea",
        "baseArgs": [
          "migrate",
          "list"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "gitea",
      "resource": "dump",
      "action": "create",
      "description": "create dump via gitea",
      "adapter": "process",
      "adapterConfig": {
        "command": "gitea",
        "missingDependencyHelp": "Install gitea: brew install gitea",
        "baseArgs": [
          "dump"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "gitea",
      "resource": "_",
      "action": "_",
      "description": "_ _ via gitea",
      "adapter": "process",
      "adapterConfig": {
        "command": "gitea",
        "missingDependencyHelp": "Install gitea: brew install gitea",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}