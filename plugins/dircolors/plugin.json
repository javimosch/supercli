{
  "name": "dircolors",
  "version": "0.1.0",
  "description": "Colorize ls output with Nord theme support",
  "source": "https://github.com/nordtheme/dircolors",
  "checks": [
    {
      "type": "binary",
      "name": "dircolors"
    }
  ],
  "install_guidance": {
    "plugin": "dircolors",
    "binary": "dircolors",
    "check": "which dircolors",
    "install_steps": [
      "npm install -g dircolors",
      "Verify: dircolors --version",
      "supercli plugins install ./plugins/dircolors --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "dircolors",
      "resource": "self",
      "action": "version",
      "description": "Print dircolors version",
      "adapter": "process",
      "adapterConfig": {
        "command": "dircolors",
        "missingDependencyHelp": "Install dircolors: npm install -g dircolors",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "dircolors",
      "resource": "dir",
      "action": "colorize",
      "description": "colorize dir via dircolors",
      "adapter": "process",
      "adapterConfig": {
        "command": "dircolors",
        "missingDependencyHelp": "Install dircolors: npm install -g dircolors",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "dircolors",
      "resource": "_",
      "action": "_",
      "description": "_ _ via dircolors",
      "adapter": "process",
      "adapterConfig": {
        "command": "dircolors",
        "missingDependencyHelp": "Install dircolors: npm install -g dircolors",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}