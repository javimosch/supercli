{
  "name": "savvy-cli",
  "version": "0.1.0",
  "description": "Record, replay and share terminal sessions",
  "source": "https://github.com/getsavvyinc/savvy-cli",
  "checks": [
    {
      "type": "binary",
      "name": "savvy"
    }
  ],
  "install_guidance": {
    "plugin": "savvy-cli",
    "binary": "savvy",
    "check": "which savvy",
    "install_steps": [
      "brew install getsavvy/tap/savvy",
      "Verify: savvy --version",
      "supercli plugins install ./plugins/savvy-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "savvy-cli",
      "resource": "self",
      "action": "version",
      "description": "Print savvy-cli version",
      "adapter": "process",
      "adapterConfig": {
        "command": "savvy",
        "missingDependencyHelp": "Install savvy-cli: brew install getsavvy/tap/savvy",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "savvy-cli",
      "resource": "session",
      "action": "record",
      "description": "record session via savvy",
      "adapter": "process",
      "adapterConfig": {
        "command": "savvy",
        "missingDependencyHelp": "Install savvy-cli: brew install getsavvy/tap/savvy",
        "baseArgs": [
          "record"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "savvy-cli",
      "resource": "session",
      "action": "replay",
      "description": "replay session via savvy",
      "adapter": "process",
      "adapterConfig": {
        "command": "savvy",
        "missingDependencyHelp": "Install savvy-cli: brew install getsavvy/tap/savvy",
        "baseArgs": [
          "replay"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "savvy-cli",
      "resource": "session",
      "action": "share",
      "description": "share session via savvy",
      "adapter": "process",
      "adapterConfig": {
        "command": "savvy",
        "missingDependencyHelp": "Install savvy-cli: brew install getsavvy/tap/savvy",
        "baseArgs": [
          "share"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "savvy-cli",
      "resource": "_",
      "action": "_",
      "description": "_ _ via savvy",
      "adapter": "process",
      "adapterConfig": {
        "command": "savvy",
        "missingDependencyHelp": "Install savvy-cli: brew install getsavvy/tap/savvy",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}