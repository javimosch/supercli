      "namespace": "QuickWall",
      "resource": "self",
      "action": "version",
      "description": "Print QuickWall version",
      "adapter": "process",
      "adapterConfig": {
        "command": "quickwall",
        "missingDependencyHelp": "Install QuickWall: pip install quickwall",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "QuickWall",
      "resource": "wallpaper",
      "action": "set",
      "description": "set wallpaper via quickwall",
      "adapter": "process",
      "adapterConfig": {
        "command": "quickwall",
        "missingDependencyHelp": "Install QuickWall: pip install quickwall",
        "baseArgs": [
          "set"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
