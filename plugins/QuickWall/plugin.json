{
  "name": "QuickWall",
  "version": "0.1.0",
  "description": "Set latest wallpapers from Unsplash from the commandline",
  "source": "https://github.com/deepjyoti30/QuickWall",
  "checks": [
    {
      "type": "binary",
      "name": "quickwall"
    }
  ],
  "install_guidance": {
    "plugin": "QuickWall",
    "binary": "quickwall",
    "check": "which quickwall",
    "install_steps": [
      "pip install quickwall",
      "Verify: quickwall --version",
      "supercli plugins install ./plugins/QuickWall --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
