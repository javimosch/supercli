{
  "name": "image-optimize",
  "version": "0.1.0",
  "description": "CLI tool for optimizing images",
  "source": "https://www.npmjs.com/package/image-optimize",
  "checks": [
    { "type": "binary", "name": "image-optimize" }
  ],
  "install_guidance": {
    "plugin": "image-optimize",
    "binary": "image-optimize",
    "check": "which image-optimize",
    "install_steps": [
      "npm install -g image-optimize",
      "Verify: image-optimize --help",
      "supercli plugins install ./plugins/image-optimize --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "image-optimize",
      "resource": "file",
      "action": "optimize",
      "description": "Optimize image files",
      "adapter": "process",
      "adapterConfig": {
        "command": "image-optimize",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000,
        "missingDependencyHelp": "Install image-optimize: npm install -g image-optimize"
      },
      "args": [
        { "name": "path", "type": "string", "required": true, "description": "File or directory to optimize" },
        { "name": "type", "type": "string", "required": false, "description": "Image type (png, jpg, etc.)" },
        { "name": "force", "type": "boolean", "required": false, "description": "Force overwrite" }
      ]
    },
    {
      "namespace": "image-optimize",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to image-optimize CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "image-optimize",
        "passthrough": true,
        "missingDependencyHelp": "Install image-optimize: npm install -g image-optimize"
      },
      "args": []
    }
  ]
}
