{
  "name": "eza",
  "version": "0.1.0",
  "description": "eza CLI plugin for dcli",
  "source": "https://eza.rocks",
  "checks": [
    {
      "type": "binary",
      "name": "eza"
    }
  ],
  "commands": [
    {
      "namespace": "eza",
      "resource": "cli",
      "action": "version",
      "description": "Show eza CLI version",
      "adapter": "process",
      "adapterConfig": {
        "command": "eza",
        "baseArgs": ["--version"],
        "parseJson": false,
        "missingDependencyHelp": "Please install eza to use this command."
      },
      "args": []
    },
    {
      "namespace": "eza",
      "resource": "_",
      "action": "_",
      "description": "Passthrough command to execute any eza CLI command",
      "adapter": "process",
      "adapterConfig": {
        "command": "eza",
        "passthrough": true,
        "parseJson": true,
        "missingDependencyHelp": "Please install eza to use this command."
      },
      "args": []
    }
  ]
}
