{
  "name": "k8scr",
  "version": "0.1.0",
  "description": "Push and pull OCI images to/from Kubernetes clusters",
  "source": "https://github.com/hasheddan/k8scr",
  "checks": [
    {
      "type": "binary",
      "name": "k8scr"
    }
  ],
  "install_guidance": {
    "plugin": "k8scr",
    "binary": "k8scr",
    "check": "which k8scr",
    "install_steps": [
      "go install github.com/hasheddan/k8scr@latest",
      "Verify: k8scr --version",
      "supercli plugins install ./plugins/k8scr --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "k8scr",
      "resource": "self",
      "action": "version",
      "description": "Print k8scr version",
      "adapter": "process",
      "adapterConfig": {
        "command": "k8scr",
        "missingDependencyHelp": "Install k8scr: go install github.com/hasheddan/k8scr@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "k8scr",
      "resource": "image",
      "action": "push",
      "description": "push image via k8scr",
      "adapter": "process",
      "adapterConfig": {
        "command": "k8scr",
        "missingDependencyHelp": "Install k8scr: go install github.com/hasheddan/k8scr@latest",
        "baseArgs": [
          "push"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "k8scr",
      "resource": "image",
      "action": "pull",
      "description": "pull image via k8scr",
      "adapter": "process",
      "adapterConfig": {
        "command": "k8scr",
        "missingDependencyHelp": "Install k8scr: go install github.com/hasheddan/k8scr@latest",
        "baseArgs": [
          "pull"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "k8scr",
      "resource": "image",
      "action": "list",
      "description": "list image via k8scr",
      "adapter": "process",
      "adapterConfig": {
        "command": "k8scr",
        "missingDependencyHelp": "Install k8scr: go install github.com/hasheddan/k8scr@latest",
        "baseArgs": [
          "list"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "k8scr",
      "resource": "_",
      "action": "_",
      "description": "_ _ via k8scr",
      "adapter": "process",
      "adapterConfig": {
        "command": "k8scr",
        "missingDependencyHelp": "Install k8scr: go install github.com/hasheddan/k8scr@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}