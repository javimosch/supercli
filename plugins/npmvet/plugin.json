{
  "name": "npmvet",
  "version": "0.1.0",
  "description": "Simple CLI tool for vetting npm package versions against allowed ranges",
  "source": "https://github.com/harksys/npmvet",
  "checks": [
    {
      "type": "binary",
      "name": "npmvet"
    }
  ],
  "install_guidance": {
    "plugin": "npmvet",
    "binary": "npmvet",
    "check": "which npmvet",
    "install_steps": [
      "npm install -g npmvet",
      "Verify: npmvet --version",
      "supercli plugins install ./plugins/npmvet --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "npmvet",
      "resource": "self",
      "action": "version",
      "description": "Print npmvet version",
      "adapter": "process",
      "adapterConfig": {
        "command": "npmvet",
        "missingDependencyHelp": "Install npmvet: npm install -g npmvet",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "npmvet",
      "resource": "packages",
      "action": "check",
      "description": "check packages via npmvet",
      "adapter": "process",
      "adapterConfig": {
        "command": "npmvet",
        "missingDependencyHelp": "Install npmvet: npm install -g npmvet",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
