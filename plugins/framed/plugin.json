{
  "name": "framed",
  "version": "0.1.0",
  "description": "Architect your project with effortless files and directories management",
  "source": "https://github.com/mactat/framed",
  "checks": [
    {
      "type": "binary",
      "name": "framed"
    }
  ],
  "install_guidance": {
    "plugin": "framed",
    "binary": "framed",
    "check": "which framed",
    "install_steps": [
      "go install github.com/mactat/framed@latest",
      "Verify: framed --version",
      "supercli plugins install ./plugins/framed --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "framed",
      "resource": "self",
      "action": "version",
      "description": "Print framed version",
      "adapter": "process",
      "adapterConfig": {
        "command": "framed",
        "missingDependencyHelp": "Install framed: go install github.com/mactat/framed@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "framed",
      "resource": "project",
      "action": "scaffold",
      "description": "scaffold project via framed",
      "adapter": "process",
      "adapterConfig": {
        "command": "framed",
        "missingDependencyHelp": "Install framed: go install github.com/mactat/framed@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "framed",
      "resource": "template",
      "action": "list",
      "description": "list template via framed",
      "adapter": "process",
      "adapterConfig": {
        "command": "framed",
        "missingDependencyHelp": "Install framed: go install github.com/mactat/framed@latest",
        "baseArgs": [
          "--list"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "framed",
      "resource": "template",
      "action": "use",
      "description": "use template via framed",
      "adapter": "process",
      "adapterConfig": {
        "command": "framed",
        "missingDependencyHelp": "Install framed: go install github.com/mactat/framed@latest",
        "baseArgs": [
          "--use"
        ],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "framed",
      "resource": "_",
      "action": "_",
      "description": "_ _ via framed",
      "adapter": "process",
      "adapterConfig": {
        "command": "framed",
        "missingDependencyHelp": "Install framed: go install github.com/mactat/framed@latest",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}