{
  "plugin": "mockd",
  "binary": "mockd",
  "check": "which mockd",
  "install_steps": [
    "curl -sSL https://get.mockd.io | sh",
    "Verify: mockd --version",
    "supercli plugins install ./plugins/mockd --on-conflict replace --json"
  ],
  "note": "Also: brew install getmockd/tap/mockd, docker run -p 4280:4280 ghcr.io/getmockd/mockd:latest"
}
