{
  "name": "mockd",
  "version": "0.1.0",
  "description": "One binary, seven protocols — mock HTTP, gRPC, GraphQL, WebSocket, MQTT, SSE, and SOAP",
  "source": "https://github.com/getmockd/mockd",
  "checks": [
    { "type": "binary", "name": "mockd" }
  ],
  "install_guidance": {
    "plugin": "mockd",
    "binary": "mockd",
    "check": "which mockd",
    "install_steps": [
      "curl -sSL https://get.mockd.io | sh",
      "Verify: mockd --version",
      "supercli plugins install ./plugins/mockd --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "mockd",
      "resource": "self",
      "action": "version",
      "description": "Print mockd version",
      "adapter": "process",
      "adapterConfig": {
        "command": "mockd",
        "baseArgs": ["--version"],
        "missingDependencyHelp": "Install mockd: curl -sSL https://get.mockd.io | sh"
      },
      "args": []
    },
    {
      "namespace": "mockd",
      "resource": "server",
      "action": "start",
      "description": "Start mockd server",
      "adapter": "process",
      "adapterConfig": {
        "command": "mockd",
        "baseArgs": ["start"],
        "passthrough": true,
        "timeout_ms": 30000,
        "missingDependencyHelp": "Install mockd"
      },
      "args": []
    },
    {
      "namespace": "mockd",
      "resource": "endpoint",
      "action": "add",
      "description": "Add a mock endpoint",
      "adapter": "process",
      "adapterConfig": {
        "command": "mockd",
        "baseArgs": ["add"],
        "passthrough": true,
        "timeout_ms": 30000,
        "missingDependencyHelp": "Install mockd"
      },
      "args": []
    },
    {
      "namespace": "mockd",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to mockd CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "mockd",
        "passthrough": true,
        "missingDependencyHelp": "Install mockd"
      },
      "args": []
    }
  ]
}
