{
  "name": "pt",
  "version": "0.1.0",
  "description": "The Platinum Searcher - A code search tool similar to ag and ack",
  "source": "https://github.com/monochromegane/the_platinum_searcher",
  "checks": [
    {
      "type": "binary",
      "name": "pt"
    }
  ],
  "install_guidance": {
    "plugin": "pt",
    "binary": "pt",
    "check": "which pt",
    "install_steps": [
      "go install github.com/monochromegane/the_platinum_searcher/cmd/pt@latest",
      "Verify: pt --version",
      "supercli plugins install ./plugins/pt --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "pt",
      "resource": "self",
      "action": "version",
      "description": "Print pt version",
      "adapter": "process",
      "adapterConfig": {
        "command": "pt",
        "missingDependencyHelp": "Install pt: go install github.com/monochromegane/the_platinum_searcher/cmd/pt@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "pt",
      "resource": "code",
      "action": "search",
      "description": "search code via pt",
      "adapter": "process",
      "adapterConfig": {
        "command": "pt",
        "missingDependencyHelp": "Install pt: go install github.com/monochromegane/the_platinum_searcher/cmd/pt@latest",
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "pt",
      "resource": "_",
      "action": "_",
      "description": "_ _ via pt",
      "adapter": "process",
      "adapterConfig": {
        "command": "pt",
        "missingDependencyHelp": "Install pt: go install github.com/monochromegane/the_platinum_searcher/cmd/pt@latest",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}