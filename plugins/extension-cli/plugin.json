{
  "name": "extension-cli",
  "version": "0.1.0",
  "description": "Build and manage browser extensions",
  "source": "https://github.com/MobileFirstLLC/extension-cli",
  "checks": [
    {
      "type": "binary",
      "name": "extension"
    }
  ],
  "install_guidance": {
    "plugin": "extension-cli",
    "binary": "extension",
    "check": "which extension",
    "install_steps": [
      "npm install -g extension-cli",
      "Verify: extension --version",
      "supercli plugins install ./plugins/extension-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "extension-cli",
      "resource": "self",
      "action": "version",
      "description": "Print extension-cli version",
      "adapter": "process",
      "adapterConfig": {
        "command": "extension",
        "missingDependencyHelp": "Install extension-cli: npm install -g extension-cli",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "extension-cli",
      "resource": "extension",
      "action": "build",
      "description": "build extension via extension",
      "adapter": "process",
      "adapterConfig": {
        "command": "extension",
        "missingDependencyHelp": "Install extension-cli: npm install -g extension-cli",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "extension-cli",
      "resource": "_",
      "action": "_",
      "description": "_ _ via extension",
      "adapter": "process",
      "adapterConfig": {
        "command": "extension",
        "missingDependencyHelp": "Install extension-cli: npm install -g extension-cli",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}