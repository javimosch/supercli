{
  "name": "openhue-cli",
  "version": "0.1.0",
  "description": "Command line tool for Philips Hue smart lights",
  "source": "https://github.com/openhue/openhue-cli",
  "checks": [
    {
      "type": "binary",
      "name": "openhue"
    }
  ],
  "install_guidance": {
    "plugin": "openhue-cli",
    "binary": "openhue",
    "check": "which openhue",
    "install_steps": [
      "brew install openhue-cli",
      "Verify: openhue --version",
      "supercli plugins install ./plugins/openhue-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "openhue-cli",
      "resource": "self",
      "action": "version",
      "description": "Print openhue-cli version",
      "adapter": "process",
      "adapterConfig": {
        "command": "openhue",
        "missingDependencyHelp": "Install openhue-cli: brew install openhue-cli",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "openhue-cli",
      "resource": "light",
      "action": "list",
      "description": "list light via openhue",
      "adapter": "process",
      "adapterConfig": {
        "command": "openhue",
        "missingDependencyHelp": "Install openhue-cli: brew install openhue-cli",
        "baseArgs": [
          "get",
          "lights"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "openhue-cli",
      "resource": "light",
      "action": "set",
      "description": "set light via openhue",
      "adapter": "process",
      "adapterConfig": {
        "command": "openhue",
        "missingDependencyHelp": "Install openhue-cli: brew install openhue-cli",
        "baseArgs": [
          "set",
          "light"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "openhue-cli",
      "resource": "room",
      "action": "list",
      "description": "list room via openhue",
      "adapter": "process",
      "adapterConfig": {
        "command": "openhue",
        "missingDependencyHelp": "Install openhue-cli: brew install openhue-cli",
        "baseArgs": [
          "get",
          "rooms"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "openhue-cli",
      "resource": "scene",
      "action": "list",
      "description": "list scene via openhue",
      "adapter": "process",
      "adapterConfig": {
        "command": "openhue",
        "missingDependencyHelp": "Install openhue-cli: brew install openhue-cli",
        "baseArgs": [
          "get",
          "scenes"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "openhue-cli",
      "resource": "_",
      "action": "_",
      "description": "_ _ via openhue",
      "adapter": "process",
      "adapterConfig": {
        "command": "openhue",
        "missingDependencyHelp": "Install openhue-cli: brew install openhue-cli",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}