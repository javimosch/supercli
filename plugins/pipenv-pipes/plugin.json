{
  "name": "pipenv-pipes",
  "version": "0.1.0",
  "description": "PipEnv Environment Switcher for managing multiple Python virtual environments",
  "source": "https://github.com/gtalarico/pipenv-pipes",
  "checks": [
    {
      "type": "binary",
      "name": "pipenv-pipes"
    }
  ],
  "install_guidance": {
    "plugin": "pipenv-pipes",
    "binary": "pipenv-pipes",
    "check": "which pipenv-pipes",
    "install_steps": [
      "pip install pipenv-pipes",
      "Verify: pipenv-pipes --version",
      "supercli plugins install ./plugins/pipenv-pipes --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
