      "resource": "self",
      "action": "version",
      "description": "Print pipenv-pipes version",
      "adapter": "process",
      "adapterConfig": {
        "command": "pipenv-pipes",
        "missingDependencyHelp": "Install pipenv-pipes: pip install pipenv-pipes",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "pipenv-pipes",
      "resource": "env",
      "action": "list",
