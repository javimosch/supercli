{
  "name": "iponmap",
  "version": "0.1.0",
  "description": "Locate IP addresses on a map in terminal",
  "source": "https://github.com/nogizhopaboroda/iponmap",
  "checks": [
    {
      "type": "binary",
      "name": "iponmap"
    }
  ],
  "install_guidance": {
    "plugin": "iponmap",
    "binary": "iponmap",
    "check": "which iponmap",
    "install_steps": [
      "npm install -g iponmap",
      "Verify: iponmap --version",
      "supercli plugins install ./plugins/iponmap --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "iponmap",
      "resource": "self",
      "action": "version",
      "description": "Print iponmap version",
      "adapter": "process",
      "adapterConfig": {
        "command": "iponmap",
        "missingDependencyHelp": "Install iponmap: npm install -g iponmap",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "iponmap",
      "resource": "ip",
      "action": "locate",
      "description": "locate ip via iponmap",
      "adapter": "process",
      "adapterConfig": {
        "command": "iponmap",
        "missingDependencyHelp": "Install iponmap: npm install -g iponmap",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "iponmap",
      "resource": "_",
      "action": "_",
      "description": "_ _ via iponmap",
      "adapter": "process",
      "adapterConfig": {
        "command": "iponmap",
        "missingDependencyHelp": "Install iponmap: npm install -g iponmap",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}