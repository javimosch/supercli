{
  "name": "yt-audio",
  "version": "0.1.0",
  "description": "Simple configurable youtube-dl wrapper to download and manage youtube audio",
  "source": "https://github.com/RijulGulati/yt-audio",
  "checks": [
    {
      "type": "binary",
      "name": "yt-audio"
    }
  ],
  "install_guidance": {
    "plugin": "yt-audio",
    "binary": "yt-audio",
    "check": "which yt-audio",
    "install_steps": [
      "pip install yt-audio",
      "Verify: yt-audio --version",
      "supercli plugins install ./plugins/yt-audio --on-conflict replace --json"
    ]
  },
