      "resource": "self",
      "action": "version",
      "description": "Print yt-audio version",
      "adapter": "process",
      "adapterConfig": {
        "command": "yt-audio",
        "missingDependencyHelp": "Install yt-audio: pip install yt-audio",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "yt-audio",
      "resource": "audio",
      "action": "download",
      "description": "download audio via yt-audio",
      "adapter": "process",
      "adapterConfig": {
        "command": "yt-audio",
        "missingDependencyHelp": "Install yt-audio: pip install yt-audio",
        "baseArgs": [
          "download"
        ],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
