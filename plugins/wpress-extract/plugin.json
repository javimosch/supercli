{
  "name": "wpress-extract",
  "version": "0.1.0",
  "description": "Extract .wpress backup files from the command line",
  "source": "https://github.com/ofhouse/wpress-extract",
  "checks": [
    {
      "type": "binary",
      "name": "wpress-extract"
    }
  ],
  "install_guidance": {
    "plugin": "wpress-extract",
    "binary": "wpress-extract",
    "check": "which wpress-extract",
    "install_steps": [
      "npm install -g wpress-extract",
      "Verify: wpress-extract --version",
      "supercli plugins install ./plugins/wpress-extract --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "wpress-extract",
      "resource": "self",
      "action": "version",
      "description": "Print wpress-extract version",
      "adapter": "process",
      "adapterConfig": {
        "command": "wpress-extract",
        "missingDependencyHelp": "Install wpress-extract: npm install -g wpress-extract",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "wpress-extract",
      "resource": "file",
      "action": "extract",
      "description": "extract file via wpress-extract",
      "adapter": "process",
      "adapterConfig": {
        "command": "wpress-extract",
        "missingDependencyHelp": "Install wpress-extract: npm install -g wpress-extract",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "wpress-extract",
      "resource": "_",
      "action": "_",
      "description": "_ _ via wpress-extract",
      "adapter": "process",
      "adapterConfig": {
        "command": "wpress-extract",
        "missingDependencyHelp": "Install wpress-extract: npm install -g wpress-extract",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}