{
  "name": "faq",
  "version": "0.1.0",
  "description": "Format agnostic querier for structured data like JSON, XML, CSV",
  "source": "https://github.com/jzelinskie/faq",
  "checks": [
    {
      "type": "binary",
      "name": "faq"
    }
  ],
  "install_guidance": {
    "plugin": "faq",
    "binary": "faq",
    "check": "which faq",
    "install_steps": [
      "brew install jzelinskie/faq/faq",
      "Verify: faq --version",
      "supercli plugins install ./plugins/faq --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "faq",
      "resource": "self",
      "action": "version",
      "description": "Print faq version",
      "adapter": "process",
      "adapterConfig": {
        "command": "faq",
        "missingDependencyHelp": "Install faq: brew install jzelinskie/faq/faq",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "faq",
      "resource": "data",
      "action": "query",
      "description": "query data via faq",
      "adapter": "process",
      "adapterConfig": {
        "command": "faq",
        "missingDependencyHelp": "Install faq: brew install jzelinskie/faq/faq",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "faq",
      "resource": "_",
      "action": "_",
      "description": "_ _ via faq",
      "adapter": "process",
      "adapterConfig": {
        "command": "faq",
        "missingDependencyHelp": "Install faq: brew install jzelinskie/faq/faq",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}