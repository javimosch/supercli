{
  "name": "micro",
  "version": "0.1.0",
  "description": "A modern and intuitive terminal-based text editor. A simple, easy-to-use terminal text editor with mouse support and keybindings.",
  "source": "https://github.com/micro-editor/micro",
  "checks": [
    { "type": "binary", "name": "micro" }
  ],
  "install_guidance": {
    "plugin": "micro",
    "binary": "micro",
    "check": "which micro",
    "install_steps": [
      "brew install micro",
      "Verify: micro --version",
      "supercli plugins install ./plugins/micro --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "micro",
      "resource": "file",
      "action": "edit",
      "description": "Edit file in micro editor",
      "adapter": "process",
      "adapterConfig": {
        "command": "micro",
        "baseArgs": [],
        "passthrough": true,
        "missingDependencyHelp": "Install micro: brew install micro"
      },
      "args": [
        { "name": "file", "type": "string", "description": "File to edit" },
        { "name": "--clean", "type": "boolean", "description": "Clean mode" }
      ]
    },
    {
      "namespace": "micro",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to micro CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "micro",
        "passthrough": true,
        "missingDependencyHelp": "Install micro: brew install micro"
      },
      "args": []
    }
  ]
}
