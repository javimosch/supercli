{
  "name": "modsurfer",
  "version": "0.1.0",
  "description": "Devtools to validate audit and investigate WebAssembly binaries",
  "source": "https://github.com/dylibso/modsurfer",
  "checks": [
    {
      "type": "binary",
      "name": "modsurfer"
    }
  ],
  "install_guidance": {
    "plugin": "modsurfer",
    "binary": "modsurfer",
    "check": "which modsurfer",
    "install_steps": [
      "cargo install modsurfer",
      "Verify: modsurfer --version",
      "supercli plugins install ./plugins/modsurfer --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "modsurfer",
      "resource": "self",
      "action": "version",
      "description": "Print modsurfer version",
      "adapter": "process",
      "adapterConfig": {
        "command": "modsurfer",
        "missingDependencyHelp": "Install modsurfer: cargo install modsurfer",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "modsurfer",
      "resource": "module",
      "action": "validate",
      "description": "validate module via modsurfer",
      "adapter": "process",
      "adapterConfig": {
        "command": "modsurfer",
        "missingDependencyHelp": "Install modsurfer: cargo install modsurfer",
        "baseArgs": [
          "validate"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
