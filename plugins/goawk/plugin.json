{
  "name": "goawk",
  "version": "0.1.0",
  "description": "AWK interpreter written in Go with CSV/TSV support",
  "source": "https://github.com/benhoyt/goawk",
  "checks": [
    {
      "type": "binary",
      "name": "goawk"
    }
  ],
  "install_guidance": {
    "plugin": "goawk",
    "binary": "goawk",
    "check": "which goawk",
    "install_steps": [
      "brew install goawk",
      "Verify: goawk --version",
      "supercli plugins install ./plugins/goawk --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "goawk",
      "resource": "self",
      "action": "version",
      "description": "Print goawk version",
      "adapter": "process",
      "adapterConfig": {
        "command": "goawk",
        "missingDependencyHelp": "Install goawk: brew install goawk",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "goawk",
      "resource": "text",
      "action": "process",
      "description": "process text via goawk",
      "adapter": "process",
      "adapterConfig": {
        "command": "goawk",
        "missingDependencyHelp": "Install goawk: brew install goawk",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "goawk",
      "resource": "file",
      "action": "filter",
      "description": "filter file via goawk",
      "adapter": "process",
      "adapterConfig": {
        "command": "goawk",
        "missingDependencyHelp": "Install goawk: brew install goawk",
        "baseArgs": [
          "-f"
        ],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "goawk",
      "resource": "_",
      "action": "_",
      "description": "_ _ via goawk",
      "adapter": "process",
      "adapterConfig": {
        "command": "goawk",
        "missingDependencyHelp": "Install goawk: brew install goawk",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}