{
  "name": "rusync",
  "version": "0.1.0",
  "description": "Minimalist rsync implementation in Rust",
  "source": "https://github.com/your-tools/rusync",
  "checks": [
    { "type": "binary", "name": "rusync" }
  ],
  "install_guidance": {
    "plugin": "rusync",
    "binary": "rusync",
    "check": "which rusync",
    "install_steps": [
      "cargo install rusync",
      "Verify: rusync --help",
      "supercli plugins install ./plugins/rusync --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "rusync",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to rusync CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "rusync",
        "cwd": "invoke_cwd",
        "passthrough": true,
        "missingDependencyHelp": "Install rusync: cargo install rusync"
      },
      "args": []
    }
  ]
}
