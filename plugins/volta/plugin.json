{
  "name": "volta",
  "version": "0.1.0",
  "description": "JS Toolchains as Code - hassle-free JavaScript tools",
  "source": "https://github.com/volta-cli/volta",
  "checks": [
    {
      "type": "binary",
      "name": "volta"
    }
  ],
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "volta",
      "resource": "install",
      "action": "package",
      "description": "Install a package",
      "adapter": "process",
      "adapterConfig": {
        "command": "volta",
        "baseArgs": [
          "install"
        ],
        "passthrough": true
      },
      "args": [
        {
          "name": "package",
          "type": "string",
          "required": true,
          "description": "Package to install"
        }
      ]
    },
    {
      "namespace": "volta",
      "resource": "pin",
      "action": "tool",
      "description": "Pin tool version",
      "adapter": "process",
      "adapterConfig": {
        "command": "volta",
        "baseArgs": [
          "pin"
        ],
        "passthrough": true
      },
      "args": [
        {
          "name": "tool",
          "type": "string",
          "required": true,
          "description": "Tool to pin"
        }
      ]
    },
    {
      "namespace": "volta",
      "resource": "list",
      "action": "tools",
      "description": "List installed tools",
      "adapter": "process",
      "adapterConfig": {
        "command": "volta",
        "baseArgs": [
          "list"
        ],
        "passthrough": true
      }
    }
  ]
}