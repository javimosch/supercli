{
  "name": "kyma-cli",
  "version": "0.1.0",
  "description": "CLI for deploying and managing Kyma runtime",
  "source": "https://github.com/kyma-project/cli",
  "checks": [
    {
      "type": "binary",
      "name": "kyma"
    }
  ],
  "install_guidance": {
    "plugin": "kyma-cli",
    "binary": "kyma",
    "check": "which kyma",
    "install_steps": [
      "brew install kyma-cli",
      "Verify: kyma --version",
      "supercli plugins install ./plugins/kyma-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "kyma-cli",
      "resource": "self",
      "action": "version",
      "description": "Print kyma-cli version",
      "adapter": "process",
      "adapterConfig": {
        "command": "kyma",
        "missingDependencyHelp": "Install kyma-cli: brew install kyma-cli",
        "baseArgs": [
          "version"
        ]
      },
      "args": []
    },
    {
      "namespace": "kyma-cli",
      "resource": "cluster",
      "action": "provision",
      "description": "provision cluster via kyma",
      "adapter": "process",
      "adapterConfig": {
        "command": "kyma",
        "missingDependencyHelp": "Install kyma-cli: brew install kyma-cli",
        "baseArgs": [
          "provision"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "kyma-cli",
      "resource": "cluster",
      "action": "deploy",
      "description": "deploy cluster via kyma",
      "adapter": "process",
      "adapterConfig": {
        "command": "kyma",
        "missingDependencyHelp": "Install kyma-cli: brew install kyma-cli",
        "baseArgs": [
          "deploy"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "kyma-cli",
      "resource": "function",
      "action": "init",
      "description": "init function via kyma",
      "adapter": "process",
      "adapterConfig": {
        "command": "kyma",
        "missingDependencyHelp": "Install kyma-cli: brew install kyma-cli",
        "baseArgs": [
          "init",
          "function"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "kyma-cli",
      "resource": "function",
      "action": "apply",
      "description": "apply function via kyma",
      "adapter": "process",
      "adapterConfig": {
        "command": "kyma",
        "missingDependencyHelp": "Install kyma-cli: brew install kyma-cli",
        "baseArgs": [
          "apply",
          "function"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "kyma-cli",
      "resource": "_",
      "action": "_",
      "description": "_ _ via kyma",
      "adapter": "process",
      "adapterConfig": {
        "command": "kyma",
        "missingDependencyHelp": "Install kyma-cli: brew install kyma-cli",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
