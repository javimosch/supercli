{
  "name": "mcporter",
  "version": "0.1.0",
  "description": "Call MCPs via TypeScript masquerading as simple TypeScript API or package them as CLI",
  "source": "https://github.com/steipete/mcporter",
  "checks": [
    {
      "type": "binary",
      "name": "mcporter"
    }
  ],
  "install_guidance": {
    "plugin": "mcporter",
    "binary": "mcporter",
    "check": "which mcporter",
    "install_steps": [
      "npm install -g mcporter",
      "Verify: mcporter --version",
      "supercli plugins install ./plugins/mcporter --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "mcporter",
      "resource": "self",
      "action": "version",
      "description": "Print mcporter version",
      "adapter": "process",
      "adapterConfig": {
        "command": "mcporter",
        "missingDependencyHelp": "Install mcporter: npm install -g mcporter",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "mcporter",
      "resource": "mcp",
      "action": "call",
      "description": "call mcp via mcporter",
      "adapter": "process",
      "adapterConfig": {
        "command": "mcporter",
        "missingDependencyHelp": "Install mcporter: npm install -g mcporter",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "mcporter",
      "resource": "mcp",
      "action": "list",
      "description": "list mcp via mcporter",
      "adapter": "process",
      "adapterConfig": {
        "command": "mcporter",
        "missingDependencyHelp": "Install mcporter: npm install -g mcporter",
        "baseArgs": [
          "--list"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "mcporter",
      "resource": "api",
      "action": "generate",
      "description": "generate api via mcporter",
      "adapter": "process",
      "adapterConfig": {
        "command": "mcporter",
        "missingDependencyHelp": "Install mcporter: npm install -g mcporter",
        "baseArgs": [
          "--api"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "mcporter",
      "resource": "cli",
      "action": "package",
      "description": "package cli via mcporter",
      "adapter": "process",
      "adapterConfig": {
        "command": "mcporter",
        "missingDependencyHelp": "Install mcporter: npm install -g mcporter",
        "baseArgs": [
          "--package"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "mcporter",
      "resource": "config",
      "action": "show",
      "description": "show config via mcporter",
      "adapter": "process",
      "adapterConfig": {
        "command": "mcporter",
        "missingDependencyHelp": "Install mcporter: npm install -g mcporter",
        "baseArgs": [
          "--config"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "mcporter",
      "resource": "verbose",
      "action": "set",
      "description": "set verbose via mcporter",
      "adapter": "process",
      "adapterConfig": {
        "command": "mcporter",
        "missingDependencyHelp": "Install mcporter: npm install -g mcporter",
        "baseArgs": [
          "--verbose"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "mcporter",
      "resource": "_",
      "action": "_",
      "description": "_ _ via mcporter",
      "adapter": "process",
      "adapterConfig": {
        "command": "mcporter",
        "missingDependencyHelp": "Install mcporter: npm install -g mcporter",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}