{
  "name": "codeowners",
  "version": "0.1.0",
  "description": "Command line tool and Go library for CODEOWNERS files",
  "source": "https://github.com/hmarr/codeowners",
  "checks": [
    {
      "type": "binary",
      "name": "codeowners"
    }
  ],
  "install_guidance": {
    "plugin": "codeowners",
    "binary": "codeowners",
    "check": "which codeowners",
    "install_steps": [
      "go install github.com/hmarr/codeowners/cmd/codeowners@latest",
      "Verify: codeowners --version",
      "supercli plugins install ./plugins/codeowners --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "codeowners",
      "resource": "self",
      "action": "version",
      "description": "Print codeowners version",
      "adapter": "process",
      "adapterConfig": {
        "command": "codeowners",
        "missingDependencyHelp": "Install codeowners: go install github.com/hmarr/codeowners/cmd/codeowners@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "codeowners",
      "resource": "file",
      "action": "check",
      "description": "check file via codeowners",
      "adapter": "process",
      "adapterConfig": {
        "command": "codeowners",
        "missingDependencyHelp": "Install codeowners: go install github.com/hmarr/codeowners/cmd/codeowners@latest",
        "baseArgs": [
          "check"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "codeowners",
      "resource": "file",
      "action": "who",
      "description": "who file via codeowners",
      "adapter": "process",
      "adapterConfig": {
        "command": "codeowners",
        "missingDependencyHelp": "Install codeowners: go install github.com/hmarr/codeowners/cmd/codeowners@latest",
        "baseArgs": [
          "who"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "codeowners",
      "resource": "_",
      "action": "_",
      "description": "_ _ via codeowners",
      "adapter": "process",
      "adapterConfig": {
        "command": "codeowners",
        "missingDependencyHelp": "Install codeowners: go install github.com/hmarr/codeowners/cmd/codeowners@latest",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}