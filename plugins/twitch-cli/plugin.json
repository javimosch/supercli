{
  "name": "twitch-cli",
  "version": "0.1.0",
  "description": "Official Twitch CLI for developing on Twitch platform",
  "source": "https://github.com/twitchdev/twitch-cli",
  "checks": [
    {
      "type": "binary",
      "name": "twitch"
    }
  ],
  "install_guidance": {
    "plugin": "twitch-cli",
    "binary": "twitch",
    "check": "which twitch",
    "install_steps": [
      "brew install twitchdev/twitch/twitch-cli",
      "Verify: twitch --version",
      "supercli plugins install ./plugins/twitch-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "twitch-cli",
      "resource": "self",
      "action": "version",
      "description": "Print twitch-cli version",
      "adapter": "process",
      "adapterConfig": {
        "command": "twitch",
        "missingDependencyHelp": "Install twitch-cli: brew install twitchdev/twitch/twitch-cli",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "twitch-cli",
      "resource": "api",
      "action": "request",
      "description": "request api via twitch",
      "adapter": "process",
      "adapterConfig": {
        "command": "twitch",
        "missingDependencyHelp": "Install twitch-cli: brew install twitchdev/twitch/twitch-cli",
        "baseArgs": [
          "api"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "twitch-cli",
