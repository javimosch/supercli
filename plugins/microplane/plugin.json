{
  "name": "microplane",
  "version": "0.1.0",
  "description": "CLI tool to make git changes across many repos especially useful with microservices",
  "source": "https://github.com/Clever/microplane",
  "checks": [
    {
      "type": "binary",
      "name": "microplane"
    }
  ],
  "install_guidance": {
    "plugin": "microplane",
    "binary": "microplane",
    "check": "which microplane",
    "install_steps": [
      "go install github.com/Clever/microplane@latest",
      "Verify: microplane --version",
      "supercli plugins install ./plugins/microplane --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "microplane",
      "resource": "self",
      "action": "version",
      "description": "Print microplane version",
      "adapter": "process",
      "adapterConfig": {
        "command": "microplane",
        "missingDependencyHelp": "Install microplane: go install github.com/Clever/microplane@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "microplane",
      "resource": "repo",
      "action": "list",
      "description": "list repo via microplane",
      "adapter": "process",
      "adapterConfig": {
        "command": "microplane",
        "missingDependencyHelp": "Install microplane: go install github.com/Clever/microplane@latest",
        "baseArgs": [
          "list"
        ],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
