{
  "name": "color-generate",
  "version": "0.1.0",
  "description": "Generate and manipulate color palettes from the command line",
  "source": "https://github.com/hd996/color-generate",
  "checks": [
    {
      "type": "binary",
      "name": "color-generate"
    }
  ],
  "install_guidance": {
    "plugin": "color-generate",
    "binary": "color-generate",
    "check": "which color-generate",
    "install_steps": [
      "npm install -g color-generate",
      "Verify: color-generate --version",
      "supercli plugins install ./plugins/color-generate --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "color-generate",
      "resource": "self",
      "action": "version",
      "description": "Print color-generate version",
      "adapter": "process",
      "adapterConfig": {
        "command": "color-generate",
        "missingDependencyHelp": "Install color-generate: npm install -g color-generate",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "color-generate",
      "resource": "color",
      "action": "generate",
      "description": "generate color via color-generate",
      "adapter": "process",
      "adapterConfig": {
        "command": "color-generate",
        "missingDependencyHelp": "Install color-generate: npm install -g color-generate",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "color-generate",
      "resource": "_",
      "action": "_",
      "description": "_ _ via color-generate",
      "adapter": "process",
      "adapterConfig": {
        "command": "color-generate",
        "missingDependencyHelp": "Install color-generate: npm install -g color-generate",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}