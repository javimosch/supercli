{
  "name": "version-bump-prompt",
  "version": "0.1.0",
  "description": "Interactive version bumping with prompts",
  "source": "https://github.com/JS-DevTools/version-bump-prompt",
  "checks": [
    {
      "type": "binary",
      "name": "version-bump-prompt"
    }
  ],
  "install_guidance": {
    "plugin": "version-bump-prompt",
    "binary": "version-bump-prompt",
    "check": "which version-bump-prompt",
    "install_steps": [
      "npm install -g version-bump-prompt",
      "Verify: version-bump-prompt --version",
      "supercli plugins install ./plugins/version-bump-prompt --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "version-bump-prompt",
      "resource": "self",
      "action": "version",
      "description": "Print version-bump-prompt version",
      "adapter": "process",
      "adapterConfig": {
        "command": "version-bump-prompt",
        "missingDependencyHelp": "Install version-bump-prompt: npm install -g version-bump-prompt",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "version-bump-prompt",
      "resource": "version",
      "action": "bump",
      "description": "bump version via version-bump-prompt",
      "adapter": "process",
      "adapterConfig": {
        "command": "version-bump-prompt",
        "missingDependencyHelp": "Install version-bump-prompt: npm install -g version-bump-prompt",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "version-bump-prompt",
      "resource": "_",
      "action": "_",
      "description": "_ _ via version-bump-prompt",
      "adapter": "process",
      "adapterConfig": {
        "command": "version-bump-prompt",
        "missingDependencyHelp": "Install version-bump-prompt: npm install -g version-bump-prompt",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}