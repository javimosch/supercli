{
  "name": "sonoscli",
  "version": "0.1.0",
  "description": "Command line controller for Sonos speakers",
  "source": "https://github.com/steipete/sonoscli",
  "checks": [
    {
      "type": "binary",
      "name": "sonos"
    }
  ],
  "install_guidance": {
    "plugin": "sonoscli",
    "binary": "sonos",
    "check": "which sonos",
    "install_steps": [
      "go install github.com/steipete/sonoscli@latest",
      "Verify: sonos --version",
      "supercli plugins install ./plugins/sonoscli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "sonoscli",
      "resource": "self",
      "action": "version",
      "description": "Print sonoscli version",
      "adapter": "process",
      "adapterConfig": {
        "command": "sonos",
        "missingDependencyHelp": "Install sonoscli: go install github.com/steipete/sonoscli@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "sonoscli",
      "resource": "speaker",
      "action": "discover",
      "description": "discover speaker via sonos",
      "adapter": "process",
      "adapterConfig": {
        "command": "sonos",
        "missingDependencyHelp": "Install sonoscli: go install github.com/steipete/sonoscli@latest",
        "baseArgs": [
          "discover"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "sonoscli",
      "resource": "speaker",
      "action": "play",
      "description": "play speaker via sonos",
      "adapter": "process",
      "adapterConfig": {
        "command": "sonos",
        "missingDependencyHelp": "Install sonoscli: go install github.com/steipete/sonoscli@latest",
        "baseArgs": [
          "play"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "sonoscli",
      "resource": "speaker",
      "action": "pause",
      "description": "pause speaker via sonos",
      "adapter": "process",
      "adapterConfig": {
        "command": "sonos",
        "missingDependencyHelp": "Install sonoscli: go install github.com/steipete/sonoscli@latest",
        "baseArgs": [
          "pause"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "sonoscli",
      "resource": "speaker",
      "action": "volume",
      "description": "volume speaker via sonos",
      "adapter": "process",
      "adapterConfig": {
        "command": "sonos",
        "missingDependencyHelp": "Install sonoscli: go install github.com/steipete/sonoscli@latest",
        "baseArgs": [
          "volume"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "sonoscli",
      "resource": "_",
      "action": "_",
      "description": "_ _ via sonos",
      "adapter": "process",
      "adapterConfig": {
        "command": "sonos",
        "missingDependencyHelp": "Install sonoscli: go install github.com/steipete/sonoscli@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}