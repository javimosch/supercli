{
  "name": "civo-cli",
  "version": "0.1.0",
  "description": "Command line interface for Civo cloud resources",
  "source": "https://github.com/civo/cli",
  "checks": [
    {
      "type": "binary",
      "name": "civo"
    }
  ],
  "install_guidance": {
    "plugin": "civo-cli",
    "binary": "civo",
    "check": "which civo",
    "install_steps": [
      "brew install civo",
      "Verify: civo --version",
      "supercli plugins install ./plugins/civo-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "civo-cli",
      "resource": "self",
      "action": "version",
      "description": "Print civo-cli version",
      "adapter": "process",
      "adapterConfig": {
        "command": "civo",
        "missingDependencyHelp": "Install civo-cli: brew install civo",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "civo-cli",
      "resource": "kubernetes",
      "action": "create",
      "description": "create kubernetes via civo",
      "adapter": "process",
      "adapterConfig": {
        "command": "civo",
        "missingDependencyHelp": "Install civo-cli: brew install civo",
        "baseArgs": [
          "kubernetes",
          "create"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "civo-cli",
