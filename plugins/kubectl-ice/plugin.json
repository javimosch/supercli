      "description": "Print kubectl-ice version",
      "adapter": "process",
      "adapterConfig": {
        "command": "kubectl-ice",
        "missingDependencyHelp": "Install kubectl-ice: brew install NimbleArchitect/tap/kubectl-ice",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
