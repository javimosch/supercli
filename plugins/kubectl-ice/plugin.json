  "install_guidance": {
    "plugin": "kubectl-ice",
    "binary": "kubectl-ice",
    "check": "which kubectl-ice",
    "install_steps": [
      "brew install NimbleArchitect/tap/kubectl-ice",
      "Verify: kubectl-ice --version",
      "supercli plugins install ./plugins/kubectl-ice --on-conflict replace --json"
    ]
  },
