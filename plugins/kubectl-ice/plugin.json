{
  "name": "kubectl-ice",
  "version": "0.1.0",
  "description": "Kubernetes resource usage monitor and optimizer for pods and containers",
  "source": "https://github.com/NimbleArchitect/kubectl-ice",
  "checks": [
    {
      "type": "binary",
      "name": "kubectl-ice"
    }
