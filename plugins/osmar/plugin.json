{
  "name": "osmar",
  "version": "0.1.0",
  "description": "OpenStreetMap data analyzer and query tool",
  "source": "https://github.com/codesoap/osmar",
  "checks": [
    {
      "type": "binary",
      "name": "osmar"
    }
  ],
  "install_guidance": {
    "plugin": "osmar",
    "binary": "osmar",
    "check": "which osmar",
    "install_steps": [
      "go install github.com/codesoap/osmar@latest",
      "Verify: osmar --version",
      "supercli plugins install ./plugins/osmar --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "osmar",
      "resource": "self",
      "action": "version",
      "description": "Print osmar version",
      "adapter": "process",
      "adapterConfig": {
        "command": "osmar",
        "missingDependencyHelp": "Install osmar: go install github.com/codesoap/osmar@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "osmar",
      "resource": "data",
      "action": "query",
      "description": "query data via osmar",
      "adapter": "process",
      "adapterConfig": {
        "command": "osmar",
        "missingDependencyHelp": "Install osmar: go install github.com/codesoap/osmar@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "osmar",
      "resource": "data",
      "action": "filter",
      "description": "filter data via osmar",
      "adapter": "process",
      "adapterConfig": {
