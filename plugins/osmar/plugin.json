        "missingDependencyHelp": "Install osmar: go install github.com/codesoap/osmar@latest",
        "baseArgs": [
          "--filter"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "osmar",
      "resource": "data",
      "action": "export",
      "description": "export data via osmar",
      "adapter": "process",
      "adapterConfig": {
        "command": "osmar",
        "missingDependencyHelp": "Install osmar: go install github.com/codesoap/osmar@latest",
        "baseArgs": [
          "--export"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
