{
  "name": "warpdrop",
  "version": "0.1.0",
  "description": "Simple secure peer-to-peer file sharing tool using WebRTC technology",
  "source": "https://github.com/BioHazard786/warpdrop",
  "checks": [
    {
      "type": "binary",
      "name": "warpdrop"
    }
  ],
  "install_guidance": {
    "plugin": "warpdrop",
    "binary": "warpdrop",
    "check": "which warpdrop",
    "install_steps": [
      "npm install -g warpdrop",
      "Verify: warpdrop --version",
      "supercli plugins install ./plugins/warpdrop --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "warpdrop",
      "resource": "self",
      "action": "version",
      "description": "Print warpdrop version",
      "adapter": "process",
      "adapterConfig": {
        "command": "warpdrop",
        "missingDependencyHelp": "Install warpdrop: npm install -g warpdrop",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "warpdrop",
      "resource": "file",
      "action": "send",
      "description": "send file via warpdrop",
      "adapter": "process",
      "adapterConfig": {
        "command": "warpdrop",
        "missingDependencyHelp": "Install warpdrop: npm install -g warpdrop",
        "baseArgs": [
          "send"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "warpdrop",
      "resource": "file",
      "action": "receive",
      "description": "receive file via warpdrop",
      "adapter": "process",
      "adapterConfig": {
