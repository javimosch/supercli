      "action": "version",
      "description": "Print todo-cli version",
      "adapter": "process",
      "adapterConfig": {
        "command": "todo-cli",
        "missingDependencyHelp": "Install todo-cli: pip install todo-cli",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
