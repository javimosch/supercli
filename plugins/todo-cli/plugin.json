{
  "name": "todo-cli",
  "version": "0.1.0",
  "description": "Command-line tool to manage Todo lists with simple and efficient interface",
  "source": "https://github.com/francoischalifour/todo-cli",
  "checks": [
    {
      "type": "binary",
      "name": "todo-cli"
    }
  ],
  "install_guidance": {
    "plugin": "todo-cli",
    "binary": "todo-cli",
    "check": "which todo-cli",
    "install_steps": [
      "pip install todo-cli",
      "Verify: todo-cli --version",
      "supercli plugins install ./plugins/todo-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
