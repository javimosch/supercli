{
  "plugin": "sonar",
  "binary": "sonar",
  "check": "which sonar",
  "install_steps": [
    "curl -sfL https://raw.githubusercontent.com/raskrebs/sonar/main/scripts/install.sh | bash",
    "Verify: sonar --version",
    "supercli plugins install ./plugins/sonar --on-conflict replace --json"
  ],
  "note": "Also available via Homebrew (brew install raskrebs/sonar/sonar) or Go (go install github.com/raskrebs/sonar@latest)."
}
