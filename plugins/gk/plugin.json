{
  "name": "gk",
  "version": "0.1.0",
  "description": "Go-Kit generator for creating Go microservices",
  "source": "https://github.com/kujtimiihoxha/gk",
  "checks": [
    {
      "type": "binary",
      "name": "gk"
    }
  ],
  "install_guidance": {
    "plugin": "gk",
    "binary": "gk",
    "check": "which gk",
    "install_steps": [
      "go install github.com/kujtimiihoxha/gk@latest",
      "Verify: gk --version",
      "supercli plugins install ./plugins/gk --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "gk",
      "resource": "self",
      "action": "version",
      "description": "Print gk version",
      "adapter": "process",
      "adapterConfig": {
        "command": "gk",
        "missingDependencyHelp": "Install gk: go install github.com/kujtimiihoxha/gk@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "gk",
      "resource": "service",
      "action": "generate",
      "description": "generate service via gk",
      "adapter": "process",
      "adapterConfig": {
        "command": "gk",
        "missingDependencyHelp": "Install gk: go install github.com/kujtimiihoxha/gk@latest",
        "baseArgs": [
          "new",
          "service"
        ],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "gk",
      "resource": "endpoint",
      "action": "generate",
      "description": "generate endpoint via gk",
      "adapter": "process",
      "adapterConfig": {
        "command": "gk",
        "missingDependencyHelp": "Install gk: go install github.com/kujtimiihoxha/gk@latest",
        "baseArgs": [
          "new",
          "endpoint"
        ],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "gk",
      "resource": "middleware",
      "action": "generate",
      "description": "generate middleware via gk",
      "adapter": "process",
      "adapterConfig": {
        "command": "gk",
        "missingDependencyHelp": "Install gk: go install github.com/kujtimiihoxha/gk@latest",
        "baseArgs": [
          "new",
          "middleware"
        ],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "gk",
      "resource": "_",
      "action": "_",
      "description": "_ _ via gk",
      "adapter": "process",
      "adapterConfig": {
        "command": "gk",
        "missingDependencyHelp": "Install gk: go install github.com/kujtimiihoxha/gk@latest",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}