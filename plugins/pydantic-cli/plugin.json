        }
      ]
    },
    {
      "namespace": "pydantic-cli",
      "resource": "verbose",
      "action": "set",
      "description": "set verbose via pydantic-cli",
      "adapter": "process",
      "adapterConfig": {
        "command": "pydantic-cli",
        "missingDependencyHelp": "Install pydantic-cli: pip install pydantic-cli",
        "baseArgs": [
          "--verbose"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
