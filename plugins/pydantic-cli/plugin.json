{
  "name": "pydantic-cli",
  "version": "0.1.0",
  "description": "Turn Pydantic defined Data Models into CLI Tools with automatic argument parsing",
  "source": "https://github.com/mpkocher/pydantic-cli",
  "checks": [
    {
      "type": "binary",
      "name": "pydantic-cli"
    }
  ],
  "install_guidance": {
    "plugin": "pydantic-cli",
    "binary": "pydantic-cli",
    "check": "which pydantic-cli",
    "install_steps": [
      "pip install pydantic-cli",
      "Verify: pydantic-cli --version",
      "supercli plugins install ./plugins/pydantic-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "pydantic-cli",
      "resource": "self",
      "action": "version",
      "description": "Print pydantic-cli version",
      "adapter": "process",
      "adapterConfig": {
        "command": "pydantic-cli",
        "missingDependencyHelp": "Install pydantic-cli: pip install pydantic-cli",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "pydantic-cli",
      "resource": "model",
      "action": "generate",
      "description": "generate model via pydantic-cli",
      "adapter": "process",
      "adapterConfig": {
        "command": "pydantic-cli",
        "missingDependencyHelp": "Install pydantic-cli: pip install pydantic-cli",
        "baseArgs": [
          "generate"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "pydantic-cli",
      "resource": "model",
      "action": "validate",
      "description": "validate model via pydantic-cli",
      "adapter": "process",
      "adapterConfig": {
        "command": "pydantic-cli",
        "missingDependencyHelp": "Install pydantic-cli: pip install pydantic-cli",
        "baseArgs": [
          "validate"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "pydantic-cli",
      "resource": "schema",
      "action": "show",
      "description": "show schema via pydantic-cli",
      "adapter": "process",
      "adapterConfig": {
        "command": "pydantic-cli",
        "missingDependencyHelp": "Install pydantic-cli: pip install pydantic-cli",
        "baseArgs": [
          "--schema"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "pydantic-cli",
      "resource": "config",
      "action": "set",
      "description": "set config via pydantic-cli",
      "adapter": "process",
      "adapterConfig": {
        "command": "pydantic-cli",
        "missingDependencyHelp": "Install pydantic-cli: pip install pydantic-cli",
        "baseArgs": [
          "--config"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "pydantic-cli",
      "resource": "output",
      "action": "set",
      "description": "set output via pydantic-cli",
      "adapter": "process",
      "adapterConfig": {
        "command": "pydantic-cli",
