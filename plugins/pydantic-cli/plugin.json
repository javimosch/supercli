    {
      "namespace": "pydantic-cli",
      "resource": "_",
      "action": "_",
      "description": "_ _ via pydantic-cli",
      "adapter": "process",
      "adapterConfig": {
        "command": "pydantic-cli",
        "missingDependencyHelp": "Install pydantic-cli: pip install pydantic-cli",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
