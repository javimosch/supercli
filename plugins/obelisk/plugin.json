{
  "name": "obelisk",
  "version": "0.1.0",
  "description": "Go package and CLI tool for saving web page as single HTML file",
  "source": "https://github.com/go-shiori/obelisk",
  "checks": [
    {
      "type": "binary",
      "name": "obelisk"
    }
  ],
  "install_guidance": {
    "plugin": "obelisk",
    "binary": "obelisk",
    "check": "which obelisk",
    "install_steps": [
      "go install github.com/go-shiori/obelisk/cmd/obelisk@latest",
      "Verify: obelisk --version",
      "supercli plugins install ./plugins/obelisk --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "obelisk",
      "resource": "self",
      "action": "version",
      "description": "Print obelisk version",
      "adapter": "process",
      "adapterConfig": {
        "command": "obelisk",
        "missingDependencyHelp": "Install obelisk: go install github.com/go-shiori/obelisk/cmd/obelisk@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "obelisk",
      "resource": "page",
      "action": "archive",
      "description": "archive page via obelisk",
      "adapter": "process",
      "adapterConfig": {
        "command": "obelisk",
        "missingDependencyHelp": "Install obelisk: go install github.com/go-shiori/obelisk/cmd/obelisk@latest",
        "baseArgs": [
          "save"
        ],
        "passthrough": true,
        "timeout_ms": 120000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "obelisk",
      "resource": "_",
      "action": "_",
      "description": "_ _ via obelisk",
      "adapter": "process",
      "adapterConfig": {
        "command": "obelisk",
        "missingDependencyHelp": "Install obelisk: go install github.com/go-shiori/obelisk/cmd/obelisk@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}