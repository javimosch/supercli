{
  "name": "srss",
  "version": "0.1.0",
  "description": "Command line RSS/ATOM/JSON feed reader",
  "source": "https://github.com/sheepla/srss",
  "checks": [
    {
      "type": "binary",
      "name": "srss"
    }
  ],
  "install_guidance": {
    "plugin": "srss",
    "binary": "srss",
    "check": "which srss",
    "install_steps": [
      "go install github.com/sheepla/srss@latest",
      "Verify: srss --version",
      "supercli plugins install ./plugins/srss --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "srss",
      "resource": "self",
      "action": "version",
      "description": "Print srss version",
      "adapter": "process",
      "adapterConfig": {
        "command": "srss",
        "missingDependencyHelp": "Install srss: go install github.com/sheepla/srss@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "srss",
      "resource": "feed",
      "action": "list",
      "description": "list feed via srss",
      "adapter": "process",
      "adapterConfig": {
        "command": "srss",
        "missingDependencyHelp": "Install srss: go install github.com/sheepla/srss@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "srss",
      "resource": "article",
      "action": "read",
      "description": "read article via srss",
      "adapter": "process",
      "adapterConfig": {
