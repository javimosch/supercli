          "--read"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "srss",
      "resource": "feed",
      "action": "add",
      "description": "add feed via srss",
      "adapter": "process",
      "adapterConfig": {
        "command": "srss",
        "missingDependencyHelp": "Install srss: go install github.com/sheepla/srss@latest",
        "baseArgs": [
          "--add"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
