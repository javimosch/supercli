{
  "plugin": "xh",
  "binary": "xh",
  "check": "which xh",
  "install_steps": [
    "curl -sfL https://raw.githubusercontent.com/ducaale/xh/master/install.sh | sh",
    "Verify: xh --version",
    "supercli plugins install ./plugins/xh --on-conflict replace --json"
  ],
  "note": "Also available via: brew, apt, pacman, scoop, cargo. Binary name 'xhs' forces HTTPS."
}