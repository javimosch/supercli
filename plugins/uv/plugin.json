{
  "name": "uv",
  "version": "0.1.0",
  "description": "uv CLI plugin for dcli",
  "source": "https://docs.astral.sh/uv/reference/cli/",
  "checks": [
    {
      "type": "binary",
      "name": "uv"
    }
  ],
  "commands": [
    {
      "namespace": "uv",
      "resource": "cli",
      "action": "version",
      "description": "Show uv CLI version",
      "adapter": "process",
      "adapterConfig": {
        "command": "uv",
        "baseArgs": ["--version"],
        "parseJson": false,
        "missingDependencyHelp": "Please install uv to use this command."
      },
      "args": []
    },
    {
      "namespace": "uv",
      "resource": "_",
      "action": "_",
      "description": "Passthrough command to execute any uv CLI command",
      "adapter": "process",
      "adapterConfig": {
        "command": "uv",
        "passthrough": true,
        "parseJson": true,
        "missingDependencyHelp": "Please install uv to use this command."
      },
      "args": []
    }
  ]
}
