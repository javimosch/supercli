{
  "name": "fuc",
  "version": "0.1.0",
  "description": "Modern, performance focused unix commands - faster alternatives to coreutils",
  "source": "https://github.com/SUPERCILEX/fuc",
  "checks": [
    { "type": "binary", "name": "fuc" }
  ],
  "install_guidance": {
    "plugin": "fuc",
    "binary": "fuc",
    "check": "which fuc",
    "install_steps": [
      "cargo install fuc",
      "Verify: fuc --help",
      "supercli plugins install ./plugins/fuc --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "fuc",
      "resource": "run",
      "action": "command",
      "description": "Run a fuc command",
      "adapter": "process",
      "adapterConfig": {
        "command": "fuc",
        "cwd": "invoke_cwd",
        "passthrough": true,
        "timeout_ms": 60000,
        "missingDependencyHelp": "Install fuc: cargo install fuc"
      },
      "args": [
        { "name": "command", "type": "string", "required": true, "description": "Fuc command to run" }
      ]
    },
    {
      "namespace": "fuc",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to fuc CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "fuc",
        "cwd": "invoke_cwd",
        "passthrough": true,
        "missingDependencyHelp": "Install fuc: cargo install fuc"
      },
      "args": []
    }
  ]
}
