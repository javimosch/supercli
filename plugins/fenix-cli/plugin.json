{
  "name": "fenix-cli",
  "version": "0.1.0",
  "description": "Command line interface for Fenix code search engine",
  "source": "https://github.com/fenixsoft/fenix-cli",
  "checks": [
    {
      "type": "binary",
      "name": "fenix"
    }
  ],
  "install_guidance": {
    "plugin": "fenix-cli",
    "binary": "fenix",
    "check": "which fenix",
    "install_steps": [
      "go install github.com/fenixsoft/fenix-cli@latest",
      "Verify: fenix --version",
      "supercli plugins install ./plugins/fenix-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "fenix-cli",
      "resource": "self",
      "action": "version",
      "description": "Print fenix-cli version",
      "adapter": "process",
      "adapterConfig": {
        "command": "fenix",
        "missingDependencyHelp": "Install fenix-cli: go install github.com/fenixsoft/fenix-cli@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "fenix-cli",
      "resource": "search",
      "action": "run",
      "description": "run search via fenix",
      "adapter": "process",
      "adapterConfig": {
        "command": "fenix",
        "missingDependencyHelp": "Install fenix-cli: go install github.com/fenixsoft/fenix-cli@latest",
        "baseArgs": [
          "search"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "fenix-cli",
      "resource": "index",
      "action": "build",
      "description": "build index via fenix",
      "adapter": "process",
      "adapterConfig": {
        "command": "fenix",
        "missingDependencyHelp": "Install fenix-cli: go install github.com/fenixsoft/fenix-cli@latest",
        "baseArgs": [
          "index"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "fenix-cli",
      "resource": "_",
      "action": "_",
      "description": "_ _ via fenix",
      "adapter": "process",
      "adapterConfig": {
        "command": "fenix",
        "missingDependencyHelp": "Install fenix-cli: go install github.com/fenixsoft/fenix-cli@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}