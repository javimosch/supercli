{
  "name": "pay-respects",
  "version": "0.1.0",
  "description": "Command suggestions command-not-found and thefuck replacement written in Rust",
  "source": "https://github.com/iffse/pay-respects",
  "checks": [
    {
      "type": "binary",
      "name": "pay-respects"
    }
  ],
  "install_guidance": {
    "plugin": "pay-respects",
    "binary": "pay-respects",
    "check": "which pay-respects",
    "install_steps": [
      "cargo install pay-respects",
      "Verify: pay-respects --version",
      "supercli plugins install ./plugins/pay-respects --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "pay-respects",
      "resource": "self",
      "action": "version",
      "description": "Print pay-respects version",
      "adapter": "process",
      "adapterConfig": {
        "command": "pay-respects",
        "missingDependencyHelp": "Install pay-respects: cargo install pay-respects",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "pay-respects",
      "resource": "command",
      "action": "fix",
      "description": "fix command via pay-respects",
      "adapter": "process",
      "adapterConfig": {
        "command": "pay-respects",
        "missingDependencyHelp": "Install pay-respects: cargo install pay-respects",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
