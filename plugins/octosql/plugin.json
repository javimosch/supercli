{
  "name": "octosql",
  "version": "0.1.0",
  "description": "Query tool that allows you to join, analyse and transform data from multiple databases and file formats using SQL. Query CSV, JSON, databases, and more with SQL.",
  "source": "https://github.com/cube2222/octosql",
  "checks": [
    { "type": "binary", "name": "octosql" }
  ],
  "install_guidance": {
    "plugin": "octosql",
    "binary": "octosql",
    "check": "which octosql",
    "install_steps": [
      "brew install octosql",
      "Verify: octosql --version",
      "supercli plugins install ./plugins/octosql --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "octosql",
      "resource": "data",
      "action": "query",
      "description": "Query data with SQL",
      "adapter": "process",
      "adapterConfig": {
        "command": "octosql",
        "passthrough": true,
        "missingDependencyHelp": "Install octosql: brew install octosql"
      },
      "args": [
        { "name": "query", "type": "string", "description": "SQL query" },
        { "name": "--output", "type": "string", "description": "Output format (json, csv, table)" },
        { "name": "--interactive", "type": "boolean", "description": "Interactive mode" },
        { "name": "--file", "type": "string", "description": "Read query from file" }
      ]
    },
    {
      "namespace": "octosql",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to octosql CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "octosql",
        "passthrough": true,
        "missingDependencyHelp": "Install octosql: brew install octosql"
      },
      "args": []
    }
  ]
}
