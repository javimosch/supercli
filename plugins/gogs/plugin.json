{
  "name": "gogs",
  "version": "0.1.0",
  "description": "Painless self-hosted Git service with CLI administration",
  "source": "https://github.com/gogs/gogs",
  "checks": [
    {
      "type": "binary",
      "name": "gogs"
    }
  ],
  "install_guidance": {
    "plugin": "gogs",
    "binary": "gogs",
    "check": "which gogs",
    "install_steps": [
      "brew install gogs",
      "Verify: gogs --version",
      "supercli plugins install ./plugins/gogs --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "gogs",
      "resource": "self",
      "action": "version",
      "description": "Print gogs version",
      "adapter": "process",
      "adapterConfig": {
        "command": "gogs",
        "missingDependencyHelp": "Install gogs: brew install gogs",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "gogs",
      "resource": "admin",
      "action": "create-user",
      "description": "create-user admin via gogs",
      "adapter": "process",
      "adapterConfig": {
        "command": "gogs",
        "missingDependencyHelp": "Install gogs: brew install gogs",
        "baseArgs": [
          "admin",
          "create-user"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "gogs",
      "resource": "admin",
      "action": "delete-user",
      "description": "delete-user admin via gogs",
      "adapter": "process",
      "adapterConfig": {
        "command": "gogs",
        "missingDependencyHelp": "Install gogs: brew install gogs",
        "baseArgs": [
          "admin",
          "delete-user"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "gogs",
      "resource": "web",
      "action": "start",
      "description": "start web via gogs",
      "adapter": "process",
      "adapterConfig": {
        "command": "gogs",
        "missingDependencyHelp": "Install gogs: brew install gogs",
        "baseArgs": [
          "web"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "gogs",
      "resource": "_",
      "action": "_",
      "description": "_ _ via gogs",
      "adapter": "process",
      "adapterConfig": {
        "command": "gogs",
        "missingDependencyHelp": "Install gogs: brew install gogs",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}