{
  "name": "ahoy",
  "version": "0.1.0",
  "description": "Create shareable, self-documenting command-line tools from simple YAML files",
  "source": "https://github.com/ahoy-cli/ahoy",
  "checks": [
    {
      "type": "binary",
      "name": "ahoy"
    }
  ],
  "install_guidance": {
    "plugin": "ahoy",
    "binary": "ahoy",
    "check": "which ahoy",
    "install_steps": [
      "brew install ahoy-cli/tap/ahoy",
      "Verify: ahoy --version",
      "supercli plugins install ./plugins/ahoy --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "ahoy",
      "resource": "self",
      "action": "version",
      "description": "Print ahoy version",
      "adapter": "process",
      "adapterConfig": {
        "command": "ahoy",
        "missingDependencyHelp": "Install ahoy: brew install ahoy-cli/tap/ahoy",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "ahoy",
      "resource": "command",
      "action": "run",
      "description": "run command via ahoy",
      "adapter": "process",
      "adapterConfig": {
        "command": "ahoy",
        "missingDependencyHelp": "Install ahoy: brew install ahoy-cli/tap/ahoy",
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "ahoy",
      "resource": "cmd",
      "action": "list",
      "description": "list cmd via ahoy",
      "adapter": "process",
      "adapterConfig": {
        "command": "ahoy",
        "missingDependencyHelp": "Install ahoy: brew install ahoy-cli/tap/ahoy",
        "baseArgs": [
          "list"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "ahoy",
      "resource": "_",
      "action": "_",
      "description": "_ _ via ahoy",
      "adapter": "process",
      "adapterConfig": {
        "command": "ahoy",
        "missingDependencyHelp": "Install ahoy: brew install ahoy-cli/tap/ahoy",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}