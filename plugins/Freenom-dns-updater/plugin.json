    "plugin": "Freenom-dns-updater",
    "binary": "freenom-dns-updater",
    "check": "which freenom-dns-updater",
    "install_steps": [
      "pip install freenom-dns-updater",
      "Verify: freenom-dns-updater --version",
      "supercli plugins install ./plugins/Freenom-dns-updater --on-conflict replace --json"
    ]
  },
