{
  "name": "Freenom-dns-updater",
  "version": "0.1.0",
  "description": "Tool to update Freenoms DNS records automatically",
  "source": "https://github.com/maxisoft/Freenom-dns-updater",
  "checks": [
    {
      "type": "binary",
      "name": "freenom-dns-updater"
    }
  ],
