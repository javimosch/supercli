{
  "name": "whis",
  "version": "0.1.0",
  "description": "Voice-to-text CLI — record, transcribe, and pipe to clipboard",
  "source": "https://github.com/frankdierolf/whis",
  "checks": [
    { "type": "binary", "name": "whis" }
  ],
  "install_guidance": {
    "plugin": "whis",
    "binary": "whis",
    "check": "which whis",
    "install_steps": [
      "cargo install whis-cli",
      "Verify: whis --version",
      "supercli plugins install ./plugins/whis --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "whis",
      "resource": "self",
      "action": "version",
      "description": "Print whis version",
      "adapter": "process",
      "adapterConfig": {
        "command": "whis",
        "baseArgs": ["--version"],
        "missingDependencyHelp": "Install whis: cargo install whis-cli"
      },
      "args": []
    },
    {
      "namespace": "whis",
      "resource": "record",
      "action": "start",
      "description": "Start voice recording",
      "adapter": "process",
      "adapterConfig": {
        "command": "whis",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 120000,
        "missingDependencyHelp": "Install whis"
      },
      "args": []
    },
    {
      "namespace": "whis",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to whis CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "whis",
        "passthrough": true,
        "missingDependencyHelp": "Install whis"
      },
      "args": []
    }
  ]
}
