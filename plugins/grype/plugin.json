{
  "name": "grype",
  "version": "0.1.0",
  "description": "Vulnerability scanner for container images and filesystems",
  "source": "https://github.com/anchore/grype",
  "checks": [
    {
      "type": "binary",
      "name": "grype"
    }
  ],
  "install_guidance": {
    "plugin": "grype",
    "binary": "grype",
    "check": "which grype",
    "install_steps": [
      "brew install grype",
      "Verify: grype --version",
      "supercli plugins install ./plugins/grype --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "grype",
      "resource": "self",
      "action": "version",
      "description": "Print grype version",
      "adapter": "process",
      "adapterConfig": {
        "command": "grype",
        "missingDependencyHelp": "Install grype: brew install grype",
        "baseArgs": [
          "version"
        ]
      },
      "args": []
    },
    {
      "namespace": "grype",
      "resource": "image",
      "action": "scan",
      "description": "scan image via grype",
      "adapter": "process",
      "adapterConfig": {
        "command": "grype",
        "missingDependencyHelp": "Install grype: brew install grype",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "grype",
      "resource": "dir",
      "action": "scan",
      "description": "scan dir via grype",
      "adapter": "process",
      "adapterConfig": {
        "command": "grype",
        "missingDependencyHelp": "Install grype: brew install grype",
        "baseArgs": [
          "dir:"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "grype",
      "resource": "sbom",
      "action": "scan",
      "description": "scan sbom via grype",
      "adapter": "process",
      "adapterConfig": {
        "command": "grype",
        "missingDependencyHelp": "Install grype: brew install grype",
        "baseArgs": [
          "sbom:"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "grype",
      "resource": "_",
      "action": "_",
      "description": "_ _ via grype",
      "adapter": "process",
      "adapterConfig": {
        "command": "grype",
        "missingDependencyHelp": "Install grype: brew install grype",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}