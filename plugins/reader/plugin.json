{
  "name": "reader",
  "version": "0.1.0",
  "description": "Readability view for web pages on the command line",
  "source": "https://github.com/mrusme/reader",
  "checks": [
    {
      "type": "binary",
      "name": "reader"
    }
  ],
  "install_guidance": {
    "plugin": "reader",
    "binary": "reader",
    "check": "which reader",
    "install_steps": [
      "go install github.com/mrusme/reader@latest",
      "Verify: reader --version",
      "supercli plugins install ./plugins/reader --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "reader",
      "resource": "self",
      "action": "version",
      "description": "Print reader version",
      "adapter": "process",
      "adapterConfig": {
        "command": "reader",
        "missingDependencyHelp": "Install reader: go install github.com/mrusme/reader@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "reader",
      "resource": "url",
      "action": "read",
      "description": "read url via reader",
      "adapter": "process",
      "adapterConfig": {
        "command": "reader",
        "missingDependencyHelp": "Install reader: go install github.com/mrusme/reader@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "reader",
      "resource": "file",
      "action": "read",
      "description": "read file via reader",
      "adapter": "process",
      "adapterConfig": {
        "command": "reader",
        "missingDependencyHelp": "Install reader: go install github.com/mrusme/reader@latest",
        "baseArgs": [
          "--file"
        ],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "reader",
      "resource": "eml",
      "action": "read",
      "description": "read eml via reader",
      "adapter": "process",
      "adapterConfig": {
        "command": "reader",
        "missingDependencyHelp": "Install reader: go install github.com/mrusme/reader@latest",
        "baseArgs": [
          "--eml"
        ],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "reader",
      "resource": "output",
      "action": "save",
      "description": "save output via reader",
      "adapter": "process",
      "adapterConfig": {
        "command": "reader",
        "missingDependencyHelp": "Install reader: go install github.com/mrusme/reader@latest",
        "baseArgs": [
          "--output"
        ],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "reader",
      "resource": "_",
      "action": "_",
      "description": "_ _ via reader",
      "adapter": "process",
