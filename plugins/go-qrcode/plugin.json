{
  "name": "go-qrcode",
  "version": "0.1.0",
  "description": "QR code generator with terminal and image output",
  "source": "https://github.com/yeqown/go-qrcode",
  "checks": [
    {
      "type": "binary",
      "name": "go-qrcode"
    }
  ],
  "install_guidance": {
    "plugin": "go-qrcode",
    "binary": "go-qrcode",
    "check": "which go-qrcode",
    "install_steps": [
      "go install github.com/yeqown/go-qrcode/cmd/go-qrcode@latest",
      "Verify: go-qrcode --version",
      "supercli plugins install ./plugins/go-qrcode --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "go-qrcode",
      "resource": "self",
      "action": "version",
      "description": "Print go-qrcode version",
      "adapter": "process",
      "adapterConfig": {
        "command": "go-qrcode",
        "missingDependencyHelp": "Install go-qrcode: go install github.com/yeqown/go-qrcode/cmd/go-qrcode@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "go-qrcode",
      "resource": "data",
      "action": "encode",
      "description": "encode data via go-qrcode",
      "adapter": "process",
      "adapterConfig": {
        "command": "go-qrcode",
        "missingDependencyHelp": "Install go-qrcode: go install github.com/yeqown/go-qrcode/cmd/go-qrcode@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "go-qrcode",
      "resource": "_",
      "action": "_",
      "description": "_ _ via go-qrcode",
      "adapter": "process",
      "adapterConfig": {
        "command": "go-qrcode",
        "missingDependencyHelp": "Install go-qrcode: go install github.com/yeqown/go-qrcode/cmd/go-qrcode@latest",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}