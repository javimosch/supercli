{
  "name": "mage",
  "version": "0.1.0",
  "description": "Build tool using Go as a scripting language",
  "source": "https://github.com/magefile/mage",
  "checks": [
    {
      "type": "binary",
      "name": "mage"
    }
  ],
  "install_guidance": {
    "plugin": "mage",
    "binary": "mage",
    "check": "which mage",
    "install_steps": [
      "go install github.com/magefile/mage@latest",
      "Verify: mage --version",
      "supercli plugins install ./plugins/mage --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "mage",
      "resource": "self",
      "action": "version",
      "description": "Print mage version",
      "adapter": "process",
      "adapterConfig": {
        "command": "mage",
        "missingDependencyHelp": "Install mage: go install github.com/magefile/mage@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "mage",
      "resource": "target",
      "action": "run",
      "description": "run target via mage",
      "adapter": "process",
      "adapterConfig": {
        "command": "mage",
        "missingDependencyHelp": "Install mage: go install github.com/magefile/mage@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "mage",
      "resource": "target",
      "action": "list",
      "description": "list target via mage",
      "adapter": "process",
      "adapterConfig": {
        "command": "mage",
        "missingDependencyHelp": "Install mage: go install github.com/magefile/mage@latest",
        "baseArgs": [
          "-l"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "mage",
      "resource": "target",
      "action": "init",
      "description": "init target via mage",
      "adapter": "process",
      "adapterConfig": {
        "command": "mage",
        "missingDependencyHelp": "Install mage: go install github.com/magefile/mage@latest",
        "baseArgs": [
          "-init"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "mage",
      "resource": "_",
      "action": "_",
      "description": "_ _ via mage",
      "adapter": "process",
      "adapterConfig": {
        "command": "mage",
        "missingDependencyHelp": "Install mage: go install github.com/magefile/mage@latest",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}