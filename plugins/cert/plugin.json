{
  "name": "cert",
  "version": "0.1.0",
  "description": "SSL/TLS certificate checker and validator CLI",
  "source": "https://github.com/genkiroid/cert",
  "checks": [
    {
      "type": "binary",
      "name": "cert"
    }
  ],
  "install_guidance": {
    "plugin": "cert",
    "binary": "cert",
    "check": "which cert",
    "install_steps": [
      "go install github.com/genkiroid/cert/cmd/cert@latest",
      "Verify: cert --version",
      "supercli plugins install ./plugins/cert --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "cert",
      "resource": "self",
      "action": "version",
      "description": "Print cert version",
      "adapter": "process",
      "adapterConfig": {
        "command": "cert",
        "missingDependencyHelp": "Install cert: go install github.com/genkiroid/cert/cmd/cert@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "cert",
      "resource": "certificate",
      "action": "check",
      "description": "check certificate via cert",
      "adapter": "process",
      "adapterConfig": {
        "command": "cert",
        "missingDependencyHelp": "Install cert: go install github.com/genkiroid/cert/cmd/cert@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "cert",
      "resource": "_",
      "action": "_",
      "description": "_ _ via cert",
      "adapter": "process",
      "adapterConfig": {
        "command": "cert",
        "missingDependencyHelp": "Install cert: go install github.com/genkiroid/cert/cmd/cert@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}