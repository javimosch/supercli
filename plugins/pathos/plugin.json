{
  "name": "pathos",
  "version": "0.1.0",
  "description": "Path manipulation and file system utility CLI",
  "source": "https://github.com/chip/pathos",
  "checks": [
    {
      "type": "binary",
      "name": "pathos"
    }
  ],
  "install_guidance": {
    "plugin": "pathos",
    "binary": "pathos",
    "check": "which pathos",
    "install_steps": [
      "go install github.com/chip/pathos@latest",
      "Verify: pathos --version",
      "supercli plugins install ./plugins/pathos --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "pathos",
      "resource": "self",
      "action": "version",
      "description": "Print pathos version",
      "adapter": "process",
      "adapterConfig": {
        "command": "pathos",
        "missingDependencyHelp": "Install pathos: go install github.com/chip/pathos@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "pathos",
      "resource": "path",
      "action": "resolve",
      "description": "resolve path via pathos",
      "adapter": "process",
      "adapterConfig": {
        "command": "pathos",
        "missingDependencyHelp": "Install pathos: go install github.com/chip/pathos@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "pathos",
      "resource": "path",
      "action": "normalize",
      "description": "normalize path via pathos",
      "adapter": "process",
      "adapterConfig": {
        "command": "pathos",
        "missingDependencyHelp": "Install pathos: go install github.com/chip/pathos@latest",
        "baseArgs": [
          "--normalize"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "pathos",
      "resource": "path",
      "action": "join",
      "description": "join path via pathos",
      "adapter": "process",
      "adapterConfig": {
        "command": "pathos",
        "missingDependencyHelp": "Install pathos: go install github.com/chip/pathos@latest",
        "baseArgs": [
          "--join"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "pathos",
      "resource": "_",
      "action": "_",
      "description": "_ _ via pathos",
      "adapter": "process",
      "adapterConfig": {
        "command": "pathos",
        "missingDependencyHelp": "Install pathos: go install github.com/chip/pathos@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}