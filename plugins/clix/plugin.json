{
  "name": "clix",
  "version": "0.1.0",
  "description": "Hybrid clix plugin with remote agent docs and safe read-only X wrappers",
  "source": "https://github.com/spideystreet/clix",
  "checks": [
    { "type": "binary", "name": "curl" },
    { "type": "binary", "name": "clix" }
  ],
  "post_install": {
    "script": "scripts/post-install.js",
    "runtime": "node",
    "timeout_ms": 15000
  },
  "post_uninstall": {
    "script": "scripts/post-uninstall.js",
    "runtime": "node",
    "timeout_ms": 15000
  },
  "commands": [
    {
      "namespace": "clix",
      "resource": "auth",
      "action": "status",
      "description": "Show clix authentication status as JSON",
      "adapter": "process",
      "adapterConfig": {
        "command": "clix",
        "baseArgs": ["auth", "status", "--json"],
        "parseJson": true,
        "timeout_ms": 15000,
        "missingDependencyHelp": "Please install clix to use this command."
      },
      "args": []
    },
    {
      "namespace": "clix",
      "resource": "timeline",
      "action": "list",
      "description": "List timeline tweets as JSON",
      "adapter": "process",
      "adapterConfig": {
        "command": "clix",
        "baseArgs": ["feed", "--json"],
        "parseJson": true,
        "timeout_ms": 15000,
        "missingDependencyHelp": "Please install clix to use this command."
      },
      "args": [
        { "name": "type", "type": "string", "required": false },
        { "name": "count", "type": "integer", "required": false }
      ]
    },
    {
      "namespace": "clix",
      "resource": "posts",
      "action": "search",
      "description": "Search posts as JSON",
      "adapter": "process",
      "adapterConfig": {
        "command": "clix",
        "baseArgs": ["search", "--json"],
        "positionalArgs": ["query"],
        "parseJson": true,
        "timeout_ms": 15000,
        "missingDependencyHelp": "Please install clix to use this command."
      },
      "args": [
        { "name": "query", "type": "string", "required": true },
        { "name": "type", "type": "string", "required": false },
        { "name": "count", "type": "integer", "required": false }
      ]
    },
    {
      "namespace": "clix",
      "resource": "posts",
      "action": "show",
      "description": "Show a tweet and thread as JSON",
      "adapter": "process",
      "adapterConfig": {
        "command": "clix",
        "baseArgs": ["tweet", "--json"],
        "positionalArgs": ["id"],
        "parseJson": true,
        "timeout_ms": 15000,
        "missingDependencyHelp": "Please install clix to use this command."
      },
      "args": [
        { "name": "id", "type": "string", "required": true }
      ]
    },
    {
      "namespace": "clix",
      "resource": "users",
      "action": "show",
      "description": "Show a user profile and recent tweets as JSON",
      "adapter": "process",
      "adapterConfig": {
        "command": "clix",
        "baseArgs": ["user", "--json"],
        "positionalArgs": ["handle"],
        "parseJson": true,
        "timeout_ms": 15000,
        "missingDependencyHelp": "Please install clix to use this command."
      },
      "args": [
        { "name": "handle", "type": "string", "required": true }
      ]
    },
    {
      "namespace": "clix",
      "resource": "bookmarks",
      "action": "list",
      "description": "List bookmarks as JSON",
      "adapter": "process",
      "adapterConfig": {
        "command": "clix",
        "baseArgs": ["bookmarks", "--json"],
        "parseJson": true,
        "timeout_ms": 15000,
        "missingDependencyHelp": "Please install clix to use this command."
      },
      "args": []
    }
  ]
}
