{
  "name": "trex",
  "version": "0.1.0",
  "description": "Command line tool for extracting and processing text data",
  "source": "https://github.com/samyakbardiya/trex",
  "checks": [
    {
      "type": "binary",
      "name": "trex"
    }
  ],
  "install_guidance": {
    "plugin": "trex",
    "binary": "trex",
    "check": "which trex",
    "install_steps": [
      "go install github.com/samyakbardiya/trex@latest",
      "Verify: trex --version",
      "supercli plugins install ./plugins/trex --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "trex",
      "resource": "self",
      "action": "version",
      "description": "Print trex version",
      "adapter": "process",
      "adapterConfig": {
        "command": "trex",
        "missingDependencyHelp": "Install trex: go install github.com/samyakbardiya/trex@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "trex",
      "resource": "text",
      "action": "extract",
      "description": "extract text via trex",
      "adapter": "process",
      "adapterConfig": {
        "command": "trex",
        "missingDependencyHelp": "Install trex: go install github.com/samyakbardiya/trex@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "trex",
      "resource": "pattern",
      "action": "search",
      "description": "search pattern via trex",
      "adapter": "process",
      "adapterConfig": {
        "command": "trex",
        "missingDependencyHelp": "Install trex: go install github.com/samyakbardiya/trex@latest",
        "baseArgs": [
          "--pattern"
        ],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "trex",
      "resource": "_",
      "action": "_",
      "description": "_ _ via trex",
      "adapter": "process",
      "adapterConfig": {
        "command": "trex",
        "missingDependencyHelp": "Install trex: go install github.com/samyakbardiya/trex@latest",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}