{
  "name": "upash",
  "version": "0.1.0",
  "description": "Unified password hashing API for Node.js",
  "source": "https://github.com/simonepri/upash",
  "checks": [
    {
      "type": "binary",
      "name": "upash"
    }
  ],
  "install_guidance": {
    "plugin": "upash",
    "binary": "upash",
    "check": "which upash",
    "install_steps": [
      "npm install -g upash-cli",
      "Verify: upash --version",
      "supercli plugins install ./plugins/upash --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "upash",
      "resource": "self",
      "action": "version",
      "description": "Print upash version",
      "adapter": "process",
      "adapterConfig": {
        "command": "upash",
        "missingDependencyHelp": "Install upash: npm install -g upash-cli",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "upash",
      "resource": "password",
      "action": "hash",
      "description": "hash password via upash",
      "adapter": "process",
      "adapterConfig": {
        "command": "upash",
        "missingDependencyHelp": "Install upash: npm install -g upash-cli",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "upash",
      "resource": "password",
      "action": "verify",
      "description": "verify password via upash",
      "adapter": "process",
      "adapterConfig": {
        "command": "upash",
        "missingDependencyHelp": "Install upash: npm install -g upash-cli",
        "baseArgs": [
          "verify"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "upash",
      "resource": "_",
      "action": "_",
      "description": "_ _ via upash",
      "adapter": "process",
      "adapterConfig": {
        "command": "upash",
        "missingDependencyHelp": "Install upash: npm install -g upash-cli",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}