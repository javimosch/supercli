{
  "name": "circleci-cli",
  "version": "0.1.0",
  "description": "Command line tool for CircleCI",
  "source": "https://github.com/CircleCI-Public/circleci-cli",
  "checks": [
    {
      "type": "binary",
      "name": "circleci"
    }
  ],
  "install_guidance": {
    "plugin": "circleci-cli",
    "binary": "circleci",
    "check": "which circleci",
    "install_steps": [
      "brew install circleci",
      "Verify: circleci --version",
      "supercli plugins install ./plugins/circleci-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "circleci-cli",
      "resource": "self",
      "action": "version",
      "description": "Print circleci-cli version",
      "adapter": "process",
      "adapterConfig": {
        "command": "circleci",
        "missingDependencyHelp": "Install circleci-cli: brew install circleci",
        "baseArgs": [
          "version"
        ]
      },
      "args": []
    },
    {
      "namespace": "circleci-cli",
      "resource": "config",
      "action": "validate",
      "description": "validate config via circleci",
      "adapter": "process",
      "adapterConfig": {
        "command": "circleci",
        "missingDependencyHelp": "Install circleci-cli: brew install circleci",
        "baseArgs": [
          "config",
          "validate"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "circleci-cli",
      "resource": "pipeline",
      "action": "list",
      "description": "list pipeline via circleci",
      "adapter": "process",
      "adapterConfig": {
        "command": "circleci",
        "missingDependencyHelp": "Install circleci-cli: brew install circleci",
        "baseArgs": [
          "pipeline",
          "list"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "circleci-cli",
      "resource": "orb",
      "action": "list",
      "description": "list orb via circleci",
      "adapter": "process",
      "adapterConfig": {
        "command": "circleci",
        "missingDependencyHelp": "Install circleci-cli: brew install circleci",
        "baseArgs": [
          "orb",
          "list"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "circleci-cli",
      "resource": "_",
      "action": "_",
      "description": "_ _ via circleci",
      "adapter": "process",
      "adapterConfig": {
        "command": "circleci",
        "missingDependencyHelp": "Install circleci-cli: brew install circleci",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}