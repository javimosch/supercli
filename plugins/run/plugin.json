{
  "name": "run",
  "version": "0.1.0",
  "description": "Run commands in the languages you love",
  "source": "https://github.com/LyonSyonII/run",
  "checks": [
    {
      "type": "binary",
      "name": "run"
    }
  ],
  "install_guidance": {
    "plugin": "run",
    "binary": "run",
    "check": "which run",
    "install_steps": [
      "cargo install run",
      "Verify: run --version",
      "supercli plugins install ./plugins/run --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "run",
      "resource": "self",
      "action": "version",
      "description": "Print run version",
      "adapter": "process",
      "adapterConfig": {
        "command": "run",
        "missingDependencyHelp": "Install run: cargo install run",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "run",
      "resource": "script",
      "action": "execute",
      "description": "execute script via run",
      "adapter": "process",
      "adapterConfig": {
        "command": "run",
        "missingDependencyHelp": "Install run: cargo install run",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "run",
      "resource": "script",
      "action": "list",
      "description": "list script via run",
      "adapter": "process",
      "adapterConfig": {
        "command": "run",
        "missingDependencyHelp": "Install run: cargo install run",
