        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "run",
      "resource": "_",
      "action": "_",
      "description": "_ _ via run",
      "adapter": "process",
      "adapterConfig": {
        "command": "run",
        "missingDependencyHelp": "Install run: cargo install run",
        "passthrough": true
