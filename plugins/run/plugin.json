        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "run",
      "resource": "language",
      "action": "detect",
      "description": "detect language via run",
      "adapter": "process",
      "adapterConfig": {
        "command": "run",
        "missingDependencyHelp": "Install run: cargo install run",
        "baseArgs": [
          "--detect"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
