{
  "name": "pin-github-action",
  "version": "0.1.0",
  "description": "Pin GitHub Actions to specific commit SHAs",
  "source": "https://github.com/mheap/pin-github-action",
  "checks": [
    {
      "type": "binary",
      "name": "pin-github-action"
    }
  ],
  "install_guidance": {
    "plugin": "pin-github-action",
    "binary": "pin-github-action",
    "check": "which pin-github-action",
    "install_steps": [
      "npm install -g pin-github-action",
      "Verify: pin-github-action --version",
      "supercli plugins install ./plugins/pin-github-action --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "pin-github-action",
      "resource": "self",
      "action": "version",
      "description": "Print pin-github-action version",
      "adapter": "process",
      "adapterConfig": {
        "command": "pin-github-action",
        "missingDependencyHelp": "Install pin-github-action: npm install -g pin-github-action",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "pin-github-action",
      "resource": "file",
      "action": "pin",
      "description": "pin file via pin-github-action",
      "adapter": "process",
      "adapterConfig": {
        "command": "pin-github-action",
        "missingDependencyHelp": "Install pin-github-action: npm install -g pin-github-action",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "pin-github-action",
      "resource": "_",
      "action": "_",
      "description": "_ _ via pin-github-action",
      "adapter": "process",
      "adapterConfig": {
        "command": "pin-github-action",
        "missingDependencyHelp": "Install pin-github-action: npm install -g pin-github-action",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}