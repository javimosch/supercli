{
  "name": "mkcert",
  "version": "0.1.0",
  "description": "A simple zero-config tool to make locally trusted development certificates with any names",
  "source": "https://github.com/FiloSottile/mkcert",
  "checks": [
    {
      "type": "binary",
      "name": "mkcert"
    }
  ],
  "install_guidance": {
    "plugin": "mkcert",
    "binary": "mkcert",
    "check": "which mkcert",
    "install_steps": [
      "brew install mkcert",
      "Verify: mkcert --version",
      "supercli plugins install ./plugins/mkcert --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "mkcert",
      "resource": "self",
      "action": "version",
      "description": "Print mkcert version",
      "adapter": "process",
      "adapterConfig": {
        "command": "mkcert",
        "missingDependencyHelp": "Install mkcert: brew install mkcert",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "mkcert",
      "resource": "cert",
      "action": "create",
      "description": "create cert via mkcert",
      "adapter": "process",
      "adapterConfig": {
        "command": "mkcert",
        "missingDependencyHelp": "Install mkcert: brew install mkcert",
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "mkcert",
      "resource": "install",
      "action": "ca",
      "description": "ca install via mkcert",
      "adapter": "process",
      "adapterConfig": {
        "command": "mkcert",
        "missingDependencyHelp": "Install mkcert: brew install mkcert",
        "baseArgs": [
          "-install"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "mkcert",
      "resource": "_",
      "action": "_",
      "description": "_ _ via mkcert",
      "adapter": "process",
      "adapterConfig": {
        "command": "mkcert",
        "missingDependencyHelp": "Install mkcert: brew install mkcert",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}