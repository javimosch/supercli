{
  "name": "cherrybomb",
  "version": "0.1.0",
  "description": "Cherrybomb is a CLI tool that helps you avoid undefined user behaviour by auditing your API specifications, validating them and running API security tests.",
  "source": "https://github.com/blst-security/cherrybomb",
  "checks": [
    { "type": "binary", "name": "cherrybomb" }
  ],
  "install_guidance": {
    "plugin": "cherrybomb",
    "binary": "cherrybomb",
    "check": "which cherrybomb",
    "install_steps": [
      "brew install cherrybomb",
      "Verify: cherrybomb --version",
      "supercli plugins install ./plugins/cherrybomb --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "cherrybomb",
      "resource": "api",
      "action": "audit",
      "description": "Audit API specification",
      "adapter": "process",
      "adapterConfig": {
        "command": "cherrybomb",
        "baseArgs": ["audit"],
        "passthrough": true,
        "missingDependencyHelp": "Install cherrybomb: brew install cherrybomb"
      },
      "args": [
        { "name": "spec", "type": "string", "description": "API specification file" },
        { "name": "--format", "type": "string", "description": "Output format" },
        { "name": "--severity", "type": "string", "description": "Severity level" },
        { "name": "--output", "type": "string", "description": "Output file" }
      ]
    },
    {
      "namespace": "cherrybomb",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to cherrybomb CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "cherrybomb",
        "passthrough": true,
        "missingDependencyHelp": "Install cherrybomb: brew install cherrybomb"
      },
      "args": []
    }
  ]
}
