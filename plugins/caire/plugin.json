{
  "name": "caire",
  "version": "0.1.0",
  "description": "Content-aware image resize library and CLI tool",
  "source": "https://github.com/esimov/caire",
  "checks": [
    {
      "type": "binary",
      "name": "caire"
    }
  ],
  "install_guidance": {
    "plugin": "caire",
    "binary": "caire",
    "check": "which caire",
    "install_steps": [
      "go install github.com/esimov/caire/cmd/caire@latest",
      "Verify: caire --version",
      "supercli plugins install ./plugins/caire --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
