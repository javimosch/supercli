      "resource": "self",
      "action": "version",
      "description": "Print caire version",
      "adapter": "process",
      "adapterConfig": {
        "command": "caire",
        "missingDependencyHelp": "Install caire: go install github.com/esimov/caire/cmd/caire@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "caire",
      "resource": "image",
      "action": "resize",
      "description": "resize image via caire",
