{
  "name": "bundle-phobia-cli",
  "version": "0.1.0",
  "description": "Check npm package bundle size from the command line",
  "source": "https://github.com/AdrieanKhisbe/bundle-phobia-cli",
  "checks": [
    {
      "type": "binary",
      "name": "bundle-phobia"
    }
  ],
  "install_guidance": {
    "plugin": "bundle-phobia-cli",
    "binary": "bundle-phobia",
    "check": "which bundle-phobia",
    "install_steps": [
      "npm install -g bundle-phobia-cli",
      "Verify: bundle-phobia --version",
      "supercli plugins install ./plugins/bundle-phobia-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "bundle-phobia-cli",
      "resource": "self",
      "action": "version",
      "description": "Print bundle-phobia-cli version",
      "adapter": "process",
      "adapterConfig": {
        "command": "bundle-phobia",
        "missingDependencyHelp": "Install bundle-phobia-cli: npm install -g bundle-phobia-cli",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "bundle-phobia-cli",
      "resource": "package",
      "action": "check",
      "description": "check package via bundle-phobia",
      "adapter": "process",
      "adapterConfig": {
        "command": "bundle-phobia",
        "missingDependencyHelp": "Install bundle-phobia-cli: npm install -g bundle-phobia-cli",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "bundle-phobia-cli",
      "resource": "_",
      "action": "_",
      "description": "_ _ via bundle-phobia",
      "adapter": "process",
      "adapterConfig": {
        "command": "bundle-phobia",
        "missingDependencyHelp": "Install bundle-phobia-cli: npm install -g bundle-phobia-cli",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}