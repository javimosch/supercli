{
  "name": "httpretty",
  "version": "0.1.0",
  "description": "Pretty-print HTTP requests and responses in terminal",
  "source": "https://github.com/henvic/httpretty",
  "checks": [
    {
      "type": "binary",
      "name": "httpretty"
    }
  ],
  "install_guidance": {
    "plugin": "httpretty",
    "binary": "httpretty",
    "check": "which httpretty",
    "install_steps": [
      "go install github.com/henvic/httpretty@latest",
      "Verify: httpretty --version",
      "supercli plugins install ./plugins/httpretty --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "httpretty",
      "resource": "self",
      "action": "version",
      "description": "Print httpretty version",
      "adapter": "process",
      "adapterConfig": {
        "command": "httpretty",
        "missingDependencyHelp": "Install httpretty: go install github.com/henvic/httpretty@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "httpretty",
      "resource": "request",
      "action": "print",
      "description": "print request via httpretty",
      "adapter": "process",
      "adapterConfig": {
        "command": "httpretty",
        "missingDependencyHelp": "Install httpretty: go install github.com/henvic/httpretty@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "httpretty",
      "resource": "response",
      "action": "print",
      "description": "print response via httpretty",
      "adapter": "process",
      "adapterConfig": {
        "command": "httpretty",
        "missingDependencyHelp": "Install httpretty: go install github.com/henvic/httpretty@latest",
        "baseArgs": [
          "--response"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "httpretty",
      "resource": "_",
      "action": "_",
      "description": "_ _ via httpretty",
      "adapter": "process",
      "adapterConfig": {
        "command": "httpretty",
        "missingDependencyHelp": "Install httpretty: go install github.com/henvic/httpretty@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}