{
  "name": "mac-cleaner-cli",
  "version": "0.1.0",
  "description": "macOS CLI to free disk space by clearing caches, logs, Homebrew and Xcode junk",
  "source": "https://github.com/guhcostan/mac-cleaner-cli",
  "checks": [
    {
      "type": "binary",
      "name": "mac-cleaner"
    }
  ],
  "install_guidance": {
    "plugin": "mac-cleaner-cli",
    "binary": "mac-cleaner",
    "check": "which mac-cleaner",
    "install_steps": [
      "npm install -g mac-cleaner-cli",
      "Verify: mac-cleaner --version",
      "supercli plugins install ./plugins/mac-cleaner-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "mac-cleaner-cli",
      "resource": "self",
      "action": "version",
      "description": "Print mac-cleaner-cli version",
      "adapter": "process",
      "adapterConfig": {
        "command": "mac-cleaner",
        "missingDependencyHelp": "Install mac-cleaner-cli: npm install -g mac-cleaner-cli",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "mac-cleaner-cli",
      "resource": "cache",
      "action": "clear",
      "description": "clear cache via mac-cleaner",
      "adapter": "process",
      "adapterConfig": {
        "command": "mac-cleaner",
        "missingDependencyHelp": "Install mac-cleaner-cli: npm install -g mac-cleaner-cli",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "mac-cleaner-cli",
