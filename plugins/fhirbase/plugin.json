{
  "name": "fhirbase",
  "version": "0.1.0",
  "description": "FHIR healthcare data CLI for PostgreSQL",
  "source": "https://github.com/fhirbase/fhirbase",
  "checks": [
    {
      "type": "binary",
      "name": "fhirbase"
    }
  ],
  "install_guidance": {
    "plugin": "fhirbase",
    "binary": "fhirbase",
    "check": "which fhirbase",
    "install_steps": [
      "go install github.com/fhirbase/fhirbase@latest",
      "Verify: fhirbase --version",
      "supercli plugins install ./plugins/fhirbase --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "fhirbase",
      "resource": "self",
      "action": "version",
      "description": "Print fhirbase version",
      "adapter": "process",
      "adapterConfig": {
        "command": "fhirbase",
        "missingDependencyHelp": "Install fhirbase: go install github.com/fhirbase/fhirbase@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "fhirbase",
      "resource": "data",
      "action": "query",
      "description": "query data via fhirbase",
      "adapter": "process",
      "adapterConfig": {
        "command": "fhirbase",
        "missingDependencyHelp": "Install fhirbase: go install github.com/fhirbase/fhirbase@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "fhirbase",
      "resource": "_",
      "action": "_",
      "description": "_ _ via fhirbase",
      "adapter": "process",
      "adapterConfig": {
        "command": "fhirbase",
        "missingDependencyHelp": "Install fhirbase: go install github.com/fhirbase/fhirbase@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}