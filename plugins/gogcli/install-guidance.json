{
  "plugin": "gogcli",
  "binary": "gog",
  "check": "which gog",
  "install_steps": [
    "macOS: brew install gogcli",
    "Linux: Build from source (see https://github.com/steipete/gogcli)",
    "Verify: gog --version",
    "Setup OAuth: gog auth credentials <client_secret.json>",
    "Add account: gog auth add <email>",
    "supercli plugins install ./plugins/gogcli --on-conflict replace --json"
  ],
  "note": "Requires Google OAuth2 setup. Create Desktop app credentials at console.cloud.google.com/apis/credentials"
}