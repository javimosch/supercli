{
  "name": "ok-mdx",
  "version": "0.1.0",
  "description": "Zero-config MDX development and prototyping CLI",
  "source": "https://github.com/jxnblk/ok-mdx",
  "checks": [
    {
      "type": "binary",
      "name": "ok-mdx"
    }
  ],
  "install_guidance": {
    "plugin": "ok-mdx",
    "binary": "ok-mdx",
    "check": "which ok-mdx",
    "install_steps": [
      "npm install -g ok-mdx",
      "Verify: ok-mdx --version",
      "supercli plugins install ./plugins/ok-mdx --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "ok-mdx",
      "resource": "self",
      "action": "version",
      "description": "Print ok-mdx version",
      "adapter": "process",
      "adapterConfig": {
        "command": "ok-mdx",
        "missingDependencyHelp": "Install ok-mdx: npm install -g ok-mdx",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "ok-mdx",
      "resource": "mdx",
      "action": "dev",
      "description": "dev mdx via ok-mdx",
      "adapter": "process",
      "adapterConfig": {
        "command": "ok-mdx",
        "missingDependencyHelp": "Install ok-mdx: npm install -g ok-mdx",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "ok-mdx",
      "resource": "mdx",
      "action": "build",
      "description": "build mdx via ok-mdx",
      "adapter": "process",
      "adapterConfig": {
        "command": "ok-mdx",
        "missingDependencyHelp": "Install ok-mdx: npm install -g ok-mdx",
        "baseArgs": [
          "build"
        ],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "ok-mdx",
      "resource": "_",
      "action": "_",
      "description": "_ _ via ok-mdx",
      "adapter": "process",
      "adapterConfig": {
        "command": "ok-mdx",
        "missingDependencyHelp": "Install ok-mdx: npm install -g ok-mdx",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}