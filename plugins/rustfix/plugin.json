{
  "name": "rustfix",
  "version": "0.1.0",
  "description": "Automatically apply the suggestions made by rustc compiler",
  "source": "https://github.com/rust-lang/rustfix",
  "checks": [
    {
      "type": "binary",
      "name": "rustfix"
    }
  ],
  "install_guidance": {
    "plugin": "rustfix",
    "binary": "rustfix",
    "check": "which rustfix",
    "install_steps": [
      "cargo install rustfix",
      "Verify: rustfix --version",
      "supercli plugins install ./plugins/rustfix --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "rustfix",
      "resource": "self",
      "action": "version",
      "description": "Print rustfix version",
      "adapter": "process",
      "adapterConfig": {
        "command": "rustfix",
        "missingDependencyHelp": "Install rustfix: cargo install rustfix",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "rustfix",
      "resource": "code",
      "action": "fix",
      "description": "fix code via rustfix",
      "adapter": "process",
      "adapterConfig": {
        "command": "rustfix",
        "missingDependencyHelp": "Install rustfix: cargo install rustfix",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "rustfix",
      "resource": "dry-run",
      "action": "run",
      "description": "run dry-run via rustfix",
      "adapter": "process",
      "adapterConfig": {
        "command": "rustfix",
        "missingDependencyHelp": "Install rustfix: cargo install rustfix",
        "baseArgs": [
          "--dry-run"
        ],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "rustfix",
      "resource": "json",
      "action": "read",
      "description": "read json via rustfix",
      "adapter": "process",
      "adapterConfig": {
        "command": "rustfix",
        "missingDependencyHelp": "Install rustfix: cargo install rustfix",
        "baseArgs": [
          "--json"
        ],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "rustfix",
      "resource": "config",
      "action": "show",
      "description": "show config via rustfix",
      "adapter": "process",
      "adapterConfig": {
        "command": "rustfix",
        "missingDependencyHelp": "Install rustfix: cargo install rustfix",
        "baseArgs": [
          "--config"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "rustfix",
      "resource": "_",
      "action": "_",
      "description": "_ _ via rustfix",
      "adapter": "process",
      "adapterConfig": {
        "command": "rustfix",
        "missingDependencyHelp": "Install rustfix: cargo install rustfix",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}