{
  "name": "library",
  "version": "0.1.0",
  "description": "99+ CLI tools to build, browse, and blend your media library",
  "source": "https://github.com/chapmanjacobd/library",
  "checks": [
    { "type": "binary", "name": "library" }
  ],
  "install_guidance": {
    "plugin": "library",
    "binary": "library",
    "check": "which library",
    "install_steps": [
      "pip install library",
      "Verify: library --help",
      "supercli plugins install ./plugins/library --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "library",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to library CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "library",
        "cwd": "invoke_cwd",
        "passthrough": true,
        "timeout_ms": 120000,
        "missingDependencyHelp": "Install library: pip install library"
      },
      "args": []
    }
  ]
}
