{
  "plugin": "dewdrops",
  "binary": "dewdrops",
  "check": "which dewdrops",
  "install_steps": [
    "wget https://raw.githubusercontent.com/MedUnes/dewdrops/master/latest.sh && chmod +x latest.sh && ./latest.sh && rm latest.sh",
    "Verify: dewdrops --version",
    "supercli plugins install ./plugins/dewdrops --on-conflict replace --json"
  ],
  "note": "Requires Go 1.25+ if building from source. Prebuilt binaries available at https://github.com/MedUnes/dewdrops/releases"
}