{
  "name": "cfnctl",
  "version": "0.1.0",
  "description": "AWS CloudFormation stack management CLI",
  "source": "https://github.com/rogerwelin/cfnctl",
  "checks": [
    {
      "type": "binary",
      "name": "cfnctl"
    }
  ],
  "install_guidance": {
    "plugin": "cfnctl",
    "binary": "cfnctl",
    "check": "which cfnctl",
    "install_steps": [
      "go install github.com/rogerwelin/cfnctl@latest",
      "Verify: cfnctl --version",
      "supercli plugins install ./plugins/cfnctl --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "cfnctl",
      "resource": "self",
      "action": "version",
      "description": "Print cfnctl version",
      "adapter": "process",
      "adapterConfig": {
        "command": "cfnctl",
        "missingDependencyHelp": "Install cfnctl: go install github.com/rogerwelin/cfnctl@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "cfnctl",
      "resource": "stack",
      "action": "deploy",
      "description": "deploy stack via cfnctl",
      "adapter": "process",
      "adapterConfig": {
        "command": "cfnctl",
        "missingDependencyHelp": "Install cfnctl: go install github.com/rogerwelin/cfnctl@latest",
        "baseArgs": [
          "deploy"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "cfnctl",
      "resource": "stack",
      "action": "delete",
      "description": "delete stack via cfnctl",
      "adapter": "process",
      "adapterConfig": {
        "command": "cfnctl",
        "missingDependencyHelp": "Install cfnctl: go install github.com/rogerwelin/cfnctl@latest",
        "baseArgs": [
          "delete"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "cfnctl",
      "resource": "stack",
      "action": "list",
      "description": "list stack via cfnctl",
      "adapter": "process",
      "adapterConfig": {
        "command": "cfnctl",
        "missingDependencyHelp": "Install cfnctl: go install github.com/rogerwelin/cfnctl@latest",
        "baseArgs": [
          "list"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "cfnctl",
      "resource": "stack",
      "action": "status",
      "description": "status stack via cfnctl",
      "adapter": "process",
      "adapterConfig": {
        "command": "cfnctl",
        "missingDependencyHelp": "Install cfnctl: go install github.com/rogerwelin/cfnctl@latest",
        "baseArgs": [
          "status"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "cfnctl",
      "resource": "_",
      "action": "_",
      "description": "_ _ via cfnctl",
      "adapter": "process",
      "adapterConfig": {
        "command": "cfnctl",
        "missingDependencyHelp": "Install cfnctl: go install github.com/rogerwelin/cfnctl@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
