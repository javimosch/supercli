{
  "name": "boilr",
  "version": "0.1.0",
  "description": "Boilr is a powerful Language-agnostic scaffolding tool that creates projects from template repositories",
  "source": "https://github.com/tmrts/boilr",
  "checks": [
    {
      "type": "binary",
      "name": "boilr"
    }
  ],
  "install_guidance": {
    "plugin": "boilr",
    "binary": "boilr",
    "check": "which boilr",
    "install_steps": [
      "go install github.com/tmrts/boilr@latest",
      "Verify: boilr --version",
      "supercli plugins install ./plugins/boilr --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "boilr",
      "resource": "self",
      "action": "version",
      "description": "Print boilr version",
      "adapter": "process",
      "adapterConfig": {
        "command": "boilr",
        "missingDependencyHelp": "Install boilr: go install github.com/tmrts/boilr@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "boilr",
      "resource": "template",
      "action": "download",
      "description": "download template via boilr",
      "adapter": "process",
      "adapterConfig": {
        "command": "boilr",
        "missingDependencyHelp": "Install boilr: go install github.com/tmrts/boilr@latest",
        "baseArgs": [
          "template",
          "download"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "boilr",
      "resource": "template",
      "action": "list",
      "description": "list template via boilr",
      "adapter": "process",
      "adapterConfig": {
        "command": "boilr",
        "missingDependencyHelp": "Install boilr: go install github.com/tmrts/boilr@latest",
        "baseArgs": [
          "template",
          "list"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "boilr",
      "resource": "template",
      "action": "use",
      "description": "use template via boilr",
      "adapter": "process",
      "adapterConfig": {
        "command": "boilr",
        "missingDependencyHelp": "Install boilr: go install github.com/tmrts/boilr@latest",
        "baseArgs": [
          "template",
          "use"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "boilr",
      "resource": "_",
      "action": "_",
      "description": "_ _ via boilr",
      "adapter": "process",
      "adapterConfig": {
        "command": "boilr",
        "missingDependencyHelp": "Install boilr: go install github.com/tmrts/boilr@latest",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}