{
  "name": "restish",
  "version": "0.1.0",
  "description": "CLI for interacting with REST-ish APIs. A user-friendly HTTP client with built-in API schema discovery, JSON navigation, and convenient resource management.",
  "source": "https://github.com/rest-sh/restish",
  "checks": [
    { "type": "binary", "name": "restish" }
  ],
  "install_guidance": {
    "plugin": "restish",
    "binary": "restish",
    "check": "which restish",
    "install_steps": [
      "brew install restish",
      "Verify: restish --version",
      "supercli plugins install ./plugins/restish --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "restish",
      "resource": "api",
      "action": "get",
      "description": "Send GET request to API",
      "adapter": "process",
      "adapterConfig": {
        "command": "restish",
        "baseArgs": ["get"],
        "passthrough": true,
        "missingDependencyHelp": "Install restish: brew install restish"
      },
      "args": [
        { "name": "url", "type": "string", "description": "API URL or resource path" },
        { "name": "--header", "type": "string", "description": "Custom header" },
        { "name": "--query", "type": "string", "description": "Query parameter" }
      ]
    },
    {
      "namespace": "restish",
      "resource": "api",
      "action": "post",
      "description": "Send POST request to API",
      "adapter": "process",
      "adapterConfig": {
        "command": "restish",
        "baseArgs": ["post"],
        "passthrough": true,
        "missingDependencyHelp": "Install restish: brew install restish"
      },
      "args": [
        { "name": "url", "type": "string", "description": "API URL or resource path" },
        { "name": "--body", "type": "string", "description": "Request body" },
        { "name": "--header", "type": "string", "description": "Custom header" }
      ]
    },
    {
      "namespace": "restish",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to restish CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "restish",
        "passthrough": true,
        "missingDependencyHelp": "Install restish: brew install restish"
      },
      "args": []
    }
  ]
}
