{
  "name": "intelli-shell",
  "version": "0.1.0",
  "description": "Like IntelliSense but for shells with command suggestions",
  "source": "https://github.com/lasantosr/intelli-shell",
  "checks": [
    {
      "type": "binary",
      "name": "intelli-shell"
    }
  ],
  "install_guidance": {
    "plugin": "intelli-shell",
    "binary": "intelli-shell",
    "check": "which intelli-shell",
    "install_steps": [
      "cargo install intelli-shell",
      "Verify: intelli-shell --version",
      "supercli plugins install ./plugins/intelli-shell --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "intelli-shell",
      "resource": "self",
      "action": "version",
      "description": "Print intelli-shell version",
      "adapter": "process",
      "adapterConfig": {
        "command": "intelli-shell",
        "missingDependencyHelp": "Install intelli-shell: cargo install intelli-shell",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "intelli-shell",
      "resource": "command",
      "action": "suggest",
      "description": "suggest command via intelli-shell",
      "adapter": "process",
      "adapterConfig": {
        "command": "intelli-shell",
        "missingDependencyHelp": "Install intelli-shell: cargo install intelli-shell",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "intelli-shell",
      "resource": "history",
      "action": "search",
      "description": "search history via intelli-shell",
      "adapter": "process",
      "adapterConfig": {
        "command": "intelli-shell",
        "missingDependencyHelp": "Install intelli-shell: cargo install intelli-shell",
        "baseArgs": [
          "--history"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "intelli-shell",
