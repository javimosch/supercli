{
  "plugin": "act",
  "binary": "act",
  "check": "which act || echo 'act not installed'",
  "install_steps": [
    "macOS: brew install act",
    "Linux: curl -s https://raw.githubusercontent.com/nektos/act/master/install.sh | sh",
    "Windows: choco install act",
    "Verify: act --version",
    "supercli plugins install ./plugins/act --on-conflict replace --json"
  ],
  "note": "Docker must be running. act runs GitHub Actions in local Docker containers."
}