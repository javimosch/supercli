{
  "name": "osc",
  "version": "0.1.0",
  "description": "Copy and paste text over SSH using OSC52 escape sequences",
  "source": "https://github.com/theimpostor/osc",
  "checks": [
    {
      "type": "binary",
      "name": "osc"
    }
  ],
  "install_guidance": {
    "plugin": "osc",
    "binary": "osc",
    "check": "which osc",
    "install_steps": [
      "brew install osc",
      "Verify: osc --version",
      "supercli plugins install ./plugins/osc --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "osc",
      "resource": "self",
      "action": "version",
      "description": "Print osc version",
      "adapter": "process",
      "adapterConfig": {
        "command": "osc",
        "missingDependencyHelp": "Install osc: brew install osc",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "osc",
      "resource": "clipboard",
      "action": "copy",
      "description": "copy clipboard via osc",
      "adapter": "process",
      "adapterConfig": {
        "command": "osc",
        "missingDependencyHelp": "Install osc: brew install osc",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "osc",
      "resource": "_",
      "action": "_",
      "description": "_ _ via osc",
      "adapter": "process",
      "adapterConfig": {
        "command": "osc",
        "missingDependencyHelp": "Install osc: brew install osc",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}