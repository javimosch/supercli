{
  "name": "click",
  "version": "0.1.0",
  "description": "Command Line Interactive Controller for Kubernetes. An interactive Kubernetes CLI that provides a more user-friendly interface for kubectl operations.",
  "source": "https://github.com/databricks/click",
  "checks": [
    { "type": "binary", "name": "click" }
  ],
  "install_guidance": {
    "plugin": "click",
    "binary": "click",
    "check": "which click",
    "install_steps": [
      "brew install click",
      "Verify: click --version",
      "supercli plugins install ./plugins/click --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "click",
      "resource": "k8s",
      "action": "run",
      "description": "Run click interactive Kubernetes CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "click",
        "baseArgs": [],
        "passthrough": true,
        "missingDependencyHelp": "Install click: brew install click"
      },
      "args": [
        { "name": "--namespace", "type": "string", "description": "Kubernetes namespace" },
        { "name": "--context", "type": "string", "description": "Kubernetes context" }
      ]
    },
    {
      "namespace": "click",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to click CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "click",
        "passthrough": true,
        "missingDependencyHelp": "Install click: brew install click"
      },
      "args": []
    }
  ]
}
