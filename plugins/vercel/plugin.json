{
  "name": "vercel",
  "version": "0.1.0",
  "description": "Vercel CLI plugin for dcli",
  "source": "https://vercel.com/docs/cli",
  "checks": [
    {
      "type": "binary",
      "name": "vercel"
    }
  ],
  "commands": [
    {
      "namespace": "vercel",
      "resource": "account",
      "action": "whoami",
      "description": "Show the currently logged in Vercel user",
      "adapter": "process",
      "adapterConfig": {
        "command": "vercel",
        "baseArgs": ["whoami"],
        "parseJson": false,
        "missingDependencyHelp": "Please install Vercel CLI to use this command."
      },
      "args": []
    },
    {
      "namespace": "vercel",
      "resource": "_",
      "action": "_",
      "description": "Passthrough command to execute any Vercel CLI command",
      "adapter": "process",
      "adapterConfig": {
        "command": "vercel",
        "passthrough": true,
        "parseJson": true,
        "missingDependencyHelp": "Please install Vercel CLI to use this command."
      },
      "args": []
    }
  ]
}
