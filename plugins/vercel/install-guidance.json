{
  "plugin": "vercel",
  "binary": "vercel",
  "check": "vercel --version",
  "install_steps": [
    "npm install -g vercel",
    "vercel --version",
    "supercli plugins install ./plugins/vercel --on-conflict replace --json"
  ],
  "note": "Run 'vercel login' before deployments. Use '--prod' flag for production deploys."
}