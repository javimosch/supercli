{
  "plugin": "massgen",
  "version": "1.0.0",
  "description": "Multi-agent scaling system that coordinates AI agents to solve complex tasks",
  "commands": [
    {
      "name": "version",
      "description": "Show massgen version",
      "command": "massgen --version"
    },
    {
      "name": "run",
      "description": "Run massgen with a task",
      "command": "massgen run <task>"
    },
    {
      "name": "serve",
      "description": "Start massgen server",
      "command": "massgen serve"
    }
  ],
  "checks": [
    {
      "name": "massgen",
      "command": "massgen --version",
      "parse": "\\d+\\.\\d+\\.\\d+"
    }
  ]
}
