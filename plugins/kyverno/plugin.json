{
  "name": "kyverno",
  "version": "0.1.0",
  "description": "Kubernetes native policy management CLI",
  "source": "https://github.com/kyverno/kyverno",
  "checks": [
    {
      "type": "binary",
      "name": "kyverno"
    }
  ],
  "install_guidance": {
    "plugin": "kyverno",
    "binary": "kyverno",
    "check": "which kyverno",
    "install_steps": [
      "brew install kyverno",
      "Verify: kyverno --version",
      "supercli plugins install ./plugins/kyverno --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "kyverno",
      "resource": "self",
      "action": "version",
      "description": "Print kyverno version",
      "adapter": "process",
      "adapterConfig": {
        "command": "kyverno",
        "missingDependencyHelp": "Install kyverno: brew install kyverno",
        "baseArgs": [
          "version"
        ]
      },
      "args": []
    },
    {
      "namespace": "kyverno",
      "resource": "policy",
      "action": "test",
      "description": "test policy via kyverno",
      "adapter": "process",
      "adapterConfig": {
        "command": "kyverno",
        "missingDependencyHelp": "Install kyverno: brew install kyverno",
        "baseArgs": [
          "test"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "kyverno",
      "resource": "policy",
      "action": "apply",
      "description": "apply policy via kyverno",
      "adapter": "process",
      "adapterConfig": {
        "command": "kyverno",
        "missingDependencyHelp": "Install kyverno: brew install kyverno",
        "baseArgs": [
          "apply"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "kyverno",
      "resource": "policy",
      "action": "scan",
      "description": "scan policy via kyverno",
      "adapter": "process",
      "adapterConfig": {
        "command": "kyverno",
        "missingDependencyHelp": "Install kyverno: brew install kyverno",
        "baseArgs": [
          "scan"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "kyverno",
      "resource": "_",
      "action": "_",
      "description": "_ _ via kyverno",
      "adapter": "process",
      "adapterConfig": {
        "command": "kyverno",
        "missingDependencyHelp": "Install kyverno: brew install kyverno",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}