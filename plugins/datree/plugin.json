      "resource": "self",
      "action": "version",
      "description": "Print datree version",
      "adapter": "process",
      "adapterConfig": {
        "command": "datree",
        "missingDependencyHelp": "Install datree: brew install datree",
        "baseArgs": [
          "version"
        ]
      },
      "args": []
    },
    {
      "namespace": "datree",
      "resource": "config",
      "action": "test",
      "description": "test config via datree",
      "adapter": "process",
      "adapterConfig": {
        "command": "datree",
        "missingDependencyHelp": "Install datree: brew install datree",
        "baseArgs": [
          "test"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
