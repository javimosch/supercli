{
  "name": "datree",
  "version": "0.1.0",
  "description": "Prevent Kubernetes misconfigurations from reaching production",
  "source": "https://github.com/datreeio/datree",
  "checks": [
    {
      "type": "binary",
      "name": "datree"
    }
  ],
  "install_guidance": {
    "plugin": "datree",
    "binary": "datree",
    "check": "which datree",
    "install_steps": [
      "brew install datree",
      "Verify: datree --version",
      "supercli plugins install ./plugins/datree --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
