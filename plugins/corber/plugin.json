{
  "name": "corber",
  "version": "0.1.0",
  "description": "Cordova and Electron hybrid app development CLI",
  "source": "https://github.com/isleofcode/corber",
  "checks": [
    {
      "type": "binary",
      "name": "corber"
    }
  ],
  "install_guidance": {
    "plugin": "corber",
    "binary": "corber",
    "check": "which corber",
    "install_steps": [
      "npm install -g corber",
      "Verify: corber --version",
      "supercli plugins install ./plugins/corber --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "corber",
      "resource": "self",
      "action": "version",
      "description": "Print corber version",
      "adapter": "process",
      "adapterConfig": {
        "command": "corber",
        "missingDependencyHelp": "Install corber: npm install -g corber",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "corber",
      "resource": "app",
      "action": "build",
      "description": "build app via corber",
      "adapter": "process",
      "adapterConfig": {
        "command": "corber",
        "missingDependencyHelp": "Install corber: npm install -g corber",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "corber",
      "resource": "app",
      "action": "serve",
      "description": "serve app via corber",
      "adapter": "process",
      "adapterConfig": {
        "command": "corber",
        "missingDependencyHelp": "Install corber: npm install -g corber",
        "baseArgs": [
          "serve"
        ],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "corber",
      "resource": "app",
      "action": "init",
      "description": "init app via corber",
      "adapter": "process",
      "adapterConfig": {
        "command": "corber",
        "missingDependencyHelp": "Install corber: npm install -g corber",
        "baseArgs": [
          "init"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "corber",
      "resource": "_",
      "action": "_",
      "description": "_ _ via corber",
      "adapter": "process",
      "adapterConfig": {
        "command": "corber",
        "missingDependencyHelp": "Install corber: npm install -g corber",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}