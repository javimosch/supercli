{
  "plugin": "howto",
  "binary": "howto",
  "check": "which howto",
  "install_steps": [
    "go install github.com/nalgeon/howto@latest",
    "Verify: howto --version",
    "supercli plugins install ./plugins/howto --on-conflict replace --json"
  ],
  "note": "Also available via Homebrew: brew tap nalgeon/howto && brew install howto"
}
