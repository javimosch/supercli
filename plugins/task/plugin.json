{
  "name": "task",
  "version": "0.1.0",
  "description": "Task runner / build tool that aims to be simpler than GNU Make",
  "source": "https://github.com/go-task/task",
  "checks": [
    {
      "type": "binary",
      "name": "task"
    }
  ],
  "install_guidance": {
    "plugin": "task",
    "binary": "task",
    "check": "which task",
    "install_steps": [
      "brew install go-task/tap/go-task",
      "Verify: task --version",
      "supercli plugins install ./plugins/task --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "task",
      "resource": "self",
      "action": "version",
      "description": "Print task version",
      "adapter": "process",
      "adapterConfig": {
        "command": "task",
        "missingDependencyHelp": "Install task: brew install go-task/tap/go-task",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "task",
      "resource": "task",
      "action": "run",
      "description": "run task via task",
      "adapter": "process",
      "adapterConfig": {
        "command": "task",
        "missingDependencyHelp": "Install task: brew install go-task/tap/go-task",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "task",
      "resource": "task",
      "action": "list",
      "description": "list task via task",
      "adapter": "process",
      "adapterConfig": {
        "command": "task",
        "missingDependencyHelp": "Install task: brew install go-task/tap/go-task",
        "baseArgs": [
          "--list"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "task",
      "resource": "task",
      "action": "init",
      "description": "init task via task",
      "adapter": "process",
      "adapterConfig": {
        "command": "task",
        "missingDependencyHelp": "Install task: brew install go-task/tap/go-task",
        "baseArgs": [
          "--init"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "task",
      "resource": "_",
      "action": "_",
      "description": "_ _ via task",
      "adapter": "process",
      "adapterConfig": {
        "command": "task",
        "missingDependencyHelp": "Install task: brew install go-task/tap/go-task",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}