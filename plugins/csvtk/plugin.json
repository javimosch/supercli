{
  "name": "csvtk",
  "version": "0.1.0",
  "description": "Cross-platform CSV/TSV toolkit and processor",
  "source": "https://github.com/shenwei356/csvtk",
  "checks": [
    {
      "type": "binary",
      "name": "csvtk"
    }
  ],
  "install_guidance": {
    "plugin": "csvtk",
    "binary": "csvtk",
    "check": "which csvtk",
    "install_steps": [
      "brew install csvtk",
      "Verify: csvtk --version",
      "supercli plugins install ./plugins/csvtk --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "csvtk",
      "resource": "self",
      "action": "version",
      "description": "Print csvtk version",
      "adapter": "process",
      "adapterConfig": {
        "command": "csvtk",
        "missingDependencyHelp": "Install csvtk: brew install csvtk",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "csvtk",
      "resource": "data",
      "action": "process",
      "description": "process data via csvtk",
      "adapter": "process",
      "adapterConfig": {
        "command": "csvtk",
        "missingDependencyHelp": "Install csvtk: brew install csvtk",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "csvtk",
      "resource": "_",
      "action": "_",
      "description": "_ _ via csvtk",
      "adapter": "process",
      "adapterConfig": {
        "command": "csvtk",
        "missingDependencyHelp": "Install csvtk: brew install csvtk",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}