{
  "name": "barrelsby",
  "version": "0.1.0",
  "description": "Automatic TypeScript barrels (index.ts files) for your entire codebase",
  "source": "https://github.com/bencoveney/barrelsby",
  "checks": [
    {
      "type": "binary",
      "name": "barrelsby"
    }
  ],
  "install_guidance": {
    "plugin": "barrelsby",
    "binary": "barrelsby",
    "check": "which barrelsby",
    "install_steps": [
      "npm install -g barrelsby",
      "Verify: barrelsby --version",
      "supercli plugins install ./plugins/barrelsby --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "barrelsby",
      "resource": "self",
      "action": "version",
      "description": "Print barrelsby version",
      "adapter": "process",
      "adapterConfig": {
        "command": "barrelsby",
        "missingDependencyHelp": "Install barrelsby: npm install -g barrelsby",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "barrelsby",
      "resource": "barrel",
      "action": "generate",
      "description": "generate barrel via barrelsby",
      "adapter": "process",
      "adapterConfig": {
        "command": "barrelsby",
        "missingDependencyHelp": "Install barrelsby: npm install -g barrelsby",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
