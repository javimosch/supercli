{
  "name": "pulumi",
  "version": "0.1.0",
  "description": "Pulumi CLI plugin for dcli",
  "source": "https://www.pulumi.com/docs/iac/cli/commands/",
  "checks": [
    {
      "type": "binary",
      "name": "pulumi"
    }
  ],
  "commands": [
    {
      "namespace": "pulumi",
      "resource": "cli",
      "action": "version",
      "description": "Show Pulumi CLI version",
      "adapter": "process",
      "adapterConfig": {
        "command": "pulumi",
        "baseArgs": ["version"],
        "parseJson": false,
        "missingDependencyHelp": "Please install Pulumi CLI to use this command."
      },
      "args": []
    },
    {
      "namespace": "pulumi",
      "resource": "_",
      "action": "_",
      "description": "Passthrough command to execute any Pulumi CLI command",
      "adapter": "process",
      "adapterConfig": {
        "command": "pulumi",
        "passthrough": true,
        "parseJson": true,
        "missingDependencyHelp": "Please install Pulumi CLI to use this command."
      },
      "args": []
    }
  ]
}
