{
  "name": "openapi-format",
  "version": "0.1.0",
  "description": "Format and filter OpenAPI specification files",
  "source": "https://github.com/thim81/openapi-format",
  "checks": [
    {
      "type": "binary",
      "name": "openapi-format"
    }
  ],
  "install_guidance": {
    "plugin": "openapi-format",
    "binary": "openapi-format",
    "check": "which openapi-format",
    "install_steps": [
      "npm install -g openapi-format",
      "Verify: openapi-format --version",
      "supercli plugins install ./plugins/openapi-format --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "openapi-format",
      "resource": "self",
      "action": "version",
      "description": "Print openapi-format version",
      "adapter": "process",
      "adapterConfig": {
        "command": "openapi-format",
        "missingDependencyHelp": "Install openapi-format: npm install -g openapi-format",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "openapi-format",
      "resource": "file",
      "action": "format",
      "description": "format file via openapi-format",
      "adapter": "process",
      "adapterConfig": {
        "command": "openapi-format",
        "missingDependencyHelp": "Install openapi-format: npm install -g openapi-format",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "openapi-format",
      "resource": "file",
      "action": "filter",
      "description": "filter file via openapi-format",
      "adapter": "process",
      "adapterConfig": {
        "command": "openapi-format",
        "missingDependencyHelp": "Install openapi-format: npm install -g openapi-format",
        "baseArgs": [
          "filter"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "openapi-format",
      "resource": "_",
      "action": "_",
      "description": "_ _ via openapi-format",
      "adapter": "process",
      "adapterConfig": {
        "command": "openapi-format",
        "missingDependencyHelp": "Install openapi-format: npm install -g openapi-format",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}