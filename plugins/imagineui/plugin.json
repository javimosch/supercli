{
  "name": "imagineui",
  "version": "0.1.0",
  "description": "CLI tool to generate wireframes from a localized human-readable format",
  "source": "https://github.com/imagineui/imagineui",
  "checks": [
    {
      "type": "binary",
      "name": "imagineui"
    }
  ],
  "install_guidance": {
    "plugin": "imagineui",
    "binary": "imagineui",
    "check": "which imagineui",
    "install_steps": [
      "npm install -g imagineui",
      "Verify: imagineui --version",
      "supercli plugins install ./plugins/imagineui --on-conflict replace --json"
