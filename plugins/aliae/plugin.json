{
  "name": "aliae",
  "version": "0.1.0",
  "description": "Cross shell and platform alias management",
  "source": "https://github.com/JanDeDobbeleer/aliae",
  "checks": [
    {
      "type": "binary",
      "name": "aliae"
    }
  ],
  "install_guidance": {
    "plugin": "aliae",
    "binary": "aliae",
    "check": "which aliae",
    "install_steps": [
      "brew install jandedobbeleer/tap/aliae",
      "Verify: aliae --version",
      "supercli plugins install ./plugins/aliae --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "aliae",
      "resource": "self",
      "action": "version",
      "description": "Print aliae version",
      "adapter": "process",
      "adapterConfig": {
        "command": "aliae",
        "missingDependencyHelp": "Install aliae: brew install jandedobbeleer/tap/aliae",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "aliae",
      "resource": "alias",
      "action": "list",
      "description": "list alias via aliae",
      "adapter": "process",
      "adapterConfig": {
        "command": "aliae",
        "missingDependencyHelp": "Install aliae: brew install jandedobbeleer/tap/aliae",
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "aliae",
      "resource": "_",
      "action": "_",
      "description": "_ _ via aliae",
      "adapter": "process",
      "adapterConfig": {
        "command": "aliae",
        "missingDependencyHelp": "Install aliae: brew install jandedobbeleer/tap/aliae",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}