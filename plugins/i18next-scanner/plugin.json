{
  "name": "i18next-scanner",
  "version": "0.1.0",
  "description": "Scan code and extract i18next translation keys",
  "source": "https://github.com/i18next/i18next-scanner",
  "checks": [
    {
      "type": "binary",
      "name": "i18next-scanner"
    }
  ],
  "install_guidance": {
    "plugin": "i18next-scanner",
    "binary": "i18next-scanner",
    "check": "which i18next-scanner",
    "install_steps": [
      "npm install -g i18next-scanner",
      "Verify: i18next-scanner --version",
      "supercli plugins install ./plugins/i18next-scanner --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "i18next-scanner",
      "resource": "self",
      "action": "version",
      "description": "Print i18next-scanner version",
      "adapter": "process",
      "adapterConfig": {
        "command": "i18next-scanner",
        "missingDependencyHelp": "Install i18next-scanner: npm install -g i18next-scanner",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "i18next-scanner",
      "resource": "code",
      "action": "scan",
      "description": "scan code via i18next-scanner",
      "adapter": "process",
      "adapterConfig": {
        "command": "i18next-scanner",
        "missingDependencyHelp": "Install i18next-scanner: npm install -g i18next-scanner",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "i18next-scanner",
      "resource": "_",
      "action": "_",
      "description": "_ _ via i18next-scanner",
      "adapter": "process",
      "adapterConfig": {
        "command": "i18next-scanner",
        "missingDependencyHelp": "Install i18next-scanner: npm install -g i18next-scanner",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}