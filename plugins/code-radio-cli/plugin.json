{
  "name": "code-radio-cli",
  "version": "0.1.0",
  "description": "Command line music radio client for freeCodeCamp Code Radio",
  "source": "https://github.com/JasonWei512/code-radio-cli",
  "checks": [
    {
      "type": "binary",
      "name": "code-radio"
    }
  ],
  "install_guidance": {
    "plugin": "code-radio-cli",
    "binary": "code-radio",
    "check": "which code-radio",
    "install_steps": [
      "cargo install code-radio-cli",
      "Verify: code-radio --version",
      "supercli plugins install ./plugins/code-radio-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "code-radio-cli",
      "resource": "self",
      "action": "version",
      "description": "Print code-radio-cli version",
      "adapter": "process",
      "adapterConfig": {
        "command": "code-radio",
        "missingDependencyHelp": "Install code-radio-cli: cargo install code-radio-cli",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "code-radio-cli",
      "resource": "radio",
      "action": "play",
      "description": "play radio via code-radio",
      "adapter": "process",
      "adapterConfig": {
        "command": "code-radio",
        "missingDependencyHelp": "Install code-radio-cli: cargo install code-radio-cli",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
