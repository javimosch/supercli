{
  "name": "envcli",
  "version": "0.1.0",
  "description": "Manage environment-specific CLI configurations",
  "source": "https://github.com/EnvCLI/EnvCLI",
  "checks": [
    {
      "type": "binary",
      "name": "envcli"
    }
  ],
  "install_guidance": {
    "plugin": "envcli",
    "binary": "envcli",
    "check": "which envcli",
    "install_steps": [
      "go install github.com/EnvCLI/EnvCLI@latest",
      "Verify: envcli --version",
      "supercli plugins install ./plugins/envcli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "envcli",
      "resource": "self",
      "action": "version",
      "description": "Print envcli version",
      "adapter": "process",
      "adapterConfig": {
        "command": "envcli",
        "missingDependencyHelp": "Install envcli: go install github.com/EnvCLI/EnvCLI@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "envcli",
      "resource": "env",
      "action": "run",
      "description": "run env via envcli",
      "adapter": "process",
      "adapterConfig": {
        "command": "envcli",
        "missingDependencyHelp": "Install envcli: go install github.com/EnvCLI/EnvCLI@latest",
        "baseArgs": [
          "run"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "envcli",
      "resource": "env",
      "action": "list",
      "description": "list env via envcli",
      "adapter": "process",
      "adapterConfig": {
        "command": "envcli",
        "missingDependencyHelp": "Install envcli: go install github.com/EnvCLI/EnvCLI@latest",
        "baseArgs": [
          "list"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "envcli",
      "resource": "env",
      "action": "init",
      "description": "init env via envcli",
      "adapter": "process",
      "adapterConfig": {
        "command": "envcli",
        "missingDependencyHelp": "Install envcli: go install github.com/EnvCLI/EnvCLI@latest",
        "baseArgs": [
          "init"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "envcli",
      "resource": "_",
      "action": "_",
      "description": "_ _ via envcli",
      "adapter": "process",
      "adapterConfig": {
        "command": "envcli",
        "missingDependencyHelp": "Install envcli: go install github.com/EnvCLI/EnvCLI@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}