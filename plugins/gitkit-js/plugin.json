{
  "name": "gitkit-js",
  "version": "0.1.0",
  "description": "JavaScript toolkit for Git operations",
  "source": "https://github.com/SamyPesse/gitkit-js",
  "checks": [
    {
      "type": "binary",
      "name": "gitkit"
    }
  ],
  "install_guidance": {
    "plugin": "gitkit-js",
    "binary": "gitkit",
    "check": "which gitkit",
    "install_steps": [
      "npm install -g gitkit",
      "Verify: gitkit --version",
      "supercli plugins install ./plugins/gitkit-js --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "gitkit-js",
      "resource": "self",
      "action": "version",
      "description": "Print gitkit-js version",
      "adapter": "process",
      "adapterConfig": {
        "command": "gitkit",
        "missingDependencyHelp": "Install gitkit-js: npm install -g gitkit",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "gitkit-js",
      "resource": "git",
      "action": "run",
      "description": "run git via gitkit",
      "adapter": "process",
      "adapterConfig": {
        "command": "gitkit",
        "missingDependencyHelp": "Install gitkit-js: npm install -g gitkit",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "gitkit-js",
      "resource": "_",
      "action": "_",
      "description": "_ _ via gitkit",
      "adapter": "process",
      "adapterConfig": {
        "command": "gitkit",
        "missingDependencyHelp": "Install gitkit-js: npm install -g gitkit",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}