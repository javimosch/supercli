{
  "name": "swagger-cli",
  "version": "0.1.0",
  "description": "Command line tools for Swagger/OpenAPI operations",
  "source": "https://github.com/APIDevTools/swagger-cli",
  "checks": [
    {
      "type": "binary",
      "name": "swagger"
    }
  ],
  "install_guidance": {
    "plugin": "swagger-cli",
    "binary": "swagger",
    "check": "which swagger",
    "install_steps": [
      "npm install -g swagger-cli",
      "Verify: swagger --version",
      "supercli plugins install ./plugins/swagger-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "swagger-cli",
      "resource": "self",
      "action": "version",
      "description": "Print swagger-cli version",
      "adapter": "process",
      "adapterConfig": {
        "command": "swagger",
        "missingDependencyHelp": "Install swagger-cli: npm install -g swagger-cli",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "swagger-cli",
      "resource": "spec",
      "action": "validate",
      "description": "validate spec via swagger",
      "adapter": "process",
      "adapterConfig": {
        "command": "swagger",
        "missingDependencyHelp": "Install swagger-cli: npm install -g swagger-cli",
        "baseArgs": [
          "validate"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "swagger-cli",
      "resource": "spec",
      "action": "bundle",
      "description": "bundle spec via swagger",
      "adapter": "process",
      "adapterConfig": {
        "command": "swagger",
        "missingDependencyHelp": "Install swagger-cli: npm install -g swagger-cli",
        "baseArgs": [
          "bundle"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "swagger-cli",
      "resource": "_",
      "action": "_",
      "description": "_ _ via swagger",
      "adapter": "process",
      "adapterConfig": {
        "command": "swagger",
        "missingDependencyHelp": "Install swagger-cli: npm install -g swagger-cli",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}