{
  "name": "gh-stars",
  "version": "0.1.0",
  "description": "List and manage your GitHub starred repositories",
  "source": "https://github.com/gkze/gh-stars",
  "checks": [
    {
      "type": "binary",
      "name": "gh-stars"
    }
  ],
  "install_guidance": {
    "plugin": "gh-stars",
    "binary": "gh-stars",
    "check": "which gh-stars",
    "install_steps": [
      "go install github.com/gkze/gh-stars@latest",
      "Verify: gh-stars --version",
      "supercli plugins install ./plugins/gh-stars --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "gh-stars",
      "resource": "self",
      "action": "version",
      "description": "Print gh-stars version",
      "adapter": "process",
      "adapterConfig": {
        "command": "gh-stars",
        "missingDependencyHelp": "Install gh-stars: go install github.com/gkze/gh-stars@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "gh-stars",
      "resource": "stars",
      "action": "list",
      "description": "list stars via gh-stars",
      "adapter": "process",
