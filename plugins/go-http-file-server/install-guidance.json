{
  "plugin": "go-http-file-server",
  "binary": "go-http-file-server",
  "check": "which go-http-file-server",
  "install_steps": [
    "go install github.com/mjpclab/go-http-file-server@latest",
    "Verify: go-http-file-server --version",
    "supercli plugins install ./plugins/go-http-file-server --on-conflict replace --json"
  ]
}