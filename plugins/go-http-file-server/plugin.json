{
  "name": "go-http-file-server",
  "version": "0.1.0",
  "description": "Simple HTTP file server with upload support",
  "source": "https://github.com/mjpclab/go-http-file-server",
  "checks": [
    {
      "type": "binary",
      "name": "go-http-file-server"
    }
  ],
  "install_guidance": {
    "plugin": "go-http-file-server",
    "binary": "go-http-file-server",
    "check": "which go-http-file-server",
    "install_steps": [
      "go install github.com/mjpclab/go-http-file-server@latest",
      "Verify: go-http-file-server --version",
      "supercli plugins install ./plugins/go-http-file-server --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "go-http-file-server",
      "resource": "self",
      "action": "version",
      "description": "Print go-http-file-server version",
      "adapter": "process",
      "adapterConfig": {
        "command": "go-http-file-server",
        "missingDependencyHelp": "Install go-http-file-server: go install github.com/mjpclab/go-http-file-server@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "go-http-file-server",
      "resource": "files",
      "action": "serve",
      "description": "serve files via go-http-file-server",
      "adapter": "process",
      "adapterConfig": {
        "command": "go-http-file-server",
        "missingDependencyHelp": "Install go-http-file-server: go install github.com/mjpclab/go-http-file-server@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "go-http-file-server",
      "resource": "_",
      "action": "_",
      "description": "_ _ via go-http-file-server",
      "adapter": "process",
      "adapterConfig": {
        "command": "go-http-file-server",
        "missingDependencyHelp": "Install go-http-file-server: go install github.com/mjpclab/go-http-file-server@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}