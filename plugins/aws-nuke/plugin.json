{
  "name": "aws-nuke",
  "version": "0.1.0",
  "description": "Remove all resources from an AWS account. Nuke a whole AWS account and delete all its resources. Useful for cleaning up test accounts.",
  "source": "https://github.com/rebuy-de/aws-nuke",
  "checks": [
    { "type": "binary", "name": "aws-nuke" }
  ],
  "install_guidance": {
    "plugin": "aws-nuke",
    "binary": "aws-nuke",
    "check": "which aws-nuke",
    "install_steps": [
      "brew install aws-nuke",
      "Verify: aws-nuke --version",
      "supercli plugins install ./plugins/aws-nuke --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "aws-nuke",
      "resource": "account",
      "action": "nuke",
      "description": "Nuke all resources in AWS account",
      "adapter": "process",
      "adapterConfig": {
        "command": "aws-nuke",
        "baseArgs": ["run"],
        "passthrough": true,
        "missingDependencyHelp": "Install aws-nuke: brew install aws-nuke"
      },
      "args": [
        { "name": "--config", "type": "string", "description": "Config file path" },
        { "name": "--profile", "type": "string", "description": "AWS profile" },
        { "name": "--dry-run", "type": "boolean", "description": "Dry run without deletion" },
        { "name": "--no-dry-run", "type": "boolean", "description": "Perform actual deletion" }
      ]
    },
    {
      "namespace": "aws-nuke",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to aws-nuke CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "aws-nuke",
        "passthrough": true,
        "missingDependencyHelp": "Install aws-nuke: brew install aws-nuke"
      },
      "args": []
    }
  ]
}
