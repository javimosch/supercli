{
  "name": "readme-md-generator",
  "version": "0.1.0",
  "description": "Generate beautiful README.md files interactively",
  "source": "https://github.com/kefranabg/readme-md-generator",
  "checks": [
    {
      "type": "binary",
      "name": "readme-md-generator"
    }
  ],
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
