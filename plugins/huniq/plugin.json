{
  "name": "huniq",
  "version": "0.1.0",
  "description": "Filter out duplicates on the command line optimized for speed",
  "source": "https://github.com/koraa/huniq",
  "checks": [
    {
      "type": "binary",
      "name": "huniq"
    }
  ],
  "install_guidance": {
    "plugin": "huniq",
    "binary": "huniq",
    "check": "which huniq",
    "install_steps": [
      "cargo install huniq",
      "Verify: huniq --version",
      "supercli plugins install ./plugins/huniq --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "huniq",
      "resource": "self",
      "action": "version",
      "description": "Print huniq version",
      "adapter": "process",
      "adapterConfig": {
        "command": "huniq",
        "missingDependencyHelp": "Install huniq: cargo install huniq",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "huniq",
      "resource": "input",
      "action": "filter",
      "description": "filter input via huniq",
      "adapter": "process",
      "adapterConfig": {
        "command": "huniq",
        "missingDependencyHelp": "Install huniq: cargo install huniq",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "huniq",
      "resource": "count",
      "action": "show",
      "description": "show count via huniq",
      "adapter": "process",
      "adapterConfig": {
        "command": "huniq",
        "missingDependencyHelp": "Install huniq: cargo install huniq",
        "baseArgs": [
          "--count"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "huniq",
      "resource": "lines",
      "action": "unique",
      "description": "unique lines via huniq",
      "adapter": "process",
      "adapterConfig": {
        "command": "huniq",
        "missingDependencyHelp": "Install huniq: cargo install huniq",
        "baseArgs": [
          "--unique"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "huniq",
      "resource": "lines",
