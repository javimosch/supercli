{
  "plugin": "http-nu",
  "binary": "http-nu",
  "check": "which http-nu",
  "install_steps": [
    "cargo binstall http-nu",
    "Verify: http-nu --version",
    "supercli plugins install ./plugins/http-nu --on-conflict replace --json"
  ],
  "note": "Also available via Homebrew (brew install cablehead/tap/http-nu), Nix, or eget."
}
