{
  "name": "fx",
  "version": "0.1.0",
  "description": "Terminal JSON viewer and processor. View, filter, and transform JSON data with a powerful query language.",
  "source": "https://github.com/antonmedv/fx",
  "checks": [
    { "type": "binary", "name": "fx" }
  ],
  "install_guidance": {
    "plugin": "fx",
    "binary": "fx",
    "check": "which fx",
    "install_steps": [
      "brew install fx",
      "Verify: fx --version",
      "supercli plugins install ./plugins/fx --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "fx",
      "resource": "view",
      "action": "json",
      "description": "View and process JSON data",
      "adapter": "process",
      "adapterConfig": {
        "command": "fx",
        "passthrough": true,
        "missingDependencyHelp": "Install fx: brew install fx"
      },
      "args": [
        { "name": "file", "type": "string", "description": "JSON file to view" }
      ]
    },
    {
      "namespace": "fx",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to fx CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "fx",
        "passthrough": true,
        "missingDependencyHelp": "Install fx: brew install fx"
      },
      "args": []
    }
  ]
}
