{
  "name": "fubectl",
  "version": "0.1.0",
  "description": "Reduced kubectl interactions wrapper",
  "source": "https://github.com/kubermatic/fubectl",
  "checks": [
    {
      "type": "binary",
      "name": "fubectl"
    }
  ],
  "install_guidance": {
    "plugin": "fubectl",
    "binary": "fubectl",
    "check": "which fubectl",
    "install_steps": [
      "brew install fubectl",
      "Verify: fubectl --version",
      "supercli plugins install ./plugins/fubectl --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "fubectl",
      "resource": "self",
      "action": "version",
      "description": "Print fubectl version",
      "adapter": "process",
      "adapterConfig": {
        "command": "fubectl",
        "missingDependencyHelp": "Install fubectl: brew install fubectl",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "fubectl",
      "resource": "resource",
      "action": "get",
      "description": "get resource via fubectl",
      "adapter": "process",
      "adapterConfig": {
        "command": "fubectl",
        "missingDependencyHelp": "Install fubectl: brew install fubectl",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "fubectl",
      "resource": "resource",
      "action": "describe",
      "description": "describe resource via fubectl",
      "adapter": "process",
      "adapterConfig": {
        "command": "fubectl",
        "missingDependencyHelp": "Install fubectl: brew install fubectl",
        "baseArgs": [
          "describe"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "fubectl",
      "resource": "_",
      "action": "_",
      "description": "_ _ via fubectl",
      "adapter": "process",
      "adapterConfig": {
        "command": "fubectl",
        "missingDependencyHelp": "Install fubectl: brew install fubectl",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}