{
  "name": "clean-css-cli",
  "version": "0.1.0",
  "description": "CSS minifier and optimizer CLI",
  "source": "https://github.com/clean-css/clean-css-cli",
  "checks": [
    {
      "type": "binary",
      "name": "cleancss"
    }
  ],
  "install_guidance": {
    "plugin": "clean-css-cli",
    "binary": "cleancss",
    "check": "which cleancss",
    "install_steps": [
      "npm install -g clean-css-cli",
      "Verify: cleancss --version",
      "supercli plugins install ./plugins/clean-css-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "clean-css-cli",
      "resource": "self",
      "action": "version",
      "description": "Print clean-css-cli version",
      "adapter": "process",
      "adapterConfig": {
        "command": "cleancss",
        "missingDependencyHelp": "Install clean-css-cli: npm install -g clean-css-cli",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "clean-css-cli",
      "resource": "file",
      "action": "minify",
      "description": "minify file via cleancss",
      "adapter": "process",
      "adapterConfig": {
        "command": "cleancss",
        "missingDependencyHelp": "Install clean-css-cli: npm install -g clean-css-cli",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "clean-css-cli",
      "resource": "_",
      "action": "_",
      "description": "_ _ via cleancss",
      "adapter": "process",
      "adapterConfig": {
        "command": "cleancss",
        "missingDependencyHelp": "Install clean-css-cli: npm install -g clean-css-cli",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}