{
  "name": "gql",
  "version": "0.1.0",
  "description": "GraphQL schema and query tool for the command line",
  "source": "https://github.com/graphql-editor/gql",
  "checks": [
    {
      "type": "binary",
      "name": "gql"
    }
  ],
  "install_guidance": {
    "plugin": "gql",
    "binary": "gql",
    "check": "which gql",
    "install_steps": [
      "go install github.com/graphql-editor/gql@latest",
      "Verify: gql --version",
      "supercli plugins install ./plugins/gql --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "gql",
      "resource": "self",
      "action": "version",
      "description": "Print gql version",
      "adapter": "process",
      "adapterConfig": {
        "command": "gql",
        "missingDependencyHelp": "Install gql: go install github.com/graphql-editor/gql@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "gql",
      "resource": "schema",
      "action": "validate",
      "description": "validate schema via gql",
      "adapter": "process",
      "adapterConfig": {
        "command": "gql",
        "missingDependencyHelp": "Install gql: go install github.com/graphql-editor/gql@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "gql",
      "resource": "query",
      "action": "execute",
      "description": "execute query via gql",
      "adapter": "process",
      "adapterConfig": {
        "command": "gql",
        "missingDependencyHelp": "Install gql: go install github.com/graphql-editor/gql@latest",
        "baseArgs": [
          "query"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "gql",
      "resource": "_",
      "action": "_",
      "description": "_ _ via gql",
      "adapter": "process",
      "adapterConfig": {
        "command": "gql",
        "missingDependencyHelp": "Install gql: go install github.com/graphql-editor/gql@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}