{
  "name": "bafi",
  "version": "0.1.0",
  "description": "Command line tool for formatting and beautifying text output",
  "source": "https://github.com/mritd/bafi",
  "checks": [
    {
      "type": "binary",
      "name": "bafi"
    }
  ],
  "install_guidance": {
    "plugin": "bafi",
    "binary": "bafi",
    "check": "which bafi",
    "install_steps": [
      "go install github.com/mritd/bafi@latest",
      "Verify: bafi --version",
      "supercli plugins install ./plugins/bafi --on-conflict replace --json"
    ]
  },
