{
  "name": "xq",
  "version": "0.1.0",
  "description": "Command-line XML and HTML beautifier and content extractor. Extract and format XML/HTML data with XPath queries.",
  "source": "https://github.com/sibprogrammer/xq",
  "checks": [
    { "type": "binary", "name": "xq" }
  ],
  "install_guidance": {
    "plugin": "xq",
    "binary": "xq",
    "check": "which xq",
    "install_steps": [
      "brew install xq",
      "Verify: xq --version",
      "supercli plugins install ./plugins/xq --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "xq",
      "resource": "xml",
      "action": "extract",
      "description": "Extract XML/HTML content",
      "adapter": "process",
      "adapterConfig": {
        "command": "xq",
        "passthrough": true,
        "missingDependencyHelp": "Install xq: brew install xq"
      },
      "args": [
        { "name": "file", "type": "string", "description": "XML/HTML file" },
        { "name": "--xpath", "type": "string", "description": "XPath query" },
        { "name": "--pretty", "type": "boolean", "description": "Pretty print output" },
        { "name": "--color", "type": "boolean", "description": "Colorize output" }
      ]
    },
    {
      "namespace": "xq",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to xq CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "xq",
        "passthrough": true,
        "missingDependencyHelp": "Install xq: brew install xq"
      },
      "args": []
    }
  ]
}
