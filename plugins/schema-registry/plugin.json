{
  "name": "schema-registry",
  "version": "0.1.0",
  "description": "Command line tool for managing Kafka schema registries",
  "source": "https://github.com/lensesio/schema-registry",
  "checks": [
    {
      "type": "binary",
      "name": "schema-registry"
    }
  ],
  "install_guidance": {
    "plugin": "schema-registry",
    "binary": "schema-registry",
    "check": "which schema-registry",
    "install_steps": [
      "brew install lensesio/tap/schema-registry",
      "Verify: schema-registry --version",
      "supercli plugins install ./plugins/schema-registry --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "schema-registry",
      "resource": "self",
      "action": "version",
      "description": "Print schema-registry version",
      "adapter": "process",
      "adapterConfig": {
        "command": "schema-registry",
        "missingDependencyHelp": "Install schema-registry: brew install lensesio/tap/schema-registry",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "schema-registry",
      "resource": "schema",
      "action": "register",
      "description": "register schema via schema-registry",
      "adapter": "process",
      "adapterConfig": {
        "command": "schema-registry",
        "missingDependencyHelp": "Install schema-registry: brew install lensesio/tap/schema-registry",
        "baseArgs": [
          "register"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "schema-registry",
      "resource": "schema",
      "action": "list",
      "description": "list schema via schema-registry",
      "adapter": "process",
      "adapterConfig": {
        "command": "schema-registry",
        "missingDependencyHelp": "Install schema-registry: brew install lensesio/tap/schema-registry",
        "baseArgs": [
          "list"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "schema-registry",
      "resource": "schema",
      "action": "delete",
      "description": "delete schema via schema-registry",
      "adapter": "process",
      "adapterConfig": {
        "command": "schema-registry",
        "missingDependencyHelp": "Install schema-registry: brew install lensesio/tap/schema-registry",
        "baseArgs": [
          "delete"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "schema-registry",
      "resource": "compatibility",
      "action": "check",
      "description": "check compatibility via schema-registry",
      "adapter": "process",
      "adapterConfig": {
        "command": "schema-registry",
        "missingDependencyHelp": "Install schema-registry: brew install lensesio/tap/schema-registry",
        "baseArgs": [
          "compatibility"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "schema-registry",
      "resource": "_",
      "action": "_",
      "description": "_ _ via schema-registry",
      "adapter": "process",
      "adapterConfig": {
        "command": "schema-registry",
        "missingDependencyHelp": "Install schema-registry: brew install lensesio/tap/schema-registry",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}