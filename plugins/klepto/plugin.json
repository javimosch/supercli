{
  "name": "klepto",
  "version": "0.1.0",
  "description": "Tool for copying and anonymizing database data",
  "source": "https://github.com/hellofresh/klepto",
  "checks": [
    {
      "type": "binary",
      "name": "klepto"
    }
  ],
  "install_guidance": {
    "plugin": "klepto",
    "binary": "klepto",
    "check": "which klepto",
    "install_steps": [
      "go install github.com/hellofresh/klepto@latest",
      "Verify: klepto --version",
      "supercli plugins install ./plugins/klepto --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "klepto",
      "resource": "self",
      "action": "version",
      "description": "Print klepto version",
      "adapter": "process",
      "adapterConfig": {
        "command": "klepto",
        "missingDependencyHelp": "Install klepto: go install github.com/hellofresh/klepto@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "klepto",
      "resource": "database",
      "action": "dump",
      "description": "dump database via klepto",
      "adapter": "process",
      "adapterConfig": {
        "command": "klepto",
        "missingDependencyHelp": "Install klepto: go install github.com/hellofresh/klepto@latest",
        "baseArgs": [
          "dump"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
