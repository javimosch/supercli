{
  "plugin": "nxv",
  "binary": "nxv",
  "check": "which nxv",
  "install_steps": [
    "curl -fsSL https://raw.githubusercontent.com/utensils/nxv/main/install.sh | sh",
    "Verify: nxv --version",
    "supercli plugins install ./plugins/nxv --on-conflict replace --json"
  ],
  "note": "Also available via cargo install nxv, or nix run github:utensils/nxv"
}
