{
  "name": "enc",
  "version": "0.1.0",
  "description": "Simple encryption and decryption CLI tool",
  "source": "https://github.com/life4/enc",
  "checks": [
    {
      "type": "binary",
      "name": "enc"
    }
  ],
  "install_guidance": {
    "plugin": "enc",
    "binary": "enc",
    "check": "which enc",
    "install_steps": [
      "go install github.com/life4/enc/cmd/enc@latest",
      "Verify: enc --version",
      "supercli plugins install ./plugins/enc --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "enc",
      "resource": "self",
      "action": "version",
      "description": "Print enc version",
      "adapter": "process",
      "adapterConfig": {
        "command": "enc",
        "missingDependencyHelp": "Install enc: go install github.com/life4/enc/cmd/enc@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "enc",
      "resource": "file",
      "action": "encrypt",
      "description": "encrypt file via enc",
      "adapter": "process",
      "adapterConfig": {
        "command": "enc",
        "missingDependencyHelp": "Install enc: go install github.com/life4/enc/cmd/enc@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "enc",
      "resource": "file",
      "action": "decrypt",
      "description": "decrypt file via enc",
      "adapter": "process",
      "adapterConfig": {
        "command": "enc",
        "missingDependencyHelp": "Install enc: go install github.com/life4/enc/cmd/enc@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "enc",
      "resource": "_",
      "action": "_",
      "description": "_ _ via enc",
      "adapter": "process",
      "adapterConfig": {
        "command": "enc",
        "missingDependencyHelp": "Install enc: go install github.com/life4/enc/cmd/enc@latest",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}