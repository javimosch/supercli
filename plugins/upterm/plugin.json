{
  "name": "upterm",
  "version": "0.1.0",
  "description": "Secure terminal sharing with end-to-end encryption",
  "source": "https://github.com/owenthereal/upterm",
  "checks": [
    {
      "type": "binary",
      "name": "upterm"
    }
  ],
  "install_guidance": {
    "plugin": "upterm",
    "binary": "upterm",
    "check": "which upterm",
    "install_steps": [
      "brew install owenthereal/upterm/upterm",
      "Verify: upterm --version",
      "supercli plugins install ./plugins/upterm --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "upterm",
      "resource": "self",
      "action": "version",
      "description": "Print upterm version",
      "adapter": "process",
      "adapterConfig": {
        "command": "upterm",
        "missingDependencyHelp": "Install upterm: brew install owenthereal/upterm/upterm",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "upterm",
      "resource": "host",
      "action": "start",
      "description": "start host via upterm",
      "adapter": "process",
      "adapterConfig": {
        "command": "upterm",
        "missingDependencyHelp": "Install upterm: brew install owenthereal/upterm/upterm",
        "baseArgs": [
          "host"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "upterm",
      "resource": "client",
      "action": "join",
      "description": "join client via upterm",
      "adapter": "process",
      "adapterConfig": {
        "command": "upterm",
        "missingDependencyHelp": "Install upterm: brew install owenthereal/upterm/upterm",
        "baseArgs": [
          "client"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "upterm",
      "resource": "_",
      "action": "_",
      "description": "_ _ via upterm",
      "adapter": "process",
      "adapterConfig": {
        "command": "upterm",
        "missingDependencyHelp": "Install upterm: brew install owenthereal/upterm/upterm",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}