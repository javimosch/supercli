{
  "name": "splash",
  "version": "0.1.0",
  "description": "Add beautiful, adaptive colors to make logs easier to read",
  "source": "https://github.com/joshi4/splash",
  "checks": [
    { "type": "binary", "name": "splash" }
  ],
  "install_guidance": {
    "plugin": "splash",
    "binary": "splash",
    "check": "which splash",
    "install_steps": [
      "brew install joshi4/splash/splash",
      "Verify: splash --help",
      "supercli plugins install ./plugins/splash --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "splash",
      "resource": "self",
      "action": "version",
      "description": "Print splash help",
      "adapter": "process",
      "adapterConfig": {
        "command": "splash",
        "baseArgs": ["--help"],
        "missingDependencyHelp": "Install splash: brew install joshi4/splash/splash"
      },
      "args": []
    },
    {
      "namespace": "splash",
      "resource": "log",
      "action": "colorize",
      "description": "Colorize log output from stdin",
      "adapter": "process",
      "adapterConfig": {
        "command": "splash",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000,
        "missingDependencyHelp": "Install splash"
      },
      "args": []
    },
    {
      "namespace": "splash",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to splash CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "splash",
        "passthrough": true,
        "missingDependencyHelp": "Install splash"
      },
      "args": []
    }
  ]
}
