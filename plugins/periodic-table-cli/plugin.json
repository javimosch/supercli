{
  "name": "periodic-table-cli",
  "version": "0.1.0",
  "description": "Periodic table of elements in your terminal",
  "source": "https://github.com/spirometaxas/periodic-table-cli",
  "checks": [
    {
      "type": "binary",
      "name": "periodic-table"
    }
  ],
  "install_guidance": {
    "plugin": "periodic-table-cli",
    "binary": "periodic-table",
    "check": "which periodic-table",
    "install_steps": [
      "npm install -g periodic-table-cli",
      "Verify: periodic-table --version",
      "supercli plugins install ./plugins/periodic-table-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "periodic-table-cli",
      "resource": "self",
      "action": "version",
      "description": "Print periodic-table-cli version",
      "adapter": "process",
      "adapterConfig": {
        "command": "periodic-table",
        "missingDependencyHelp": "Install periodic-table-cli: npm install -g periodic-table-cli",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "periodic-table-cli",
      "resource": "element",
      "action": "lookup",
      "description": "lookup element via periodic-table",
      "adapter": "process",
      "adapterConfig": {
        "command": "periodic-table",
        "missingDependencyHelp": "Install periodic-table-cli: npm install -g periodic-table-cli",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "periodic-table-cli",
      "resource": "_",
      "action": "_",
      "description": "_ _ via periodic-table",
      "adapter": "process",
      "adapterConfig": {
        "command": "periodic-table",
        "missingDependencyHelp": "Install periodic-table-cli: npm install -g periodic-table-cli",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}