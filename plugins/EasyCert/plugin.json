{
  "name": "EasyCert",
  "version": "0.1.0",
  "description": "Simple tool for creating SSL/TLS certificates for development",
  "source": "https://github.com/deckarep/EasyCert",
  "checks": [
    {
      "type": "binary",
      "name": "easycert"
    }
  ],
  "install_guidance": {
    "plugin": "EasyCert",
    "binary": "easycert",
    "check": "which easycert",
    "install_steps": [
      "go install github.com/deckarep/EasyCert@latest",
      "Verify: easycert --version",
      "supercli plugins install ./plugins/EasyCert --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "EasyCert",
      "resource": "self",
      "action": "version",
      "description": "Print EasyCert version",
      "adapter": "process",
      "adapterConfig": {
        "command": "easycert",
        "missingDependencyHelp": "Install EasyCert: go install github.com/deckarep/EasyCert@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "EasyCert",
      "resource": "cert",
      "action": "create",
      "description": "create cert via easycert",
      "adapter": "process",
      "adapterConfig": {
        "command": "easycert",
        "missingDependencyHelp": "Install EasyCert: go install github.com/deckarep/EasyCert@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "EasyCert",
      "resource": "cert",
      "action": "verify",
      "description": "verify cert via easycert",
      "adapter": "process",
      "adapterConfig": {
        "command": "easycert",
        "missingDependencyHelp": "Install EasyCert: go install github.com/deckarep/EasyCert@latest",
        "baseArgs": [
          "--verify"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "EasyCert",
      "resource": "cert",
      "action": "renew",
      "description": "renew cert via easycert",
      "adapter": "process",
      "adapterConfig": {
        "command": "easycert",
        "missingDependencyHelp": "Install EasyCert: go install github.com/deckarep/EasyCert@latest",
        "baseArgs": [
          "--renew"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "EasyCert",
      "resource": "_",
      "action": "_",
      "description": "_ _ via easycert",
      "adapter": "process",
      "adapterConfig": {
        "command": "easycert",
        "missingDependencyHelp": "Install EasyCert: go install github.com/deckarep/EasyCert@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}