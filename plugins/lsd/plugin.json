{
  "name": "lsd",
  "version": "0.1.0",
  "description": "The next gen ls command. Modern ls with colors, icons, tree view, and git integration for a more visually appealing directory listing.",
  "source": "https://github.com/lsd-rs/lsd",
  "checks": [
    { "type": "binary", "name": "lsd" }
  ],
  "install_guidance": {
    "plugin": "lsd",
    "binary": "lsd",
    "check": "which lsd",
    "install_steps": [
      "brew install lsd",
      "Verify: lsd --version",
      "supercli plugins install ./plugins/lsd --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "lsd",
      "resource": "dir",
      "action": "list",
      "description": "List directory with icons and colors",
      "adapter": "process",
      "adapterConfig": {
        "command": "lsd",
        "baseArgs": [],
        "passthrough": true,
        "missingDependencyHelp": "Install lsd: brew install lsd"
      },
      "args": [
        { "name": "path", "type": "string", "description": "Directory path to list" },
        { "name": "--all", "type": "boolean", "description": "Show hidden files" },
        { "name": "--long", "type": "boolean", "description": "Long format with details" },
        { "name": "--tree", "type": "boolean", "description": "Tree view listing" },
        { "name": "--icons", "type": "boolean", "description": "Show file icons" }
      ]
    },
    {
      "namespace": "lsd",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to lsd CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "lsd",
        "passthrough": true,
        "missingDependencyHelp": "Install lsd: brew install lsd"
      },
      "args": []
    }
  ]
}
