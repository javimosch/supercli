{
  "name": "zx",
  "version": "0.1.0",
  "description": "A tool for writing better scripts. Write shell scripts in JavaScript/TypeScript with modern async/await syntax.",
  "source": "https://github.com/google/zx",
  "checks": [
    { "type": "binary", "name": "zx" }
  ],
  "install_guidance": {
    "plugin": "zx",
    "binary": "zx",
    "check": "which zx",
    "install_steps": [
      "npm install -g zx",
      "Verify: zx --version",
      "supercli plugins install ./plugins/zx --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "zx",
      "resource": "run",
      "action": "script",
      "description": "Run a zx script",
      "adapter": "process",
      "adapterConfig": {
        "command": "zx",
        "passthrough": true,
        "missingDependencyHelp": "Install zx: npm install -g zx"
      },
      "args": [
        { "name": "script", "type": "string", "description": "Script file to run" }
      ]
    },
    {
      "namespace": "zx",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to zx CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "zx",
        "passthrough": true,
        "missingDependencyHelp": "Install zx: npm install -g zx"
      },
      "args": []
    }
  ]
}
