{
  "name": "gojekyll",
  "version": "0.1.0",
  "description": "Fast Jekyll-compatible static site generator in Go",
  "source": "https://github.com/osteele/gojekyll",
  "checks": [
    {
      "type": "binary",
      "name": "gojekyll"
    }
  ],
  "install_guidance": {
    "plugin": "gojekyll",
    "binary": "gojekyll",
    "check": "which gojekyll",
    "install_steps": [
      "go install github.com/osteele/gojekyll@latest",
      "Verify: gojekyll --version",
      "supercli plugins install ./plugins/gojekyll --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "gojekyll",
      "resource": "self",
      "action": "version",
      "description": "Print gojekyll version",
      "adapter": "process",
      "adapterConfig": {
        "command": "gojekyll",
        "missingDependencyHelp": "Install gojekyll: go install github.com/osteele/gojekyll@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "gojekyll",
      "resource": "site",
      "action": "build",
      "description": "build site via gojekyll",
      "adapter": "process",
      "adapterConfig": {
        "command": "gojekyll",
        "missingDependencyHelp": "Install gojekyll: go install github.com/osteele/gojekyll@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "gojekyll",
      "resource": "site",
      "action": "serve",
      "description": "serve site via gojekyll",
      "adapter": "process",
      "adapterConfig": {
        "command": "gojekyll",
        "missingDependencyHelp": "Install gojekyll: go install github.com/osteele/gojekyll@latest",
        "baseArgs": [
          "serve"
        ],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "gojekyll",
      "resource": "site",
      "action": "drafts",
      "description": "drafts site via gojekyll",
      "adapter": "process",
      "adapterConfig": {
        "command": "gojekyll",
        "missingDependencyHelp": "Install gojekyll: go install github.com/osteele/gojekyll@latest",
        "baseArgs": [
          "drafts"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "gojekyll",
      "resource": "_",
      "action": "_",
      "description": "_ _ via gojekyll",
      "adapter": "process",
      "adapterConfig": {
        "command": "gojekyll",
        "missingDependencyHelp": "Install gojekyll: go install github.com/osteele/gojekyll@latest",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}