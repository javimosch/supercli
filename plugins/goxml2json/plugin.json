{
  "name": "goxml2json",
  "version": "0.1.0",
  "description": "Convert XML to JSON with a simple Go CLI",
  "source": "https://github.com/basgys/goxml2json",
  "checks": [
    {
      "type": "binary",
      "name": "goxml2json"
    }
  ],
  "install_guidance": {
    "plugin": "goxml2json",
    "binary": "goxml2json",
    "check": "which goxml2json",
    "install_steps": [
      "go install github.com/basgys/goxml2json/cmd/goxml2json@latest",
      "Verify: goxml2json --version",
      "supercli plugins install ./plugins/goxml2json --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "goxml2json",
      "resource": "self",
      "action": "version",
      "description": "Print goxml2json version",
      "adapter": "process",
      "adapterConfig": {
        "command": "goxml2json",
        "missingDependencyHelp": "Install goxml2json: go install github.com/basgys/goxml2json/cmd/goxml2json@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "goxml2json",
      "resource": "file",
      "action": "convert",
      "description": "convert file via goxml2json",
      "adapter": "process",
      "adapterConfig": {
        "command": "goxml2json",
        "missingDependencyHelp": "Install goxml2json: go install github.com/basgys/goxml2json/cmd/goxml2json@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "goxml2json",
      "resource": "_",
      "action": "_",
      "description": "_ _ via goxml2json",
      "adapter": "process",
      "adapterConfig": {
        "command": "goxml2json",
        "missingDependencyHelp": "Install goxml2json: go install github.com/basgys/goxml2json/cmd/goxml2json@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}