{
  "name": "nvidia_oc",
  "version": "0.1.0",
  "description": "NVIDIA GPU overclocking CLI for Linux using NVML",
  "source": "https://github.com/Dreaming-Codes/nvidia_oc",
  "checks": [
    { "type": "binary", "name": "nvidia_oc" }
  ],
  "install_guidance": {
    "plugin": "nvidia_oc",
    "binary": "nvidia_oc",
    "check": "which nvidia_oc",
    "install_steps": [
      "cargo install nvidia_oc",
      "Verify: nvidia_oc --help",
      "supercli plugins install ./plugins/nvidia_oc --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "nvidia_oc",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to nvidia_oc CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "nvidia_oc",
        "cwd": "invoke_cwd",
        "passthrough": true,
        "missingDependencyHelp": "Install nvidia_oc: cargo install nvidia_oc"
      },
      "args": []
    }
  ]
}
