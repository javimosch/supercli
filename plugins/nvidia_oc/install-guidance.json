{
  "plugin": "nvidia_oc",
  "binary": "nvidia_oc",
  "check": "which nvidia_oc",
  "install_steps": [
    "cargo install nvidia_oc",
    "Verify: nvidia_oc --help",
    "supercli plugins install ./plugins/nvidia_oc --on-conflict replace --json"
  ],
  "note": "nvidia_oc provides NVIDIA GPU overclocking on Linux"
}
