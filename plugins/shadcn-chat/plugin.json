{
  "name": "shadcn-chat",
  "version": "0.1.0",
  "description": "CLI for adding customizable and re-usable chat components to your applications",
  "source": "https://github.com/jakobhoeg/shadcn-chat",
  "checks": [
    {
      "type": "binary",
      "name": "shadcn-chat"
    }
  ],
  "install_guidance": {
    "plugin": "shadcn-chat",
    "binary": "shadcn-chat",
    "check": "which shadcn-chat",
    "install_steps": [
      "npm install -g shadcn-chat",
      "Verify: shadcn-chat --version",
      "supercli plugins install ./plugins/shadcn-chat --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "shadcn-chat",
      "resource": "self",
      "action": "version",
      "description": "Print shadcn-chat version",
      "adapter": "process",
      "adapterConfig": {
        "command": "shadcn-chat",
        "missingDependencyHelp": "Install shadcn-chat: npm install -g shadcn-chat",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "shadcn-chat",
      "resource": "component",
      "action": "add",
      "description": "add component via shadcn-chat",
      "adapter": "process",
      "adapterConfig": {
        "command": "shadcn-chat",
        "missingDependencyHelp": "Install shadcn-chat: npm install -g shadcn-chat",
        "baseArgs": [
          "add"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "shadcn-chat",
      "resource": "component",
      "action": "list",
      "description": "list component via shadcn-chat",
      "adapter": "process",
      "adapterConfig": {
        "command": "shadcn-chat",
        "missingDependencyHelp": "Install shadcn-chat: npm install -g shadcn-chat",
        "baseArgs": [
          "list"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "shadcn-chat",
      "resource": "component",
      "action": "remove",
      "description": "remove component via shadcn-chat",
      "adapter": "process",
      "adapterConfig": {
        "command": "shadcn-chat",
        "missingDependencyHelp": "Install shadcn-chat: npm install -g shadcn-chat",
        "baseArgs": [
          "remove"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "shadcn-chat",
      "resource": "config",
      "action": "init",
      "description": "init config via shadcn-chat",
      "adapter": "process",
      "adapterConfig": {
        "command": "shadcn-chat",
        "missingDependencyHelp": "Install shadcn-chat: npm install -g shadcn-chat",
        "baseArgs": [
          "init"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "shadcn-chat",
      "resource": "config",
      "action": "show",
      "description": "show config via shadcn-chat",
      "adapter": "process",
      "adapterConfig": {
        "command": "shadcn-chat",
        "missingDependencyHelp": "Install shadcn-chat: npm install -g shadcn-chat",
        "baseArgs": [
          "--config"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "shadcn-chat",
      "resource": "_",
      "action": "_",
      "description": "_ _ via shadcn-chat",
      "adapter": "process",
      "adapterConfig": {
        "command": "shadcn-chat",
        "missingDependencyHelp": "Install shadcn-chat: npm install -g shadcn-chat",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}