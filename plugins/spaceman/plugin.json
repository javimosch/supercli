{
  "name": "spaceman",
  "version": "0.1.0",
  "description": "A gRPC client from another world for testing and exploring gRPC services",
  "source": "https://github.com/eliaperantoni/spaceman",
  "checks": [
    {
      "type": "binary",
      "name": "spaceman"
    }
  ],
  "install_guidance": {
    "plugin": "spaceman",
    "binary": "spaceman",
    "check": "which spaceman",
    "install_steps": [
      "cargo install spaceman",
      "Verify: spaceman --version",
      "supercli plugins install ./plugins/spaceman --on-conflict replace --json"
    ]
  },
