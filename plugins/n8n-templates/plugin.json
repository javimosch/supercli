{
  "name": "n8n-templates",
  "version": "0.1.0",
  "description": "Discover and browse 280+ free n8n automation templates from the awesome-n8n-templates repository",
  "source": "https://github.com/enescingoz/awesome-n8n-templates",
  "checks": [
    { "type": "binary", "name": "gh" }
  ],
  "install_guidance": {
    "plugin": "n8n-templates",
    "binary": "gh",
    "check": "which gh",
    "install_steps": [
      "Install GitHub CLI: https://cli.github.com/",
      "Authenticate: gh auth login",
      "supercli plugins install ./plugins/n8n-templates --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "n8n-templates",
      "resource": "repo",
      "action": "clone",
      "description": "Clone the awesome-n8n-templates repository",
      "adapter": "process",
      "adapterConfig": {
        "command": "gh",
        "baseArgs": ["repo", "clone", "enescingoz/awesome-n8n-templates"],
        "cwd": "invoke_cwd",
        "missingDependencyHelp": "Install GitHub CLI: https://cli.github.com/"
      },
      "args": [
        { "name": "directory", "type": "string", "required": false, "description": "Target directory name (default: awesome-n8n-templates)" }
      ]
    },
    {
      "namespace": "n8n-templates",
      "resource": "repo",
      "action": "browse",
      "description": "Open the awesome-n8n-templates repository in browser",
      "adapter": "process",
      "adapterConfig": {
        "command": "gh",
        "baseArgs": ["repo", "view", "enescingoz/awesome-n8n-templates", "--web"],
        "cwd": "invoke_cwd",
        "missingDependencyHelp": "Install GitHub CLI: https://cli.github.com/"
      },
      "args": []
    },
    {
      "namespace": "n8n-templates",
      "resource": "templates",
      "action": "list",
      "description": "List available n8n template categories",
      "adapter": "process",
      "adapterConfig": {
        "command": "gh",
        "baseArgs": ["repo", "view", "enescingoz/awesome-n8n-templates", "--web"],
        "cwd": "invoke_cwd",
        "missingDependencyHelp": "Install GitHub CLI: https://cli.github.com/"
      },
      "args": []
    },
    {
      "namespace": "n8n-templates",
      "resource": "n8n",
      "action": "signup",
      "description": "Open n8n signup page",
      "adapter": "process",
      "adapterConfig": {
        "command": "gh",
        "baseArgs": ["repo", "view", "enescingoz/awesome-n8n-templates", "--web"],
        "cwd": "invoke_cwd",
        "missingDependencyHelp": "Install GitHub CLI: https://cli.github.com/"
      },
      "args": []
    }
  ]
}
