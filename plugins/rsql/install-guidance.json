{
  "plugin": "rsql",
  "binary": "rsql",
  "check": "which rsql",
  "install_steps": [
    "cargo install rsql_cli",
    "Verify: rsql --version",
    "supercli plugins install ./plugins/rsql --on-conflict replace --json"
  ],
  "note": "Package name on crates.io is 'rsql_cli'. Also available via homebrew: brew install rsql."
}
