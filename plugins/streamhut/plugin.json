{
  "name": "streamhut",
  "version": "0.1.0",
  "description": "Real-time stream sharing over WebSockets",
  "source": "https://github.com/miguelmota/streamhut",
  "checks": [
    {
      "type": "binary",
      "name": "streamhut"
    }
  ],
  "install_guidance": {
    "plugin": "streamhut",
    "binary": "streamhut",
    "check": "which streamhut",
    "install_steps": [
      "npm install -g streamhut",
      "Verify: streamhut --version",
      "supercli plugins install ./plugins/streamhut --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "streamhut",
      "resource": "self",
      "action": "version",
      "description": "Print streamhut version",
      "adapter": "process",
      "adapterConfig": {
        "command": "streamhut",
        "missingDependencyHelp": "Install streamhut: npm install -g streamhut",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "streamhut",
      "resource": "stream",
      "action": "share",
      "description": "share stream via streamhut",
      "adapter": "process",
      "adapterConfig": {
        "command": "streamhut",
        "missingDependencyHelp": "Install streamhut: npm install -g streamhut",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "streamhut",
      "resource": "_",
      "action": "_",
      "description": "_ _ via streamhut",
      "adapter": "process",
      "adapterConfig": {
        "command": "streamhut",
        "missingDependencyHelp": "Install streamhut: npm install -g streamhut",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}