{
  "name": "commit-and-tag-version",
  "version": "0.1.0",
  "description": "Automate versioning and CHANGELOG generation",
  "source": "https://github.com/absolute-version/commit-and-tag-version",
  "checks": [
    {
      "type": "binary",
      "name": "commit-and-tag-version"
    }
  ],
  "install_guidance": {
    "plugin": "commit-and-tag-version",
    "binary": "commit-and-tag-version",
    "check": "which commit-and-tag-version",
    "install_steps": [
      "npm install -g commit-and-tag-version",
      "Verify: commit-and-tag-version --version",
      "supercli plugins install ./plugins/commit-and-tag-version --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "commit-and-tag-version",
      "resource": "self",
      "action": "version",
      "description": "Print commit-and-tag-version version",
      "adapter": "process",
      "adapterConfig": {
        "command": "commit-and-tag-version",
        "missingDependencyHelp": "Install commit-and-tag-version: npm install -g commit-and-tag-version",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "commit-and-tag-version",
      "resource": "version",
      "action": "bump",
      "description": "bump version via commit-and-tag-version",
      "adapter": "process",
      "adapterConfig": {
        "command": "commit-and-tag-version",
        "missingDependencyHelp": "Install commit-and-tag-version: npm install -g commit-and-tag-version",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "commit-and-tag-version",
      "resource": "_",
      "action": "_",
      "description": "_ _ via commit-and-tag-version",
      "adapter": "process",
      "adapterConfig": {
        "command": "commit-and-tag-version",
        "missingDependencyHelp": "Install commit-and-tag-version: npm install -g commit-and-tag-version",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}