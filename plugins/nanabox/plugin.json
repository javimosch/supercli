{
  "name": "nanabox",
  "version": "0.1.0",
  "description": "Local development environment and deployment platform",
  "source": "https://github.com/nanobox-io/nanobox",
  "checks": [
    {
      "type": "binary",
      "name": "nanobox"
    }
  ],
  "install_guidance": {
    "plugin": "nanabox",
    "binary": "nanobox",
    "check": "which nanobox",
    "install_steps": [
      "brew install nanobox",
      "Verify: nanobox --version",
      "supercli plugins install ./plugins/nanabox --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "nanabox",
      "resource": "self",
      "action": "version",
      "description": "Print nanabox version",
      "adapter": "process",
      "adapterConfig": {
        "command": "nanobox",
        "missingDependencyHelp": "Install nanabox: brew install nanobox",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "nanabox",
      "resource": "app",
      "action": "run",
      "description": "run app via nanobox",
      "adapter": "process",
      "adapterConfig": {
        "command": "nanobox",
        "missingDependencyHelp": "Install nanabox: brew install nanobox",
        "baseArgs": [
          "run"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "nanabox",
      "resource": "app",
      "action": "deploy",
      "description": "deploy app via nanobox",
      "adapter": "process",
      "adapterConfig": {
        "command": "nanobox",
        "missingDependencyHelp": "Install nanabox: brew install nanobox",
        "baseArgs": [
          "deploy"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "nanabox",
      "resource": "_",
      "action": "_",
      "description": "_ _ via nanobox",
      "adapter": "process",
      "adapterConfig": {
        "command": "nanobox",
        "missingDependencyHelp": "Install nanabox: brew install nanobox",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}