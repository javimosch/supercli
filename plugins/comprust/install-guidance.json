{
  "plugin": "comprust",
  "binary": "comprust",
  "check": "which comprust",
  "install_steps": [
    "cargo install https://github.com/karim-w/comprust",
    "Verify: comprust --version",
    "supercli plugins install ./plugins/comprust --on-conflict replace --json"
  ],
  "note": "Simple installation via cargo. Compresses images with configurable quality (0.0-100.0) and size factor (0.0-1.0)."
}
