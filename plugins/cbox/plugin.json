          "list"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "cbox",
      "resource": "output",
      "action": "set",
      "description": "set output via cbox",
      "adapter": "process",
      "adapterConfig": {
        "command": "cbox",
        "missingDependencyHelp": "Install cbox: pip install cbox",
        "baseArgs": [
          "--output"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "cbox",
      "resource": "config",
