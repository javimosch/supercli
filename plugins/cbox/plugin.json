{
  "name": "cbox",
  "version": "0.1.0",
  "description": "Convert any Python function to unix-style command with argument parsing",
  "source": "https://github.com/shmuelamar/cbox",
  "checks": [
    {
      "type": "binary",
      "name": "cbox"
    }
  ],
  "install_guidance": {
    "plugin": "cbox",
    "binary": "cbox",
    "check": "which cbox",
    "install_steps": [
      "pip install cbox",
      "Verify: cbox --version",
      "supercli plugins install ./plugins/cbox --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "cbox",
      "resource": "self",
      "action": "version",
      "description": "Print cbox version",
      "adapter": "process",
      "adapterConfig": {
        "command": "cbox",
        "missingDependencyHelp": "Install cbox: pip install cbox",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "cbox",
      "resource": "function",
      "action": "convert",
      "description": "convert function via cbox",
      "adapter": "process",
      "adapterConfig": {
        "command": "cbox",
        "missingDependencyHelp": "Install cbox: pip install cbox",
        "baseArgs": [
          "convert"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "cbox",
      "resource": "function",
      "action": "list",
      "description": "list function via cbox",
      "adapter": "process",
      "adapterConfig": {
        "command": "cbox",
        "missingDependencyHelp": "Install cbox: pip install cbox",
