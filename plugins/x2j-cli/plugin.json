{
  "name": "x2j-cli",
  "version": "0.1.0",
  "description": "Node.js command line script to convert XML input into JSON output",
  "source": "https://github.com/lmammino/x2j-cli",
  "checks": [
    { "type": "binary", "name": "x2j" }
  ],
  "install_guidance": {
    "plugin": "x2j-cli",
    "binary": "x2j",
    "check": "which x2j",
    "install_steps": [
      "npm install --global x2j-cli",
      "Verify: x2j --help",
      "supercli plugins install ./plugins/x2j-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "x2j-cli",
      "resource": "file",
      "action": "convert",
      "description": "Convert XML to JSON",
      "adapter": "process",
      "adapterConfig": {
        "command": "x2j",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 60000,
        "missingDependencyHelp": "Install x2j-cli: npm install --global x2j-cli"
      },
      "args": [
        { "name": "input", "type": "string", "required": false, "description": "XML input (read from stdin if not provided)" }
      ]
    },
    {
      "namespace": "x2j-cli",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to x2j CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "x2j",
        "passthrough": true,
        "missingDependencyHelp": "Install x2j-cli: npm install --global x2j-cli"
      },
      "args": []
    }
  ]
}
