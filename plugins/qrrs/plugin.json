{
  "name": "qrrs",
  "version": "0.1.0",
  "description": "CLI QR code generator and reader written in Rust",
  "source": "https://github.com/Lenivaya/qrrs",
  "checks": [
    {
      "type": "binary",
      "name": "qrrs"
    }
  ],
  "install_guidance": {
    "plugin": "qrrs",
    "binary": "qrrs",
    "check": "which qrrs",
    "install_steps": [
      "cargo install qrrs",
      "Verify: qrrs --version",
      "supercli plugins install ./plugins/qrrs --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
