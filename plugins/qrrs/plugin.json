      "namespace": "qrrs",
      "resource": "self",
      "action": "version",
      "description": "Print qrrs version",
      "adapter": "process",
      "adapterConfig": {
        "command": "qrrs",
        "missingDependencyHelp": "Install qrrs: cargo install qrrs",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "qrrs",
      "resource": "qr",
      "action": "generate",
      "description": "generate qr via qrrs",
      "adapter": "process",
      "adapterConfig": {
        "command": "qrrs",
        "missingDependencyHelp": "Install qrrs: cargo install qrrs",
        "baseArgs": [
          "generate"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
