{
  "name": "summarize",
  "version": "0.1.0",
  "description": "Fast text summarization CLI",
  "source": "https://github.com/steipete/summarize",
  "checks": [
    {
      "type": "binary",
      "name": "summarize"
    }
  ],
  "install_guidance": {
    "plugin": "summarize",
    "binary": "summarize",
    "check": "which summarize",
    "install_steps": [
      "npm install -g @steipete/summarize",
      "Verify: summarize --version",
      "supercli plugins install ./plugins/summarize --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "summarize",
      "resource": "self",
      "action": "version",
      "description": "Print summarize version",
      "adapter": "process",
      "adapterConfig": {
        "command": "summarize",
        "missingDependencyHelp": "Install summarize: npm install -g @steipete/summarize",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "summarize",
      "resource": "text",
      "action": "summarize",
      "description": "summarize text via summarize",
      "adapter": "process",
      "adapterConfig": {
        "command": "summarize",
        "missingDependencyHelp": "Install summarize: npm install -g @steipete/summarize",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "summarize",
      "resource": "_",
      "action": "_",
      "description": "_ _ via summarize",
      "adapter": "process",
      "adapterConfig": {
        "command": "summarize",
        "missingDependencyHelp": "Install summarize: npm install -g @steipete/summarize",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}