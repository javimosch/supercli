{
  "name": "craftql",
  "version": "0.1.0",
  "description": "CLI tool to visualize GraphQL schemas and output graph data structures",
  "source": "https://github.com/yamafaktory/craftql",
  "checks": [
    {
      "type": "binary",
      "name": "craftql"
    }
  ],
  "install_guidance": {
    "plugin": "craftql",
    "binary": "craftql",
    "check": "which craftql",
    "install_steps": [
      "cargo install craftql",
      "Verify: craftql --version",
      "supercli plugins install ./plugins/craftql --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "craftql",
      "resource": "self",
      "action": "version",
      "description": "Print craftql version",
      "adapter": "process",
      "adapterConfig": {
        "command": "craftql",
        "missingDependencyHelp": "Install craftql: cargo install craftql",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "craftql",
      "resource": "schema",
      "action": "visualize",
      "description": "visualize schema via craftql",
      "adapter": "process",
      "adapterConfig": {
        "command": "craftql",
        "missingDependencyHelp": "Install craftql: cargo install craftql",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "craftql",
      "resource": "schema",
      "action": "output",
      "description": "output schema via craftql",
      "adapter": "process",
      "adapterConfig": {
        "command": "craftql",
        "missingDependencyHelp": "Install craftql: cargo install craftql",
        "baseArgs": [
          "--output"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "craftql",
      "resource": "schema",
      "action": "dot",
      "description": "dot schema via craftql",
      "adapter": "process",
      "adapterConfig": {
        "command": "craftql",
        "missingDependencyHelp": "Install craftql: cargo install craftql",
        "baseArgs": [
          "--dot"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "craftql",
      "resource": "_",
      "action": "_",
