{
  "name": "corgi",
  "version": "0.1.0",
  "description": "Command line tool for project scaffolding and code generation",
  "source": "https://github.com/junyu-w/corgi",
  "checks": [
    {
      "type": "binary",
      "name": "corgi"
    }
  ],
  "install_guidance": {
    "plugin": "corgi",
    "binary": "corgi",
    "check": "which corgi",
    "install_steps": [
      "go install github.com/junyu-w/corgi@latest",
      "Verify: corgi --version",
      "supercli plugins install ./plugins/corgi --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "corgi",
      "resource": "self",
      "action": "version",
      "description": "Print corgi version",
      "adapter": "process",
      "adapterConfig": {
        "command": "corgi",
        "missingDependencyHelp": "Install corgi: go install github.com/junyu-w/corgi@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "corgi",
      "resource": "project",
      "action": "scaffold",
      "description": "scaffold project via corgi",
      "adapter": "process",
      "adapterConfig": {
        "command": "corgi",
        "missingDependencyHelp": "Install corgi: go install github.com/junyu-w/corgi@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "corgi",
      "resource": "project",
      "action": "init",
      "description": "init project via corgi",
      "adapter": "process",
      "adapterConfig": {
        "command": "corgi",
        "missingDependencyHelp": "Install corgi: go install github.com/junyu-w/corgi@latest",
        "baseArgs": [
          "init"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "corgi",
      "resource": "_",
      "action": "_",
      "description": "_ _ via corgi",
      "adapter": "process",
      "adapterConfig": {
        "command": "corgi",
        "missingDependencyHelp": "Install corgi: go install github.com/junyu-w/corgi@latest",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}