{
  "name": "scc",
  "version": "0.1.0",
  "description": "Sloc, Cloc and Code: A very fast accurate code counter with complexity calculations and COCOMO estimates written in pure Go. Count lines of code, complexity, and estimate effort.",
  "source": "https://github.com/boyter/scc",
  "checks": [
    { "type": "binary", "name": "scc" }
  ],
  "install_guidance": {
    "plugin": "scc",
    "binary": "scc",
    "check": "which scc",
    "install_steps": [
      "brew install scc",
      "Verify: scc --version",
      "supercli plugins install ./plugins/scc --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "scc",
      "resource": "code",
      "action": "count",
      "description": "Count lines of code and complexity",
      "adapter": "process",
      "adapterConfig": {
        "command": "scc",
        "passthrough": true,
        "missingDependencyHelp": "Install scc: brew install scc"
      },
      "args": [
        { "name": "paths", "type": "string", "description": "Paths to count" },
        { "name": "--by-file", "type": "boolean", "description": "Show results by file" },
        { "name": "--format", "type": "string", "description": "Output format (json, csv, html)" },
        { "name": "--complexity", "type": "boolean", "description": "Calculate complexity" },
        { "name": "--cocomo", "type": "boolean", "description": "COCOMO estimates" },
        { "name": "--exclude-dir", "type": "string", "description": "Exclude directories" }
      ]
    },
    {
      "namespace": "scc",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to scc CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "scc",
        "passthrough": true,
        "missingDependencyHelp": "Install scc: brew install scc"
      },
      "args": []
    }
  ]
}
