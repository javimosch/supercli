      "namespace": "mmdbctl",
      "resource": "self",
      "action": "version",
      "description": "Print mmdbctl version",
      "adapter": "process",
      "adapterConfig": {
        "command": "mmdbctl",
        "missingDependencyHelp": "Install mmdbctl: brew install ipinfo/tap/mmdbctl",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "mmdbctl",
      "resource": "db",
