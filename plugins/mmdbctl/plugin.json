{
  "name": "mmdbctl",
  "version": "0.1.0",
  "description": "MMDB file management CLI supporting various operations on MMDB database files",
  "source": "https://github.com/ipinfo/mmdbctl",
  "checks": [
    {
      "type": "binary",
      "name": "mmdbctl"
    }
  ],
  "install_guidance": {
    "plugin": "mmdbctl",
    "binary": "mmdbctl",
    "check": "which mmdbctl",
    "install_steps": [
      "brew install ipinfo/tap/mmdbctl",
      "Verify: mmdbctl --version",
      "supercli plugins install ./plugins/mmdbctl --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
