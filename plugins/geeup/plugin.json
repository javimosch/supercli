{
  "name": "geeup",
  "version": "0.1.0",
  "description": "Simple CLI for Google Earth Engine Uploads to manage cloud assets",
  "source": "https://github.com/samapriya/geeup",
  "checks": [
    {
      "type": "binary",
      "name": "geeup"
    }
  ],
  "install_guidance": {
    "plugin": "geeup",
    "binary": "geeup",
    "check": "which geeup",
    "install_steps": [
      "pip install geeup",
      "Verify: geeup --version",
      "supercli plugins install ./plugins/geeup --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "geeup",
      "resource": "self",
      "action": "version",
      "description": "Print geeup version",
      "adapter": "process",
      "adapterConfig": {
        "command": "geeup",
        "missingDependencyHelp": "Install geeup: pip install geeup",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "geeup",
      "resource": "asset",
      "action": "upload",
      "description": "upload asset via geeup",
      "adapter": "process",
      "adapterConfig": {
        "command": "geeup",
        "missingDependencyHelp": "Install geeup: pip install geeup",
        "baseArgs": [
          "upload"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
