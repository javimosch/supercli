      "resource": "self",
      "action": "version",
      "description": "Print jut version",
      "adapter": "process",
      "adapterConfig": {
        "command": "jut",
        "missingDependencyHelp": "Install jut: pip install jut",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "jut",
      "resource": "notebook",
      "action": "render",
      "description": "render notebook via jut",
      "adapter": "process",
      "adapterConfig": {
        "command": "jut",
        "missingDependencyHelp": "Install jut: pip install jut",
        "baseArgs": [
          "render"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
