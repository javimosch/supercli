{
  "name": "jut",
  "version": "0.1.0",
  "description": "Render Jupyter notebook in the terminal with text-based visualization",
  "source": "https://github.com/kracekumar/jut",
  "checks": [
    {
      "type": "binary",
      "name": "jut"
    }
  ],
  "install_guidance": {
    "plugin": "jut",
    "binary": "jut",
    "check": "which jut",
    "install_steps": [
      "pip install jut",
      "Verify: jut --version",
      "supercli plugins install ./plugins/jut --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
