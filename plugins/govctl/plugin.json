{
  "name": "govctl",
  "version": "0.1.0",
  "description": "A governance harness for AI coding — turn prompts and patches into RFCs, ADRs, work items, and guarded delivery",
  "source": "https://github.com/govctl-org/govctl",
  "checks": [
    { "type": "binary", "name": "govctl" }
  ],
  "install_guidance": {
    "plugin": "govctl",
    "binary": "govctl",
    "check": "which govctl",
    "install_steps": [
      "cargo install govctl",
      "Verify: govctl --version",
      "supercli plugins install ./plugins/govctl --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "govctl",
      "resource": "self",
      "action": "version",
      "description": "Print govctl version",
      "adapter": "process",
      "adapterConfig": {
        "command": "govctl",
        "baseArgs": ["--version"],
        "missingDependencyHelp": "Install govctl: cargo install govctl"
      },
      "args": []
    },
    {
      "namespace": "govctl",
      "resource": "rfc",
      "action": "new",
      "description": "Create a new RFC",
      "adapter": "process",
      "adapterConfig": {
        "command": "govctl",
        "baseArgs": ["rfc", "new"],
        "passthrough": true,
        "timeout_ms": 30000,
        "missingDependencyHelp": "Install govctl"
      },
      "args": []
    },
    {
      "namespace": "govctl",
      "resource": "adr",
      "action": "new",
      "description": "Create a new ADR",
      "adapter": "process",
      "adapterConfig": {
        "command": "govctl",
        "baseArgs": ["adr", "new"],
        "passthrough": true,
        "timeout_ms": 30000,
        "missingDependencyHelp": "Install govctl"
      },
      "args": []
    },
    {
      "namespace": "govctl",
      "resource": "work",
      "action": "new",
      "description": "Create a new work item",
      "adapter": "process",
      "adapterConfig": {
        "command": "govctl",
        "baseArgs": ["work", "new"],
        "passthrough": true,
        "timeout_ms": 30000,
        "missingDependencyHelp": "Install govctl"
      },
      "args": []
    },
    {
      "namespace": "govctl",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to govctl CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "govctl",
        "passthrough": true,
        "missingDependencyHelp": "Install govctl"
      },
      "args": []
    }
  ]
}
