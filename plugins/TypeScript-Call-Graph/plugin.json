{
  "name": "TypeScript-Call-Graph",
  "version": "0.1.0",
  "description": "Generate a call graph for TypeScript projects",
  "source": "https://github.com/whyboris/TypeScript-Call-Graph",
  "checks": [
    {
      "type": "binary",
      "name": "ts-call-graph"
    }
  ],
  "install_guidance": {
    "plugin": "TypeScript-Call-Graph",
    "binary": "ts-call-graph",
    "check": "which ts-call-graph",
    "install_steps": [
      "npm install -g typescript-call-graph",
      "Verify: ts-call-graph --version",
      "supercli plugins install ./plugins/TypeScript-Call-Graph --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "TypeScript-Call-Graph",
      "resource": "self",
      "action": "version",
      "description": "Print TypeScript-Call-Graph version",
      "adapter": "process",
      "adapterConfig": {
        "command": "ts-call-graph",
        "missingDependencyHelp": "Install TypeScript-Call-Graph: npm install -g typescript-call-graph",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "TypeScript-Call-Graph",
      "resource": "project",
      "action": "analyze",
      "description": "analyze project via ts-call-graph",
      "adapter": "process",
      "adapterConfig": {
        "command": "ts-call-graph",
        "missingDependencyHelp": "Install TypeScript-Call-Graph: npm install -g typescript-call-graph",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "TypeScript-Call-Graph",
      "resource": "_",
      "action": "_",
      "description": "_ _ via ts-call-graph",
      "adapter": "process",
      "adapterConfig": {
        "command": "ts-call-graph",
        "missingDependencyHelp": "Install TypeScript-Call-Graph: npm install -g typescript-call-graph",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}