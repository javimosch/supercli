{
  "name": "humanenv",
  "version": "0.2.0",
  "description": "Secure environment variable injection - secrets for humans only",
  "source": "https://github.com/javamosch/humanenv",
  "checks": [
    { "type": "binary", "name": "humanenv" }
  ],
  "install_guidance": {
    "plugin": "humanenv",
    "binary": "humanenv",
    "check": "which humanenv",
    "install_steps": [
      "npm install -g humanenv",
      "Verify: humanenv",
      "supercli plugins install ./plugins/humanenv --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "humanenv",
      "resource": "self",
      "action": "version",
      "description": "Print humanenv version and status",
      "adapter": "process",
      "adapterConfig": {
        "command": "humanenv",
        "baseArgs": ["--json"],
        "missingDependencyHelp": "Install humanenv: npm install -g humanenv"
      },
      "args": []
    },
    {
      "namespace": "humanenv",
      "resource": "local",
      "action": "init",
      "description": "Initialize local database for serverless mode",
      "adapter": "process",
      "adapterConfig": {
        "command": "humanenv",
        "baseArgs": ["local", "init", "--force"],
        "passthrough": true,
        "timeout_ms": 30000,
        "missingDependencyHelp": "Install humanenv: npm install -g humanenv"
      },
      "args": [
        { "name": "mnemonic", "type": "string", "required": false, "description": "12-word BIP39 mnemonic (optional, one will be generated)" },
        { "name": "force", "type": "boolean", "required": false, "description": "Reset existing database (default: false)" }
      ]
    },
    {
      "namespace": "humanenv",
      "resource": "local",
      "action": "get",
      "description": "Retrieve a secret from local database",
      "adapter": "process",
      "adapterConfig": {
        "command": "humanenv",
        "baseArgs": ["local", "get"],
        "parseJson": true,
        "positionalArgs": ["key"],
        "timeout_ms": 15000,
        "missingDependencyHelp": "Install humanenv: npm install -g humanenv"
      },
      "args": [
        { "name": "key", "type": "string", "required": true, "description": "Environment variable key to retrieve" }
      ]
    },
    {
      "namespace": "humanenv",
      "resource": "local",
      "action": "set",
      "description": "Set a secret in local database",
      "adapter": "process",
      "adapterConfig": {
        "command": "humanenv",
        "baseArgs": ["local", "set", "--force"],
        "parseJson": true,
        "positionalArgs": ["key", "value"],
        "timeout_ms": 15000,
        "missingDependencyHelp": "Install humanenv: npm install -g humanenv"
      },
      "args": [
        { "name": "key", "type": "string", "required": true, "description": "Environment variable key" },
        { "name": "value", "type": "string", "required": true, "description": "Environment variable value" }
      ]
    },
    {
      "namespace": "humanenv",
      "resource": "local",
      "action": "projects",
      "description": "List projects in local database",
      "adapter": "process",
      "adapterConfig": {
        "command": "humanenv",
        "baseArgs": ["local", "projects"],
        "passthrough": true,
        "parseJson": true,
        "timeout_ms": 15000,
        "missingDependencyHelp": "Install humanenv: npm install -g humanenv"
      },
      "args": []
    },
    {
      "namespace": "humanenv",
      "resource": "local",
      "action": "envs",
      "description": "List environment variables in local database",
      "adapter": "process",
      "adapterConfig": {
        "command": "humanenv",
        "baseArgs": ["local", "envs"],
        "passthrough": true,
        "parseJson": true,
        "timeout_ms": 15000,
        "missingDependencyHelp": "Install humanenv: npm install -g humanenv"
      },
      "args": []
    },
    {
      "namespace": "humanenv",
      "resource": "local",
      "action": "export",
      "description": "Export local database to file",
      "adapter": "process",
      "adapterConfig": {
        "command": "humanenv",
        "baseArgs": ["local", "export"],
        "parseJson": true,
        "positionalArgs": ["file"],
        "timeout_ms": 30000,
        "missingDependencyHelp": "Install humanenv: npm install -g humanenv"
      },
      "args": [
        { "name": "file", "type": "string", "required": true, "description": "Export file path" }
      ]
    },
    {
      "namespace": "humanenv",
      "resource": "local",
      "action": "import",
      "description": "Import database from file",
      "adapter": "process",
      "adapterConfig": {
        "command": "humanenv",
        "baseArgs": ["local", "import"],
        "parseJson": true,
        "positionalArgs": ["file"],
        "timeout_ms": 30000,
        "missingDependencyHelp": "Install humanenv: npm install -g humanenv"
      },
      "args": [
        { "name": "file", "type": "string", "required": true, "description": "Import file path" }
      ]
    },
    {
      "namespace": "humanenv",
      "resource": "env",
      "action": "get",
      "description": "Retrieve a single secret from the humanenv server (remote mode)",
      "adapter": "process",
      "adapterConfig": {
        "command": "humanenv",
        "baseArgs": ["get"],
        "passthrough": true,
        "parseJson": true,
        "timeout_ms": 15000,
        "missingDependencyHelp": "Install humanenv: npm install -g humanenv"
      },
      "args": [
        { "name": "key", "type": "string", "required": true, "description": "Environment variable key to retrieve" }
      ]
    },
    {
      "namespace": "humanenv",
      "resource": "env",
      "action": "set",
      "description": "Create or update a secret on the humanenv server (remote mode)",
      "adapter": "process",
      "adapterConfig": {
        "command": "humanenv",
        "baseArgs": ["set"],
        "passthrough": true,
        "parseJson": true,
        "timeout_ms": 15000,
        "missingDependencyHelp": "Install humanenv: npm install -g humanenv"
      },
      "args": [
        { "name": "key", "type": "string", "required": true, "description": "Environment variable key" },
        { "name": "value", "type": "string", "required": true, "description": "Environment variable value" }
      ]
    },
    {
      "namespace": "humanenv",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to humanenv CLI for auth, server, and advanced usage",
      "adapter": "process",
      "adapterConfig": {
        "command": "humanenv",
        "passthrough": true,
        "parseJson": true,
        "missingDependencyHelp": "Install humanenv: npm install -g humanenv"
      },
      "args": []
    }
  ]
}
