{
  "name": "webpalm",
  "version": "0.1.0",
  "description": "Web crawler and data mining tool",
  "source": "https://github.com/XORbit01/webpalm",
  "checks": [
    {
      "type": "binary",
      "name": "webpalm"
    }
  ],
  "install_guidance": {
    "plugin": "webpalm",
    "binary": "webpalm",
    "check": "which webpalm",
    "install_steps": [
      "go install github.com/XORbit01/webpalm@latest",
      "Verify: webpalm --version",
      "supercli plugins install ./plugins/webpalm --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "webpalm",
      "resource": "self",
      "action": "version",
      "description": "Print webpalm version",
      "adapter": "process",
      "adapterConfig": {
        "command": "webpalm",
        "missingDependencyHelp": "Install webpalm: go install github.com/XORbit01/webpalm@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "webpalm",
      "resource": "url",
      "action": "crawl",
      "description": "crawl url via webpalm",
      "adapter": "process",
      "adapterConfig": {
        "command": "webpalm",
        "missingDependencyHelp": "Install webpalm: go install github.com/XORbit01/webpalm@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "webpalm",
      "resource": "_",
      "action": "_",
      "description": "_ _ via webpalm",
      "adapter": "process",
      "adapterConfig": {
        "command": "webpalm",
        "missingDependencyHelp": "Install webpalm: go install github.com/XORbit01/webpalm@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}