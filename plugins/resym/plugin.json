{
  "name": "resym",
  "version": "0.1.0",
  "description": "Cross-platform tool to browse and extract C and C++ type declarations from PDB files",
  "source": "https://github.com/ergrelet/resym",
  "checks": [
    {
      "type": "binary",
      "name": "resym"
    }
  ],
  "install_guidance": {
    "plugin": "resym",
    "binary": "resym",
    "check": "which resym",
    "install_steps": [
      "cargo install resym",
      "Verify: resym --version",
      "supercli plugins install ./plugins/resym --on-conflict replace --json"
    ]
  },
