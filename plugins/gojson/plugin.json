{
  "name": "gojson",
  "version": "0.1.0",
  "description": "Automatically generate Go (golang) struct definitions from example JSON. Convert JSON to Go structs instantly.",
  "source": "https://github.com/ChimeraCoder/gojson",
  "checks": [
    { "type": "binary", "name": "gojson" }
  ],
  "install_guidance": {
    "plugin": "gojson",
    "binary": "gojson",
    "check": "which gojson",
    "install_steps": [
      "brew install gojson",
      "Verify: gojson --version",
      "supercli plugins install ./plugins/gojson --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "gojson",
      "resource": "json",
      "action": "convert",
      "description": "Convert JSON to Go struct",
      "adapter": "process",
      "adapterConfig": {
        "command": "gojson",
        "passthrough": true,
        "missingDependencyHelp": "Install gojson: brew install gojson"
      },
      "args": [
        { "name": "input", "type": "string", "description": "JSON input file or string" },
        { "name": "--name", "type": "string", "description": "Struct name" },
        { "name": "--output", "type": "string", "description": "Output file" },
        { "name": "--omitempty", "type": "boolean", "description": "Add omitempty tags" }
      ]
    },
    {
      "namespace": "gojson",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to gojson CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "gojson",
        "passthrough": true,
        "missingDependencyHelp": "Install gojson: brew install gojson"
      },
      "args": []
    }
  ]
}
