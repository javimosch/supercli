{
  "name": "Malvid",
  "version": "0.1.0",
  "description": "Component library documentation generator",
  "source": "https://github.com/Malvid/Malvid",
  "checks": [
    {
      "type": "binary",
      "name": "malvid"
    }
  ],
  "install_guidance": {
    "plugin": "Malvid",
    "binary": "malvid",
    "check": "which malvid",
    "install_steps": [
      "npm install -g malvid",
      "Verify: malvid --version",
      "supercli plugins install ./plugins/Malvid --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "Malvid",
      "resource": "self",
      "action": "version",
      "description": "Print Malvid version",
      "adapter": "process",
      "adapterConfig": {
        "command": "malvid",
        "missingDependencyHelp": "Install Malvid: npm install -g malvid",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "Malvid",
      "resource": "components",
      "action": "generate",
      "description": "generate components via malvid",
      "adapter": "process",
      "adapterConfig": {
        "command": "malvid",
        "missingDependencyHelp": "Install Malvid: npm install -g malvid",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "Malvid",
      "resource": "_",
      "action": "_",
      "description": "_ _ via malvid",
      "adapter": "process",
      "adapterConfig": {
        "command": "malvid",
        "missingDependencyHelp": "Install Malvid: npm install -g malvid",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}