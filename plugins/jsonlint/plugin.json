{
  "name": "jsonlint",
  "version": "0.1.0",
  "description": "A JSON parser and validator with a CLI. Validate JSON files, sort keys, and format JSON.",
  "source": "https://github.com/zaach/jsonlint",
  "checks": [
    { "type": "binary", "name": "jsonlint" }
  ],
  "install_guidance": {
    "plugin": "jsonlint",
    "binary": "jsonlint",
    "check": "which jsonlint",
    "install_steps": [
      "npm install -g jsonlint",
      "Verify: jsonlint --version",
      "supercli plugins install ./plugins/jsonlint --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "jsonlint",
      "resource": "validate",
      "action": "file",
      "description": "Validate JSON file",
      "adapter": "process",
      "adapterConfig": {
        "command": "jsonlint",
        "passthrough": true,
        "missingDependencyHelp": "Install jsonlint: npm install -g jsonlint"
      },
      "args": [
        { "name": "file", "type": "string", "description": "JSON file to validate" },
        { "name": "-s", "type": "boolean", "description": "Sort object keys" },
        { "name": "-i", "type": "boolean", "description": "In-place edit" }
      ]
    },
    {
      "namespace": "jsonlint",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to jsonlint CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "jsonlint",
        "passthrough": true,
        "missingDependencyHelp": "Install jsonlint: npm install -g jsonlint"
      },
      "args": []
    }
  ]
}
