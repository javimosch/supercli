{
  "name": "go-wkhtmltopdf",
  "version": "0.1.0",
  "description": "Convert HTML to PDF using wkhtmltopdf in Go",
  "source": "https://github.com/adrg/go-wkhtmltopdf",
  "checks": [
    {
      "type": "binary",
      "name": "wkhtmltopdf"
    }
  ],
  "install_guidance": {
    "plugin": "go-wkhtmltopdf",
    "binary": "wkhtmltopdf",
    "check": "which wkhtmltopdf",
    "install_steps": [
      "go install github.com/adrg/go-wkhtmltopdf/cmd/wkhtmltopdf@latest",
      "Verify: wkhtmltopdf --version",
      "supercli plugins install ./plugins/go-wkhtmltopdf --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "go-wkhtmltopdf",
      "resource": "self",
      "action": "version",
      "description": "Print go-wkhtmltopdf version",
      "adapter": "process",
      "adapterConfig": {
        "command": "wkhtmltopdf",
        "missingDependencyHelp": "Install go-wkhtmltopdf: go install github.com/adrg/go-wkhtmltopdf/cmd/wkhtmltopdf@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "go-wkhtmltopdf",
      "resource": "file",
      "action": "convert",
      "description": "convert file via wkhtmltopdf",
      "adapter": "process",
      "adapterConfig": {
        "command": "wkhtmltopdf",
        "missingDependencyHelp": "Install go-wkhtmltopdf: go install github.com/adrg/go-wkhtmltopdf/cmd/wkhtmltopdf@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "go-wkhtmltopdf",
      "resource": "_",
      "action": "_",
      "description": "_ _ via wkhtmltopdf",
      "adapter": "process",
      "adapterConfig": {
        "command": "wkhtmltopdf",
        "missingDependencyHelp": "Install go-wkhtmltopdf: go install github.com/adrg/go-wkhtmltopdf/cmd/wkhtmltopdf@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}