{
  "name": "apk-mitm",
  "version": "0.1.0",
  "description": "Prepare APKs for HTTPS inspection",
  "source": "https://github.com/niklashigi/apk-mitm",
  "checks": [
    {
      "type": "binary",
      "name": "apk-mitm"
    }
  ],
  "install_guidance": {
    "plugin": "apk-mitm",
    "binary": "apk-mitm",
    "check": "which apk-mitm",
    "install_steps": [
      "npm install -g apk-mitm",
      "Verify: apk-mitm --version",
      "supercli plugins install ./plugins/apk-mitm --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "apk-mitm",
      "resource": "self",
      "action": "version",
      "description": "Print apk-mitm version",
      "adapter": "process",
      "adapterConfig": {
        "command": "apk-mitm",
        "missingDependencyHelp": "Install apk-mitm: npm install -g apk-mitm",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "apk-mitm",
      "resource": "apk",
      "action": "patch",
      "description": "patch apk via apk-mitm",
      "adapter": "process",
      "adapterConfig": {
        "command": "apk-mitm",
        "missingDependencyHelp": "Install apk-mitm: npm install -g apk-mitm",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "apk-mitm",
      "resource": "_",
      "action": "_",
      "description": "_ _ via apk-mitm",
      "adapter": "process",
      "adapterConfig": {
        "command": "apk-mitm",
        "missingDependencyHelp": "Install apk-mitm: npm install -g apk-mitm",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}