{
  "name": "fandogh-cli",
  "version": "0.1.0",
  "description": "Fandogh CLI for managing cloud services and deployments",
  "source": "https://github.com/fandoghpaas/fandogh-cli",
  "checks": [
    {
      "type": "binary",
      "name": "fandogh"
    }
  ],
  "install_guidance": {
    "plugin": "fandogh-cli",
    "binary": "fandogh",
    "check": "which fandogh",
    "install_steps": [
      "pip install fandogh-cli",
      "Verify: fandogh --version",
      "supercli plugins install ./plugins/fandogh-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "fandogh-cli",
      "resource": "self",
      "action": "version",
      "description": "Print fandogh-cli version",
      "adapter": "process",
      "adapterConfig": {
        "command": "fandogh",
        "missingDependencyHelp": "Install fandogh-cli: pip install fandogh-cli",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "fandogh-cli",
      "resource": "service",
      "action": "deploy",
      "description": "deploy service via fandogh",
      "adapter": "process",
      "adapterConfig": {
        "command": "fandogh",
        "missingDependencyHelp": "Install fandogh-cli: pip install fandogh-cli",
        "baseArgs": [
          "deploy"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "fandogh-cli",
      "resource": "service",
      "action": "list",
      "description": "list service via fandogh",
      "adapter": "process",
      "adapterConfig": {
