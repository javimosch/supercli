{
  "name": "license-up",
  "version": "0.1.0",
  "description": "License generator and manager for open-source projects",
  "source": "https://github.com/nikivdev/license-up",
  "checks": [
    {
      "type": "binary",
      "name": "license-up"
    }
  ],
  "install_guidance": {
    "plugin": "license-up",
    "binary": "license-up",
    "check": "which license-up",
    "install_steps": [
      "npm install -g license-up",
      "Verify: license-up --version",
      "supercli plugins install ./plugins/license-up --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "license-up",
      "resource": "self",
      "action": "version",
      "description": "Print license-up version",
      "adapter": "process",
      "adapterConfig": {
        "command": "license-up",
        "missingDependencyHelp": "Install license-up: npm install -g license-up",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "license-up",
      "resource": "license",
      "action": "generate",
      "description": "generate license via license-up",
      "adapter": "process",
      "adapterConfig": {
        "command": "license-up",
        "missingDependencyHelp": "Install license-up: npm install -g license-up",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "license-up",
      "resource": "_",
      "action": "_",
      "description": "_ _ via license-up",
      "adapter": "process",
      "adapterConfig": {
        "command": "license-up",
        "missingDependencyHelp": "Install license-up: npm install -g license-up",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}