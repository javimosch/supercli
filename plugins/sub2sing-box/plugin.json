{
  "name": "sub2sing-box",
  "version": "0.1.0",
  "description": "Convert proxy subscription links to sing-box configuration",
  "source": "https://github.com/bestnite/sub2sing-box",
  "checks": [
    {
      "type": "binary",
      "name": "sub2sing-box"
    }
  ],
  "install_guidance": {
    "plugin": "sub2sing-box",
    "binary": "sub2sing-box",
    "check": "which sub2sing-box",
    "install_steps": [
      "go install github.com/bestnite/sub2sing-box@latest",
      "Verify: sub2sing-box --version",
      "supercli plugins install ./plugins/sub2sing-box --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "sub2sing-box",
      "resource": "self",
      "action": "version",
      "description": "Print sub2sing-box version",
      "adapter": "process",
      "adapterConfig": {
        "command": "sub2sing-box",
        "missingDependencyHelp": "Install sub2sing-box: go install github.com/bestnite/sub2sing-box@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "sub2sing-box",
      "resource": "subscription",
      "action": "convert",
      "description": "convert subscription via sub2sing-box",
      "adapter": "process",
      "adapterConfig": {
        "command": "sub2sing-box",
        "missingDependencyHelp": "Install sub2sing-box: go install github.com/bestnite/sub2sing-box@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "sub2sing-box",
      "resource": "_",
      "action": "_",
      "description": "_ _ via sub2sing-box",
      "adapter": "process",
      "adapterConfig": {
        "command": "sub2sing-box",
        "missingDependencyHelp": "Install sub2sing-box: go install github.com/bestnite/sub2sing-box@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}