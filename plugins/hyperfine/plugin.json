{
  "name": "hyperfine",
  "version": "0.1.0",
  "description": "A command-line benchmarking tool. Compare command execution times, run warmup/preparation commands, parameterized benchmarks, and export results to various formats.",
  "source": "https://github.com/sharkdp/hyperfine",
  "checks": [
    { "type": "binary", "name": "hyperfine" }
  ],
  "install_guidance": {
    "plugin": "hyperfine",
    "binary": "hyperfine",
    "check": "which hyperfine",
    "install_steps": [
      "brew install hyperfine",
      "Verify: hyperfine --version",
      "supercli plugins install ./plugins/hyperfine --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "hyperfine",
      "resource": "benchmark",
      "action": "run",
      "description": "Run benchmark on one or more commands",
      "adapter": "process",
      "adapterConfig": {
        "command": "hyperfine",
        "passthrough": true,
        "missingDependencyHelp": "Install hyperfine: brew install hyperfine"
      },
      "args": [
        { "name": "--runs", "type": "integer", "description": "Number of benchmark runs" },
        { "name": "--warmup", "type": "integer", "description": "Number of warmup runs" },
        { "name": "--prepare", "type": "string", "description": "Command to run before each timing run" },
        { "name": "--parameter-scan", "type": "string", "description": "Scan parameter range" },
        { "name": "--parameter-list", "type": "string", "description": "List of parameter values" },
        { "name": "--shell", "type": "string", "description": "Shell to use for command execution" },
        { "name": "--export-json", "type": "string", "description": "Export results to JSON file" },
        { "name": "--export-csv", "type": "string", "description": "Export results to CSV file" },
        { "name": "--export-markdown", "type": "string", "description": "Export results to Markdown file" },
        { "name": "commands", "type": "string", "required": true, "description": "Commands to benchmark" }
      ]
    },
    {
      "namespace": "hyperfine",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to hyperfine CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "hyperfine",
        "passthrough": true,
        "missingDependencyHelp": "Install hyperfine: brew install hyperfine"
      },
      "args": []
    }
  ]
}
