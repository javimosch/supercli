{
  "name": "hyperfine",
  "version": "0.1.0",
  "description": "Hyperfine — command-line benchmarking tool to measure and compare command execution times with statistical analysis",
  "source": "https://github.com/sharkdp/hyperfine",
  "checks": [
    { "type": "binary", "name": "hyperfine" }
  ],
  "install_guidance": {
    "plugin": "hyperfine",
    "binary": "hyperfine",
    "check": "hyperfine --version",
    "install_steps": [
      "cargo install hyperfine",
      "Verify: hyperfine --version",
      "supercli plugins install ./plugins/hyperfine --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "hyperfine",
      "resource": "self",
      "action": "version",
      "description": "Print hyperfine version",
      "adapter": "process",
      "adapterConfig": {
        "command": "hyperfine",
        "baseArgs": ["--version"],
        "missingDependencyHelp": "Install hyperfine: cargo install hyperfine"
      },
      "args": []
    },
    {
      "namespace": "hyperfine",
      "resource": "benchmark",
      "action": "run",
      "description": "Benchmark a command with statistical analysis",
      "adapter": "process",
      "adapterConfig": {
        "command": "hyperfine",
        "positionalArgs": ["command"],
        "passthrough": true,
        "timeout_ms": 120000,
        "missingDependencyHelp": "Install hyperfine"
      },
      "args": [
        { "name": "command", "type": "string", "required": true, "description": "Command to benchmark" }
      ]
    },
    {
      "namespace": "hyperfine",
      "resource": "benchmark",
      "action": "compare",
      "description": "Compare multiple commands",
      "adapter": "process",
      "adapterConfig": {
        "command": "hyperfine",
        "positionalArgs": ["commands"],
        "passthrough": true,
        "timeout_ms": 120000,
        "missingDependencyHelp": "Install hyperfine"
      },
      "args": [
        { "name": "commands", "type": "string", "required": true, "description": "Commands to compare (space-separated)" }
      ]
    },
    {
      "namespace": "hyperfine",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to hyperfine CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "hyperfine",
        "passthrough": true,
        "missingDependencyHelp": "Install hyperfine"
      },
      "args": []
    }
  ]
}
