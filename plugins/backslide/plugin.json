{
  "name": "backslide",
  "version": "0.1.0",
  "description": "CLI tool for creating and presenting Markdown-based slides",
  "source": "https://github.com/sinedied/backslide",
  "checks": [
    {
      "type": "binary",
      "name": "backslide"
    }
  ],
  "install_guidance": {
    "plugin": "backslide",
    "binary": "backslide",
    "check": "which backslide",
    "install_steps": [
      "npm install -g backslide",
      "Verify: backslide --version",
      "supercli plugins install ./plugins/backslide --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "backslide",
      "resource": "self",
      "action": "version",
      "description": "Print backslide version",
      "adapter": "process",
      "adapterConfig": {
        "command": "backslide",
        "missingDependencyHelp": "Install backslide: npm install -g backslide",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "backslide",
      "resource": "slides",
      "action": "create",
      "description": "create slides via backslide",
      "adapter": "process",
      "adapterConfig": {
        "command": "backslide",
        "missingDependencyHelp": "Install backslide: npm install -g backslide",
        "baseArgs": [
          "init"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "backslide",
      "resource": "slides",
      "action": "serve",
      "description": "serve slides via backslide",
      "adapter": "process",
      "adapterConfig": {
        "command": "backslide",
        "missingDependencyHelp": "Install backslide: npm install -g backslide",
        "baseArgs": [
          "serve"
        ],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "backslide",
      "resource": "slides",
      "action": "export",
      "description": "export slides via backslide",
      "adapter": "process",
      "adapterConfig": {
        "command": "backslide",
        "missingDependencyHelp": "Install backslide: npm install -g backslide",
        "baseArgs": [
          "export"
        ],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "backslide",
      "resource": "_",
      "action": "_",
      "description": "_ _ via backslide",
      "adapter": "process",
      "adapterConfig": {
        "command": "backslide",
        "missingDependencyHelp": "Install backslide: npm install -g backslide",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}