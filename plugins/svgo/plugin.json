{
  "name": "svgo",
  "version": "0.1.0",
  "description": "Node.js tool for optimizing SVG files. Remove redundant information, optimize paths, and reduce file size.",
  "source": "https://github.com/svg/svgo",
  "checks": [
    { "type": "binary", "name": "svgo" }
  ],
  "install_guidance": {
    "plugin": "svgo",
    "binary": "svgo",
    "check": "which svgo",
    "install_steps": [
      "npm install -g svgo",
      "Verify: svgo --version",
      "supercli plugins install ./plugins/svgo --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "svgo",
      "resource": "optimize",
      "action": "svg",
      "description": "Optimize SVG files",
      "adapter": "process",
      "adapterConfig": {
        "command": "svgo",
        "passthrough": true,
        "missingDependencyHelp": "Install svgo: npm install -g svgo"
      },
      "args": [
        { "name": "input", "type": "string", "description": "Input SVG file" },
        { "name": "-o", "type": "string", "description": "Output file" },
        { "name": "-p", "type": "integer", "description": "Precision" },
        { "name": "--multipass", "type": "boolean", "description": "Multiple passes" }
      ]
    },
    {
      "namespace": "svgo",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to svgo CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "svgo",
        "passthrough": true,
        "missingDependencyHelp": "Install svgo: npm install -g svgo"
      },
      "args": []
    }
  ]
}
