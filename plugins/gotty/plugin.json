{
  "name": "gotty",
  "version": "0.1.0",
  "description": "Share your terminal as a web application",
  "source": "https://github.com/yudai/gotty",
  "checks": [
    {
      "type": "binary",
      "name": "gotty"
    }
  ],
  "install_guidance": {
    "plugin": "gotty",
    "binary": "gotty",
    "check": "which gotty",
    "install_steps": [
      "go install github.com/yudai/gotty@latest",
      "Verify: gotty --version",
      "supercli plugins install ./plugins/gotty --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "gotty",
      "resource": "self",
      "action": "version",
      "description": "Print gotty version",
      "adapter": "process",
      "adapterConfig": {
        "command": "gotty",
        "missingDependencyHelp": "Install gotty: go install github.com/yudai/gotty@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "gotty",
      "resource": "command",
      "action": "run",
      "description": "run command via gotty",
      "adapter": "process",
      "adapterConfig": {
        "command": "gotty",
        "missingDependencyHelp": "Install gotty: go install github.com/yudai/gotty@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "gotty",
      "resource": "_",
      "action": "_",
      "description": "_ _ via gotty",
      "adapter": "process",
      "adapterConfig": {
        "command": "gotty",
        "missingDependencyHelp": "Install gotty: go install github.com/yudai/gotty@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}