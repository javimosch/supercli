{
  "name": "speedtest-go",
  "version": "0.1.0",
  "description": "Go based Speedtest CLI",
  "source": "https://github.com/showwin/speedtest-go",
  "checks": [
    {
      "type": "binary",
      "name": "speedtest-go"
    }
  ],
  "install_guidance": {
    "plugin": "speedtest-go",
    "binary": "speedtest-go",
    "check": "which speedtest-go",
    "install_steps": [
      "brew install speedtest-go",
      "Verify: speedtest-go --version",
      "supercli plugins install ./plugins/speedtest-go --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "speedtest-go",
      "resource": "self",
      "action": "version",
      "description": "Print speedtest-go version",
      "adapter": "process",
      "adapterConfig": {
        "command": "speedtest-go",
        "missingDependencyHelp": "Install speedtest-go: brew install speedtest-go",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "speedtest-go",
      "resource": "network",
      "action": "measure",
      "description": "measure network via speedtest-go",
      "adapter": "process",
      "adapterConfig": {
        "command": "speedtest-go",
        "missingDependencyHelp": "Install speedtest-go: brew install speedtest-go",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 120000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "speedtest-go",
      "resource": "_",
      "action": "_",
      "description": "_ _ via speedtest-go",
      "adapter": "process",
      "adapterConfig": {
        "command": "speedtest-go",
        "missingDependencyHelp": "Install speedtest-go: brew install speedtest-go",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}