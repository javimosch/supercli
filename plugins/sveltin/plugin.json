{
  "name": "sveltin",
  "version": "0.1.0",
  "description": "CLI tool for building SvelteKit static websites",
  "source": "https://github.com/sveltinio/sveltin",
  "checks": [
    {
      "type": "binary",
      "name": "sveltin"
    }
  ],
  "install_guidance": {
    "plugin": "sveltin",
    "binary": "sveltin",
    "check": "which sveltin",
    "install_steps": [
      "go install github.com/sveltinio/sveltin@latest",
      "Verify: sveltin --version",
      "supercli plugins install ./plugins/sveltin --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "sveltin",
      "resource": "self",
      "action": "version",
      "description": "Print sveltin version",
      "adapter": "process",
      "adapterConfig": {
        "command": "sveltin",
        "missingDependencyHelp": "Install sveltin: go install github.com/sveltinio/sveltin@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "sveltin",
      "resource": "site",
      "action": "create",
      "description": "create site via sveltin",
      "adapter": "process",
      "adapterConfig": {
        "command": "sveltin",
        "missingDependencyHelp": "Install sveltin: go install github.com/sveltinio/sveltin@latest",
        "baseArgs": [
          "new"
        ],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "sveltin",
      "resource": "site",
      "action": "build",
      "description": "build site via sveltin",
      "adapter": "process",
      "adapterConfig": {
        "command": "sveltin",
        "missingDependencyHelp": "Install sveltin: go install github.com/sveltinio/sveltin@latest",
        "baseArgs": [
          "build"
        ],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "sveltin",
      "resource": "site",
      "action": "deploy",
      "description": "deploy site via sveltin",
      "adapter": "process",
      "adapterConfig": {
        "command": "sveltin",
        "missingDependencyHelp": "Install sveltin: go install github.com/sveltinio/sveltin@latest",
        "baseArgs": [
          "deploy"
        ],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "sveltin",
      "resource": "content",
      "action": "add",
      "description": "add content via sveltin",
      "adapter": "process",
      "adapterConfig": {
        "command": "sveltin",
        "missingDependencyHelp": "Install sveltin: go install github.com/sveltinio/sveltin@latest",
        "baseArgs": [
          "add",
          "content"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "sveltin",
      "resource": "resource",
      "action": "add",
      "description": "add resource via sveltin",
      "adapter": "process",
      "adapterConfig": {
        "command": "sveltin",
        "missingDependencyHelp": "Install sveltin: go install github.com/sveltinio/sveltin@latest",
        "baseArgs": [
          "add",
          "resource"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "sveltin",
      "resource": "_",
      "action": "_",
      "description": "_ _ via sveltin",
      "adapter": "process",
      "adapterConfig": {
        "command": "sveltin",
        "missingDependencyHelp": "Install sveltin: go install github.com/sveltinio/sveltin@latest",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}