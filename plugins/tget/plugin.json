{
  "name": "tget",
  "version": "0.1.0",
  "description": "Torrent file downloader and getter CLI",
  "source": "https://github.com/jeffjose/tget",
  "checks": [
    {
      "type": "binary",
      "name": "tget"
    }
  ],
  "install_guidance": {
    "plugin": "tget",
    "binary": "tget",
    "check": "which tget",
    "install_steps": [
      "npm install -g tget",
      "Verify: tget --version",
      "supercli plugins install ./plugins/tget --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "tget",
      "resource": "self",
      "action": "version",
      "description": "Print tget version",
      "adapter": "process",
      "adapterConfig": {
        "command": "tget",
        "missingDependencyHelp": "Install tget: npm install -g tget",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "tget",
      "resource": "torrent",
      "action": "download",
      "description": "download torrent via tget",
      "adapter": "process",
      "adapterConfig": {
        "command": "tget",
        "missingDependencyHelp": "Install tget: npm install -g tget",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "tget",
      "resource": "_",
      "action": "_",
      "description": "_ _ via tget",
      "adapter": "process",
      "adapterConfig": {
        "command": "tget",
        "missingDependencyHelp": "Install tget: npm install -g tget",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}