{
  "name": "static-react",
  "version": "0.1.0",
  "description": "Zero-config static site generator for React",
  "source": "https://github.com/jxnblk/static-react",
  "checks": [
    {
      "type": "binary",
      "name": "static-react"
    }
  ],
  "install_guidance": {
    "plugin": "static-react",
    "binary": "static-react",
    "check": "which static-react",
    "install_steps": [
      "npm install -g static-react",
      "Verify: static-react --version",
      "supercli plugins install ./plugins/static-react --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "static-react",
      "resource": "self",
      "action": "version",
      "description": "Print static-react version",
      "adapter": "process",
      "adapterConfig": {
        "command": "static-react",
        "missingDependencyHelp": "Install static-react: npm install -g static-react",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "static-react",
      "resource": "site",
      "action": "build",
      "description": "build site via static-react",
      "adapter": "process",
      "adapterConfig": {
        "command": "static-react",
        "missingDependencyHelp": "Install static-react: npm install -g static-react",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "static-react",
      "resource": "_",
      "action": "_",
      "description": "_ _ via static-react",
      "adapter": "process",
      "adapterConfig": {
        "command": "static-react",
        "missingDependencyHelp": "Install static-react: npm install -g static-react",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}