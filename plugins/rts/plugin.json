{
  "name": "rts",
  "version": "0.1.0",
  "description": "Mock JSON server and REST API testing tool",
  "source": "https://github.com/galeone/rts",
  "checks": [
    {
      "type": "binary",
      "name": "rts"
    }
  ],
  "install_guidance": {
    "plugin": "rts",
    "binary": "rts",
    "check": "which rts",
    "install_steps": [
      "go install github.com/galeone/rts@latest",
      "Verify: rts --version",
      "supercli plugins install ./plugins/rts --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "rts",
      "resource": "self",
      "action": "version",
      "description": "Print rts version",
      "adapter": "process",
      "adapterConfig": {
        "command": "rts",
        "missingDependencyHelp": "Install rts: go install github.com/galeone/rts@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "rts",
      "resource": "server",
      "action": "start",
      "description": "start server via rts",
      "adapter": "process",
      "adapterConfig": {
        "command": "rts",
        "missingDependencyHelp": "Install rts: go install github.com/galeone/rts@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "rts",
      "resource": "_",
      "action": "_",
      "description": "_ _ via rts",
      "adapter": "process",
      "adapterConfig": {
        "command": "rts",
        "missingDependencyHelp": "Install rts: go install github.com/galeone/rts@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}