{
  "name": "github-files-fetcher",
  "version": "0.1.0",
  "description": "Download files and directories from GitHub",
  "source": "https://github.com/Gyumeijie/github-files-fetcher",
  "checks": [
    {
      "type": "binary",
      "name": "github-files-fetcher"
    }
  ],
  "install_guidance": {
    "plugin": "github-files-fetcher",
    "binary": "github-files-fetcher",
    "check": "which github-files-fetcher",
    "install_steps": [
      "npm install -g github-files-fetcher",
      "Verify: github-files-fetcher --version",
      "supercli plugins install ./plugins/github-files-fetcher --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "github-files-fetcher",
      "resource": "self",
      "action": "version",
      "description": "Print github-files-fetcher version",
      "adapter": "process",
      "adapterConfig": {
        "command": "github-files-fetcher",
        "missingDependencyHelp": "Install github-files-fetcher: npm install -g github-files-fetcher",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "github-files-fetcher",
      "resource": "repo",
      "action": "fetch",
      "description": "fetch repo via github-files-fetcher",
      "adapter": "process",
      "adapterConfig": {
        "command": "github-files-fetcher",
        "missingDependencyHelp": "Install github-files-fetcher: npm install -g github-files-fetcher",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "github-files-fetcher",
      "resource": "_",
      "action": "_",
      "description": "_ _ via github-files-fetcher",
      "adapter": "process",
      "adapterConfig": {
        "command": "github-files-fetcher",
        "missingDependencyHelp": "Install github-files-fetcher: npm install -g github-files-fetcher",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}