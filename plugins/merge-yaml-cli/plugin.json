{
  "name": "merge-yaml-cli",
  "version": "0.1.0",
  "description": "Node.js CLI utility for merging YAML files. Merge multiple YAML files together using glob patterns.",
  "source": "https://github.com/brainsiq/merge-yaml-cli",
  "checks": [
    { "type": "binary", "name": "merge-yaml" }
  ],
  "install_guidance": {
    "plugin": "merge-yaml-cli",
    "binary": "merge-yaml",
    "check": "which merge-yaml",
    "install_steps": [
      "npm install -g merge-yaml-cli",
      "Verify: merge-yaml --version",
      "supercli plugins install ./plugins/merge-yaml-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "merge-yaml",
      "resource": "merge",
      "action": "files",
      "description": "Merge YAML files together",
      "adapter": "process",
      "adapterConfig": {
        "command": "merge-yaml",
        "passthrough": true,
        "missingDependencyHelp": "Install merge-yaml-cli: npm install -g merge-yaml-cli"
      },
      "args": [
        { "name": "-i", "type": "string", "description": "Input file pattern" },
        { "name": "-o", "type": "string", "description": "Output file" }
      ]
    },
    {
      "namespace": "merge-yaml",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to merge-yaml CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "merge-yaml",
        "passthrough": true,
        "missingDependencyHelp": "Install merge-yaml-cli: npm install -g merge-yaml-cli"
      },
      "args": []
    }
  ]
}
