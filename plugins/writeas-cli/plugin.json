{
  "name": "writeas-cli",
  "version": "0.1.0",
  "description": "Command line publishing tool for Write.as",
  "source": "https://github.com/writeas/writeas-cli",
  "checks": [
    {
      "type": "binary",
      "name": "writeas"
    }
  ],
  "install_guidance": {
    "plugin": "writeas-cli",
    "binary": "writeas",
    "check": "which writeas",
    "install_steps": [
      "brew install writeas",
      "Verify: writeas --version",
      "supercli plugins install ./plugins/writeas-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "writeas-cli",
      "resource": "self",
      "action": "version",
      "description": "Print writeas-cli version",
      "adapter": "process",
      "adapterConfig": {
        "command": "writeas",
        "missingDependencyHelp": "Install writeas-cli: brew install writeas",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "writeas-cli",
      "resource": "post",
      "action": "publish",
      "description": "publish post via writeas",
      "adapter": "process",
      "adapterConfig": {
        "command": "writeas",
        "missingDependencyHelp": "Install writeas-cli: brew install writeas",
        "baseArgs": [
          "publish"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "writeas-cli",
      "resource": "post",
      "action": "list",
      "description": "list post via writeas",
      "adapter": "process",
      "adapterConfig": {
        "command": "writeas",
        "missingDependencyHelp": "Install writeas-cli: brew install writeas",
        "baseArgs": [
          "list"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "writeas-cli",
      "resource": "post",
      "action": "delete",
      "description": "delete post via writeas",
      "adapter": "process",
      "adapterConfig": {
        "command": "writeas",
        "missingDependencyHelp": "Install writeas-cli: brew install writeas",
        "baseArgs": [
          "delete"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "writeas-cli",
      "resource": "_",
      "action": "_",
      "description": "_ _ via writeas",
      "adapter": "process",
      "adapterConfig": {
        "command": "writeas",
        "missingDependencyHelp": "Install writeas-cli: brew install writeas",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}