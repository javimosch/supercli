{
  "name": "dksnap",
  "version": "0.1.0",
  "description": "Docker snapshots for development and test data management",
  "source": "https://github.com/kelda/dksnap",
  "checks": [
    {
      "type": "binary",
      "name": "dksnap"
    }
  ],
  "install_guidance": {
    "plugin": "dksnap",
    "binary": "dksnap",
    "check": "which dksnap",
    "install_steps": [
      "go install github.com/kelda/dksnap@latest",
      "Verify: dksnap --version",
      "supercli plugins install ./plugins/dksnap --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "dksnap",
      "resource": "self",
      "action": "version",
      "description": "Print dksnap version",
      "adapter": "process",
      "adapterConfig": {
        "command": "dksnap",
        "missingDependencyHelp": "Install dksnap: go install github.com/kelda/dksnap@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "dksnap",
      "resource": "container",
      "action": "snapshot",
      "description": "snapshot container via dksnap",
      "adapter": "process",
      "adapterConfig": {
        "command": "dksnap",
        "missingDependencyHelp": "Install dksnap: go install github.com/kelda/dksnap@latest",
        "baseArgs": [
          "snapshot"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "dksnap",
      "resource": "container",
      "action": "restore",
      "description": "restore container via dksnap",
      "adapter": "process",
      "adapterConfig": {
        "command": "dksnap",
        "missingDependencyHelp": "Install dksnap: go install github.com/kelda/dksnap@latest",
        "baseArgs": [
          "restore"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "dksnap",
      "resource": "container",
      "action": "list",
      "description": "list container via dksnap",
      "adapter": "process",
      "adapterConfig": {
        "command": "dksnap",
        "missingDependencyHelp": "Install dksnap: go install github.com/kelda/dksnap@latest",
        "baseArgs": [
          "list"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "dksnap",
      "resource": "container",
      "action": "delete",
      "description": "delete container via dksnap",
      "adapter": "process",
      "adapterConfig": {
        "command": "dksnap",
        "missingDependencyHelp": "Install dksnap: go install github.com/kelda/dksnap@latest",
        "baseArgs": [
          "delete"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "dksnap",
      "resource": "_",
      "action": "_",
      "description": "_ _ via dksnap",
      "adapter": "process",
      "adapterConfig": {
        "command": "dksnap",
        "missingDependencyHelp": "Install dksnap: go install github.com/kelda/dksnap@latest",
        "passthrough": true
