{
  "name": "textnote",
  "version": "0.1.0",
  "description": "Simple tool for creating and organizing daily notes on the command line",
  "source": "https://github.com/dkaslovsky/textnote",
  "checks": [
    {
      "type": "binary",
      "name": "textnote"
    }
  ],
  "install_guidance": {
    "plugin": "textnote",
    "binary": "textnote",
    "check": "which textnote",
    "install_steps": [
      "go install github.com/dkaslovsky/textnote/cmd/textnote@latest",
      "Verify: textnote --version",
      "supercli plugins install ./plugins/textnote --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "textnote",
      "resource": "self",
      "action": "version",
      "description": "Print textnote version",
      "adapter": "process",
      "adapterConfig": {
        "command": "textnote",
        "missingDependencyHelp": "Install textnote: go install github.com/dkaslovsky/textnote/cmd/textnote@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "textnote",
      "resource": "note",
      "action": "open",
      "description": "open note via textnote",
      "adapter": "process",
      "adapterConfig": {
        "command": "textnote",
        "missingDependencyHelp": "Install textnote: go install github.com/dkaslovsky/textnote/cmd/textnote@latest",
        "baseArgs": [
          "open"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "textnote",
      "resource": "note",
      "action": "list",
      "description": "list note via textnote",
      "adapter": "process",
      "adapterConfig": {
        "command": "textnote",
        "missingDependencyHelp": "Install textnote: go install github.com/dkaslovsky/textnote/cmd/textnote@latest",
        "baseArgs": [
          "list"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "textnote",
      "resource": "note",
      "action": "archive",
      "description": "archive note via textnote",
      "adapter": "process",
      "adapterConfig": {
        "command": "textnote",
        "missingDependencyHelp": "Install textnote: go install github.com/dkaslovsky/textnote/cmd/textnote@latest",
        "baseArgs": [
          "archive"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "textnote",
      "resource": "_",
      "action": "_",
      "description": "_ _ via textnote",
      "adapter": "process",
      "adapterConfig": {
        "command": "textnote",
        "missingDependencyHelp": "Install textnote: go install github.com/dkaslovsky/textnote/cmd/textnote@latest",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}