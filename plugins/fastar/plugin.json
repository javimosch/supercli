  "install_guidance": {
    "plugin": "fastar",
    "binary": "fastar",
    "check": "which fastar",
    "install_steps": [
      "cargo install fastar",
      "Verify: fastar --version",
      "supercli plugins install ./plugins/fastar --on-conflict replace --json"
