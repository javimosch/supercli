{
  "name": "watch-cli",
  "version": "0.1.0",
  "description": "Watch files and execute npm scripts when files change. File watcher for development workflows.",
  "source": "https://github.com/doowb/watch-cli",
  "checks": [
    { "type": "binary", "name": "watch" }
  ],
  "install_guidance": {
    "plugin": "watch-cli",
    "binary": "watch",
    "check": "which watch",
    "install_steps": [
      "npm install -g watch-cli",
      "Verify: watch --version",
      "supercli plugins install ./plugins/watch-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "watch",
      "resource": "monitor",
      "action": "files",
      "description": "Watch files and execute commands on change",
      "adapter": "process",
      "adapterConfig": {
        "command": "watch",
        "passthrough": true,
        "missingDependencyHelp": "Install watch-cli: npm install -g watch-cli"
      },
      "args": [
        { "name": "pattern", "type": "string", "description": "File pattern to watch" },
        { "name": "command", "type": "string", "description": "Command to execute" }
      ]
    },
    {
      "namespace": "watch",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to watch CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "watch",
        "passthrough": true,
        "missingDependencyHelp": "Install watch-cli: npm install -g watch-cli"
      },
      "args": []
    }
  ]
}
