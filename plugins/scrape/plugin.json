{
  "name": "scrape",
  "version": "0.1.0",
  "description": "CLI utility to scrape emails from websites",
  "source": "https://github.com/lawzava/scrape",
  "checks": [
    {
      "type": "binary",
      "name": "scrape"
    }
  ],
  "install_guidance": {
    "plugin": "scrape",
    "binary": "scrape",
    "check": "which scrape",
    "install_steps": [
      "go install github.com/lawzava/scrape@latest",
      "Verify: scrape --version",
      "supercli plugins install ./plugins/scrape --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "scrape",
      "resource": "self",
      "action": "version",
      "description": "Print scrape version",
      "adapter": "process",
      "adapterConfig": {
        "command": "scrape",
        "missingDependencyHelp": "Install scrape: go install github.com/lawzava/scrape@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "scrape",
      "resource": "url",
      "action": "scrape",
      "description": "scrape url via scrape",
      "adapter": "process",
      "adapterConfig": {
        "command": "scrape",
        "missingDependencyHelp": "Install scrape: go install github.com/lawzava/scrape@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "scrape",
      "resource": "output",
      "action": "save",
      "description": "save output via scrape",
      "adapter": "process",
      "adapterConfig": {
        "command": "scrape",
        "missingDependencyHelp": "Install scrape: go install github.com/lawzava/scrape@latest",
        "baseArgs": [
          "--output"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "scrape",
      "resource": "_",
      "action": "_",
      "description": "_ _ via scrape",
      "adapter": "process",
      "adapterConfig": {
        "command": "scrape",
        "missingDependencyHelp": "Install scrape: go install github.com/lawzava/scrape@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
