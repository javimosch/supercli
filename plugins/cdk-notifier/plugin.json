{
  "name": "cdk-notifier",
  "version": "0.1.0",
  "description": "AWS CDK deployment notifier for Slack and other channels",
  "source": "https://github.com/karlderkaefer/cdk-notifier",
  "checks": [
    {
      "type": "binary",
      "name": "cdk-notifier"
    }
  ],
  "install_guidance": {
    "plugin": "cdk-notifier",
    "binary": "cdk-notifier",
    "check": "which cdk-notifier",
    "install_steps": [
      "go install github.com/karlderkaefer/cdk-notifier@latest",
      "Verify: cdk-notifier --version",
      "supercli plugins install ./plugins/cdk-notifier --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "cdk-notifier",
      "resource": "self",
      "action": "version",
      "description": "Print cdk-notifier version",
      "adapter": "process",
      "adapterConfig": {
        "command": "cdk-notifier",
        "missingDependencyHelp": "Install cdk-notifier: go install github.com/karlderkaefer/cdk-notifier@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "cdk-notifier",
      "resource": "notify",
      "action": "send",
      "description": "send notify via cdk-notifier",
      "adapter": "process",
      "adapterConfig": {
        "command": "cdk-notifier",
        "missingDependencyHelp": "Install cdk-notifier: go install github.com/karlderkaefer/cdk-notifier@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "cdk-notifier",
      "resource": "config",
      "action": "show",
      "description": "show config via cdk-notifier",
      "adapter": "process",
      "adapterConfig": {
        "command": "cdk-notifier",
        "missingDependencyHelp": "Install cdk-notifier: go install github.com/karlderkaefer/cdk-notifier@latest",
        "baseArgs": [
          "--config"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "cdk-notifier",
      "resource": "_",
      "action": "_",
      "description": "_ _ via cdk-notifier",
      "adapter": "process",
      "adapterConfig": {
        "command": "cdk-notifier",
        "missingDependencyHelp": "Install cdk-notifier: go install github.com/karlderkaefer/cdk-notifier@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}