{
  "name": "lux",
  "version": "0.1.0",
  "description": "Fast and simple video download library and CLI tool",
  "source": "https://github.com/iawia002/lux",
  "checks": [
    {
      "type": "binary",
      "name": "lux"
    }
  ],
  "install_guidance": {
    "plugin": "lux",
    "binary": "lux",
    "check": "which lux",
    "install_steps": [
      "go install github.com/iawia002/lux@latest",
      "Verify: lux --version",
      "supercli plugins install ./plugins/lux --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "lux",
      "resource": "self",
      "action": "version",
      "description": "Print lux version",
      "adapter": "process",
      "adapterConfig": {
        "command": "lux",
        "missingDependencyHelp": "Install lux: go install github.com/iawia002/lux@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "lux",
      "resource": "video",
      "action": "download",
      "description": "download video via lux",
      "adapter": "process",
      "adapterConfig": {
        "command": "lux",
        "missingDependencyHelp": "Install lux: go install github.com/iawia002/lux@latest",
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "lux",
      "resource": "_",
      "action": "_",
      "description": "_ _ via lux",
      "adapter": "process",
      "adapterConfig": {
        "command": "lux",
        "missingDependencyHelp": "Install lux: go install github.com/iawia002/lux@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}