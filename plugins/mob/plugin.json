{
  "name": "mob",
  "version": "0.1.0",
  "description": "Tool for smooth git handover. Fast git branch switching and remote mob programming with WIP commits. Optimized for pair and mob programming.",
  "source": "https://github.com/remotemobprogramming/mob",
  "checks": [
    { "type": "binary", "name": "mob" }
  ],
  "install_guidance": {
    "plugin": "mob",
    "binary": "mob",
    "check": "which mob",
    "install_steps": [
      "brew install mob",
      "Verify: mob --version",
      "supercli plugins install ./plugins/mob --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "mob",
      "resource": "session",
      "action": "start",
      "description": "Start a mob programming session",
      "adapter": "process",
      "adapterConfig": {
        "command": "mob",
        "baseArgs": ["start"],
        "passthrough": true,
        "missingDependencyHelp": "Install mob: brew install mob"
      },
      "args": [
        { "name": "--branch", "type": "string", "description": "Base branch name" },
        { "name": "--create", "type": "boolean", "description": "Create new branch" }
      ]
    },
    {
      "namespace": "mob",
      "resource": "session",
      "action": "done",
      "description": "Finish mob programming session",
      "adapter": "process",
      "adapterConfig": {
        "command": "mob",
        "baseArgs": ["done"],
        "passthrough": true,
        "missingDependencyHelp": "Install mob: brew install mob"
      },
      "args": [
        { "name": "--message", "type": "string", "description": "Commit message for squashed commits" },
        { "name": "--no-squash", "type": "boolean", "description": "Keep all WIP commits" }
      ]
    },
    {
      "namespace": "mob",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to mob CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "mob",
        "passthrough": true,
        "missingDependencyHelp": "Install mob: brew install mob"
      },
      "args": []
    }
  ]
}
