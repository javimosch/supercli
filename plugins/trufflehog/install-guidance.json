{
  "plugin": "trufflehog",
  "binary": "trufflehog",
  "check": "which trufflehog",
  "install_steps": [
    "curl -sSfL https://raw.githubusercontent.com/trufflesecurity/trufflehog/main/scripts/install.sh | sh -s -- -b /usr/local/bin",
    "Verify: trufflehog --version",
    "supercli plugins install ./plugins/trufflehog --on-conflict replace --json"
  ],
  "note": "Requires git for repo scanning. Supports Docker, S3, GCS, and more sources with --json flag for CI/CD."
}
