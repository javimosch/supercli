{
  "name": "httpie",
  "version": "0.1.0",
  "description": "A user-friendly command-line HTTP client for the API era",
  "source": "https://github.com/httpie/httpie",
  "checks": [
    { "type": "binary", "name": "http" }
  ],
  "install_guidance": {
    "plugin": "httpie",
    "binary": "http",
    "check": "which http",
    "install_steps": [
      "pip install httpie",
      "Or: brew install httpie",
      "Or: sudo apt install httpie",
      "supercli plugins install ./plugins/httpie --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "httpie",
      "resource": "self",
      "action": "version",
      "description": "Print httpie version",
      "adapter": "process",
      "adapterConfig": {
        "command": "http",
        "baseArgs": ["--version"],
        "cwd": "invoke_cwd",
        "missingDependencyHelp": "Install httpie: pip install httpie"
      },
      "args": []
    },
    {
      "namespace": "httpie",
      "resource": "request",
      "action": "get",
      "description": "Send HTTP GET request",
      "adapter": "process",
      "adapterConfig": {
        "command": "http",
        "baseArgs": ["GET"],
        "positionalArgs": ["url"],
        "cwd": "invoke_cwd",
        "missingDependencyHelp": "Install httpie: pip install httpie"
      },
      "args": [
        { "name": "url", "type": "string", "required": false, "description": "URL to request" },
        { "name": "--header", "type": "string", "required": false, "description": "HTTP header" },
        { "name": "--auth", "type": "string", "required": false, "description": "Basic auth (user:pass)" },
        { "name": "--verify", "type": "string", "required": false, "description": "SSL verification" }
      ]
    },
    {
      "namespace": "httpie",
      "resource": "request",
      "action": "post",
      "description": "Send HTTP POST request",
      "adapter": "process",
      "adapterConfig": {
        "command": "http",
        "baseArgs": ["POST"],
        "positionalArgs": ["url"],
        "cwd": "invoke_cwd",
        "missingDependencyHelp": "Install httpie: pip install httpie"
      },
      "args": [
        { "name": "url", "type": "string", "required": false, "description": "URL to request" },
        { "name": "--json", "type": "string", "required": false, "description": "JSON data" },
        { "name": "--form", "type": "string", "required": false, "description": "Form data" },
        { "name": "--header", "type": "string", "required": false, "description": "HTTP header" },
        { "name": "--auth", "type": "string", "required": false, "description": "Basic auth (user:pass)" }
      ]
    },
    {
      "namespace": "httpie",
      "resource": "request",
      "action": "put",
      "description": "Send HTTP PUT request",
      "adapter": "process",
      "adapterConfig": {
        "command": "http",
        "baseArgs": ["PUT"],
        "positionalArgs": ["url"],
        "cwd": "invoke_cwd",
        "missingDependencyHelp": "Install httpie: pip install httpie"
      },
      "args": [
        { "name": "url", "type": "string", "required": false, "description": "URL to request" },
        { "name": "--json", "type": "string", "required": false, "description": "JSON data" },
        { "name": "--header", "type": "string", "required": false, "description": "HTTP header" },
        { "name": "--auth", "type": "string", "required": false, "description": "Basic auth (user:pass)" }
      ]
    },
    {
      "namespace": "httpie",
      "resource": "request",
      "action": "delete",
      "description": "Send HTTP DELETE request",
      "adapter": "process",
      "adapterConfig": {
        "command": "http",
        "baseArgs": ["DELETE"],
        "positionalArgs": ["url"],
        "cwd": "invoke_cwd",
        "missingDependencyHelp": "Install httpie: pip install httpie"
      },
      "args": [
        { "name": "url", "type": "string", "required": false, "description": "URL to request" },
        { "name": "--header", "type": "string", "required": false, "description": "HTTP header" },
        { "name": "--auth", "type": "string", "required": false, "description": "Basic auth (user:pass)" }
      ]
    },
    {
      "namespace": "httpie",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to httpie CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "http",
        "cwd": "invoke_cwd",
        "passthrough": true,
        "missingDependencyHelp": "Install httpie: pip install httpie"
      },
      "args": []
    }
  ]
}
