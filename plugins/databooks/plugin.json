{
  "name": "databooks",
  "version": "0.1.0",
  "description": "CLI tool to reduce friction between data scientists by removing notebook metadata and resolving git conflicts",
  "source": "https://github.com/datarootsio/databooks",
  "checks": [
    {
      "type": "binary",
      "name": "databooks"
    }
  ],
  "install_guidance": {
    "plugin": "databooks",
    "binary": "databooks",
    "check": "which databooks",
    "install_steps": [
      "pip install databooks",
      "Verify: databooks --version",
      "supercli plugins install ./plugins/databooks --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "databooks",
      "resource": "self",
      "action": "version",
      "description": "Print databooks version",
      "adapter": "process",
      "adapterConfig": {
        "command": "databooks",
        "missingDependencyHelp": "Install databooks: pip install databooks",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "databooks",
      "resource": "notebook",
      "action": "clean",
      "description": "clean notebook via databooks",
      "adapter": "process",
      "adapterConfig": {
        "command": "databooks",
        "missingDependencyHelp": "Install databooks: pip install databooks",
        "baseArgs": [
          "clean"
        ],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
