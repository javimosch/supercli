{
  "name": "compose-generator",
  "version": "0.1.0",
  "description": "Easy to use CLI tool to generate Docker Compose configurations",
  "source": "https://github.com/compose-generator/compose-generator",
  "checks": [
    {
      "type": "binary",
      "name": "compose-generator"
    }
  ],
  "install_guidance": {
    "plugin": "compose-generator",
    "binary": "compose-generator",
    "check": "which compose-generator",
    "install_steps": [
      "brew install compose-generator",
      "Verify: compose-generator --version",
      "supercli plugins install ./plugins/compose-generator --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "compose-generator",
      "resource": "self",
      "action": "version",
      "description": "Print compose-generator version",
      "adapter": "process",
      "adapterConfig": {
        "command": "compose-generator",
        "missingDependencyHelp": "Install compose-generator: brew install compose-generator",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "compose-generator",
      "resource": "compose",
      "action": "generate",
      "description": "generate compose via compose-generator",
      "adapter": "process",
      "adapterConfig": {
        "command": "compose-generator",
        "missingDependencyHelp": "Install compose-generator: brew install compose-generator",
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "compose-generator",
      "resource": "_",
      "action": "_",
      "description": "_ _ via compose-generator",
      "adapter": "process",
      "adapterConfig": {
        "command": "compose-generator",
        "missingDependencyHelp": "Install compose-generator: brew install compose-generator",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}