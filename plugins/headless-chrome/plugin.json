{
  "name": "headless-chrome",
  "version": "0.1.0",
  "description": "Run headless Chrome from the command line for automation",
  "source": "https://github.com/integrii/headlessChrome",
  "checks": [
    {
      "type": "binary",
      "name": "headless-chrome"
    }
  ],
  "install_guidance": {
    "plugin": "headless-chrome",
    "binary": "headless-chrome",
    "check": "which headless-chrome",
    "install_steps": [
      "npm install -g headless-chrome-cli",
      "Verify: headless-chrome --version",
      "supercli plugins install ./plugins/headless-chrome --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "headless-chrome",
      "resource": "self",
      "action": "version",
      "description": "Print headless-chrome version",
      "adapter": "process",
      "adapterConfig": {
        "command": "headless-chrome",
        "missingDependencyHelp": "Install headless-chrome: npm install -g headless-chrome-cli",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "headless-chrome",
      "resource": "page",
      "action": "screenshot",
      "description": "screenshot page via headless-chrome",
      "adapter": "process",
      "adapterConfig": {
        "command": "headless-chrome",
        "missingDependencyHelp": "Install headless-chrome: npm install -g headless-chrome-cli",
        "baseArgs": [
          "screenshot"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "headless-chrome",
      "resource": "page",
      "action": "pdf",
      "description": "pdf page via headless-chrome",
      "adapter": "process",
      "adapterConfig": {
        "command": "headless-chrome",
        "missingDependencyHelp": "Install headless-chrome: npm install -g headless-chrome-cli",
        "baseArgs": [
          "pdf"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "headless-chrome",
      "resource": "page",
      "action": "eval",
      "description": "eval page via headless-chrome",
      "adapter": "process",
      "adapterConfig": {
        "command": "headless-chrome",
        "missingDependencyHelp": "Install headless-chrome: npm install -g headless-chrome-cli",
        "baseArgs": [
          "eval"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "headless-chrome",
      "resource": "_",
      "action": "_",
      "description": "_ _ via headless-chrome",
      "adapter": "process",
      "adapterConfig": {
        "command": "headless-chrome",
        "missingDependencyHelp": "Install headless-chrome: npm install -g headless-chrome-cli",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}