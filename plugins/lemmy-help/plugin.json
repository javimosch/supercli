{
  "name": "lemmy-help",
  "version": "0.1.0",
  "description": "CLI to generate vim and neovim help documentation from EmmyLua annotations",
  "source": "https://github.com/numToStr/lemmy-help",
  "checks": [
    {
      "type": "binary",
      "name": "lemmy-help"
    }
  ],
  "install_guidance": {
    "plugin": "lemmy-help",
    "binary": "lemmy-help",
    "check": "which lemmy-help",
    "install_steps": [
      "cargo install lemmy-help",
      "Verify: lemmy-help --version",
      "supercli plugins install ./plugins/lemmy-help --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "lemmy-help",
      "resource": "self",
      "action": "version",
      "description": "Print lemmy-help version",
      "adapter": "process",
      "adapterConfig": {
        "command": "lemmy-help",
        "missingDependencyHelp": "Install lemmy-help: cargo install lemmy-help",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "lemmy-help",
      "resource": "doc",
      "action": "generate",
      "description": "generate doc via lemmy-help",
      "adapter": "process",
      "adapterConfig": {
        "command": "lemmy-help",
        "missingDependencyHelp": "Install lemmy-help: cargo install lemmy-help",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "lemmy-help",
      "resource": "file",
      "action": "parse",
      "description": "parse file via lemmy-help",
      "adapter": "process",
      "adapterConfig": {
        "command": "lemmy-help",
        "missingDependencyHelp": "Install lemmy-help: cargo install lemmy-help",
        "baseArgs": [
          "--parse"
        ],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "lemmy-help",
      "resource": "config",
      "action": "show",
      "description": "show config via lemmy-help",
      "adapter": "process",
      "adapterConfig": {
        "command": "lemmy-help",
        "missingDependencyHelp": "Install lemmy-help: cargo install lemmy-help",
        "baseArgs": [
          "--config"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "lemmy-help",
      "resource": "output",
      "action": "save",
      "description": "save output via lemmy-help",
      "adapter": "process",
      "adapterConfig": {
        "command": "lemmy-help",
        "missingDependencyHelp": "Install lemmy-help: cargo install lemmy-help",
        "baseArgs": [
          "--output"
        ],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "lemmy-help",
      "resource": "_",
      "action": "_",
      "description": "_ _ via lemmy-help",
      "adapter": "process",
      "adapterConfig": {
        "command": "lemmy-help",
        "missingDependencyHelp": "Install lemmy-help: cargo install lemmy-help",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}