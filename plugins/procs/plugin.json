{
  "name": "procs",
  "version": "0.1.0",
  "description": "A modern replacement for ps written in Rust. View and manage processes with advanced filtering, sorting, and visualization capabilities.",
  "source": "https://github.com/dalance/procs",
  "checks": [
    { "type": "binary", "name": "procs" }
  ],
  "install_guidance": {
    "plugin": "procs",
    "binary": "procs",
    "check": "which procs",
    "install_steps": [
      "brew install procs",
      "Verify: procs --version",
      "supercli plugins install ./plugins/procs --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "procs",
      "resource": "process",
      "action": "list",
      "description": "List and filter processes",
      "adapter": "process",
      "adapterConfig": {
        "command": "procs",
        "passthrough": true,
        "missingDependencyHelp": "Install procs: brew install procs"
      },
      "args": [
        { "name": "--sort", "type": "string", "description": "Sort by column" },
        { "name": "--insert", "type": "string", "description": "Insert column" },
        { "name": "--tree", "type": "boolean", "description": "Tree view" },
        { "name": "--watch", "type": "boolean", "description": "Watch mode" },
        { "name": "--no-header", "type": "boolean", "description": "Hide header" },
        { "name": "--color", "type": "string", "description": "Color mode (auto, always, never)" }
      ]
    },
    {
      "namespace": "procs",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to procs CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "procs",
        "passthrough": true,
        "missingDependencyHelp": "Install procs: brew install procs"
      },
      "args": []
    }
  ]
}
