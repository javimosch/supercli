{
  "name": "gomplate",
  "version": "0.1.0",
  "description": "A flexible commandline tool for template rendering. Supports lots of local and remote datasources. Render templates with data from various sources.",
  "source": "https://github.com/hairyhenderson/gomplate",
  "checks": [
    { "type": "binary", "name": "gomplate" }
  ],
  "install_guidance": {
    "plugin": "gomplate",
    "binary": "gomplate",
    "check": "which gomplate",
    "install_steps": [
      "brew install gomplate",
      "Verify: gomplate --version",
      "supercli plugins install ./plugins/gomplate --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "gomplate",
      "resource": "template",
      "action": "render",
      "description": "Render template with data",
      "adapter": "process",
      "adapterConfig": {
        "command": "gomplate",
        "passthrough": true,
        "missingDependencyHelp": "Install gomplate: brew install gomplate"
      },
      "args": [
        { "name": "file", "type": "string", "description": "Template file" },
        { "name": "--data", "type": "string", "description": "Data source" },
        { "name": "--out", "type": "string", "description": "Output file" },
        { "name": "--context", "type": "string", "description": "Context data" }
      ]
    },
    {
      "namespace": "gomplate",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to gomplate CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "gomplate",
        "passthrough": true,
        "missingDependencyHelp": "Install gomplate: brew install gomplate"
      },
      "args": []
    }
  ]
}
