{
  "name": "textimg",
  "version": "0.1.0",
  "description": "Convert text to image from terminal",
  "source": "https://github.com/jiro4989/textimg",
  "checks": [
    {
      "type": "binary",
      "name": "textimg"
    }
  ],
  "install_guidance": {
    "plugin": "textimg",
    "binary": "textimg",
    "check": "which textimg",
    "install_steps": [
      "go install github.com/jiro4989/textimg/cmd/textimg@latest",
      "Verify: textimg --version",
      "supercli plugins install ./plugins/textimg --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "textimg",
      "resource": "self",
      "action": "version",
      "description": "Print textimg version",
      "adapter": "process",
      "adapterConfig": {
        "command": "textimg",
        "missingDependencyHelp": "Install textimg: go install github.com/jiro4989/textimg/cmd/textimg@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "textimg",
      "resource": "text",
      "action": "convert",
      "description": "convert text via textimg",
      "adapter": "process",
      "adapterConfig": {
        "command": "textimg",
        "missingDependencyHelp": "Install textimg: go install github.com/jiro4989/textimg/cmd/textimg@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "textimg",
      "resource": "_",
      "action": "_",
      "description": "_ _ via textimg",
      "adapter": "process",
      "adapterConfig": {
        "command": "textimg",
        "missingDependencyHelp": "Install textimg: go install github.com/jiro4989/textimg/cmd/textimg@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}