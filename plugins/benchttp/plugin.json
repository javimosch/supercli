{
  "name": "benchttp",
  "version": "0.1.0",
  "description": "HTTP benchmarking tool with configurable requests",
  "source": "https://github.com/siadat/benchttp",
  "checks": [
    {
      "type": "binary",
      "name": "benchttp"
    }
  ],
  "install_guidance": {
    "plugin": "benchttp",
    "binary": "benchttp",
    "check": "which benchttp",
    "install_steps": [
      "go install github.com/siadat/benchttp@latest",
      "Verify: benchttp --version",
      "supercli plugins install ./plugins/benchttp --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "benchttp",
      "resource": "self",
      "action": "version",
      "description": "Print benchttp version",
      "adapter": "process",
      "adapterConfig": {
        "command": "benchttp",
        "missingDependencyHelp": "Install benchttp: go install github.com/siadat/benchttp@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "benchttp",
      "resource": "request",
      "action": "bench",
      "description": "bench request via benchttp",
      "adapter": "process",
      "adapterConfig": {
        "command": "benchttp",
        "missingDependencyHelp": "Install benchttp: go install github.com/siadat/benchttp@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "benchttp",
      "resource": "config",
      "action": "show",
      "description": "show config via benchttp",
      "adapter": "process",
      "adapterConfig": {
        "command": "benchttp",
        "missingDependencyHelp": "Install benchttp: go install github.com/siadat/benchttp@latest",
        "baseArgs": [
          "--config"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "benchttp",
      "resource": "_",
      "action": "_",
      "description": "_ _ via benchttp",
      "adapter": "process",
      "adapterConfig": {
        "command": "benchttp",
        "missingDependencyHelp": "Install benchttp: go install github.com/siadat/benchttp@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}