{
  "name": "protodep",
  "version": "0.1.0",
  "description": "Protocol Buffers dependency management tool",
  "source": "https://github.com/stormcat24/protodep",
  "checks": [
    {
      "type": "binary",
      "name": "protodep"
    }
  ],
  "install_guidance": {
    "plugin": "protodep",
    "binary": "protodep",
    "check": "which protodep",
    "install_steps": [
      "go install github.com/stormcat24/protodep@latest",
      "Verify: protodep --version",
      "supercli plugins install ./plugins/protodep --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "protodep",
      "resource": "self",
      "action": "version",
      "description": "Print protodep version",
      "adapter": "process",
      "adapterConfig": {
        "command": "protodep",
        "missingDependencyHelp": "Install protodep: go install github.com/stormcat24/protodep@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "protodep",
      "resource": "deps",
      "action": "update",
      "description": "update deps via protodep",
      "adapter": "process",
      "adapterConfig": {
        "command": "protodep",
        "missingDependencyHelp": "Install protodep: go install github.com/stormcat24/protodep@latest",
        "baseArgs": [
          "up"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "protodep",
      "resource": "deps",
      "action": "status",
      "description": "status deps via protodep",
      "adapter": "process",
      "adapterConfig": {
        "command": "protodep",
        "missingDependencyHelp": "Install protodep: go install github.com/stormcat24/protodep@latest",
        "baseArgs": [
          "status"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "protodep",
      "resource": "_",
      "action": "_",
      "description": "_ _ via protodep",
      "adapter": "process",
      "adapterConfig": {
        "command": "protodep",
        "missingDependencyHelp": "Install protodep: go install github.com/stormcat24/protodep@latest",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}