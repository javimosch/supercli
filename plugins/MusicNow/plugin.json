{
  "name": "MusicNow",
  "version": "0.1.0",
  "description": "CLI tool to download songs with metadata from various sources",
  "source": "https://github.com/kalbhor/MusicNow",
  "checks": [
    {
      "type": "binary",
      "name": "musicnow"
    }
  ],
  "install_guidance": {
    "plugin": "MusicNow",
    "binary": "musicnow",
    "check": "which musicnow",
    "install_steps": [
      "pip install MusicNow",
      "Verify: musicnow --version",
      "supercli plugins install ./plugins/MusicNow --on-conflict replace --json"
    ]
  },
