      "resource": "self",
      "action": "version",
      "description": "Print MusicNow version",
      "adapter": "process",
      "adapterConfig": {
        "command": "musicnow",
        "missingDependencyHelp": "Install MusicNow: pip install MusicNow",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "MusicNow",
      "resource": "song",
      "action": "download",
      "description": "download song via musicnow",
      "adapter": "process",
      "adapterConfig": {
        "command": "musicnow",
        "missingDependencyHelp": "Install MusicNow: pip install MusicNow",
        "baseArgs": [
          "download"
        ],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
