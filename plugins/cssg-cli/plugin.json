      "namespace": "cssg-cli",
      "resource": "self",
      "action": "version",
      "description": "Print cssg-cli version",
      "adapter": "process",
      "adapterConfig": {
        "command": "cssg",
        "missingDependencyHelp": "Install cssg-cli: npm install -g cssg-cli",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "cssg-cli",
      "resource": "tokens",
      "action": "generate",
      "description": "generate tokens via cssg",
      "adapter": "process",
