{
  "name": "cssg-cli",
  "version": "0.1.0",
  "description": "CSS Generator for transforming user interfaces from design tokens",
  "source": "https://github.com/joshuacerbito/cssg-cli",
  "checks": [
    {
      "type": "binary",
      "name": "cssg"
    }
  ],
  "install_guidance": {
    "plugin": "cssg-cli",
    "binary": "cssg",
    "check": "which cssg",
    "install_steps": [
      "npm install -g cssg-cli",
      "Verify: cssg --version",
      "supercli plugins install ./plugins/cssg-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
