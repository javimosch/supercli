{
  "name": "modd",
  "version": "0.1.0",
  "description": "Flexible developer tool for responding to filesystem changes",
  "source": "https://github.com/cortesi/modd",
  "checks": [
    {
      "type": "binary",
      "name": "modd"
    }
  ],
  "install_guidance": {
    "plugin": "modd",
    "binary": "modd",
    "check": "which modd",
    "install_steps": [
      "brew install modd",
      "Verify: modd --version",
      "supercli plugins install ./plugins/modd --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "modd",
      "resource": "self",
      "action": "version",
      "description": "Print modd version",
      "adapter": "process",
      "adapterConfig": {
        "command": "modd",
        "missingDependencyHelp": "Install modd: brew install modd",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "modd",
      "resource": "watch",
      "action": "start",
      "description": "start watch via modd",
      "adapter": "process",
      "adapterConfig": {
        "command": "modd",
        "missingDependencyHelp": "Install modd: brew install modd",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "modd",
      "resource": "_",
      "action": "_",
      "description": "_ _ via modd",
      "adapter": "process",
      "adapterConfig": {
        "command": "modd",
        "missingDependencyHelp": "Install modd: brew install modd",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}