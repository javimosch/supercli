{
  "name": "sttr",
  "version": "0.1.0",
  "description": "Cross-platform CLI app to perform various operations on strings. Transform, encode, decode, and manipulate text.",
  "source": "https://github.com/abhimanyu003/sttr",
  "checks": [
    { "type": "binary", "name": "sttr" }
  ],
  "install_guidance": {
    "plugin": "sttr",
    "binary": "sttr",
    "check": "which sttr",
    "install_steps": [
      "brew install abhimanyu003/sttr/sttr",
      "Verify: sttr -h",
      "supercli plugins install ./plugins/sttr --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "sttr",
      "resource": "transform",
      "action": "string",
      "description": "Transform string with various operations",
      "adapter": "process",
      "adapterConfig": {
        "command": "sttr",
        "passthrough": true,
        "missingDependencyHelp": "Install sttr: brew install abhimanyu003/sttr/sttr"
      },
      "args": [
        { "name": "operation", "type": "string", "description": "Operation to perform" },
        { "name": "input", "type": "string", "description": "Input string or file" }
      ]
    },
    {
      "namespace": "sttr",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to sttr CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "sttr",
        "passthrough": true,
        "missingDependencyHelp": "Install sttr: brew install abhimanyu003/sttr/sttr"
      },
      "args": []
    }
  ]
}
