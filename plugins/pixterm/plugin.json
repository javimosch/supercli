{
  "name": "pixterm",
  "version": "0.1.0",
  "description": "A terminal image viewer. Display images directly in the terminal using ANSI escape codes and TrueColor support.",
  "source": "https://github.com/eliukblau/pixterm",
  "checks": [
    { "type": "binary", "name": "pixterm" }
  ],
  "install_guidance": {
    "plugin": "pixterm",
    "binary": "pixterm",
    "check": "which pixterm",
    "install_steps": [
      "brew install pixterm",
      "Verify: pixterm --version",
      "supercli plugins install ./plugins/pixterm --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "pixterm",
      "resource": "image",
      "action": "display",
      "description": "Display image in terminal",
      "adapter": "process",
      "adapterConfig": {
        "command": "pixterm",
        "baseArgs": [],
        "passthrough": true,
        "missingDependencyHelp": "Install pixterm: brew install pixterm"
      },
      "args": [
        { "name": "image_path", "type": "string", "description": "Image file path" },
        { "name": "--scale", "type": "float", "description": "Image scale factor" },
        { "name": "--true-color", "type": "boolean", "description": "Use TrueColor" }
      ]
    },
    {
      "namespace": "pixterm",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to pixterm CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "pixterm",
        "passthrough": true,
        "missingDependencyHelp": "Install pixterm: brew install pixterm"
      },
      "args": []
    }
  ]
}
