{
  "name": "linchpin",
  "version": "0.1.0",
  "description": "Ansible based multicloud orchestrator for managing infrastructure across cloud providers",
  "source": "https://github.com/CentOS-PaaS-SIG/linchpin",
  "checks": [
    {
      "type": "binary",
      "name": "linchpin"
    }
  ],
  "install_guidance": {
    "plugin": "linchpin",
    "binary": "linchpin",
    "check": "which linchpin",
    "install_steps": [
      "pip install linchpin",
      "Verify: linchpin --version",
      "supercli plugins install ./plugins/linchpin --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "linchpin",
      "resource": "self",
      "action": "version",
      "description": "Print linchpin version",
      "adapter": "process",
      "adapterConfig": {
        "command": "linchpin",
        "missingDependencyHelp": "Install linchpin: pip install linchpin",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "linchpin",
      "resource": "infrastructure",
      "action": "up",
      "description": "up infrastructure via linchpin",
      "adapter": "process",
      "adapterConfig": {
        "command": "linchpin",
        "missingDependencyHelp": "Install linchpin: pip install linchpin",
        "baseArgs": [
          "up"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "linchpin",
      "resource": "infrastructure",
      "action": "destroy",
      "description": "destroy infrastructure via linchpin",
