    "plugin": "stencil",
    "binary": "stencil",
    "check": "which stencil",
    "install_steps": [
      "go install github.com/raystack/stencil@latest",
      "Verify: stencil --version",
      "supercli plugins install ./plugins/stencil --on-conflict replace --json"
