{
  "name": "ftl",
  "version": "0.1.0",
  "description": "Faster than light deployment tool",
  "source": "https://github.com/yarlson/ftl",
  "checks": [
    {
      "type": "binary",
      "name": "ftl"
    }
  ],
  "install_guidance": {
    "plugin": "ftl",
    "binary": "ftl",
    "check": "which ftl",
    "install_steps": [
      "brew install yarlson/tap/ftl",
      "Verify: ftl --version",
      "supercli plugins install ./plugins/ftl --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "ftl",
      "resource": "self",
      "action": "version",
      "description": "Print ftl version",
      "adapter": "process",
      "adapterConfig": {
        "command": "ftl",
        "missingDependencyHelp": "Install ftl: brew install yarlson/tap/ftl",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "ftl",
      "resource": "deploy",
      "action": "run",
      "description": "run deploy via ftl",
      "adapter": "process",
      "adapterConfig": {
        "command": "ftl",
        "missingDependencyHelp": "Install ftl: brew install yarlson/tap/ftl",
        "baseArgs": [
          "deploy"
        ],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "ftl",
      "resource": "build",
      "action": "run",
      "description": "run build via ftl",
      "adapter": "process",
      "adapterConfig": {
        "command": "ftl",
        "missingDependencyHelp": "Install ftl: brew install yarlson/tap/ftl",
        "baseArgs": [
          "build"
        ],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "ftl",
      "resource": "_",
      "action": "_",
      "description": "_ _ via ftl",
      "adapter": "process",
      "adapterConfig": {
        "command": "ftl",
        "missingDependencyHelp": "Install ftl: brew install yarlson/tap/ftl",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}