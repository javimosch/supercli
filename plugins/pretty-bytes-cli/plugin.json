{
  "name": "pretty-bytes-cli",
  "version": "0.1.0",
  "description": "Convert bytes to a human readable string. 1337 → 1.34 kB",
  "source": "https://github.com/sindresorhus/pretty-bytes-cli",
  "checks": [
    { "type": "binary", "name": "pretty-bytes" }
  ],
  "install_guidance": {
    "plugin": "pretty-bytes-cli",
    "binary": "pretty-bytes",
    "check": "which pretty-bytes",
    "install_steps": [
      "npm install -g pretty-bytes-cli",
      "Verify: pretty-bytes --version",
      "supercli plugins install ./plugins/pretty-bytes-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "pretty-bytes",
      "resource": "convert",
      "action": "bytes",
      "description": "Convert bytes to human readable format",
      "adapter": "process",
      "adapterConfig": {
        "command": "pretty-bytes",
        "passthrough": true,
        "missingDependencyHelp": "Install pretty-bytes-cli: npm install -g pretty-bytes-cli"
      },
      "args": [
        { "name": "bytes", "type": "string", "description": "Number of bytes" }
      ]
    },
    {
      "namespace": "pretty-bytes",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to pretty-bytes CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "pretty-bytes",
        "passthrough": true,
        "missingDependencyHelp": "Install pretty-bytes-cli: npm install -g pretty-bytes-cli"
      },
      "args": []
    }
  ]
}
