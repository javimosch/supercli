{
  "name": "wtp",
  "version": "0.1.0",
  "description": "A powerful Git worktree CLI tool with automated setup, branch tracking, and smart navigation",
  "source": "https://github.com/satococoa/wtp",
  "checks": [
    { "type": "binary", "name": "wtp" }
  ],
  "install_guidance": {
    "plugin": "wtp",
    "binary": "wtp",
    "check": "which wtp",
    "install_steps": [
      "brew install satococoa/tap/wtp",
      "Verify: wtp --version"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "wtp",
      "resource": "self",
      "action": "version",
      "description": "Print wtp version",
      "adapter": "process",
      "adapterConfig": {
        "command": "wtp",
        "baseArgs": ["--version"],
        "missingDependencyHelp": "Install wtp: brew install satococoa/tap/wtp"
      },
      "args": []
    },
    {
      "namespace": "wtp",
      "resource": "worktree",
      "action": "add",
      "description": "Add a new Git worktree",
      "adapter": "process",
      "adapterConfig": {
        "command": "wtp",
        "baseArgs": ["add"],
        "missingDependencyHelp": "Install wtp: brew install satococoa/tap/wtp"
      },
      "args": [
        { "name": "branch", "type": "string", "required": true, "description": "Branch name for the worktree" },
        { "name": "path", "type": "string", "required": false, "description": "Directory path for the worktree" }
      ]
    },
    {
      "namespace": "wtp",
      "resource": "worktree",
      "action": "list",
      "description": "List all Git worktrees",
      "adapter": "process",
      "adapterConfig": {
        "command": "wtp",
        "baseArgs": ["list"],
        "missingDependencyHelp": "Install wtp: brew install satococoa/tap/wtp"
      },
      "args": []
    },
    {
      "namespace": "wtp",
      "resource": "worktree",
      "action": "remove",
      "description": "Remove a Git worktree",
      "adapter": "process",
      "adapterConfig": {
        "command": "wtp",
        "baseArgs": ["remove"],
        "missingDependencyHelp": "Install wtp: brew install satococoa/tap/wtp"
      },
      "args": [
        { "name": "worktree", "type": "string", "required": true, "description": "Worktree path or branch to remove" },
        { "name": "force", "type": "boolean", "required": false, "description": "Force removal even if worktree has uncommitted changes" }
      ]
    },
    {
      "namespace": "wtp",
      "resource": "worktree",
      "action": "switch",
      "description": "Switch between worktrees",
      "adapter": "process",
      "adapterConfig": {
        "command": "wtp",
        "baseArgs": ["switch"],
        "missingDependencyHelp": "Install wtp: brew install satococoa/tap/wtp"
      },
      "args": [
        { "name": "branch", "type": "string", "required": true, "description": "Branch to switch to" }
      ]
    },
    {
      "namespace": "wtp",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to wtp CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "wtp",
        "passthrough": true,
        "missingDependencyHelp": "Install wtp: brew install satococoa/tap/wtp"
      },
      "args": []
    }
  ]
}
