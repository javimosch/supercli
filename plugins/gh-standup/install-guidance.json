{
  "plugin": "gh-standup",
  "binary": "gh-standup",
  "check": "gh extension list | grep standup",
  "install_steps": [
    "gh extension install sgoedecke/gh-standup",
    "Verify: gh standup --help",
    "supercli plugins install ./plugins/gh-standup --on-conflict replace --json"
  ],
  "note": "Uses free GitHub Models - no API key needed"
}
