{
  "name": "zq",
  "version": "0.1.0",
  "description": "Zed query language for structured data search and analytics",
  "source": "https://github.com/brimdata/zq",
  "checks": [
    {
      "type": "binary",
      "name": "zq"
    }
  ],
  "install_guidance": {
    "plugin": "zq",
    "binary": "zq",
    "check": "which zq",
    "install_steps": [
      "brew install zed",
      "Verify: zq --version",
      "supercli plugins install ./plugins/zq --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "zq",
      "resource": "self",
      "action": "version",
      "description": "Print zq version",
      "adapter": "process",
      "adapterConfig": {
        "command": "zq",
        "missingDependencyHelp": "Install zq: brew install zed",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "zq",
      "resource": "data",
      "action": "query",
      "description": "query data via zq",
      "adapter": "process",
      "adapterConfig": {
        "command": "zq",
        "missingDependencyHelp": "Install zq: brew install zed",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "zq",
      "resource": "data",
      "action": "search",
      "description": "search data via zq",
      "adapter": "process",
      "adapterConfig": {
        "command": "zq",
        "missingDependencyHelp": "Install zq: brew install zed",
        "baseArgs": [
          "search"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "zq",
      "resource": "_",
      "action": "_",
      "description": "_ _ via zq",
      "adapter": "process",
      "adapterConfig": {
        "command": "zq",
        "missingDependencyHelp": "Install zq: brew install zed",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}