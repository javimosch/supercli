{
  "name": "standard",
  "version": "0.1.0",
  "description": "JavaScript style guide, linter, and formatter",
  "source": "https://github.com/standard/standard",
  "checks": [
    { "type": "binary", "name": "standard" }
  ],
  "install_guidance": {
    "plugin": "standard",
    "binary": "standard",
    "check": "which standard",
    "install_steps": [
      "npm install -g standard",
      "Verify: standard --version",
      "supercli plugins install ./plugins/standard --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "standard",
      "resource": "self",
      "action": "version",
      "description": "Print standard version",
      "adapter": "process",
      "adapterConfig": {
        "command": "standard",
        "baseArgs": ["--version"],
        "missingDependencyHelp": "Install standard: npm install -g standard"
      },
      "args": []
    },
    {
      "namespace": "standard",
      "resource": "file",
      "action": "lint",
      "description": "Lint files with standard",
      "adapter": "process",
      "adapterConfig": {
        "command": "standard",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 60000,
        "missingDependencyHelp": "Install standard: npm install -g standard"
      },
      "args": [
        { "name": "file", "type": "string", "required": false, "description": "File or directory to lint" },
        { "name": "fix", "type": "boolean", "required": false, "description": "Auto-fix problems" },
        { "name": "verbose", "type": "boolean", "required": false, "description": "Verbose output" }
      ]
    },
    {
      "namespace": "standard",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to standard CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "standard",
        "passthrough": true,
        "missingDependencyHelp": "Install standard: npm install -g standard"
      },
      "args": []
    }
  ]
}
