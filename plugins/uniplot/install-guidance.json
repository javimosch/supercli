{
  "plugin": "uniplot",
  "binary": "uniplot",
  "check": "which uniplot",
  "install_steps": [
    "pip install uniplot",
    "Verify: uniplot --help",
    "supercli plugins install ./plugins/uniplot --on-conflict replace --json"
  ],
  "note": "uniplot provides lightweight plotting to the terminal with Unicode"
}
