{
  "name": "uniplot",
  "version": "0.1.0",
  "description": "Lightweight plotting to the terminal with 4x resolution via Unicode",
  "source": "https://github.com/olavolav/uniplot",
  "checks": [
    { "type": "binary", "name": "uniplot" }
  ],
  "install_guidance": {
    "plugin": "uniplot",
    "binary": "uniplot",
    "check": "which uniplot",
    "install_steps": [
      "pip install uniplot",
      "Verify: uniplot --help",
      "supercli plugins install ./plugins/uniplot --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "uniplot",
      "resource": "plot",
      "action": "data",
      "description": "Plot data to terminal",
      "adapter": "process",
      "adapterConfig": {
        "command": "uniplot",
        "cwd": "invoke_cwd",
        "passthrough": true,
        "timeout_ms": 60000,
        "missingDependencyHelp": "Install uniplot: pip install uniplot"
      },
      "args": [
        { "name": "data", "type": "string", "required": true, "description": "Data to plot" }
      ]
    },
    {
      "namespace": "uniplot",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to uniplot CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "uniplot",
        "cwd": "invoke_cwd",
        "passthrough": true,
        "missingDependencyHelp": "Install uniplot: pip install uniplot"
      },
      "args": []
    }
  ]
}
