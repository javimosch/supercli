          "repository",
          "connect"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "kopia",
      "resource": "_",
      "action": "_",
      "description": "_ _ via kopia",
      "adapter": "process",
      "adapterConfig": {
        "command": "kopia",
