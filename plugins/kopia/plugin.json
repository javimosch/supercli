{
  "name": "kopia",
  "version": "0.1.0",
  "description": "Cross-platform backup tool with fast, incremental backups",
  "source": "https://github.com/kopia/kopia",
  "checks": [
    {
      "type": "binary",
      "name": "kopia"
    }
  ],
  "install_guidance": {
    "plugin": "kopia",
    "binary": "kopia",
    "check": "which kopia",
    "install_steps": [
      "brew install kopia",
      "Verify: kopia --version",
      "supercli plugins install ./plugins/kopia --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "kopia",
      "resource": "self",
      "action": "version",
      "description": "Print kopia version",
      "adapter": "process",
      "adapterConfig": {
        "command": "kopia",
        "missingDependencyHelp": "Install kopia: brew install kopia",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "kopia",
      "resource": "snapshot",
      "action": "list",
      "description": "list snapshot via kopia",
      "adapter": "process",
      "adapterConfig": {
        "command": "kopia",
        "missingDependencyHelp": "Install kopia: brew install kopia",
        "baseArgs": [
          "snapshot",
          "list"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "kopia",
      "resource": "repository",
