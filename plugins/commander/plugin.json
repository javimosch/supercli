{
  "name": "commander",
  "version": "0.1.0",
  "description": "CLI testing tool for shell commands",
  "source": "https://github.com/commander-cli/commander",
  "checks": [
    {
      "type": "binary",
      "name": "commander"
    }
  ],
  "install_guidance": {
    "plugin": "commander",
    "binary": "commander",
    "check": "which commander",
    "install_steps": [
      "go install github.com/commander-cli/commander@latest",
      "Verify: commander --version",
      "supercli plugins install ./plugins/commander --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "commander",
      "resource": "self",
      "action": "version",
      "description": "Print commander version",
      "adapter": "process",
      "adapterConfig": {
        "command": "commander",
        "missingDependencyHelp": "Install commander: go install github.com/commander-cli/commander@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "commander",
      "resource": "test",
      "action": "run",
      "description": "run test via commander",
      "adapter": "process",
      "adapterConfig": {
        "command": "commander",
        "missingDependencyHelp": "Install commander: go install github.com/commander-cli/commander@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "commander",
      "resource": "_",
      "action": "_",
      "description": "_ _ via commander",
      "adapter": "process",
      "adapterConfig": {
        "command": "commander",
        "missingDependencyHelp": "Install commander: go install github.com/commander-cli/commander@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}