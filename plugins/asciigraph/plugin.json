{
  "name": "asciigraph",
  "version": "0.1.0",
  "description": "Lightweight ASCII line charting with no dependencies",
  "source": "https://github.com/guptarohit/asciigraph",
  "checks": [
    {
      "type": "binary",
      "name": "asciigraph"
    }
  ],
  "install_guidance": {
    "plugin": "asciigraph",
    "binary": "asciigraph",
    "check": "which asciigraph",
    "install_steps": [
      "go install github.com/guptarohit/asciigraph/cmd/asciigraph@latest",
      "Verify: asciigraph --version",
      "supercli plugins install ./plugins/asciigraph --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "asciigraph",
      "resource": "self",
      "action": "version",
      "description": "Print asciigraph version",
      "adapter": "process",
      "adapterConfig": {
        "command": "asciigraph",
        "missingDependencyHelp": "Install asciigraph: go install github.com/guptarohit/asciigraph/cmd/asciigraph@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "asciigraph",
      "resource": "data",
      "action": "chart",
      "description": "chart data via asciigraph",
      "adapter": "process",
      "adapterConfig": {
        "command": "asciigraph",
        "missingDependencyHelp": "Install asciigraph: go install github.com/guptarohit/asciigraph/cmd/asciigraph@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "asciigraph",
      "resource": "_",
      "action": "_",
      "description": "_ _ via asciigraph",
      "adapter": "process",
      "adapterConfig": {
        "command": "asciigraph",
        "missingDependencyHelp": "Install asciigraph: go install github.com/guptarohit/asciigraph/cmd/asciigraph@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}