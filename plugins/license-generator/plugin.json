{
  "name": "license-generator",
  "version": "0.1.0",
  "description": "Create licenses for your projects right from your terminal",
  "source": "https://github.com/nexxeln/license-generator",
  "checks": [
    {
      "type": "binary",
      "name": "license-generator"
    }
  ],
  "install_guidance": {
    "plugin": "license-generator",
    "binary": "license-generator",
    "check": "which license-generator",
    "install_steps": [
      "cargo install license-generator",
      "Verify: license-generator --version",
      "supercli plugins install ./plugins/license-generator --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "license-generator",
      "resource": "self",
      "action": "version",
      "description": "Print license-generator version",
      "adapter": "process",
      "adapterConfig": {
        "command": "license-generator",
        "missingDependencyHelp": "Install license-generator: cargo install license-generator",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "license-generator",
      "resource": "license",
      "action": "create",
      "description": "create license via license-generator",
      "adapter": "process",
      "adapterConfig": {
        "command": "license-generator",
        "missingDependencyHelp": "Install license-generator: cargo install license-generator",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "license-generator",
      "resource": "license",
      "action": "list",
      "description": "list license via license-generator",
      "adapter": "process",
      "adapterConfig": {
        "command": "license-generator",
        "missingDependencyHelp": "Install license-generator: cargo install license-generator",
        "baseArgs": [
          "--list"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "license-generator",
      "resource": "license",
      "action": "info",
      "description": "info license via license-generator",
      "adapter": "process",
      "adapterConfig": {
        "command": "license-generator",
        "missingDependencyHelp": "Install license-generator: cargo install license-generator",
        "baseArgs": [
          "--info"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "license-generator",
      "resource": "config",
      "action": "show",
      "description": "show config via license-generator",
      "adapter": "process",
      "adapterConfig": {
        "command": "license-generator",
        "missingDependencyHelp": "Install license-generator: cargo install license-generator",
        "baseArgs": [
          "--config"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "license-generator",
      "resource": "_",
      "action": "_",
      "description": "_ _ via license-generator",
      "adapter": "process",
      "adapterConfig": {
        "command": "license-generator",
        "missingDependencyHelp": "Install license-generator: cargo install license-generator",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}