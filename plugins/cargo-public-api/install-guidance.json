{
  "plugin": "cargo-public-api",
  "binary": "cargo-public-api",
  "check": "which cargo-public-api",
  "install_steps": [
    "cargo install cargo-public-api",
    "Verify: cargo public-api --version",
    "supercli plugins install ./plugins/cargo-public-api --on-conflict replace --json"
  ],
  "note": "Requires Rust toolchain. Install via: rustup component add rustfmt."
}
