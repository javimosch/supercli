{
  "plugin": "npkill",
  "binary": "npkill",
  "check": "which npkill",
  "install_steps": [
    "npm install -g npkill",
    "Verify: npkill --help",
    "supercli plugins install ./plugins/npkill --on-conflict replace --json"
