{
  "name": "havener",
  "version": "0.1.0",
  "description": "Swiss army knife for Kubernetes cluster operations",
  "source": "https://github.com/homeport/havener",
  "checks": [
    {
      "type": "binary",
      "name": "havener"
    }
  ],
  "install_guidance": {
    "plugin": "havener",
    "binary": "havener",
    "check": "which havener",
    "install_steps": [
      "brew install havener",
      "Verify: havener --version",
      "supercli plugins install ./plugins/havener --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "havener",
      "resource": "self",
      "action": "version",
      "description": "Print havener version",
      "adapter": "process",
      "adapterConfig": {
        "command": "havener",
        "missingDependencyHelp": "Install havener: brew install havener",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "havener",
      "resource": "node",
      "action": "top",
      "description": "top node via havener",
      "adapter": "process",
      "adapterConfig": {
        "command": "havener",
        "missingDependencyHelp": "Install havener: brew install havener",
        "baseArgs": [
          "node-top"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "havener",
      "resource": "pod",
      "action": "exec",
      "description": "exec pod via havener",
      "adapter": "process",
      "adapterConfig": {
        "command": "havener",
        "missingDependencyHelp": "Install havener: brew install havener",
        "baseArgs": [
          "pod-exec"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "havener",
      "resource": "_",
      "action": "_",
      "description": "_ _ via havener",
      "adapter": "process",
      "adapterConfig": {
        "command": "havener",
        "missingDependencyHelp": "Install havener: brew install havener",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}