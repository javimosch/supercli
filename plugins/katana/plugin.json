{
  "name": "katana",
  "version": "0.1.0",
  "description": "A next-generation crawling and spidering framework. Discover URLs, endpoints, and assets from web applications with headless and standard crawling modes.",
  "source": "https://github.com/projectdiscovery/katana",
  "checks": [
    { "type": "binary", "name": "katana" }
  ],
  "install_guidance": {
    "plugin": "katana",
    "binary": "katana",
    "check": "which katana",
    "install_steps": [
      "brew install katana",
      "Verify: katana -version",
      "supercli plugins install ./plugins/katana --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "katana",
      "resource": "crawl",
      "action": "url",
      "description": "Crawl URL for endpoints and assets",
      "adapter": "process",
      "adapterConfig": {
        "command": "katana",
        "passthrough": true,
        "missingDependencyHelp": "Install katana: brew install katana"
      },
      "args": [
        { "name": "-u", "type": "string", "description": "URL to crawl" },
        { "name": "-d", "type": "integer", "description": "Crawl depth" },
        { "name": "-js-crawl", "type": "boolean", "description": "Enable JavaScript crawling" },
        { "name": "-headless", "type": "boolean", "description": "Headless browser mode" },
        { "name": "-o", "type": "string", "description": "Output file" },
        { "name": "-json", "type": "boolean", "description": "JSON output" },
        { "name": "-field-scope", "type": "string", "description": "Scope field" },
        { "name": "-concurrency", "type": "integer", "description": "Concurrency level" },
        { "name": "-rate-limit", "type": "integer", "description": "Rate limit requests" }
      ]
    },
    {
      "namespace": "katana",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to katana CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "katana",
        "passthrough": true,
        "missingDependencyHelp": "Install katana: brew install katana"
      },
      "args": []
    }
  ]
}
