{
  "name": "bat",
  "version": "0.1.0",
  "description": "A cat(1) clone with syntax highlighting, git integration, automatic paging, and support for showing non-printable characters.",
  "source": "https://github.com/sharkdp/bat",
  "checks": [
    { "type": "binary", "name": "bat" }
  ],
  "install_guidance": {
    "plugin": "bat",
    "binary": "bat",
    "check": "which bat",
    "install_steps": [
      "brew install bat",
      "Verify: bat --version",
      "supercli plugins install ./plugins/bat --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "bat",
      "resource": "file",
      "action": "view",
      "description": "View file with syntax highlighting",
      "adapter": "process",
      "adapterConfig": {
        "command": "bat",
        "passthrough": true,
        "missingDependencyHelp": "Install bat: brew install bat"
      },
      "args": [
        { "name": "--language", "type": "string", "description": "Set language for syntax highlighting" },
        { "name": "--line-range", "type": "string", "description": "Only show specified line range" },
        { "name": "--number", "type": "boolean", "description": "Show line numbers" },
        { "name": "--style", "type": "string", "description": "Set output style" },
        { "name": "--color", "type": "string", "description": "Set color mode" },
        { "name": "--paging", "type": "string", "description": "Control paging mode" },
        { "name": "--wrap", "type": "string", "description": "Control text wrapping" },
        { "name": "--theme", "type": "string", "description": "Set syntax highlighting theme" },
        { "name": "--show-all", "type": "boolean", "description": "Show non-printable characters" },
        { "name": "files", "type": "string", "required": true, "description": "Files to view" }
      ]
    },
    {
      "namespace": "bat",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to bat CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "bat",
        "passthrough": true,
        "missingDependencyHelp": "Install bat: brew install bat"
      },
      "args": []
    }
  ]
}
