{
  "name": "inlets",
  "version": "0.1.0",
  "description": "Expose your local endpoints to the Internet",
  "source": "https://github.com/inlets/inletsctl",
  "checks": [
    {
      "type": "binary",
      "name": "inlets"
    }
  ],
  "install_guidance": {
    "plugin": "inlets",
    "binary": "inlets",
    "check": "which inlets",
    "install_steps": [
      "brew install inlets",
      "Verify: inlets --version",
      "supercli plugins install ./plugins/inlets --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "inlets",
      "resource": "self",
      "action": "version",
      "description": "Print inlets version",
      "adapter": "process",
      "adapterConfig": {
        "command": "inlets",
        "missingDependencyHelp": "Install inlets: brew install inlets",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "inlets",
      "resource": "tunnel",
      "action": "create",
      "description": "create tunnel via inlets",
      "adapter": "process",
      "adapterConfig": {
        "command": "inlets",
        "missingDependencyHelp": "Install inlets: brew install inlets",
        "baseArgs": [
          "create"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "inlets",
      "resource": "tunnel",
      "action": "delete",
      "description": "delete tunnel via inlets",
      "adapter": "process",
      "adapterConfig": {
        "command": "inlets",
        "missingDependencyHelp": "Install inlets: brew install inlets",
        "baseArgs": [
          "delete"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "inlets",
      "resource": "_",
      "action": "_",
      "description": "_ _ via inlets",
      "adapter": "process",
      "adapterConfig": {
        "command": "inlets",
        "missingDependencyHelp": "Install inlets: brew install inlets",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}