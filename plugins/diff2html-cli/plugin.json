{
  "name": "diff2html-cli",
  "version": "0.1.0",
  "description": "Pretty diff to HTML JavaScript CLI for converting diff output to beautiful HTML",
  "source": "https://github.com/rtfpessoa/diff2html-cli",
  "checks": [
    {
      "type": "binary",
      "name": "diff2html"
    }
  ],
  "install_guidance": {
    "plugin": "diff2html-cli",
    "binary": "diff2html",
    "check": "which diff2html",
    "install_steps": [
      "npm install -g diff2html-cli",
      "Verify: diff2html --version",
      "supercli plugins install ./plugins/diff2html-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
