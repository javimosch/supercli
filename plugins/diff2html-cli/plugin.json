        "missingDependencyHelp": "Install diff2html-cli: npm install -g diff2html-cli",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
