      "resource": "self",
      "action": "version",
      "description": "Print diff2html-cli version",
      "adapter": "process",
      "adapterConfig": {
        "command": "diff2html",
        "missingDependencyHelp": "Install diff2html-cli: npm install -g diff2html-cli",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
