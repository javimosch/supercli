{
  "name": "podcast-dl",
  "version": "0.1.0",
  "description": "Download podcast episodes from RSS feeds",
  "source": "https://github.com/lightpohl/podcast-dl",
  "checks": [
    {
      "type": "binary",
      "name": "podcast-dl"
    }
  ],
  "install_guidance": {
    "plugin": "podcast-dl",
    "binary": "podcast-dl",
    "check": "which podcast-dl",
    "install_steps": [
      "npm install -g podcast-dl",
      "Verify: podcast-dl --version",
      "supercli plugins install ./plugins/podcast-dl --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "podcast-dl",
      "resource": "self",
      "action": "version",
      "description": "Print podcast-dl version",
      "adapter": "process",
      "adapterConfig": {
        "command": "podcast-dl",
        "missingDependencyHelp": "Install podcast-dl: npm install -g podcast-dl",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "podcast-dl",
      "resource": "feed",
      "action": "download",
      "description": "download feed via podcast-dl",
      "adapter": "process",
      "adapterConfig": {
        "command": "podcast-dl",
        "missingDependencyHelp": "Install podcast-dl: npm install -g podcast-dl",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "podcast-dl",
      "resource": "_",
      "action": "_",
      "description": "_ _ via podcast-dl",
      "adapter": "process",
      "adapterConfig": {
        "command": "podcast-dl",
        "missingDependencyHelp": "Install podcast-dl: npm install -g podcast-dl",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}