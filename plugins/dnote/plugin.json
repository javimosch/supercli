{
  "name": "dnote",
  "version": "0.1.0",
  "description": "A simple command line notebook for programmers. Take notes, create flashcards, and build a personal knowledge base directly from the terminal.",
  "source": "https://github.com/dnote/dnote",
  "checks": [
    { "type": "binary", "name": "dnote" }
  ],
  "install_guidance": {
    "plugin": "dnote",
    "binary": "dnote",
    "check": "which dnote",
    "install_steps": [
      "brew install dnote",
      "Verify: dnote --version",
      "supercli plugins install ./plugins/dnote --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "dnote",
      "resource": "note",
      "action": "add",
      "description": "Add a new note",
      "adapter": "process",
      "adapterConfig": {
        "command": "dnote",
        "baseArgs": ["add"],
        "passthrough": true,
        "missingDependencyHelp": "Install dnote: brew install dnote"
      },
      "args": [
        { "name": "book", "type": "string", "description": "Notebook name" },
        { "name": "content", "type": "string", "description": "Note content" }
      ]
    },
    {
      "namespace": "dnote",
      "resource": "note",
      "action": "view",
      "description": "View notes",
      "adapter": "process",
      "adapterConfig": {
        "command": "dnote",
        "baseArgs": ["view"],
        "passthrough": true,
        "missingDependencyHelp": "Install dnote: brew install dnote"
      },
      "args": [
        { "name": "book", "type": "string", "description": "Notebook name" },
        { "name": "--query", "type": "string", "description": "Search query" }
      ]
    },
    {
      "namespace": "dnote",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to dnote CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "dnote",
        "passthrough": true,
        "missingDependencyHelp": "Install dnote: brew install dnote"
      },
      "args": []
    }
  ]
}
