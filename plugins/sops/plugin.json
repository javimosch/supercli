  "install_guidance": {
    "plugin": "sops",
    "binary": "sops",
    "check": "which sops",
    "install_steps": [
      "brew install sops",
      "Verify: sops --version",
      "supercli plugins install ./plugins/sops --on-conflict replace --json"
    ]
