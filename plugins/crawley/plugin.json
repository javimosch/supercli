{
  "name": "crawley",
  "version": "0.1.0",
  "description": "Unix-way web crawler and scraping tool",
  "source": "https://github.com/s0rg/crawley",
  "checks": [
    {
      "type": "binary",
      "name": "crawley"
    }
  ],
  "install_guidance": {
    "plugin": "crawley",
    "binary": "crawley",
    "check": "which crawley",
    "install_steps": [
      "go install github.com/s0rg/crawley/cmd/crawley@latest",
      "Verify: crawley --version",
      "supercli plugins install ./plugins/crawley --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "crawley",
      "resource": "self",
      "action": "version",
      "description": "Print crawley version",
      "adapter": "process",
      "adapterConfig": {
        "command": "crawley",
        "missingDependencyHelp": "Install crawley: go install github.com/s0rg/crawley/cmd/crawley@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "crawley",
      "resource": "url",
      "action": "crawl",
      "description": "crawl url via crawley",
      "adapter": "process",
      "adapterConfig": {
        "command": "crawley",
        "missingDependencyHelp": "Install crawley: go install github.com/s0rg/crawley/cmd/crawley@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "crawley",
      "resource": "_",
      "action": "_",
      "description": "_ _ via crawley",
      "adapter": "process",
      "adapterConfig": {
        "command": "crawley",
        "missingDependencyHelp": "Install crawley: go install github.com/s0rg/crawley/cmd/crawley@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}