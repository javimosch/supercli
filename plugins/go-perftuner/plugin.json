{
  "name": "go-perftuner",
  "version": "0.1.0",
  "description": "Performance tuning helper for Go programs",
  "source": "https://github.com/go-perf/go-perftuner",
  "checks": [
    {
      "type": "binary",
      "name": "go-perftuner"
    }
  ],
  "install_guidance": {
    "plugin": "go-perftuner",
    "binary": "go-perftuner",
    "check": "which go-perftuner",
    "install_steps": [
      "go install github.com/go-perf/go-perftuner/cmd/go-perftuner@latest",
      "Verify: go-perftuner --version",
      "supercli plugins install ./plugins/go-perftuner --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "go-perftuner",
      "resource": "self",
      "action": "version",
      "description": "Print go-perftuner version",
      "adapter": "process",
      "adapterConfig": {
        "command": "go-perftuner",
        "missingDependencyHelp": "Install go-perftuner: go install github.com/go-perf/go-perftuner/cmd/go-perftuner@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "go-perftuner",
      "resource": "code",
      "action": "check",
      "description": "check code via go-perftuner",
      "adapter": "process",
      "adapterConfig": {
        "command": "go-perftuner",
        "missingDependencyHelp": "Install go-perftuner: go install github.com/go-perf/go-perftuner/cmd/go-perftuner@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "go-perftuner",
      "resource": "_",
      "action": "_",
      "description": "_ _ via go-perftuner",
      "adapter": "process",
      "adapterConfig": {
        "command": "go-perftuner",
        "missingDependencyHelp": "Install go-perftuner: go install github.com/go-perf/go-perftuner/cmd/go-perftuner@latest",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}