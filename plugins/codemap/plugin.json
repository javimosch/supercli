{
  "name": "codemap",
  "version": "0.1.0",
  "description": "Generate code maps and visualization from source code",
  "source": "https://github.com/JordanCoin/codemap",
  "checks": [
    {
      "type": "binary",
      "name": "codemap"
    }
  ],
  "install_guidance": {
    "plugin": "codemap",
    "binary": "codemap",
    "check": "which codemap",
    "install_steps": [
      "go install github.com/JordanCoin/codemap@latest",
      "Verify: codemap --version",
      "supercli plugins install ./plugins/codemap --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "codemap",
      "resource": "self",
      "action": "version",
      "description": "Print codemap version",
      "adapter": "process",
      "adapterConfig": {
        "command": "codemap",
        "missingDependencyHelp": "Install codemap: go install github.com/JordanCoin/codemap@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "codemap",
      "resource": "code",
      "action": "map",
      "description": "map code via codemap",
      "adapter": "process",
      "adapterConfig": {
        "command": "codemap",
        "missingDependencyHelp": "Install codemap: go install github.com/JordanCoin/codemap@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "codemap",
      "resource": "_",
      "action": "_",
      "description": "_ _ via codemap",
      "adapter": "process",
      "adapterConfig": {
        "command": "codemap",
        "missingDependencyHelp": "Install codemap: go install github.com/JordanCoin/codemap@latest",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}