{
  "name": "git-branchless",
  "version": "0.1.0",
  "description": "High-velocity, monorepo-scale workflow for Git. Branchless workflow for Git with advanced features for managing commits and branches.",
  "source": "https://github.com/arxanas/git-branchless",
  "checks": [
    { "type": "binary", "name": "git-branchless" }
  ],
  "install_guidance": {
    "plugin": "git-branchless",
    "binary": "git-branchless",
    "check": "which git-branchless",
    "install_steps": [
      "brew install git-branchless",
      "Verify: git-branchless --version",
      "supercli plugins install ./plugins/git-branchless --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "git-branchless",
      "resource": "git",
      "action": "smartlog",
      "description": "Show smartlog of commits",
      "adapter": "process",
      "adapterConfig": {
        "command": "git",
        "baseArgs": ["branchless", "smartlog"],
        "passthrough": true,
        "missingDependencyHelp": "Install git-branchless: brew install git-branchless"
      },
      "args": []
    },
    {
      "namespace": "git-branchless",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to git-branchless CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "git",
        "baseArgs": ["branchless"],
        "passthrough": true,
        "missingDependencyHelp": "Install git-branchless: brew install git-branchless"
      },
      "args": []
    }
  ]
}
