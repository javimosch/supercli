      "description": "show config via hud",
      "adapter": "process",
      "adapterConfig": {
        "command": "hud",
        "missingDependencyHelp": "Install hud: cargo install hud",
        "baseArgs": [
          "--config"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
