{
  "name": "hud",
  "version": "0.1.0",
  "description": "Find code blocking your Tokio workers with eBPF-powered diagnostics",
  "source": "https://github.com/cong-or/hud",
  "checks": [
    {
      "type": "binary",
      "name": "hud"
    }
  ],
  "install_guidance": {
    "plugin": "hud",
    "binary": "hud",
    "check": "which hud",
    "install_steps": [
      "cargo install hud",
      "Verify: hud --version",
      "supercli plugins install ./plugins/hud --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "hud",
      "resource": "self",
      "action": "version",
      "description": "Print hud version",
      "adapter": "process",
      "adapterConfig": {
        "command": "hud",
        "missingDependencyHelp": "Install hud: cargo install hud",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "hud",
      "resource": "process",
      "action": "monitor",
      "description": "monitor process via hud",
      "adapter": "process",
      "adapterConfig": {
        "command": "hud",
        "missingDependencyHelp": "Install hud: cargo install hud",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "hud",
      "resource": "process",
      "action": "report",
      "description": "report process via hud",
      "adapter": "process",
      "adapterConfig": {
        "command": "hud",
        "missingDependencyHelp": "Install hud: cargo install hud",
        "baseArgs": [
          "--report"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "hud",
      "resource": "process",
      "action": "trace",
      "description": "trace process via hud",
      "adapter": "process",
      "adapterConfig": {
        "command": "hud",
        "missingDependencyHelp": "Install hud: cargo install hud",
        "baseArgs": [
          "--trace"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "hud",
      "resource": "config",
