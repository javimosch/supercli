{
  "name": "agentic-radar",
  "version": "0.1.0",
  "description": "Security scanner for agentic workflows. Analyzes and assesses agentic systems for security and operational insights.",
  "source": "https://github.com/splx-ai/agentic-radar",
  "checks": [
    { "type": "binary", "name": "agentic-radar" }
  ],
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "agentic-radar",
      "resource": "self",
      "action": "version",
      "description": "Show agentic-radar version",
      "adapter": "process",
      "adapterConfig": {
        "command": "agentic-radar",
        "baseArgs": ["--version"],
        "parseJson": false,
        "missingDependencyHelp": "Please install agentic-radar: pip install agentic-radar"
      },
      "args": []
    },
    {
      "namespace": "agentic-radar",
      "resource": "scan",
      "action": "run",
      "description": "Scan agentic workflow for security issues",
      "adapter": "process",
      "adapterConfig": {
        "command": "agentic-radar",
        "baseArgs": ["scan"],
        "parseJson": false,
        "timeout_ms": 120000,
        "missingDependencyHelp": "Please install agentic-radar: pip install agentic-radar"
      },
      "args": [
        { "name": "target", "type": "string", "required": true, "description": "Target workflow path or URL to scan" },
        { "name": "format", "type": "string", "required": false, "description": "Output format (json, yaml, html)" },
        { "name": "output", "type": "string", "required": false, "description": "Output file path" }
      ]
    },
    {
      "namespace": "agentic-radar",
      "resource": "test",
      "action": "run",
      "description": "Run security tests on agentic system",
      "adapter": "process",
      "adapterConfig": {
        "command": "agentic-radar",
        "baseArgs": ["test"],
        "parseJson": false,
        "timeout_ms": 180000,
        "missingDependencyHelp": "Please install agentic-radar: pip install agentic-radar"
      },
      "args": [
        { "name": "target", "type": "string", "required": true, "description": "Target system or workflow to test" },
        { "name": "suite", "type": "string", "required": false, "description": "Test suite to run" },
        { "name": "verbose", "type": "boolean", "required": false, "description": "Verbose output" }
      ]
    },
    {
      "namespace": "agentic-radar",
      "resource": "report",
      "action": "show",
      "description": "Show security assessment report",
      "adapter": "process",
      "adapterConfig": {
        "command": "agentic-radar",
        "baseArgs": ["report"],
        "parseJson": false,
        "timeout_ms": 60000,
        "missingDependencyHelp": "Please install agentic-radar: pip install agentic-radar"
      },
      "args": [
        { "name": "scan-id", "type": "string", "required": false, "description": "Scan ID to show report for" },
        { "name": "format", "type": "string", "required": false, "description": "Report format (json, yaml, html)" },
        { "name": "output", "type": "string", "required": false, "description": "Output file path" }
      ]
    }
  ]
}
