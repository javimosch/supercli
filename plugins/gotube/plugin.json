{
  "name": "gotube",
  "version": "0.1.0",
  "description": "Simple command line tool for downloading YouTube videos",
  "source": "https://github.com/marethyu/gotube",
  "checks": [
    {
      "type": "binary",
      "name": "gotube"
    }
  ],
  "install_guidance": {
    "plugin": "gotube",
    "binary": "gotube",
    "check": "which gotube",
    "install_steps": [
      "go install github.com/marethyu/gotube@latest",
      "Verify: gotube --version",
      "supercli plugins install ./plugins/gotube --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "gotube",
      "resource": "self",
      "action": "version",
      "description": "Print gotube version",
      "adapter": "process",
      "adapterConfig": {
        "command": "gotube",
        "missingDependencyHelp": "Install gotube: go install github.com/marethyu/gotube@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "gotube",
      "resource": "video",
      "action": "download",
      "description": "download video via gotube",
      "adapter": "process",
      "adapterConfig": {
        "command": "gotube",
        "missingDependencyHelp": "Install gotube: go install github.com/marethyu/gotube@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "gotube",
      "resource": "playlist",
      "action": "download",
      "description": "download playlist via gotube",
      "adapter": "process",
      "adapterConfig": {
        "command": "gotube",
        "missingDependencyHelp": "Install gotube: go install github.com/marethyu/gotube@latest",
        "baseArgs": [
          "--playlist"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "gotube",
      "resource": "audio",
      "action": "extract",
      "description": "extract audio via gotube",
      "adapter": "process",
      "adapterConfig": {
        "command": "gotube",
        "missingDependencyHelp": "Install gotube: go install github.com/marethyu/gotube@latest",
        "baseArgs": [
          "--audio"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "gotube",
      "resource": "_",
      "action": "_",
      "description": "_ _ via gotube",
      "adapter": "process",
      "adapterConfig": {
        "command": "gotube",
        "missingDependencyHelp": "Install gotube: go install github.com/marethyu/gotube@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}