{
  "name": "helm",
  "version": "0.1.0",
  "description": "Helm CLI plugin for dcli",
  "source": "https://helm.sh/docs/helm/",
  "checks": [
    {
      "type": "binary",
      "name": "helm"
    }
  ],
  "commands": [
    {
      "namespace": "helm",
      "resource": "cli",
      "action": "version",
      "description": "Show Helm CLI version",
      "adapter": "process",
      "adapterConfig": {
        "command": "helm",
        "baseArgs": ["version", "--short"],
        "parseJson": false,
        "missingDependencyHelp": "Please install Helm CLI to use this command."
      },
      "args": []
    },
    {
      "namespace": "helm",
      "resource": "_",
      "action": "_",
      "description": "Passthrough command to execute any Helm CLI command",
      "adapter": "process",
      "adapterConfig": {
        "command": "helm",
        "passthrough": true,
        "parseJson": true,
        "missingDependencyHelp": "Please install Helm CLI to use this command."
      },
      "args": []
    }
  ]
}
