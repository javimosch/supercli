{
  "name": "curlie",
  "version": "0.1.0",
  "description": "The power of curl, the ease of use of httpie. A command-line HTTP client with curl's power and httpie's user-friendly interface.",
  "source": "https://github.com/rs/curlie",
  "checks": [
    { "type": "binary", "name": "curlie" }
  ],
  "install_guidance": {
    "plugin": "curlie",
    "binary": "curlie",
    "check": "which curlie",
    "install_steps": [
      "brew install curlie",
      "Verify: curlie --version",
      "supercli plugins install ./plugins/curlie --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "curlie",
      "resource": "http",
      "action": "request",
      "description": "Make HTTP request",
      "adapter": "process",
      "adapterConfig": {
        "command": "curlie",
        "passthrough": true,
        "missingDependencyHelp": "Install curlie: brew install curlie"
      },
      "args": [
        { "name": "method", "type": "string", "description": "HTTP method (GET, POST, PUT, DELETE)" },
        { "name": "url", "type": "string", "description": "Request URL" },
        { "name": "--data", "type": "string", "description": "Request body data" },
        { "name": "--header", "type": "string", "description": "Custom header" },
        { "name": "--verbose", "type": "boolean", "description": "Verbose output" }
      ]
    },
    {
      "namespace": "curlie",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to curlie CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "curlie",
        "passthrough": true,
        "missingDependencyHelp": "Install curlie: brew install curlie"
      },
      "args": []
    }
  ]
}
