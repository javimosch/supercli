{
  "name": "single-file-cli",
  "version": "0.1.0",
  "description": "CLI tool for saving a faithful copy of a complete web page in a single HTML file. Saves all resources inline.",
  "source": "https://github.com/gildas-lormeau/single-file-cli",
  "checks": [
    { "type": "binary", "name": "single-file" }
  ],
  "install_guidance": {
    "plugin": "single-file-cli",
    "binary": "single-file",
    "check": "which single-file",
    "install_steps": [
      "Download from https://github.com/gildas-lormeau/single-file-cli/releases",
      "Verify: single-file --version",
      "supercli plugins install ./plugins/single-file-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "single-file",
      "resource": "save",
      "action": "page",
      "description": "Save web page as single HTML file",
      "adapter": "process",
      "adapterConfig": {
        "command": "single-file",
        "passthrough": true,
        "missingDependencyHelp": "Install single-file-cli from GitHub releases"
      },
      "args": [
        { "name": "url", "type": "string", "description": "URL to save" },
        { "name": "-o", "type": "string", "description": "Output file" },
        { "name": "--browser-executable-path", "type": "string", "description": "Browser path" }
      ]
    },
    {
      "namespace": "single-file",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to single-file CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "single-file",
        "passthrough": true,
        "missingDependencyHelp": "Install single-file-cli from GitHub releases"
      },
      "args": []
    }
  ]
}
