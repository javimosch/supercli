{
  "plugin": "single-file-cli",
  "binary": "single-file",
  "check": "which single-file",
  "install_steps": [
    "Download executable from https://github.com/gildas-lormeau/single-file-cli/releases",
    "Make executable: chmod +x single-file",
    "Move to PATH: mv single-file /usr/local/bin/",
    "Verify: single-file --version",
    "supercli plugins install ./plugins/single-file-cli --on-conflict replace --json"
  ],
  "note": "Requires Chrome or Chromium-based browser. Can run via Deno as standalone script. Saves all CSS, images, and resources inline in a single HTML file."
}
