{
  "name": "cls3",
  "version": "0.1.0",
  "description": "CLI tool to clear and delete S3 buckets and all objects",
  "source": "https://github.com/go-to-k/cls3",
  "checks": [
    {
      "type": "binary",
      "name": "cls3"
    }
  ],
  "install_guidance": {
    "plugin": "cls3",
    "binary": "cls3",
    "check": "which cls3",
    "install_steps": [
      "go install github.com/go-to-k/cls3@latest",
      "Verify: cls3 --version",
      "supercli plugins install ./plugins/cls3 --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "cls3",
      "resource": "self",
      "action": "version",
      "description": "Print cls3 version",
      "adapter": "process",
      "adapterConfig": {
        "command": "cls3",
        "missingDependencyHelp": "Install cls3: go install github.com/go-to-k/cls3@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "cls3",
      "resource": "bucket",
      "action": "clear",
      "description": "clear bucket via cls3",
      "adapter": "process",
      "adapterConfig": {
        "command": "cls3",
        "missingDependencyHelp": "Install cls3: go install github.com/go-to-k/cls3@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "cls3",
      "resource": "bucket",
      "action": "delete",
      "description": "delete bucket via cls3",
      "adapter": "process",
      "adapterConfig": {
        "command": "cls3",
        "missingDependencyHelp": "Install cls3: go install github.com/go-to-k/cls3@latest",
        "baseArgs": [
          "--delete"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "cls3",
      "resource": "_",
      "action": "_",
      "description": "_ _ via cls3",
      "adapter": "process",
      "adapterConfig": {
        "command": "cls3",
        "missingDependencyHelp": "Install cls3: go install github.com/go-to-k/cls3@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}