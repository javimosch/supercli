{
  "name": "terragrunt",
  "version": "0.1.0",
  "description": "Terragrunt is a thin wrapper for Terraform that provides extra tools for working with multiple Terraform modules, managing remote state, and keeping configurations DRY.",
  "source": "https://github.com/gruntwork-io/terragrunt",
  "checks": [
    { "type": "binary", "name": "terragrunt" }
  ],
  "install_guidance": {
    "plugin": "terragrunt",
    "binary": "terragrunt",
    "check": "which terragrunt",
    "install_steps": [
      "brew install terragrunt",
      "Verify: terragrunt --version",
      "supercli plugins install ./plugins/terragrunt --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "terragrunt",
      "resource": "infra",
      "action": "apply",
      "description": "Apply Terraform infrastructure changes",
      "adapter": "process",
      "adapterConfig": {
        "command": "terragrunt",
        "baseArgs": ["apply"],
        "passthrough": true,
        "missingDependencyHelp": "Install terragrunt: brew install terragrunt"
      },
      "args": [
        { "name": "path", "type": "string", "description": "Module path" },
        { "name": "--auto-approve", "type": "boolean", "description": "Auto approve changes" },
        { "name": "--plan", "type": "boolean", "description": "Plan only" }
      ]
    },
    {
      "namespace": "terragrunt",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to terragrunt CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "terragrunt",
        "passthrough": true,
        "missingDependencyHelp": "Install terragrunt: brew install terragrunt"
      },
      "args": []
    }
  ]
}
