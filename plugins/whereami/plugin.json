{
  "name": "whereami",
  "version": "0.1.0",
  "description": "Get your geolocation information from the command line",
  "source": "https://github.com/rafaelrinaldi/whereami",
  "checks": [
    {
      "type": "binary",
      "name": "whereami"
    }
  ],
  "install_guidance": {
    "plugin": "whereami",
    "binary": "whereami",
    "check": "which whereami",
    "install_steps": [
      "npm install -g @rafaelrinaldi/whereami",
      "Verify: whereami --version",
      "supercli plugins install ./plugins/whereami --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "whereami",
      "resource": "self",
      "action": "version",
      "description": "Print whereami version",
      "adapter": "process",
      "adapterConfig": {
        "command": "whereami",
        "missingDependencyHelp": "Install whereami: npm install -g @rafaelrinaldi/whereami",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "whereami",
      "resource": "location",
      "action": "get",
      "description": "get location via whereami",
      "adapter": "process",
      "adapterConfig": {
        "command": "whereami",
        "missingDependencyHelp": "Install whereami: npm install -g @rafaelrinaldi/whereami",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "whereami",
      "resource": "_",
      "action": "_",
      "description": "_ _ via whereami",
      "adapter": "process",
      "adapterConfig": {
        "command": "whereami",
        "missingDependencyHelp": "Install whereami: npm install -g @rafaelrinaldi/whereami",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}