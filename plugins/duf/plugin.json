{
  "name": "duf",
  "version": "0.1.0",
  "description": "Disk Usage/Free Utility - a better df alternative",
  "source": "https://github.com/muesli/duf",
  "checks": [
    {
      "type": "binary",
      "name": "duf"
    }
  ],
  "install_guidance": {
    "plugin": "duf",
    "binary": "duf",
    "check": "which duf",
    "install_steps": [
      "brew install duf",
      "Verify: duf --version",
      "supercli plugins install ./plugins/duf --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "duf",
      "resource": "self",
      "action": "version",
      "description": "Print duf version",
      "adapter": "process",
      "adapterConfig": {
        "command": "duf",
        "missingDependencyHelp": "Install duf: brew install duf",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "duf",
      "resource": "usage",
      "action": "show",
      "description": "show usage via duf",
      "adapter": "process",
      "adapterConfig": {
        "command": "duf",
        "missingDependencyHelp": "Install duf: brew install duf",
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "duf",
      "resource": "_",
      "action": "_",
      "description": "_ _ via duf",
      "adapter": "process",
      "adapterConfig": {
        "command": "duf",
        "missingDependencyHelp": "Install duf: brew install duf",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}