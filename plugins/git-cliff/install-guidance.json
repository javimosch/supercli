{
  "plugin": "git-cliff",
  "binary": "git-cliff",
  "check": "which git-cliff",
  "install_steps": [
    "cargo install git-cliff",
    "Verify: git-cliff --version",
    "Initialize config: git-cliff --init",
    "supercli plugins install ./plugins/git-cliff --on-conflict replace --json"
  ],
  "note": "Generate beautiful changelogs from conventional commits. Supports JSON output for CI pipelines."
}