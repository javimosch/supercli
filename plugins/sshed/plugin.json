{
  "name": "sshed",
  "version": "0.1.0",
  "description": "SSH config editor and bookmarks manager",
  "source": "https://github.com/trntv/sshed",
  "checks": [
    {
      "type": "binary",
      "name": "sshed"
    }
  ],
  "install_guidance": {
    "plugin": "sshed",
    "binary": "sshed",
    "check": "which sshed",
    "install_steps": [
      "go install github.com/trntv/sshed@latest",
      "Verify: sshed --version",
      "supercli plugins install ./plugins/sshed --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "sshed",
      "resource": "self",
      "action": "version",
      "description": "Print sshed version",
      "adapter": "process",
      "adapterConfig": {
        "command": "sshed",
        "missingDependencyHelp": "Install sshed: go install github.com/trntv/sshed@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "sshed",
      "resource": "host",
      "action": "add",
      "description": "add host via sshed",
      "adapter": "process",
      "adapterConfig": {
        "command": "sshed",
        "missingDependencyHelp": "Install sshed: go install github.com/trntv/sshed@latest",
        "baseArgs": [
          "add"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "sshed",
      "resource": "host",
      "action": "list",
      "description": "list host via sshed",
      "adapter": "process",
      "adapterConfig": {
        "command": "sshed",
        "missingDependencyHelp": "Install sshed: go install github.com/trntv/sshed@latest",
        "baseArgs": [
          "list"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "sshed",
      "resource": "host",
      "action": "connect",
      "description": "connect host via sshed",
      "adapter": "process",
      "adapterConfig": {
        "command": "sshed",
        "missingDependencyHelp": "Install sshed: go install github.com/trntv/sshed@latest",
        "baseArgs": [
          "connect"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "sshed",
      "resource": "_",
      "action": "_",
      "description": "_ _ via sshed",
      "adapter": "process",
      "adapterConfig": {
        "command": "sshed",
        "missingDependencyHelp": "Install sshed: go install github.com/trntv/sshed@latest",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}