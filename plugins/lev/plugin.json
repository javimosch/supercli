{
  "name": "lev",
  "version": "0.1.0",
  "description": "LevelDB CLI tool for database inspection",
  "source": "https://github.com/heapwolf/lev",
  "checks": [
    {
      "type": "binary",
      "name": "lev"
    }
  ],
  "install_guidance": {
    "plugin": "lev",
    "binary": "lev",
    "check": "which lev",
    "install_steps": [
      "npm install -g lev",
      "Verify: lev --version",
      "supercli plugins install ./plugins/lev --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "lev",
      "resource": "self",
      "action": "version",
      "description": "Print lev version",
      "adapter": "process",
      "adapterConfig": {
        "command": "lev",
        "missingDependencyHelp": "Install lev: npm install -g lev",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "lev",
      "resource": "db",
      "action": "inspect",
      "description": "inspect db via lev",
      "adapter": "process",
      "adapterConfig": {
        "command": "lev",
        "missingDependencyHelp": "Install lev: npm install -g lev",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "lev",
      "resource": "_",
      "action": "_",
      "description": "_ _ via lev",
      "adapter": "process",
      "adapterConfig": {
        "command": "lev",
        "missingDependencyHelp": "Install lev: npm install -g lev",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}