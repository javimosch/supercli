{
  "name": "parquet-tools",
  "version": "0.1.0",
  "description": "Easy install parquet-tools for working with Parquet files from command line",
  "source": "https://github.com/ktrueda/parquet-tools",
  "checks": [
    {
      "type": "binary",
      "name": "parquet-tools"
    }
  ],
  "install_guidance": {
    "plugin": "parquet-tools",
    "binary": "parquet-tools",
    "check": "which parquet-tools",
    "install_steps": [
      "pip install parquet-tools",
      "Verify: parquet-tools --version",
      "supercli plugins install ./plugins/parquet-tools --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "parquet-tools",
      "resource": "self",
      "action": "version",
      "description": "Print parquet-tools version",
      "adapter": "process",
      "adapterConfig": {
        "command": "parquet-tools",
        "missingDependencyHelp": "Install parquet-tools: pip install parquet-tools",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "parquet-tools",
      "resource": "file",
      "action": "show",
      "description": "show file via parquet-tools",
      "adapter": "process",
      "adapterConfig": {
        "command": "parquet-tools",
        "missingDependencyHelp": "Install parquet-tools: pip install parquet-tools",
        "baseArgs": [
          "show"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
