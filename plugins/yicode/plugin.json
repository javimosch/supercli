{
  "name": "yicode",
  "version": "0.1.0",
  "description": "CLI tool for code generation and management",
  "source": "https://github.com/chenbimo/yicode",
  "checks": [
    {
      "type": "binary",
      "name": "yicode"
    }
  ],
  "install_guidance": {
    "plugin": "yicode",
    "binary": "yicode",
    "check": "which yicode",
    "install_steps": [
      "npm install -g yicode",
      "Verify: yicode --version",
      "supercli plugins install ./plugins/yicode --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "yicode",
      "resource": "self",
      "action": "version",
      "description": "Print yicode version",
      "adapter": "process",
      "adapterConfig": {
        "command": "yicode",
        "missingDependencyHelp": "Install yicode: npm install -g yicode",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "yicode",
      "resource": "code",
      "action": "generate",
      "description": "generate code via yicode",
      "adapter": "process",
      "adapterConfig": {
        "command": "yicode",
        "missingDependencyHelp": "Install yicode: npm install -g yicode",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "yicode",
      "resource": "project",
      "action": "init",
      "description": "init project via yicode",
      "adapter": "process",
      "adapterConfig": {
        "command": "yicode",
        "missingDependencyHelp": "Install yicode: npm install -g yicode",
        "baseArgs": [
          "init"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "yicode",
      "resource": "_",
      "action": "_",
      "description": "_ _ via yicode",
      "adapter": "process",
      "adapterConfig": {
        "command": "yicode",
        "missingDependencyHelp": "Install yicode: npm install -g yicode",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}