{
  "name": "ramadan-cli",
  "version": "0.1.0",
  "description": "CLI to check Sehar and Iftar times in Ramadan anywhere in the world",
  "source": "https://github.com/ahmadawais/ramadan-cli",
  "checks": [
    {
      "type": "binary",
      "name": "ramadan-cli"
    }
  ],
  "install_guidance": {
    "plugin": "ramadan-cli",
    "binary": "ramadan-cli",
    "check": "which ramadan-cli",
    "install_steps": [
      "npm install -g ramadan-cli",
      "Verify: ramadan-cli --version",
      "supercli plugins install ./plugins/ramadan-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "ramadan-cli",
      "resource": "self",
      "action": "version",
      "description": "Print ramadan-cli version",
      "adapter": "process",
      "adapterConfig": {
        "command": "ramadan-cli",
        "missingDependencyHelp": "Install ramadan-cli: npm install -g ramadan-cli",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "ramadan-cli",
      "resource": "ramadan",
      "action": "times",
      "description": "times ramadan via ramadan-cli",
      "adapter": "process",
      "adapterConfig": {
        "command": "ramadan-cli",
        "missingDependencyHelp": "Install ramadan-cli: npm install -g ramadan-cli",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
