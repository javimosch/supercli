{
  "name": "pnpm",
  "version": "0.1.0",
  "description": "pnpm CLI plugin for dcli",
  "source": "https://pnpm.io/cli",
  "checks": [
    {
      "type": "binary",
      "name": "pnpm"
    }
  ],
  "commands": [
    {
      "namespace": "pnpm",
      "resource": "cli",
      "action": "version",
      "description": "Show pnpm CLI version",
      "adapter": "process",
      "adapterConfig": {
        "command": "pnpm",
        "baseArgs": ["--version"],
        "parseJson": false,
        "missingDependencyHelp": "Please install pnpm to use this command."
      },
      "args": []
    },
    {
      "namespace": "pnpm",
      "resource": "_",
      "action": "_",
      "description": "Passthrough command to execute any pnpm CLI command",
      "adapter": "process",
      "adapterConfig": {
        "command": "pnpm",
        "passthrough": true,
        "parseJson": true,
        "missingDependencyHelp": "Please install pnpm to use this command."
      },
      "args": []
    }
  ]
}
