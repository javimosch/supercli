{
  "name": "node-rename-cli",
  "version": "0.1.0",
  "description": "Batch rename files and directories",
  "source": "https://github.com/jhotmann/node-rename-cli",
  "checks": [
    {
      "type": "binary",
      "name": "rename"
    }
  ],
  "install_guidance": {
    "plugin": "node-rename-cli",
    "binary": "rename",
    "check": "which rename",
    "install_steps": [
      "npm install -g rename-cli",
      "Verify: rename --version",
      "supercli plugins install ./plugins/node-rename-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "node-rename-cli",
      "resource": "self",
      "action": "version",
      "description": "Print node-rename-cli version",
      "adapter": "process",
      "adapterConfig": {
        "command": "rename",
        "missingDependencyHelp": "Install node-rename-cli: npm install -g rename-cli",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "node-rename-cli",
      "resource": "files",
      "action": "rename",
      "description": "rename files via rename",
      "adapter": "process",
      "adapterConfig": {
        "command": "rename",
        "missingDependencyHelp": "Install node-rename-cli: npm install -g rename-cli",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "node-rename-cli",
      "resource": "_",
      "action": "_",
      "description": "_ _ via rename",
      "adapter": "process",
      "adapterConfig": {
        "command": "rename",
        "missingDependencyHelp": "Install node-rename-cli: npm install -g rename-cli",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}