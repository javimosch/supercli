{
  "name": "node-file-converter",
  "version": "0.1.0",
  "description": "CLI tool for converting files to different formats",
  "source": "https://github.com/suroorwijdan/node-file-converter",
  "checks": [
    { "type": "binary", "name": "nfc" }
  ],
  "install_guidance": {
    "plugin": "node-file-converter",
    "binary": "nfc",
    "check": "which nfc",
    "install_steps": [
      "npm install -g node-file-converter",
      "Verify: nfc",
      "supercli plugins install ./plugins/node-file-converter --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "node-file-converter",
      "resource": "file",
      "action": "convert",
      "description": "Convert file format",
      "adapter": "process",
      "adapterConfig": {
        "command": "nfc",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 120000,
        "missingDependencyHelp": "Install node-file-converter: npm install -g node-file-converter"
      },
      "args": [
        { "name": "source", "type": "string", "required": true, "description": "Source file path" },
        { "name": "destination", "type": "string", "required": true, "description": "Destination file path" }
      ]
    },
    {
      "namespace": "node-file-converter",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to nfc CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "nfc",
        "passthrough": true,
        "missingDependencyHelp": "Install node-file-converter: npm install -g node-file-converter"
      },
      "args": []
    }
  ]
}
