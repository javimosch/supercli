{
  "plugin": "qrtool",
  "binary": "qrtool",
  "check": "which qrtool",
  "install_steps": [
    "cargo install qrtool",
    "Verify: qrtool --help",
    "supercli plugins install ./plugins/qrtool --on-conflict replace --json"
  ],
  "note": "qrtool provides QR code encoding and decoding from CLI"
}
