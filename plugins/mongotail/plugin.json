{
  "name": "mongotail",
  "version": "0.1.0",
  "description": "Command line tool to log all MongoDB queries in a tailable format",
  "source": "https://github.com/mrsarm/mongotail",
  "checks": [
    {
      "type": "binary",
      "name": "mongotail"
    }
  ],
  "install_guidance": {
    "plugin": "mongotail",
    "binary": "mongotail",
    "check": "which mongotail",
    "install_steps": [
      "pip install mongotail",
      "Verify: mongotail --version",
      "supercli plugins install ./plugins/mongotail --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "mongotail",
      "resource": "self",
      "action": "version",
      "description": "Print mongotail version",
      "adapter": "process",
      "adapterConfig": {
        "command": "mongotail",
        "missingDependencyHelp": "Install mongotail: pip install mongotail",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "mongotail",
      "resource": "query",
      "action": "tail",
      "description": "tail query via mongotail",
      "adapter": "process",
      "adapterConfig": {
        "command": "mongotail",
        "missingDependencyHelp": "Install mongotail: pip install mongotail",
        "baseArgs": [
          "tail"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
