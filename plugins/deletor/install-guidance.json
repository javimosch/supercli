{
  "plugin": "deletor",
  "binary": "deletor",
  "check": "which deletor",
  "install_steps": [
    "go install github.com/pashkov256/deletor@latest",
    "Verify: deletor --version",
    "supercli plugins install ./plugins/deletor --on-conflict replace --json"
  ],
  "note": "Requires Go installed. Also supports building from source (git clone + go build)."
}
