{
  "name": "dtctl",
  "version": "0.1.0",
  "description": "Command line tool for Dynatrace platform management",
  "source": "https://github.com/dynatrace-oss/dtctl",
  "checks": [
    {
      "type": "binary",
      "name": "dtctl"
    }
  ],
  "install_guidance": {
    "plugin": "dtctl",
    "binary": "dtctl",
    "check": "which dtctl",
    "install_steps": [
      "go install github.com/dynatrace-oss/dtctl@latest",
      "Verify: dtctl --version",
      "supercli plugins install ./plugins/dtctl --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "dtctl",
      "resource": "self",
      "action": "version",
      "description": "Print dtctl version",
      "adapter": "process",
      "adapterConfig": {
        "command": "dtctl",
        "missingDependencyHelp": "Install dtctl: go install github.com/dynatrace-oss/dtctl@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "dtctl",
      "resource": "config",
      "action": "list",
      "description": "list config via dtctl",
      "adapter": "process",
      "adapterConfig": {
        "command": "dtctl",
        "missingDependencyHelp": "Install dtctl: go install github.com/dynatrace-oss/dtctl@latest",
        "baseArgs": [
          "config",
          "list"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "dtctl",
      "resource": "tenant",
      "action": "list",
      "description": "list tenant via dtctl",
      "adapter": "process",
      "adapterConfig": {
        "command": "dtctl",
        "missingDependencyHelp": "Install dtctl: go install github.com/dynatrace-oss/dtctl@latest",
        "baseArgs": [
          "tenant",
          "list"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "dtctl",
      "resource": "_",
      "action": "_",
      "description": "_ _ via dtctl",
      "adapter": "process",
      "adapterConfig": {
        "command": "dtctl",
        "missingDependencyHelp": "Install dtctl: go install github.com/dynatrace-oss/dtctl@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}