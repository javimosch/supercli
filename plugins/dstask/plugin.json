{
  "name": "dstask",
  "version": "0.1.0",
  "description": "A personal command-line todo manager. Manage tasks with tags, contexts, and priorities from the command line with git-backed storage.",
  "source": "https://github.com/naggie/dstask",
  "checks": [
    { "type": "binary", "name": "dstask" }
  ],
  "install_guidance": {
    "plugin": "dstask",
    "binary": "dstask",
    "check": "which dstask",
    "install_steps": [
      "brew install dstask",
      "Verify: dstask --version",
      "supercli plugins install ./plugins/dstask --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "dstask",
      "resource": "task",
      "action": "add",
      "description": "Add a new task",
      "adapter": "process",
      "adapterConfig": {
        "command": "dstask",
        "baseArgs": ["add"],
        "passthrough": true,
        "missingDependencyHelp": "Install dstask: brew install dstask"
      },
      "args": [
        { "name": "text", "type": "string", "description": "Task description" },
        { "name": "--tag", "type": "string", "description": "Task tag" },
        { "name": "--priority", "type": "string", "description": "Task priority (P1, P2, P3)" },
        { "name": "--project", "type": "string", "description": "Project name" }
      ]
    },
    {
      "namespace": "dstask",
      "resource": "task",
      "action": "list",
      "description": "List tasks",
      "adapter": "process",
      "adapterConfig": {
        "command": "dstask",
        "baseArgs": ["show"],
        "passthrough": true,
        "missingDependencyHelp": "Install dstask: brew install dstask"
      },
      "args": [
        { "name": "--tag", "type": "string", "description": "Filter by tag" },
        { "name": "--project", "type": "string", "description": "Filter by project" },
        { "name": "--status", "type": "string", "description": "Filter by status" }
      ]
    },
    {
      "namespace": "dstask",
      "resource": "task",
      "action": "complete",
      "description": "Complete a task",
      "adapter": "process",
      "adapterConfig": {
        "command": "dstask",
        "baseArgs": ["done"],
        "passthrough": true,
        "missingDependencyHelp": "Install dstask: brew install dstask"
      },
      "args": [
        { "name": "id", "type": "string", "description": "Task ID" }
      ]
    },
    {
      "namespace": "dstask",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to dstask CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "dstask",
        "passthrough": true,
        "missingDependencyHelp": "Install dstask: brew install dstask"
      },
      "args": []
    }
  ]
}
