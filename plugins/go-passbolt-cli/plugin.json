{
  "name": "go-passbolt-cli",
  "version": "0.1.0",
  "description": "Command line client for Passbolt password manager",
  "source": "https://github.com/passbolt/go-passbolt-cli",
  "checks": [
    {
      "type": "binary",
      "name": "passbolt"
    }
  ],
  "install_guidance": {
    "plugin": "go-passbolt-cli",
    "binary": "passbolt",
    "check": "which passbolt",
    "install_steps": [
      "go install github.com/passbolt/go-passbolt-cli@latest",
      "Verify: passbolt --version",
      "supercli plugins install ./plugins/go-passbolt-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "go-passbolt-cli",
      "resource": "self",
      "action": "version",
      "description": "Print go-passbolt-cli version",
      "adapter": "process",
      "adapterConfig": {
        "command": "passbolt",
        "missingDependencyHelp": "Install go-passbolt-cli: go install github.com/passbolt/go-passbolt-cli@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "go-passbolt-cli",
      "resource": "resource",
      "action": "list",
      "description": "list resource via passbolt",
      "adapter": "process",
      "adapterConfig": {
        "command": "passbolt",
        "missingDependencyHelp": "Install go-passbolt-cli: go install github.com/passbolt/go-passbolt-cli@latest",
        "baseArgs": [
          "list",
          "resource"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "go-passbolt-cli",
      "resource": "resource",
      "action": "get",
      "description": "get resource via passbolt",
      "adapter": "process",
      "adapterConfig": {
        "command": "passbolt",
        "missingDependencyHelp": "Install go-passbolt-cli: go install github.com/passbolt/go-passbolt-cli@latest",
        "baseArgs": [
          "get",
          "resource"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "go-passbolt-cli",
      "resource": "folder",
      "action": "list",
      "description": "list folder via passbolt",
      "adapter": "process",
      "adapterConfig": {
        "command": "passbolt",
        "missingDependencyHelp": "Install go-passbolt-cli: go install github.com/passbolt/go-passbolt-cli@latest",
        "baseArgs": [
          "list",
          "folder"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "go-passbolt-cli",
      "resource": "user",
      "action": "list",
      "description": "list user via passbolt",
      "adapter": "process",
      "adapterConfig": {
        "command": "passbolt",
        "missingDependencyHelp": "Install go-passbolt-cli: go install github.com/passbolt/go-passbolt-cli@latest",
        "baseArgs": [
          "list",
          "user"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "go-passbolt-cli",
      "resource": "_",
      "action": "_",
      "description": "_ _ via passbolt",
      "adapter": "process",
      "adapterConfig": {
        "command": "passbolt",
        "missingDependencyHelp": "Install go-passbolt-cli: go install github.com/passbolt/go-passbolt-cli@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}