{
  "plugin": "prism",
  "binary": "prism",
  "check": "which prism",
  "install_steps": [
    "go install go.dalton.dog/prism@latest",
    "Verify: prism --help",
    "supercli plugins install ./plugins/prism --on-conflict replace --json"
  ],
  "note": "Also available via Homebrew: brew install --cask daltonsw/tap/prism"
}
