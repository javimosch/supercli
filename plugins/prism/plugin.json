{
  "name": "prism",
  "version": "0.1.0",
  "description": "Make unit test output beautiful — colorized, formatted Go test results",
  "source": "https://github.com/DaltonSW/prism",
  "checks": [
    { "type": "binary", "name": "prism" }
  ],
  "install_guidance": {
    "plugin": "prism",
    "binary": "prism",
    "check": "which prism",
    "install_steps": [
      "go install go.dalton.dog/prism@latest",
      "Verify: prism --version",
      "supercli plugins install ./plugins/prism --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "prism",
      "resource": "self",
      "action": "version",
      "description": "Print prism help",
      "adapter": "process",
      "adapterConfig": {
        "command": "prism",
        "baseArgs": ["--help"],
        "missingDependencyHelp": "Install prism: go install go.dalton.dog/prism@latest"
      },
      "args": []
    },
    {
      "namespace": "prism",
      "resource": "test",
      "action": "run",
      "description": "Run tests with prism",
      "adapter": "process",
      "adapterConfig": {
        "command": "prism",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 120000,
        "missingDependencyHelp": "Install prism"
      },
      "args": []
    },
    {
      "namespace": "prism",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to prism CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "prism",
        "passthrough": true,
        "missingDependencyHelp": "Install prism"
      },
      "args": []
    }
  ]
}
