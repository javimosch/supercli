{
  "name": "addons-linter",
  "version": "0.1.0",
  "description": "Linter for Firefox WebExtensions and addons",
  "source": "https://github.com/mozilla/addons-linter",
  "checks": [
    {
      "type": "binary",
      "name": "addons-linter"
    }
  ],
  "install_guidance": {
    "plugin": "addons-linter",
    "binary": "addons-linter",
    "check": "which addons-linter",
    "install_steps": [
      "npm install -g addons-linter",
      "Verify: addons-linter --version",
      "supercli plugins install ./plugins/addons-linter --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "addons-linter",
      "resource": "self",
      "action": "version",
      "description": "Print addons-linter version",
      "adapter": "process",
      "adapterConfig": {
        "command": "addons-linter",
        "missingDependencyHelp": "Install addons-linter: npm install -g addons-linter",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "addons-linter",
      "resource": "extension",
      "action": "lint",
      "description": "lint extension via addons-linter",
      "adapter": "process",
      "adapterConfig": {
        "command": "addons-linter",
        "missingDependencyHelp": "Install addons-linter: npm install -g addons-linter",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "addons-linter",
      "resource": "_",
      "action": "_",
      "description": "_ _ via addons-linter",
      "adapter": "process",
      "adapterConfig": {
        "command": "addons-linter",
        "missingDependencyHelp": "Install addons-linter: npm install -g addons-linter",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}