{
  "name": "dua-cli",
  "version": "0.1.0",
  "description": "View disk space usage and delete unwanted data",
  "source": "https://github.com/Byron/dua-cli",
  "checks": [
    {
      "type": "binary",
      "name": "dua"
    }
  ],
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "dua",
      "resource": "usage",
      "action": "view",
      "description": "View disk space usage",
      "adapter": "process",
      "adapterConfig": {
        "command": "dua",
        "passthrough": true
      },
      "args": [
        {
          "name": "path",
          "type": "string",
          "description": "Path to analyze",
          "default": "."
        }
      ]
    },
    {
      "namespace": "dua",
      "resource": "interactive",
      "action": "browse",
      "description": "Interactive disk usage browser",
      "adapter": "process",
      "adapterConfig": {
        "command": "dua",
        "baseArgs": [
          "i"
        ],
        "passthrough": true
      },
      "args": [
        {
          "name": "path",
          "type": "string",
          "description": "Path to browse"
        }
      ]
    }
  ]
}