    {
      "type": "binary",
      "name": "age"
    }
  ],
  "install_guidance": {
    "plugin": "age",
    "binary": "age",
    "check": "which age",
    "install_steps": [
      "brew install age",
      "Verify: age --version",
      "supercli plugins install ./plugins/age --on-conflict replace --json"
    ]
