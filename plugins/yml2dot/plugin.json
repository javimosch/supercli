{
  "name": "yml2dot",
  "version": "0.1.0",
  "description": "Convert YAML to DOT language representation",
  "source": "https://github.com/lucasepe/yml2dot",
  "checks": [
    {
      "type": "binary",
      "name": "yml2dot"
    }
  ],
  "install_guidance": {
    "plugin": "yml2dot",
    "binary": "yml2dot",
    "check": "which yml2dot",
    "install_steps": [
      "go install github.com/lucasepe/yml2dot@latest",
      "Verify: yml2dot --version",
      "supercli plugins install ./plugins/yml2dot --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "yml2dot",
      "resource": "self",
      "action": "version",
      "description": "Print yml2dot version",
      "adapter": "process",
      "adapterConfig": {
        "command": "yml2dot",
        "missingDependencyHelp": "Install yml2dot: go install github.com/lucasepe/yml2dot@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "yml2dot",
      "resource": "file",
      "action": "convert",
      "description": "convert file via yml2dot",
      "adapter": "process",
      "adapterConfig": {
        "command": "yml2dot",
        "missingDependencyHelp": "Install yml2dot: go install github.com/lucasepe/yml2dot@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "yml2dot",
      "resource": "_",
      "action": "_",
      "description": "_ _ via yml2dot",
      "adapter": "process",
      "adapterConfig": {
        "command": "yml2dot",
        "missingDependencyHelp": "Install yml2dot: go install github.com/lucasepe/yml2dot@latest",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}