{
  "plugin": "bluebuild",
  "binary": "bluebuild",
  "check": "which bluebuild",
  "install_steps": [
    "cargo install bluebuild",
    "Verify: bluebuild --version",
    "supercli plugins install ./plugins/bluebuild --on-conflict replace --json"
  ],
  "note": "Requires Docker v23+, Podman v4+, or Buildah v1.29+. Also available via GitHub releases."
}
