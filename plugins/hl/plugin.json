{
  "name": "hl",
  "version": "0.1.0",
  "description": "Log file highlighter. A fast and powerful log viewer with syntax highlighting, filtering, and live tail support for various log formats.",
  "source": "https://github.com/pamburus/hl",
  "checks": [
    { "type": "binary", "name": "hl" }
  ],
  "install_guidance": {
    "plugin": "hl",
    "binary": "hl",
    "check": "which hl",
    "install_steps": [
      "brew install pamburus/tap/hl",
      "Verify: hl --version",
      "supercli plugins install ./plugins/hl --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "hl",
      "resource": "log",
      "action": "view",
      "description": "View and highlight log files",
      "adapter": "process",
      "adapterConfig": {
        "command": "hl",
        "passthrough": true,
        "missingDependencyHelp": "Install hl: brew install pamburus/tap/hl"
      },
      "args": [
        { "name": "file", "type": "string", "description": "Log file path" },
        { "name": "--filter", "type": "string", "description": "Filter expression" },
        { "name": "--follow", "type": "boolean", "description": "Follow mode (tail -f)" },
        { "name": "--level", "type": "string", "description": "Minimum log level" }
      ]
    },
    {
      "namespace": "hl",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to hl CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "hl",
        "passthrough": true,
        "missingDependencyHelp": "Install hl: brew install pamburus/tap/hl"
      },
      "args": []
    }
  ]
}
