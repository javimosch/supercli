{
  "name": "npm-upgrade",
  "version": "0.1.0",
  "description": "Interactive CLI utility to upgrade npm packages",
  "source": "https://github.com/th0r/npm-upgrade",
  "checks": [
    {
      "type": "binary",
      "name": "npm-upgrade"
    }
  ],
  "install_guidance": {
    "plugin": "npm-upgrade",
    "binary": "npm-upgrade",
    "check": "which npm-upgrade",
    "install_steps": [
      "npm install -g npm-upgrade",
      "Verify: npm-upgrade --version",
      "supercli plugins install ./plugins/npm-upgrade --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "npm-upgrade",
      "resource": "self",
      "action": "version",
      "description": "Print npm-upgrade version",
      "adapter": "process",
      "adapterConfig": {
        "command": "npm-upgrade",
        "missingDependencyHelp": "Install npm-upgrade: npm install -g npm-upgrade",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "npm-upgrade",
      "resource": "deps",
      "action": "check",
      "description": "check deps via npm-upgrade",
      "adapter": "process",
      "adapterConfig": {
        "command": "npm-upgrade",
        "missingDependencyHelp": "Install npm-upgrade: npm install -g npm-upgrade",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "npm-upgrade",
      "resource": "deps",
      "action": "upgrade",
      "description": "upgrade deps via npm-upgrade",
      "adapter": "process",
      "adapterConfig": {
        "command": "npm-upgrade",
        "missingDependencyHelp": "Install npm-upgrade: npm install -g npm-upgrade",
        "baseArgs": [
          "-i"
        ],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "npm-upgrade",
      "resource": "_",
      "action": "_",
      "description": "_ _ via npm-upgrade",
      "adapter": "process",
      "adapterConfig": {
        "command": "npm-upgrade",
        "missingDependencyHelp": "Install npm-upgrade: npm install -g npm-upgrade",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}