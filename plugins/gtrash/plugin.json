{
  "name": "gtrash",
  "version": "0.1.0",
  "description": "Trash CLI that moves files to system trash instead of deleting",
  "source": "https://github.com/umlx5h/gtrash",
  "checks": [
    {
      "type": "binary",
      "name": "gtrash"
    }
  ],
  "install_guidance": {
    "plugin": "gtrash",
    "binary": "gtrash",
    "check": "which gtrash",
    "install_steps": [
      "brew install gtrash",
      "Verify: gtrash --version",
      "supercli plugins install ./plugins/gtrash --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "gtrash",
      "resource": "self",
      "action": "version",
      "description": "Print gtrash version",
      "adapter": "process",
      "adapterConfig": {
        "command": "gtrash",
        "missingDependencyHelp": "Install gtrash: brew install gtrash",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "gtrash",
      "resource": "file",
      "action": "trash",
      "description": "trash file via gtrash",
      "adapter": "process",
      "adapterConfig": {
        "command": "gtrash",
        "missingDependencyHelp": "Install gtrash: brew install gtrash",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "gtrash",
      "resource": "file",
      "action": "restore",
      "description": "restore file via gtrash",
      "adapter": "process",
      "adapterConfig": {
        "command": "gtrash",
        "missingDependencyHelp": "Install gtrash: brew install gtrash",
        "baseArgs": [
          "restore"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "gtrash",
      "resource": "file",
      "action": "list",
      "description": "list file via gtrash",
      "adapter": "process",
      "adapterConfig": {
        "command": "gtrash",
        "missingDependencyHelp": "Install gtrash: brew install gtrash",
        "baseArgs": [
          "list"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "gtrash",
      "resource": "file",
      "action": "empty",
      "description": "empty file via gtrash",
      "adapter": "process",
      "adapterConfig": {
        "command": "gtrash",
        "missingDependencyHelp": "Install gtrash: brew install gtrash",
        "baseArgs": [
          "empty"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "gtrash",
      "resource": "_",
      "action": "_",
      "description": "_ _ via gtrash",
      "adapter": "process",
      "adapterConfig": {
        "command": "gtrash",
        "missingDependencyHelp": "Install gtrash: brew install gtrash",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
