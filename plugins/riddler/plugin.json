{
  "name": "riddler",
  "version": "0.1.0",
  "description": "Convert docker inspect output to the opencontainers runc spec",
  "source": "https://github.com/genuinetools/riddler",
  "checks": [
    {
      "type": "binary",
      "name": "riddler"
    }
  ],
  "install_guidance": {
    "plugin": "riddler",
    "binary": "riddler",
    "check": "which riddler",
    "install_steps": [
      "go install github.com/genuinetools/riddler@latest",
      "Verify: riddler --version",
      "supercli plugins install ./plugins/riddler --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "riddler",
      "resource": "self",
      "action": "version",
      "description": "Print riddler version",
      "adapter": "process",
      "adapterConfig": {
        "command": "riddler",
        "missingDependencyHelp": "Install riddler: go install github.com/genuinetools/riddler@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "riddler",
      "resource": "container",
      "action": "convert",
      "description": "convert container via riddler",
      "adapter": "process",
      "adapterConfig": {
        "command": "riddler",
        "missingDependencyHelp": "Install riddler: go install github.com/genuinetools/riddler@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "riddler",
      "resource": "image",
      "action": "inspect",
      "description": "inspect image via riddler",
      "adapter": "process",
      "adapterConfig": {
        "command": "riddler",
        "missingDependencyHelp": "Install riddler: go install github.com/genuinetools/riddler@latest",
        "baseArgs": [
          "--inspect"
        ],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "riddler",
      "resource": "spec",
      "action": "generate",
      "description": "generate spec via riddler",
      "adapter": "process",
      "adapterConfig": {
        "command": "riddler",
        "missingDependencyHelp": "Install riddler: go install github.com/genuinetools/riddler@latest",
        "baseArgs": [
          "--generate"
        ],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "riddler",
      "resource": "_",
      "action": "_",
      "description": "_ _ via riddler",
      "adapter": "process",
      "adapterConfig": {
        "command": "riddler",
        "missingDependencyHelp": "Install riddler: go install github.com/genuinetools/riddler@latest",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}