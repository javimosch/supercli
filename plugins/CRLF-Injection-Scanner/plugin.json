{
  "name": "CRLF-Injection-Scanner",
  "version": "0.1.0",
  "description": "Command line tool for testing CRLF injection on a list of domains",
  "source": "https://github.com/MichaelStott/CRLF-Injection-Scanner",
  "checks": [
    {
      "type": "binary",
      "name": "crlf-scanner"
    }
  ],
  "install_guidance": {
    "plugin": "CRLF-Injection-Scanner",
    "binary": "crlf-scanner",
    "check": "which crlf-scanner",
    "install_steps": [
      "pip install crlf-scanner",
      "Verify: crlf-scanner --version",
      "supercli plugins install ./plugins/CRLF-Injection-Scanner --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "CRLF-Injection-Scanner",
      "resource": "self",
      "action": "version",
      "description": "Print CRLF-Injection-Scanner version",
      "adapter": "process",
      "adapterConfig": {
        "command": "crlf-scanner",
        "missingDependencyHelp": "Install CRLF-Injection-Scanner: pip install crlf-scanner",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "CRLF-Injection-Scanner",
      "resource": "domain",
      "action": "scan",
      "description": "scan domain via crlf-scanner",
      "adapter": "process",
      "adapterConfig": {
        "command": "crlf-scanner",
        "missingDependencyHelp": "Install CRLF-Injection-Scanner: pip install crlf-scanner",
        "baseArgs": [
          "scan"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "CRLF-Injection-Scanner",
      "resource": "domain",
      "action": "list",
      "description": "list domain via crlf-scanner",
      "adapter": "process",
      "adapterConfig": {
        "command": "crlf-scanner",
        "missingDependencyHelp": "Install CRLF-Injection-Scanner: pip install crlf-scanner",
        "baseArgs": [
          "--list"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "CRLF-Injection-Scanner",
      "resource": "file",
      "action": "load",
      "description": "load file via crlf-scanner",
      "adapter": "process",
      "adapterConfig": {
        "command": "crlf-scanner",
        "missingDependencyHelp": "Install CRLF-Injection-Scanner: pip install crlf-scanner",
        "baseArgs": [
          "--file"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "CRLF-Injection-Scanner",
      "resource": "output",
      "action": "set",
      "description": "set output via crlf-scanner",
      "adapter": "process",
      "adapterConfig": {
        "command": "crlf-scanner",
        "missingDependencyHelp": "Install CRLF-Injection-Scanner: pip install crlf-scanner",
        "baseArgs": [
          "--output"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "CRLF-Injection-Scanner",
      "resource": "verbose",
      "action": "set",
      "description": "set verbose via crlf-scanner",
      "adapter": "process",
      "adapterConfig": {
