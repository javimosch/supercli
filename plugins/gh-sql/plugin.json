{
  "name": "gh-sql",
  "version": "0.1.0",
  "description": "Query GitHub Projects and repositories with SQL syntax",
  "source": "https://github.com/KOBA789/gh-sql",
  "checks": [
    {
      "type": "binary",
      "name": "gh-sql"
    }
  ],
  "install_guidance": {
    "plugin": "gh-sql",
    "binary": "gh-sql",
    "check": "which gh-sql",
    "install_steps": [
      "cargo install gh-sql",
      "Verify: gh-sql --version",
      "supercli plugins install ./plugins/gh-sql --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "gh-sql",
      "resource": "self",
      "action": "version",
      "description": "Print gh-sql version",
      "adapter": "process",
      "adapterConfig": {
        "command": "gh-sql",
        "missingDependencyHelp": "Install gh-sql: cargo install gh-sql",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "gh-sql",
      "resource": "repo",
      "action": "query",
      "description": "query repo via gh-sql",
      "adapter": "process",
      "adapterConfig": {
        "command": "gh-sql",
        "missingDependencyHelp": "Install gh-sql: cargo install gh-sql",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
