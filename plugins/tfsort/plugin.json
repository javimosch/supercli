{
  "name": "tfsort",
  "version": "0.1.0",
  "description": "A CLI utility to sort Terraform variables and outputs",
  "source": "https://github.com/AlexNabokikh/tfsort",
  "checks": [
    {
      "type": "binary",
      "name": "tfsort"
    }
  ],
  "install_guidance": {
    "plugin": "tfsort",
    "binary": "tfsort",
    "check": "which tfsort",
    "install_steps": [
      "brew install tfsort",
      "Verify: tfsort --version",
      "supercli plugins install ./plugins/tfsort --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "tfsort",
      "resource": "self",
      "action": "version",
      "description": "Print tfsort version",
      "adapter": "process",
      "adapterConfig": {
        "command": "tfsort",
        "missingDependencyHelp": "Install tfsort: brew install tfsort",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "tfsort",
      "resource": "file",
      "action": "sort",
      "description": "sort file via tfsort",
      "adapter": "process",
      "adapterConfig": {
        "command": "tfsort",
        "missingDependencyHelp": "Install tfsort: brew install tfsort",
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "tfsort",
      "resource": "_",
      "action": "_",
      "description": "_ _ via tfsort",
      "adapter": "process",
      "adapterConfig": {
        "command": "tfsort",
        "missingDependencyHelp": "Install tfsort: brew install tfsort",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}