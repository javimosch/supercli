{
  "name": "ipinfo-cli",
  "version": "0.1.0",
  "description": "IP geolocation and network data lookup CLI",
  "source": "https://github.com/ipinfo/cli",
  "checks": [
    {
      "type": "binary",
      "name": "ipinfo"
    }
  ],
  "install_guidance": {
    "plugin": "ipinfo-cli",
    "binary": "ipinfo",
    "check": "which ipinfo",
    "install_steps": [
      "brew install ipinfo-cli",
      "Verify: ipinfo --version",
      "supercli plugins install ./plugins/ipinfo-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "ipinfo-cli",
      "resource": "self",
      "action": "version",
      "description": "Print ipinfo-cli version",
      "adapter": "process",
      "adapterConfig": {
        "command": "ipinfo",
        "missingDependencyHelp": "Install ipinfo-cli: brew install ipinfo-cli",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "ipinfo-cli",
      "resource": "ip",
      "action": "lookup",
      "description": "lookup ip via ipinfo",
      "adapter": "process",
      "adapterConfig": {
        "command": "ipinfo",
        "missingDependencyHelp": "Install ipinfo-cli: brew install ipinfo-cli",
        "baseArgs": [
          ""
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "ipinfo-cli",
      "resource": "asn",
      "action": "lookup",
      "description": "lookup asn via ipinfo",
      "adapter": "process",
