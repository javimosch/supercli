          "asn"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "ipinfo-cli",
      "resource": "range",
      "action": "check",
      "description": "check range via ipinfo",
      "adapter": "process",
      "adapterConfig": {
        "command": "ipinfo",
        "missingDependencyHelp": "Install ipinfo-cli: brew install ipinfo-cli",
        "baseArgs": [
          "range"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "ipinfo-cli",
      "resource": "summarize",
