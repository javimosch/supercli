      "adapter": "process",
      "adapterConfig": {
        "command": "ipinfo",
        "missingDependencyHelp": "Install ipinfo-cli: brew install ipinfo-cli",
        "baseArgs": [
          "summarize"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
