{
  "name": "newrelic-cli",
  "version": "0.1.0",
  "description": "Command line interface for New Relic observability platform",
  "source": "https://github.com/newrelic/newrelic-cli",
  "checks": [
    {
      "type": "binary",
      "name": "newrelic"
    }
  ],
  "install_guidance": {
    "plugin": "newrelic-cli",
    "binary": "newrelic",
    "check": "which newrelic",
    "install_steps": [
      "brew install newrelic-cli",
      "Verify: newrelic --version",
      "supercli plugins install ./plugins/newrelic-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "newrelic-cli",
      "resource": "self",
      "action": "version",
      "description": "Print newrelic-cli version",
      "adapter": "process",
      "adapterConfig": {
        "command": "newrelic",
        "missingDependencyHelp": "Install newrelic-cli: brew install newrelic-cli",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "newrelic-cli",
      "resource": "apm",
      "action": "list",
      "description": "list apm via newrelic",
      "adapter": "process",
      "adapterConfig": {
        "command": "newrelic",
        "missingDependencyHelp": "Install newrelic-cli: brew install newrelic-cli",
        "baseArgs": [
          "apm",
          "application",
          "list"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "newrelic-cli",
      "resource": "entity",
      "action": "search",
      "description": "search entity via newrelic",
      "adapter": "process",
      "adapterConfig": {
        "command": "newrelic",
        "missingDependencyHelp": "Install newrelic-cli: brew install newrelic-cli",
        "baseArgs": [
          "entity",
          "search"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "newrelic-cli",
      "resource": "nerdgraph",
      "action": "query",
      "description": "query nerdgraph via newrelic",
      "adapter": "process",
      "adapterConfig": {
        "command": "newrelic",
        "missingDependencyHelp": "Install newrelic-cli: brew install newrelic-cli",
        "baseArgs": [
          "nerdgraph",
          "query"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "newrelic-cli",
      "resource": "_",
      "action": "_",
      "description": "_ _ via newrelic",
      "adapter": "process",
      "adapterConfig": {
        "command": "newrelic",
        "missingDependencyHelp": "Install newrelic-cli: brew install newrelic-cli",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}