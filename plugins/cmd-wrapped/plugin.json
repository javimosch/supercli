{
  "name": "cmd-wrapped",
  "version": "0.1.0",
  "description": "A command line history stats analyzer. Generate beautiful statistics and insights from your shell command history.",
  "source": "https://github.com/YiNNx/cmd-wrapped",
  "checks": [
    { "type": "binary", "name": "cmd-wrapped" }
  ],
  "install_guidance": {
    "plugin": "cmd-wrapped",
    "binary": "cmd-wrapped",
    "check": "which cmd-wrapped",
    "install_steps": [
      "brew install cmd-wrapped",
      "Verify: cmd-wrapped --version",
      "supercli plugins install ./plugins/cmd-wrapped --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "cmd-wrapped",
      "resource": "history",
      "action": "analyze",
      "description": "Analyze shell command history",
      "adapter": "process",
      "adapterConfig": {
        "command": "cmd-wrapped",
        "baseArgs": [],
        "passthrough": true,
        "missingDependencyHelp": "Install cmd-wrapped: brew install cmd-wrapped"
      },
      "args": [
        { "name": "--shell", "type": "string", "description": "Shell type (bash, zsh, fish, nu)" },
        { "name": "--year", "type": "integer", "description": "Filter by year" }
      ]
    },
    {
      "namespace": "cmd-wrapped",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to cmd-wrapped CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "cmd-wrapped",
        "passthrough": true,
        "missingDependencyHelp": "Install cmd-wrapped: brew install cmd-wrapped"
      },
      "args": []
    }
  ]
}
