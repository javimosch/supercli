{
  "name": "carbon-now-cli",
  "version": "0.1.0",
  "description": "Beautiful images of your code from the command line",
  "source": "https://github.com/mixn/carbon-now-cli",
  "checks": [
    {
      "type": "binary",
      "name": "carbon-now"
    }
  ],
  "install_guidance": {
    "plugin": "carbon-now-cli",
    "binary": "carbon-now",
    "check": "which carbon-now",
    "install_steps": [
      "npm install -g carbon-now-cli",
      "Verify: carbon-now --version",
      "supercli plugins install ./plugins/carbon-now-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "carbon-now-cli",
      "resource": "self",
      "action": "version",
      "description": "Print carbon-now-cli version",
      "adapter": "process",
      "adapterConfig": {
        "command": "carbon-now",
        "missingDependencyHelp": "Install carbon-now-cli: npm install -g carbon-now-cli",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "carbon-now-cli",
      "resource": "file",
      "action": "convert",
      "description": "convert file via carbon-now",
      "adapter": "process",
      "adapterConfig": {
        "command": "carbon-now",
        "missingDependencyHelp": "Install carbon-now-cli: npm install -g carbon-now-cli",
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "carbon-now-cli",
      "resource": "_",
      "action": "_",
      "description": "_ _ via carbon-now",
      "adapter": "process",
      "adapterConfig": {
        "command": "carbon-now",
        "missingDependencyHelp": "Install carbon-now-cli: npm install -g carbon-now-cli",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}