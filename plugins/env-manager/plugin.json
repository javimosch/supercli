{
  "name": "env-manager",
  "version": "0.1.0",
  "description": "A CLI tool for managing environment files in different environments. Switch, validate, and check environment variables.",
  "source": "https://github.com/hitankshah/env-manager",
  "checks": [
    { "type": "binary", "name": "env-manager" }
  ],
  "install_guidance": {
    "plugin": "env-manager",
    "binary": "env-manager",
    "check": "which env-manager",
    "install_steps": [
      "npm install -g env-manager",
      "Verify: env-manager --version",
      "supercli plugins install ./plugins/env-manager --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "env-manager",
      "resource": "switch",
      "action": "environment",
      "description": "Switch between environment configurations",
      "adapter": "process",
      "adapterConfig": {
        "command": "env-manager",
        "passthrough": true,
        "missingDependencyHelp": "Install env-manager: npm install -g env-manager"
      },
      "args": [
        { "name": "environment", "type": "string", "description": "Environment name (development, production, etc.)" }
      ]
    },
    {
      "namespace": "env-manager",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to env-manager CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "env-manager",
        "passthrough": true,
        "missingDependencyHelp": "Install env-manager: npm install -g env-manager"
      },
      "args": []
    }
  ]
}
