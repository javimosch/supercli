{
  "name": "soundcloud-dl",
  "version": "0.1.0",
  "description": "Download tracks and playlists from SoundCloud",
  "source": "https://github.com/AYehia0/soundcloud-dl",
  "checks": [
    {
      "type": "binary",
      "name": "soundcloud-dl"
    }
  ],
  "install_guidance": {
    "plugin": "soundcloud-dl",
    "binary": "soundcloud-dl",
    "check": "which soundcloud-dl",
    "install_steps": [
      "go install github.com/AYehia0/soundcloud-dl@latest",
      "Verify: soundcloud-dl --version",
      "supercli plugins install ./plugins/soundcloud-dl --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "soundcloud-dl",
      "resource": "self",
      "action": "version",
      "description": "Print soundcloud-dl version",
      "adapter": "process",
      "adapterConfig": {
        "command": "soundcloud-dl",
        "missingDependencyHelp": "Install soundcloud-dl: go install github.com/AYehia0/soundcloud-dl@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "soundcloud-dl",
      "resource": "track",
      "action": "download",
      "description": "download track via soundcloud-dl",
      "adapter": "process",
      "adapterConfig": {
        "command": "soundcloud-dl",
        "missingDependencyHelp": "Install soundcloud-dl: go install github.com/AYehia0/soundcloud-dl@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "soundcloud-dl",
      "resource": "playlist",
      "action": "download",
      "description": "download playlist via soundcloud-dl",
      "adapter": "process",
      "adapterConfig": {
        "command": "soundcloud-dl",
        "missingDependencyHelp": "Install soundcloud-dl: go install github.com/AYehia0/soundcloud-dl@latest",
        "baseArgs": [
          "--playlist"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "soundcloud-dl",
      "resource": "_",
      "action": "_",
      "description": "_ _ via soundcloud-dl",
      "adapter": "process",
      "adapterConfig": {
        "command": "soundcloud-dl",
        "missingDependencyHelp": "Install soundcloud-dl: go install github.com/AYehia0/soundcloud-dl@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}