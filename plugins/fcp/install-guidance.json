{
  "plugin": "fcp",
  "binary": "fcp",
  "check": "which fcp",
  "install_steps": [
    "cargo install fcp",
    "Verify: fcp --help",
    "supercli plugins install ./plugins/fcp --on-conflict replace --json"
  ],
  "note": "fcp is a faster alternative to the Unix cp command for large files and directories"
}
