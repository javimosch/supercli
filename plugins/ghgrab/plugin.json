{
  "name": "ghgrab",
  "version": "1.0.0",
  "description": "Search and download files from GitHub directly from your terminal",
  "commands": [
    {
      "name": "version",
      "description": "Show ghgrab version information",
      "command": "ghgrab version"
    },
    {
      "name": "search",
      "description": "Search for files on GitHub",
      "command": "ghgrab search [query]",
      "args": true
    },
    {
      "name": "download",
      "description": "Download a file from GitHub",
      "command": "ghgrab download [owner] [repo] [path]",
      "args": true
    }
  ],
  "checks": [
    {
      "type": "binary",
      "value": "ghgrab"
    }
  ]
}
