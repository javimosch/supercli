{
  "name": "protolock",
  "version": "0.1.0",
  "description": "Protocol Buffer companion tool for tracking .proto files",
  "source": "https://github.com/nilslice/protolock",
  "checks": [
    {
      "type": "binary",
      "name": "protolock"
    }
  ],
  "install_guidance": {
    "plugin": "protolock",
    "binary": "protolock",
    "check": "which protolock",
    "install_steps": [
      "go install github.com/nilslice/protolock@latest",
      "Verify: protolock --version",
      "supercli plugins install ./plugins/protolock --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "protolock",
      "resource": "self",
      "action": "version",
      "description": "Print protolock version",
      "adapter": "process",
      "adapterConfig": {
        "command": "protolock",
        "missingDependencyHelp": "Install protolock: go install github.com/nilslice/protolock@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "protolock",
      "resource": "proto",
      "action": "commit",
      "description": "commit proto via protolock",
      "adapter": "process",
      "adapterConfig": {
        "command": "protolock",
        "missingDependencyHelp": "Install protolock: go install github.com/nilslice/protolock@latest",
        "baseArgs": [
          "commit"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "protolock",
      "resource": "proto",
      "action": "status",
      "description": "status proto via protolock",
      "adapter": "process",
      "adapterConfig": {
        "command": "protolock",
        "missingDependencyHelp": "Install protolock: go install github.com/nilslice/protolock@latest",
        "baseArgs": [
          "status"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "protolock",
      "resource": "proto",
      "action": "force",
      "description": "force proto via protolock",
      "adapter": "process",
      "adapterConfig": {
        "command": "protolock",
        "missingDependencyHelp": "Install protolock: go install github.com/nilslice/protolock@latest",
        "baseArgs": [
          "force"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "protolock",
      "resource": "config",
      "action": "init",
      "description": "init config via protolock",
      "adapter": "process",
      "adapterConfig": {
        "command": "protolock",
        "missingDependencyHelp": "Install protolock: go install github.com/nilslice/protolock@latest",
        "baseArgs": [
          "init"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "protolock",
      "resource": "_",
      "action": "_",
      "description": "_ _ via protolock",
      "adapter": "process",
      "adapterConfig": {
        "command": "protolock",
        "missingDependencyHelp": "Install protolock: go install github.com/nilslice/protolock@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}