{
  "name": "markdown-to-html-cli",
  "version": "0.1.0",
  "description": "Command line tool that converts markdown to HTML. Supports GFM footnotes, task lists, and custom CSS.",
  "source": "https://github.com/jaywcjlove/markdown-to-html-cli",
  "checks": [
    { "type": "binary", "name": "markdown-to-html" }
  ],
  "install_guidance": {
    "plugin": "markdown-to-html-cli",
    "binary": "markdown-to-html",
    "check": "which markdown-to-html",
    "install_steps": [
      "npm install -g markdown-to-html-cli",
      "Verify: markdown-to-html --version",
      "supercli plugins install ./plugins/markdown-to-html-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "markdown-to-html",
      "resource": "convert",
      "action": "file",
      "description": "Convert markdown to HTML",
      "adapter": "process",
      "adapterConfig": {
        "command": "markdown-to-html",
        "passthrough": true,
        "missingDependencyHelp": "Install markdown-to-html-cli: npm install -g markdown-to-html-cli"
      },
      "args": [
        { "name": "input", "type": "string", "description": "Input markdown file" },
        { "name": "-o", "type": "string", "description": "Output HTML file" }
      ]
    },
    {
      "namespace": "markdown-to-html",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to markdown-to-html CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "markdown-to-html",
        "passthrough": true,
        "missingDependencyHelp": "Install markdown-to-html-cli: npm install -g markdown-to-html-cli"
      },
      "args": []
    }
  ]
}
