{
  "plugin": "xmaster",
  "binary": "xmaster",
  "check": "which xmaster",
  "install_steps": [
    "curl -fsSL https://raw.githubusercontent.com/199-biotechnologies/xmaster/master/install.sh | sh",
    "Verify: xmaster --version",
    "supercli plugins install ./plugins/xmaster --on-conflict replace --json"
  ],
  "note": "Also available via Homebrew: brew install 199-biotechnologies/tap/xmaster"
}
