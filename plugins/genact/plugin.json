{
  "name": "genact",
  "version": "0.1.0",
  "description": "A nonsense activity generator. Generate fake activity for demos, screenshots, or to look busy in the terminal.",
  "source": "https://github.com/svenstaro/genact",
  "checks": [
    { "type": "binary", "name": "genact" }
  ],
  "install_guidance": {
    "plugin": "genact",
    "binary": "genact",
    "check": "which genact",
    "install_steps": [
      "brew install genact",
      "Verify: genact --version",
      "supercli plugins install ./plugins/genact --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "genact",
      "resource": "activity",
      "action": "generate",
      "description": "Generate fake activity",
      "adapter": "process",
      "adapterConfig": {
        "command": "genact",
        "passthrough": true,
        "missingDependencyHelp": "Install genact: brew install genact"
      },
      "args": [
        { "name": "--list", "type": "boolean", "description": "List available modules" },
        { "name": "--modules", "type": "string", "description": "Comma-separated list of modules" },
        { "name": "--random", "type": "boolean", "description": "Randomize modules" },
        { "name": "--speed", "type": "float", "description": "Activity speed multiplier" },
        { "name": "--duration", "type": "integer", "description": "Run duration in seconds" }
      ]
    },
    {
      "namespace": "genact",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to genact CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "genact",
        "passthrough": true,
        "missingDependencyHelp": "Install genact: brew install genact"
      },
      "args": []
    }
  ]
}
