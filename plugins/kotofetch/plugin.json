{
  "name": "kotofetch",
  "version": "0.1.0",
  "description": "Display Japanese quotes in the terminal",
  "source": "https://github.com/hxpe-dev/kotofetch",
  "checks": [
    { "type": "binary", "name": "kotofetch" }
  ],
  "install_guidance": {
    "plugin": "kotofetch",
    "binary": "kotofetch",
    "check": "which kotofetch",
    "install_steps": [
      "cargo install kotofetch",
      "Verify: kotofetch --help",
      "supercli plugins install ./plugins/kotofetch --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "kotofetch",
      "resource": "fetch",
      "action": "quote",
      "description": "Display Japanese quote",
      "adapter": "process",
      "adapterConfig": {
        "command": "kotofetch",
        "cwd": "invoke_cwd",
        "timeout_ms": 60000,
        "missingDependencyHelp": "Install kotofetch: cargo install kotofetch"
      },
      "args": []
    },
    {
      "namespace": "kotofetch",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to kotofetch CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "kotofetch",
        "cwd": "invoke_cwd",
        "passthrough": true,
        "missingDependencyHelp": "Install kotofetch: cargo install kotofetch"
      },
      "args": []
    }
  ]
}
