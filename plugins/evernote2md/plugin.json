{
  "name": "evernote2md",
  "version": "0.1.0",
  "description": "Convert Evernote ENEX files to Markdown",
  "source": "https://github.com/wormi4ok/evernote2md",
  "checks": [
    {
      "type": "binary",
      "name": "evernote2md"
    }
  ],
  "install_guidance": {
    "plugin": "evernote2md",
    "binary": "evernote2md",
    "check": "which evernote2md",
    "install_steps": [
      "go install github.com/wormi4ok/evernote2md@latest",
      "Verify: evernote2md --version",
      "supercli plugins install ./plugins/evernote2md --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "evernote2md",
      "resource": "self",
      "action": "version",
      "description": "Print evernote2md version",
      "adapter": "process",
      "adapterConfig": {
        "command": "evernote2md",
        "missingDependencyHelp": "Install evernote2md: go install github.com/wormi4ok/evernote2md@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "evernote2md",
      "resource": "file",
      "action": "convert",
      "description": "convert file via evernote2md",
      "adapter": "process",
      "adapterConfig": {
        "command": "evernote2md",
        "missingDependencyHelp": "Install evernote2md: go install github.com/wormi4ok/evernote2md@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "evernote2md",
      "resource": "_",
      "action": "_",
      "description": "_ _ via evernote2md",
      "adapter": "process",
      "adapterConfig": {
        "command": "evernote2md",
        "missingDependencyHelp": "Install evernote2md: go install github.com/wormi4ok/evernote2md@latest",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}