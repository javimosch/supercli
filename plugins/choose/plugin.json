{
  "name": "choose",
  "version": "0.1.0",
  "description": "A human-friendly and fast alternative to cut and sometimes awk. Extract fields from lines of text with intuitive syntax.",
  "source": "https://github.com/theryangeary/choose",
  "checks": [
    { "type": "binary", "name": "choose" }
  ],
  "install_guidance": {
    "plugin": "choose",
    "binary": "choose",
    "check": "which choose",
    "install_steps": [
      "brew install choose-rust",
      "Verify: choose --version",
      "supercli plugins install ./plugins/choose --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "choose",
      "resource": "text",
      "action": "extract",
      "description": "Extract fields from text input",
      "adapter": "process",
      "adapterConfig": {
        "command": "choose",
        "baseArgs": [],
        "passthrough": true,
        "missingDependencyHelp": "Install choose: brew install choose-rust"
      },
      "args": [
        { "name": "fields", "type": "string", "description": "Field indices or ranges (e.g. 0, 1:3, -1)" },
        { "name": "--field-separator", "type": "string", "description": "Custom field separator" },
        { "name": "--output-field-separator", "type": "string", "description": "Custom output separator" }
      ]
    },
    {
      "namespace": "choose",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to choose CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "choose",
        "passthrough": true,
        "missingDependencyHelp": "Install choose: brew install choose-rust"
      },
      "args": []
    }
  ]
}
