{
  "name": "notesmd-cli",
  "version": "0.1.0",
  "description": "Obsidian CLI (Community) - Interact with Obsidian in the terminal",
  "source": "https://github.com/Yakitrak/notesmd-cli",
  "checks": [
    {
      "type": "binary",
      "name": "notesmd"
    }
  ],
  "install_guidance": {
    "plugin": "notesmd-cli",
    "binary": "notesmd",
    "check": "which notesmd",
    "install_steps": [
      "go install github.com/Yakitrak/notesmd-cli@latest",
      "Verify: notesmd --version",
      "supercli plugins install ./plugins/notesmd-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "notesmd-cli",
      "resource": "self",
      "action": "version",
      "description": "Print notesmd-cli version",
      "adapter": "process",
      "adapterConfig": {
        "command": "notesmd",
        "missingDependencyHelp": "Install notesmd-cli: go install github.com/Yakitrak/notesmd-cli@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "notesmd-cli",
      "resource": "note",
      "action": "create",
      "description": "create note via notesmd",
      "adapter": "process",
      "adapterConfig": {
        "command": "notesmd",
        "missingDependencyHelp": "Install notesmd-cli: go install github.com/Yakitrak/notesmd-cli@latest",
        "baseArgs": [
          "create"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "notesmd-cli",
      "resource": "note",
      "action": "search",
      "description": "search note via notesmd",
      "adapter": "process",
      "adapterConfig": {
        "command": "notesmd",
        "missingDependencyHelp": "Install notesmd-cli: go install github.com/Yakitrak/notesmd-cli@latest",
        "baseArgs": [
          "search"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "notesmd-cli",
      "resource": "note",
      "action": "list",
      "description": "list note via notesmd",
      "adapter": "process",
      "adapterConfig": {
        "command": "notesmd",
        "missingDependencyHelp": "Install notesmd-cli: go install github.com/Yakitrak/notesmd-cli@latest",
        "baseArgs": [
          "list"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "notesmd-cli",
      "resource": "_",
      "action": "_",
      "description": "_ _ via notesmd",
      "adapter": "process",
      "adapterConfig": {
        "command": "notesmd",
        "missingDependencyHelp": "Install notesmd-cli: go install github.com/Yakitrak/notesmd-cli@latest",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}