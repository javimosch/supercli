{
  "name": "MyJWT",
  "version": "0.1.0",
  "description": "CLI for cracking testing vulnerabilities on Json Web Token JWT security testing",
  "source": "https://github.com/tyki6/MyJWT",
  "checks": [
    {
      "type": "binary",
      "name": "myjwt"
    }
  ],
  "install_guidance": {
    "plugin": "MyJWT",
    "binary": "myjwt",
    "check": "which myjwt",
    "install_steps": [
      "pip install myjwt",
      "Verify: myjwt --version",
      "supercli plugins install ./plugins/MyJWT --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
