      "description": "Print MyJWT version",
      "adapter": "process",
      "adapterConfig": {
        "command": "myjwt",
        "missingDependencyHelp": "Install MyJWT: pip install myjwt",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "MyJWT",
      "resource": "token",
      "action": "decode",
      "description": "decode token via myjwt",
      "adapter": "process",
      "adapterConfig": {
        "command": "myjwt",
        "missingDependencyHelp": "Install MyJWT: pip install myjwt",
        "baseArgs": [
          "decode"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
