{
  "name": "jqp",
  "version": "0.1.0",
  "description": "TUI JSON processor and interactive jq playground",
  "source": "https://github.com/noahgorstein/jqp",
  "checks": [
    {
      "type": "binary",
      "name": "jqp"
    }
  ],
  "install_guidance": {
    "plugin": "jqp",
    "binary": "jqp",
    "check": "which jqp",
    "install_steps": [
      "brew install jqp",
      "Verify: jqp --version",
      "supercli plugins install ./plugins/jqp --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "jqp",
      "resource": "self",
      "action": "version",
      "description": "Print jqp version",
      "adapter": "process",
      "adapterConfig": {
        "command": "jqp",
        "missingDependencyHelp": "Install jqp: brew install jqp",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "jqp",
      "resource": "json",
      "action": "process",
      "description": "process json via jqp",
      "adapter": "process",
      "adapterConfig": {
        "command": "jqp",
        "missingDependencyHelp": "Install jqp: brew install jqp",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "jqp",
      "resource": "_",
      "action": "_",
      "description": "_ _ via jqp",
      "adapter": "process",
      "adapterConfig": {
        "command": "jqp",
        "missingDependencyHelp": "Install jqp: brew install jqp",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}