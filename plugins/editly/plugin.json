{
  "name": "editly",
  "version": "0.1.0",
  "description": "Slick, declarative command line video editing",
  "source": "https://github.com/mifi/editly",
  "checks": [
    {
      "type": "binary",
      "name": "editly"
    }
  ],
  "install_guidance": {
    "plugin": "editly",
    "binary": "editly",
    "check": "which editly",
    "install_steps": [
      "npm install -g editly",
      "Verify: editly --version",
      "supercli plugins install ./plugins/editly --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "editly",
      "resource": "self",
      "action": "version",
      "description": "Print editly version",
      "adapter": "process",
      "adapterConfig": {
        "command": "editly",
        "missingDependencyHelp": "Install editly: npm install -g editly",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "editly",
      "resource": "video",
      "action": "edit",
      "description": "edit video via editly",
      "adapter": "process",
      "adapterConfig": {
        "command": "editly",
        "missingDependencyHelp": "Install editly: npm install -g editly",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "editly",
      "resource": "_",
      "action": "_",
      "description": "_ _ via editly",
      "adapter": "process",
      "adapterConfig": {
        "command": "editly",
        "missingDependencyHelp": "Install editly: npm install -g editly",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}