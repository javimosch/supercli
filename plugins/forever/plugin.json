{
  "name": "forever",
  "version": "0.1.0",
  "description": "Ensure scripts run continuously",
  "source": "https://github.com/foreversd/forever",
  "checks": [
    {
      "type": "binary",
      "name": "forever"
    }
  ],
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "forever",
      "resource": "script",
      "action": "start",
      "description": "Start script continuously",
      "adapter": "process",
      "adapterConfig": {
        "command": "forever",
        "baseArgs": [
          "start"
        ],
        "passthrough": true
      },
      "args": [
        {
          "name": "script",
          "type": "string",
          "required": true,
          "description": "Script to run"
        }
      ]
    },
    {
      "namespace": "forever",
      "resource": "processes",
      "action": "list",
      "description": "List running processes",
      "adapter": "process",
      "adapterConfig": {
        "command": "forever",
        "baseArgs": [
          "list"
        ],
        "passthrough": true
      }
    },
    {
      "namespace": "forever",
      "resource": "process",
      "action": "stop",
      "description": "Stop a process",
      "adapter": "process",
      "adapterConfig": {
        "command": "forever",
        "baseArgs": [
          "stop"
        ],
        "passthrough": true
      },
      "args": [
        {
          "name": "uid",
          "type": "string",
          "required": true,
          "description": "Process UID"
        }
      ]
    }
  ]
}