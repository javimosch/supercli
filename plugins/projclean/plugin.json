{
  "name": "projclean",
  "version": "0.1.0",
  "description": "Project dependencies and build artifacts cleanup tool",
  "source": "https://github.com/sigoden/projclean",
  "checks": [
    {
      "type": "binary",
      "name": "projclean"
    }
  ],
  "install_guidance": {
    "plugin": "projclean",
    "binary": "projclean",
    "check": "which projclean",
    "install_steps": [
      "cargo install projclean",
      "Verify: projclean --version",
      "supercli plugins install ./plugins/projclean --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "projclean",
      "resource": "self",
      "action": "version",
      "description": "Print projclean version",
      "adapter": "process",
      "adapterConfig": {
        "command": "projclean",
        "missingDependencyHelp": "Install projclean: cargo install projclean",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "projclean",
      "resource": "project",
      "action": "clean",
      "description": "clean project via projclean",
      "adapter": "process",
      "adapterConfig": {
        "command": "projclean",
        "missingDependencyHelp": "Install projclean: cargo install projclean",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
