{
  "name": "yj",
  "version": "0.1.0",
  "description": "Convert between YAML, TOML, JSON, and HCL formats with preserved map order",
  "source": "https://github.com/sclevine/yj",
  "checks": [
    { "type": "binary", "name": "yj" }
  ],
  "install_guidance": {
    "plugin": "yj",
    "binary": "yj",
    "check": "which yj",
    "install_steps": [
      "brew install yj",
      "Verify: yj -v",
      "supercli plugins install ./plugins/yj --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "yj",
      "resource": "self",
      "action": "version",
      "description": "Print yj version",
      "adapter": "process",
      "adapterConfig": {
        "command": "yj",
        "baseArgs": ["-v"],
        "missingDependencyHelp": "Install yj: brew install yj"
      },
      "args": []
    },
    {
      "namespace": "yj",
      "resource": "yaml",
      "action": "to-json",
      "description": "Convert YAML to JSON",
      "adapter": "process",
      "adapterConfig": {
        "command": "yj",
        "baseArgs": ["-yj"],
        "passthrough": true,
        "missingDependencyHelp": "Install yj: brew install yj"
      },
      "args": []
    },
    {
      "namespace": "yj",
      "resource": "yaml",
      "action": "to-toml",
      "description": "Convert YAML to TOML",
      "adapter": "process",
      "adapterConfig": {
        "command": "yj",
        "baseArgs": ["-yt"],
        "passthrough": true,
        "missingDependencyHelp": "Install yj: brew install yj"
      },
      "args": []
    },
    {
      "namespace": "yj",
      "resource": "yaml",
      "action": "to-hcl",
      "description": "Convert YAML to HCL",
      "adapter": "process",
      "adapterConfig": {
        "command": "yj",
        "baseArgs": ["-yc"],
        "passthrough": true,
        "missingDependencyHelp": "Install yj: brew install yj"
      },
      "args": []
    },
    {
      "namespace": "yj",
      "resource": "toml",
      "action": "to-json",
      "description": "Convert TOML to JSON",
      "adapter": "process",
      "adapterConfig": {
        "command": "yj",
        "baseArgs": ["-tj"],
        "passthrough": true,
        "missingDependencyHelp": "Install yj: brew install yj"
      },
      "args": []
    },
    {
      "namespace": "yj",
      "resource": "toml",
      "action": "to-yaml",
      "description": "Convert TOML to YAML",
      "adapter": "process",
      "adapterConfig": {
        "command": "yj",
        "baseArgs": ["-ty"],
        "passthrough": true,
        "missingDependencyHelp": "Install yj: brew install yj"
      },
      "args": []
    },
    {
      "namespace": "yj",
      "resource": "json",
      "action": "to-yaml",
      "description": "Convert JSON to YAML",
      "adapter": "process",
      "adapterConfig": {
        "command": "yj",
        "baseArgs": ["-jy", "-r"],
        "passthrough": true,
        "missingDependencyHelp": "Install yj: brew install yj"
      },
      "args": []
    },
    {
      "namespace": "yj",
      "resource": "json",
      "action": "to-toml",
      "description": "Convert JSON to TOML",
      "adapter": "process",
      "adapterConfig": {
        "command": "yj",
        "baseArgs": ["-jt"],
        "passthrough": true,
        "missingDependencyHelp": "Install yj: brew install yj"
      },
      "args": []
    },
    {
      "namespace": "yj",
      "resource": "hcl",
      "action": "to-json",
      "description": "Convert HCL to JSON",
      "adapter": "process",
      "adapterConfig": {
        "command": "yj",
        "baseArgs": ["-cj"],
        "passthrough": true,
        "missingDependencyHelp": "Install yj: brew install yj"
      },
      "args": []
    },
    {
      "namespace": "yj",
      "resource": "hcl",
      "action": "to-yaml",
      "description": "Convert HCL to YAML",
      "adapter": "process",
      "adapterConfig": {
        "command": "yj",
        "baseArgs": ["-cy"],
        "passthrough": true,
        "missingDependencyHelp": "Install yj: brew install yj"
      },
      "args": []
    },
    {
      "namespace": "yj",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to yj CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "yj",
        "passthrough": true,
        "missingDependencyHelp": "Install yj: brew install yj"
      },
      "args": []
    }
  ]
}