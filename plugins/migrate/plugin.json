{
  "name": "migrate",
  "version": "0.1.0",
  "description": "Database migration tool with CLI",
  "source": "https://github.com/golang-migrate/migrate",
  "checks": [
    {
      "type": "binary",
      "name": "migrate"
    }
  ],
  "install_guidance": {
    "plugin": "migrate",
    "binary": "migrate",
    "check": "which migrate",
    "install_steps": [
      "brew install golang-migrate",
      "Verify: migrate --version",
      "supercli plugins install ./plugins/migrate --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "migrate",
      "resource": "self",
      "action": "version",
      "description": "Print migrate version",
      "adapter": "process",
      "adapterConfig": {
        "command": "migrate",
        "missingDependencyHelp": "Install migrate: brew install golang-migrate",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "migrate",
      "resource": "migration",
      "action": "up",
      "description": "up migration via migrate",
      "adapter": "process",
      "adapterConfig": {
        "command": "migrate",
        "missingDependencyHelp": "Install migrate: brew install golang-migrate",
        "baseArgs": [
          "up"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "migrate",
      "resource": "migration",
      "action": "down",
      "description": "down migration via migrate",
      "adapter": "process",
      "adapterConfig": {
        "command": "migrate",
        "missingDependencyHelp": "Install migrate: brew install golang-migrate",
        "baseArgs": [
          "down"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "migrate",
      "resource": "migration",
      "action": "create",
      "description": "create migration via migrate",
      "adapter": "process",
      "adapterConfig": {
        "command": "migrate",
        "missingDependencyHelp": "Install migrate: brew install golang-migrate",
        "baseArgs": [
          "create"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "migrate",
      "resource": "_",
      "action": "_",
      "description": "_ _ via migrate",
      "adapter": "process",
      "adapterConfig": {
        "command": "migrate",
        "missingDependencyHelp": "Install migrate: brew install golang-migrate",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}