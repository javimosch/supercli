{
  "plugin": "runprompt",
  "binary": "runprompt",
  "check": "which runprompt",
  "install_steps": [
    "pip install runprompt",
    "Verify: runprompt --version",
    "supercli plugins install ./plugins/runprompt --on-conflict replace --json"
  ],
  "note": "Requires API key environment variable (ANTHROPIC_API_KEY, OPENAI_API_KEY, etc.)"
}
