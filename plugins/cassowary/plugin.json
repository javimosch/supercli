{
  "name": "cassowary",
  "version": "0.1.0",
  "description": "Modern cross-platform HTTP load-testing tool",
  "source": "https://github.com/rogerwelin/cassowary",
  "checks": [
    {
      "type": "binary",
      "name": "cassowary"
    }
  ],
  "install_guidance": {
    "plugin": "cassowary",
    "binary": "cassowary",
    "check": "which cassowary",
    "install_steps": [
      "brew install cassowary",
      "Verify: cassowary --version",
      "supercli plugins install ./plugins/cassowary --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "cassowary",
      "resource": "self",
      "action": "version",
      "description": "Print cassowary version",
      "adapter": "process",
      "adapterConfig": {
        "command": "cassowary",
        "missingDependencyHelp": "Install cassowary: brew install cassowary",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "cassowary",
      "resource": "endpoint",
      "action": "test",
      "description": "test endpoint via cassowary",
      "adapter": "process",
      "adapterConfig": {
        "command": "cassowary",
        "missingDependencyHelp": "Install cassowary: brew install cassowary",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "cassowary",
      "resource": "_",
      "action": "_",
      "description": "_ _ via cassowary",
      "adapter": "process",
      "adapterConfig": {
        "command": "cassowary",
        "missingDependencyHelp": "Install cassowary: brew install cassowary",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}