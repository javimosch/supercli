{
  "name": "cf-tool",
  "version": "0.1.0",
  "description": "Command line tool for Codeforces competitive programming",
  "source": "https://github.com/xalanq/cf-tool",
  "checks": [
    {
      "type": "binary",
      "name": "cf"
    }
  ],
  "install_guidance": {
    "plugin": "cf-tool",
    "binary": "cf",
    "check": "which cf",
    "install_steps": [
      "brew install cf-tool",
      "Verify: cf --version",
      "supercli plugins install ./plugins/cf-tool --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "cf-tool",
      "resource": "self",
      "action": "version",
      "description": "Print cf-tool version",
      "adapter": "process",
      "adapterConfig": {
        "command": "cf",
        "missingDependencyHelp": "Install cf-tool: brew install cf-tool",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "cf-tool",
      "resource": "contest",
      "action": "parse",
      "description": "parse contest via cf",
      "adapter": "process",
      "adapterConfig": {
        "command": "cf",
        "missingDependencyHelp": "Install cf-tool: brew install cf-tool",
        "baseArgs": [
          "parse"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "cf-tool",
      "resource": "contest",
      "action": "submit",
      "description": "submit contest via cf",
      "adapter": "process",
      "adapterConfig": {
        "command": "cf",
        "missingDependencyHelp": "Install cf-tool: brew install cf-tool",
        "baseArgs": [
          "submit"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "cf-tool",
      "resource": "_",
      "action": "_",
      "description": "_ _ via cf",
      "adapter": "process",
      "adapterConfig": {
        "command": "cf",
        "missingDependencyHelp": "Install cf-tool: brew install cf-tool",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}