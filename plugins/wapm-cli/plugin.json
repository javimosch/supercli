{
  "name": "wapm-cli",
  "version": "0.1.0",
  "description": "WebAssembly Package Manager CLI for managing WebAssembly packages",
  "source": "https://github.com/wasmerio/wapm-cli",
  "checks": [
    {
      "type": "binary",
      "name": "wapm"
    }
  ],
  "install_guidance": {
    "plugin": "wapm-cli",
    "binary": "wapm",
    "check": "which wapm",
    "install_steps": [
      "cargo install wapm-cli",
      "Verify: wapm --version",
      "supercli plugins install ./plugins/wapm-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "wapm-cli",
      "resource": "self",
      "action": "version",
      "description": "Print wapm-cli version",
      "adapter": "process",
      "adapterConfig": {
        "command": "wapm",
        "missingDependencyHelp": "Install wapm-cli: cargo install wapm-cli",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "wapm-cli",
      "resource": "package",
      "action": "install",
      "description": "install package via wapm",
      "adapter": "process",
      "adapterConfig": {
        "command": "wapm",
        "missingDependencyHelp": "Install wapm-cli: cargo install wapm-cli",
        "baseArgs": [
          "install"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
