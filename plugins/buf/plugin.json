{
  "name": "buf",
  "version": "0.1.0",
  "description": "Protocol Buffers tool for linting and breaking change detection",
  "source": "https://github.com/bufbuild/buf",
  "checks": [
    {
      "type": "binary",
      "name": "buf"
    }
  ],
  "install_guidance": {
    "plugin": "buf",
    "binary": "buf",
    "check": "which buf",
    "install_steps": [
      "brew install buf",
      "Verify: buf --version",
      "supercli plugins install ./plugins/buf --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "buf",
      "resource": "self",
      "action": "version",
      "description": "Print buf version",
      "adapter": "process",
      "adapterConfig": {
        "command": "buf",
        "missingDependencyHelp": "Install buf: brew install buf",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "buf",
      "resource": "proto",
      "action": "lint",
      "description": "lint proto via buf",
      "adapter": "process",
      "adapterConfig": {
        "command": "buf",
        "missingDependencyHelp": "Install buf: brew install buf",
        "baseArgs": [
          "lint"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "buf",
      "resource": "proto",
      "action": "generate",
      "description": "generate proto via buf",
      "adapter": "process",
      "adapterConfig": {
        "command": "buf",
        "missingDependencyHelp": "Install buf: brew install buf",
        "baseArgs": [
          "generate"
        ],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "buf",
      "resource": "proto",
      "action": "breaking",
      "description": "breaking proto via buf",
      "adapter": "process",
      "adapterConfig": {
        "command": "buf",
        "missingDependencyHelp": "Install buf: brew install buf",
        "baseArgs": [
          "breaking"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "buf",
      "resource": "_",
      "action": "_",
      "description": "_ _ via buf",
      "adapter": "process",
      "adapterConfig": {
        "command": "buf",
        "missingDependencyHelp": "Install buf: brew install buf",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}