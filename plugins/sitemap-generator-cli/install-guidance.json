{
  "plugin": "sitemap-generator-cli",
  "binary": "sitemap-generator",
  "check": "which sitemap-generator",
  "install_steps": [
    "npm install -g sitemap-generator-cli",
    "Verify: sitemap-generator --version",
    "supercli plugins install ./plugins/sitemap-generator-cli --on-conflict replace --json"
  ]
}