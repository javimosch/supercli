{
  "name": "sitemap-generator-cli",
  "version": "0.1.0",
  "description": "Generate sitemap XML from a URL",
  "source": "https://github.com/lgraubner/sitemap-generator-cli",
  "checks": [
    {
      "type": "binary",
      "name": "sitemap-generator"
    }
  ],
  "install_guidance": {
    "plugin": "sitemap-generator-cli",
    "binary": "sitemap-generator",
    "check": "which sitemap-generator",
    "install_steps": [
      "npm install -g sitemap-generator-cli",
      "Verify: sitemap-generator --version",
      "supercli plugins install ./plugins/sitemap-generator-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "sitemap-generator-cli",
      "resource": "self",
      "action": "version",
      "description": "Print sitemap-generator-cli version",
      "adapter": "process",
      "adapterConfig": {
        "command": "sitemap-generator",
        "missingDependencyHelp": "Install sitemap-generator-cli: npm install -g sitemap-generator-cli",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "sitemap-generator-cli",
      "resource": "url",
      "action": "generate",
      "description": "generate url via sitemap-generator",
      "adapter": "process",
      "adapterConfig": {
        "command": "sitemap-generator",
        "missingDependencyHelp": "Install sitemap-generator-cli: npm install -g sitemap-generator-cli",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "sitemap-generator-cli",
      "resource": "_",
      "action": "_",
      "description": "_ _ via sitemap-generator",
      "adapter": "process",
      "adapterConfig": {
        "command": "sitemap-generator",
        "missingDependencyHelp": "Install sitemap-generator-cli: npm install -g sitemap-generator-cli",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}