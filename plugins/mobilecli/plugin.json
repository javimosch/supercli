{
  "name": "mobilecli",
  "version": "0.1.0",
  "description": "Universal CLI for managing iOS and Android devices, simulators, emulators and apps. List devices, take screenshots, stream screen, control devices, manage apps, and fetch crash reports.",
  "source": "https://github.com/mobile-next/mobilecli",
  "checks": [
    { "type": "binary", "name": "mobilecli" }
  ],
  "install_guidance": {
    "plugin": "mobilecli",
    "binary": "mobilecli",
    "check": "which mobilecli",
    "install_steps": [
      "npm install -g mobilecli@latest",
      "Verify: mobilecli --version",
      "supercli plugins install ./plugins/mobilecli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "mobilecli",
      "resource": "self",
      "action": "version",
      "description": "Print mobilecli version",
      "adapter": "process",
      "adapterConfig": {
        "command": "mobilecli",
        "baseArgs": ["--version"],
        "missingDependencyHelp": "Install mobilecli: npm install -g mobilecli@latest"
      },
      "args": []
    },
    {
      "namespace": "mobilecli",
      "resource": "device",
      "action": "list",
      "description": "List connected devices and simulators",
      "adapter": "process",
      "adapterConfig": {
        "command": "mobilecli",
        "baseArgs": ["devices"],
        "passthrough": true,
        "missingDependencyHelp": "Install mobilecli: npm install -g mobilecli@latest"
      },
      "args": [
        { "name": "--include-offline", "type": "boolean", "description": "Include offline emulators and simulators" }
      ]
    },
    {
      "namespace": "mobilecli",
      "resource": "device",
      "action": "boot",
      "description": "Boot an offline emulator or simulator",
      "adapter": "process",
      "adapterConfig": {
        "command": "mobilecli",
        "baseArgs": ["device", "boot"],
        "passthrough": true,
        "missingDependencyHelp": "Install mobilecli: npm install -g mobilecli@latest"
      },
      "args": [
        { "name": "--device", "type": "string", "required": true, "description": "Device ID or name" }
      ]
    },
    {
      "namespace": "mobilecli",
      "resource": "device",
      "action": "shutdown",
      "description": "Shutdown a running emulator or simulator",
      "adapter": "process",
      "adapterConfig": {
        "command": "mobilecli",
        "baseArgs": ["device", "shutdown"],
        "passthrough": true,
        "missingDependencyHelp": "Install mobilecli: npm install -g mobilecli@latest"
      },
      "args": [
        { "name": "--device", "type": "string", "required": true, "description": "Device ID or name" }
      ]
    },
    {
      "namespace": "mobilecli",
      "resource": "device",
      "action": "reboot",
      "description": "Reboot a device",
      "adapter": "process",
      "adapterConfig": {
        "command": "mobilecli",
        "baseArgs": ["device", "reboot"],
        "passthrough": true,
        "missingDependencyHelp": "Install mobilecli: npm install -g mobilecli@latest"
      },
      "args": [
        { "name": "--device", "type": "string", "required": true, "description": "Device ID or name" }
      ]
    },
    {
      "namespace": "mobilecli",
      "resource": "screenshot",
      "action": "capture",
      "description": "Take a screenshot from a device",
      "adapter": "process",
      "adapterConfig": {
        "command": "mobilecli",
        "baseArgs": ["screenshot"],
        "passthrough": true,
        "missingDependencyHelp": "Install mobilecli: npm install -g mobilecli@latest"
      },
      "args": [
        { "name": "--device", "type": "string", "required": true, "description": "Device ID or name" },
        { "name": "--format", "type": "string", "description": "Screenshot format: png (default) or jpeg" },
        { "name": "--quality", "type": "string", "description": "JPEG quality (1-100, default: 90)" },
        { "name": "--output", "type": "string", "description": "Output file path (use - for stdout)" }
      ]
    },
    {
      "namespace": "mobilecli",
      "resource": "apps",
      "action": "list",
      "description": "List installed apps on a device",
      "adapter": "process",
      "adapterConfig": {
        "command": "mobilecli",
        "baseArgs": ["apps", "list"],
        "passthrough": true,
        "missingDependencyHelp": "Install mobilecli: npm install -g mobilecli@latest"
      },
      "args": [
        { "name": "--device", "type": "string", "required": true, "description": "Device ID or name" }
      ]
    },
    {
      "namespace": "mobilecli",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to mobilecli CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "mobilecli",
        "passthrough": true,
        "missingDependencyHelp": "Install mobilecli: npm install -g mobilecli@latest"
      },
      "args": []
    }
  ]
}
