{
  "name": "ferret",
  "version": "0.1.0",
  "description": "Declarative web scraping tool. Extract data from websites using a query language. Supports scraping, crawling, and data extraction from web pages.",
  "source": "https://github.com/MontFerret/ferret",
  "checks": [
    { "type": "binary", "name": "ferret" }
  ],
  "install_guidance": {
    "plugin": "ferret",
    "binary": "ferret",
    "check": "which ferret",
    "install_steps": [
      "brew install ferret",
      "Verify: ferret --version",
      "supercli plugins install ./plugins/ferret --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "ferret",
      "resource": "web",
      "action": "scrape",
      "description": "Scrape data from websites",
      "adapter": "process",
      "adapterConfig": {
        "command": "ferret",
        "passthrough": true,
        "missingDependencyHelp": "Install ferret: brew install ferret"
      },
      "args": [
        { "name": "file", "type": "string", "description": "FQL script file" },
        { "name": "--output", "type": "string", "description": "Output file" },
        { "name": "--format", "type": "string", "description": "Output format (json, csv)" },
        { "name": "--headless", "type": "boolean", "description": "Run in headless mode" },
        { "name": "--timeout", "type": "integer", "description": "Timeout in seconds" }
      ]
    },
    {
      "namespace": "ferret",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to ferret CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "ferret",
        "passthrough": true,
        "missingDependencyHelp": "Install ferret: brew install ferret"
      },
      "args": []
    }
  ]
}
