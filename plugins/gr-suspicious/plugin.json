{
  "name": "gr-suspicious",
  "version": "0.1.0",
  "description": "Suspicious lines of code detector for Git Repositories",
  "source": "https://github.com/kamsar/gr-suspicious",
  "checks": [
    {
      "type": "binary",
      "name": "gr-suspicious"
    }
  ],
  "install_guidance": {
    "plugin": "gr-suspicious",
    "binary": "gr-suspicious",
    "check": "which gr-suspicious",
    "install_steps": [
      "npm install -g gr-suspicious",
      "Verify: gr-suspicious --version",
      "supercli plugins install ./plugins/gr-suspicious --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "gr-suspicious",
      "resource": "self",
      "action": "version",
      "description": "Print gr-suspicious version",
      "adapter": "process",
      "adapterConfig": {
        "command": "gr-suspicious",
        "missingDependencyHelp": "Install gr-suspicious: npm install -g gr-suspicious",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "gr-suspicious",
      "resource": "repo",
      "action": "scan",
      "description": "scan repo via gr-suspicious",
      "adapter": "process",
      "adapterConfig": {
        "command": "gr-suspicious",
        "missingDependencyHelp": "Install gr-suspicious: npm install -g gr-suspicious",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
