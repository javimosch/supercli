{
  "name": "figma-export",
  "version": "0.1.0",
  "description": "CLI tool to bulk export Figma, FigJam, and Figma Slides files",
  "source": "https://github.com/alexchantastic/figma-export",
  "checks": [
    {
      "type": "binary",
      "name": "figma-export"
    }
  ],
  "install_guidance": {
    "plugin": "figma-export",
    "binary": "figma-export",
    "check": "which figma-export",
    "install_steps": [
      "npm install -g figma-export",
      "Verify: figma-export --version",
      "supercli plugins install ./plugins/figma-export --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
