      "resource": "self",
      "action": "version",
      "description": "Print figma-export version",
      "adapter": "process",
      "adapterConfig": {
        "command": "figma-export",
        "missingDependencyHelp": "Install figma-export: npm install -g figma-export",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
