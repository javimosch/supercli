{
  "name": "stackit-cli",
  "version": "0.1.0",
  "description": "Command line interface to manage STACKIT cloud resources",
  "source": "https://github.com/stackitcloud/stackit-cli",
  "checks": [
    {
      "type": "binary",
      "name": "stackit"
    }
  ],
  "install_guidance": {
    "plugin": "stackit-cli",
    "binary": "stackit",
    "check": "which stackit",
    "install_steps": [
      "brew install stackit",
      "Verify: stackit --version",
      "supercli plugins install ./plugins/stackit-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "stackit-cli",
      "resource": "self",
      "action": "version",
      "description": "Print stackit-cli version",
      "adapter": "process",
      "adapterConfig": {
        "command": "stackit",
        "missingDependencyHelp": "Install stackit-cli: brew install stackit",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "stackit-cli",
      "resource": "project",
      "action": "list",
      "description": "list project via stackit",
      "adapter": "process",
      "adapterConfig": {
        "command": "stackit",
        "missingDependencyHelp": "Install stackit-cli: brew install stackit",
        "baseArgs": [
          "project",
          "list"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "stackit-cli",
      "resource": "resource",
      "action": "list",
      "description": "list resource via stackit",
      "adapter": "process",
      "adapterConfig": {
        "command": "stackit",
        "missingDependencyHelp": "Install stackit-cli: brew install stackit",
        "baseArgs": [
          "list"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "stackit-cli",
      "resource": "config",
      "action": "set",
      "description": "set config via stackit",
      "adapter": "process",
      "adapterConfig": {
        "command": "stackit",
        "missingDependencyHelp": "Install stackit-cli: brew install stackit",
        "baseArgs": [
          "config",
          "set"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "stackit-cli",
      "resource": "_",
      "action": "_",
      "description": "_ _ via stackit",
      "adapter": "process",
      "adapterConfig": {
        "command": "stackit",
        "missingDependencyHelp": "Install stackit-cli: brew install stackit",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}