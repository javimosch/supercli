{
  "name": "replace-in-file",
  "version": "0.1.0",
  "description": "Replace text in files from the command line",
  "source": "https://github.com/adamreisnz/replace-in-file",
  "checks": [
    {
      "type": "binary",
      "name": "replace-in-file"
    }
  ],
  "install_guidance": {
    "plugin": "replace-in-file",
    "binary": "replace-in-file",
    "check": "which replace-in-file",
    "install_steps": [
      "npm install -g replace-in-file-cli",
      "Verify: replace-in-file --version",
      "supercli plugins install ./plugins/replace-in-file --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "replace-in-file",
      "resource": "self",
      "action": "version",
      "description": "Print replace-in-file version",
      "adapter": "process",
      "adapterConfig": {
        "command": "replace-in-file",
        "missingDependencyHelp": "Install replace-in-file: npm install -g replace-in-file-cli",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "replace-in-file",
      "resource": "file",
      "action": "replace",
      "description": "replace file via replace-in-file",
      "adapter": "process",
      "adapterConfig": {
        "command": "replace-in-file",
        "missingDependencyHelp": "Install replace-in-file: npm install -g replace-in-file-cli",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "replace-in-file",
      "resource": "_",
      "action": "_",
      "description": "_ _ via replace-in-file",
      "adapter": "process",
      "adapterConfig": {
        "command": "replace-in-file",
        "missingDependencyHelp": "Install replace-in-file: npm install -g replace-in-file-cli",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}