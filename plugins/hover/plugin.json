{
  "name": "hover",
  "version": "0.1.0",
  "description": "A CLI tool to build and run Flutter desktop applications. Build, run, and manage Flutter desktop apps from the command line.",
  "source": "https://github.com/go-flutter-desktop/hover",
  "checks": [
    { "type": "binary", "name": "hover" }
  ],
  "install_guidance": {
    "plugin": "hover",
    "binary": "hover",
    "check": "which hover",
    "install_steps": [
      "brew install hover",
      "Verify: hover --version",
      "supercli plugins install ./plugins/hover --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "hover",
      "resource": "app",
      "action": "run",
      "description": "Run Flutter desktop app",
      "adapter": "process",
      "adapterConfig": {
        "command": "hover",
        "baseArgs": ["run"],
        "passthrough": true,
        "missingDependencyHelp": "Install hover: brew install hover"
      },
      "args": [
        { "name": "--target", "type": "string", "description": "Target platform" },
        { "name": "--debug", "type": "boolean", "description": "Debug build" }
      ]
    },
    {
      "namespace": "hover",
      "resource": "app",
      "action": "build",
      "description": "Build Flutter desktop app",
      "adapter": "process",
      "adapterConfig": {
        "command": "hover",
        "baseArgs": ["build"],
        "passthrough": true,
        "missingDependencyHelp": "Install hover: brew install hover"
      },
      "args": [
        { "name": "--target", "type": "string", "description": "Target platform" },
        { "name": "--release", "type": "boolean", "description": "Release build" }
      ]
    },
    {
      "namespace": "hover",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to hover CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "hover",
        "passthrough": true,
        "missingDependencyHelp": "Install hover: brew install hover"
      },
      "args": []
    }
  ]
}
