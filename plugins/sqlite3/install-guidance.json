{
  "plugin": "sqlite3",
  "binary": "sqlite3",
  "check": "which sqlite3",
  "install_steps": [
    "macOS: brew install sqlite3",
    "Ubuntu/Debian: sudo apt install sqlite3",
    "Windows: choco install sqlite (with Chocolatey)",
    "Verify: sqlite3 --version",
    "supercli plugins install ./plugins/sqlite3 --on-conflict replace --json"
  ],
  "note": "All queries use -json output by default. Use sqlite3 _ _ for raw passthrough commands."
}