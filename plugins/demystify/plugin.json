{
  "name": "demystify",
  "version": "0.1.0",
  "description": "Automated documentation for APIs from command line",
  "source": "https://github.com/AndrewWalsh/demystify",
  "checks": [
    {
      "type": "binary",
      "name": "demystify"
    }
  ],
  "install_guidance": {
    "plugin": "demystify",
    "binary": "demystify",
    "check": "which demystify",
    "install_steps": [
      "npm install -g demystify",
      "Verify: demystify --version",
      "supercli plugins install ./plugins/demystify --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "demystify",
      "resource": "self",
      "action": "version",
      "description": "Print demystify version",
      "adapter": "process",
      "adapterConfig": {
        "command": "demystify",
        "missingDependencyHelp": "Install demystify: npm install -g demystify",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "demystify",
      "resource": "api",
      "action": "document",
      "description": "document api via demystify",
      "adapter": "process",
      "adapterConfig": {
        "command": "demystify",
        "missingDependencyHelp": "Install demystify: npm install -g demystify",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
