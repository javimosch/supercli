      "resource": "self",
      "action": "version",
      "description": "Print os-cli version",
      "adapter": "process",
      "adapterConfig": {
        "command": "os-cli",
        "missingDependencyHelp": "Install os-cli: npm install -g os-cli",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
