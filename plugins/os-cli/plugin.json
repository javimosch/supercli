{
  "name": "os-cli",
  "version": "0.1.0",
  "description": "Fine-grained cross-platform OS information from the command line",
  "source": "https://github.com/nexxeln/os-cli",
  "checks": [
    {
      "type": "binary",
      "name": "os-cli"
    }
  ],
  "install_guidance": {
    "plugin": "os-cli",
    "binary": "os-cli",
    "check": "which os-cli",
    "install_steps": [
      "npm install -g os-cli",
      "Verify: os-cli --version",
      "supercli plugins install ./plugins/os-cli --on-conflict replace --json"
    ]
  },
