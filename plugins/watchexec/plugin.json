{
  "name": "watchexec",
  "version": "0.1.0",
  "description": "watchexec CLI plugin for dcli",
  "source": "https://github.com/watchexec/watchexec",
  "checks": [
    {
      "type": "binary",
      "name": "watchexec"
    }
  ],
  "commands": [
    {
      "namespace": "watchexec",
      "resource": "cli",
      "action": "version",
      "description": "Show watchexec CLI version",
      "adapter": "process",
      "adapterConfig": {
        "command": "watchexec",
        "baseArgs": ["--version"],
        "parseJson": false,
        "missingDependencyHelp": "Please install watchexec to use this command."
      },
      "args": []
    },
    {
      "namespace": "watchexec",
      "resource": "_",
      "action": "_",
      "description": "Passthrough command to execute any watchexec CLI command",
      "adapter": "process",
      "adapterConfig": {
        "command": "watchexec",
        "passthrough": true,
        "parseJson": true,
        "missingDependencyHelp": "Please install watchexec to use this command."
      },
      "args": []
    }
  ]
}
