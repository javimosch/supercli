{
  "name": "just",
  "version": "0.1.0",
  "description": "just CLI plugin for dcli",
  "source": "https://just.systems/man/en/",
  "checks": [
    {
      "type": "binary",
      "name": "just"
    }
  ],
  "commands": [
    {
      "namespace": "just",
      "resource": "cli",
      "action": "version",
      "description": "Show just CLI version",
      "adapter": "process",
      "adapterConfig": {
        "command": "just",
        "baseArgs": ["--version"],
        "parseJson": false,
        "missingDependencyHelp": "Please install just to use this command."
      },
      "args": []
    },
    {
      "namespace": "just",
      "resource": "_",
      "action": "_",
      "description": "Passthrough command to execute any just CLI command",
      "adapter": "process",
      "adapterConfig": {
        "command": "just",
        "passthrough": true,
        "parseJson": true,
        "missingDependencyHelp": "Please install just to use this command."
      },
      "args": []
    }
  ]
}
