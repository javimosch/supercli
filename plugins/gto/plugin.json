{
  "name": "gto",
  "version": "0.1.0",
  "description": "Git Tag Ops turn your Git repository into Artifact Registry or Model Registry",
  "source": "https://github.com/iterative/gto",
  "checks": [
    {
      "type": "binary",
      "name": "gto"
    }
  ],
  "install_guidance": {
    "plugin": "gto",
    "binary": "gto",
    "check": "which gto",
    "install_steps": [
      "pip install gto",
      "Verify: gto --version",
      "supercli plugins install ./plugins/gto --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "gto",
      "resource": "self",
      "action": "version",
      "description": "Print gto version",
      "adapter": "process",
      "adapterConfig": {
        "command": "gto",
        "missingDependencyHelp": "Install gto: pip install gto",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "gto",
      "resource": "tag",
      "action": "create",
      "description": "create tag via gto",
      "adapter": "process",
      "adapterConfig": {
        "command": "gto",
        "missingDependencyHelp": "Install gto: pip install gto",
        "baseArgs": [
          "create"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "gto",
