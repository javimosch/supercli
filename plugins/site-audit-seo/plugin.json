{
  "name": "site-audit-seo",
  "version": "0.1.0",
  "description": "SEO site audit tool for command line",
  "source": "https://github.com/viasite/site-audit-seo",
  "checks": [
    {
      "type": "binary",
      "name": "site-audit-seo"
    }
  ],
  "install_guidance": {
    "plugin": "site-audit-seo",
    "binary": "site-audit-seo",
    "check": "which site-audit-seo",
    "install_steps": [
      "npm install -g site-audit-seo",
      "Verify: site-audit-seo --version",
      "supercli plugins install ./plugins/site-audit-seo --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "site-audit-seo",
      "resource": "self",
      "action": "version",
      "description": "Print site-audit-seo version",
      "adapter": "process",
      "adapterConfig": {
        "command": "site-audit-seo",
        "missingDependencyHelp": "Install site-audit-seo: npm install -g site-audit-seo",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "site-audit-seo",
      "resource": "site",
      "action": "audit",
      "description": "audit site via site-audit-seo",
      "adapter": "process",
      "adapterConfig": {
        "command": "site-audit-seo",
        "missingDependencyHelp": "Install site-audit-seo: npm install -g site-audit-seo",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "site-audit-seo",
      "resource": "_",
      "action": "_",
      "description": "_ _ via site-audit-seo",
      "adapter": "process",
      "adapterConfig": {
        "command": "site-audit-seo",
        "missingDependencyHelp": "Install site-audit-seo: npm install -g site-audit-seo",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}