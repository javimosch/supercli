{
  "name": "vale",
  "version": "0.1.0",
  "description": "Markup-aware linter for prose",
  "source": "https://github.com/vale-cli/vale",
  "checks": [
    {
      "type": "binary",
      "name": "vale"
    }
  ],
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "vale",
      "resource": "lint",
      "action": "run",
      "description": "Lint prose files",
      "adapter": "process",
      "adapterConfig": {
        "command": "vale",
        "passthrough": true
      },
      "args": [
        {
          "name": "files",
          "type": "string",
          "required": true,
          "description": "Files to lint"
        }
      ]
    },
    {
      "namespace": "vale",
      "resource": "config",
      "action": "init",
      "description": "Initialize vale config",
      "adapter": "process",
      "adapterConfig": {
        "command": "vale",
        "baseArgs": [
          "--config"
        ],
        "passthrough": true
      }
    }
  ]
}