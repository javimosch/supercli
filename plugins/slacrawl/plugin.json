{
  "name": "slacrawl",
  "version": "0.1.0",
  "description": "Crawl and archive Slack workspaces from the command line",
  "source": "https://github.com/vincentkoc/slacrawl",
  "checks": [
    {
      "type": "binary",
      "name": "slacrawl"
    }
  ],
  "install_guidance": {
    "plugin": "slacrawl",
    "binary": "slacrawl",
    "check": "which slacrawl",
    "install_steps": [
      "go install github.com/vincentkoc/slacrawl@latest",
      "Verify: slacrawl --version",
      "supercli plugins install ./plugins/slacrawl --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "slacrawl",
      "resource": "self",
      "action": "version",
      "description": "Print slacrawl version",
      "adapter": "process",
      "adapterConfig": {
        "command": "slacrawl",
        "missingDependencyHelp": "Install slacrawl: go install github.com/vincentkoc/slacrawl@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "slacrawl",
      "resource": "workspace",
      "action": "crawl",
      "description": "crawl workspace via slacrawl",
      "adapter": "process",
      "adapterConfig": {
        "command": "slacrawl",
        "missingDependencyHelp": "Install slacrawl: go install github.com/vincentkoc/slacrawl@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "slacrawl",
      "resource": "channel",
      "action": "list",
      "description": "list channel via slacrawl",
      "adapter": "process",
      "adapterConfig": {
        "command": "slacrawl",
        "missingDependencyHelp": "Install slacrawl: go install github.com/vincentkoc/slacrawl@latest",
        "baseArgs": [
          "--channels"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "slacrawl",
      "resource": "_",
      "action": "_",
      "description": "_ _ via slacrawl",
      "adapter": "process",
      "adapterConfig": {
        "command": "slacrawl",
        "missingDependencyHelp": "Install slacrawl: go install github.com/vincentkoc/slacrawl@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}