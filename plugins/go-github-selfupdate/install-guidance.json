{
  "plugin": "go-github-selfupdate",
  "binary": "go-github-selfupdate",
  "check": "which go-github-selfupdate",
  "install_steps": [
    "go install github.com/rhysd/go-github-selfupdate@latest",
    "Verify: go-github-selfupdate --version",
    "supercli plugins install ./plugins/go-github-selfupdate --on-conflict replace --json"
  ]
}