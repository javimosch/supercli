{
  "name": "go-github-selfupdate",
  "version": "0.1.0",
  "description": "Binary self-update mechanism for Go applications",
  "source": "https://github.com/rhysd/go-github-selfupdate",
  "checks": [
    {
      "type": "binary",
      "name": "go-github-selfupdate"
    }
  ],
  "install_guidance": {
    "plugin": "go-github-selfupdate",
    "binary": "go-github-selfupdate",
    "check": "which go-github-selfupdate",
    "install_steps": [
      "go install github.com/rhysd/go-github-selfupdate@latest",
      "Verify: go-github-selfupdate --version",
      "supercli plugins install ./plugins/go-github-selfupdate --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "go-github-selfupdate",
      "resource": "self",
      "action": "version",
      "description": "Print go-github-selfupdate version",
      "adapter": "process",
      "adapterConfig": {
        "command": "go-github-selfupdate",
        "missingDependencyHelp": "Install go-github-selfupdate: go install github.com/rhysd/go-github-selfupdate@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "go-github-selfupdate",
      "resource": "binary",
      "action": "update",
      "description": "update binary via go-github-selfupdate",
      "adapter": "process",
      "adapterConfig": {
        "command": "go-github-selfupdate",
        "missingDependencyHelp": "Install go-github-selfupdate: go install github.com/rhysd/go-github-selfupdate@latest",
        "baseArgs": [
          "update"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "go-github-selfupdate",
      "resource": "binary",
      "action": "check",
      "description": "check binary via go-github-selfupdate",
      "adapter": "process",
      "adapterConfig": {
        "command": "go-github-selfupdate",
        "missingDependencyHelp": "Install go-github-selfupdate: go install github.com/rhysd/go-github-selfupdate@latest",
        "baseArgs": [
          "check"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "go-github-selfupdate",
      "resource": "release",
      "action": "list",
      "description": "list release via go-github-selfupdate",
      "adapter": "process",
      "adapterConfig": {
        "command": "go-github-selfupdate",
        "missingDependencyHelp": "Install go-github-selfupdate: go install github.com/rhysd/go-github-selfupdate@latest",
        "baseArgs": [
          "releases"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "go-github-selfupdate",
      "resource": "config",
      "action": "show",
      "description": "show config via go-github-selfupdate",
      "adapter": "process",
      "adapterConfig": {
        "command": "go-github-selfupdate",
        "missingDependencyHelp": "Install go-github-selfupdate: go install github.com/rhysd/go-github-selfupdate@latest",
        "baseArgs": [
          "--config"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "go-github-selfupdate",
      "resource": "_",
      "action": "_",
      "description": "_ _ via go-github-selfupdate",
      "adapter": "process",
      "adapterConfig": {
        "command": "go-github-selfupdate",
        "missingDependencyHelp": "Install go-github-selfupdate: go install github.com/rhysd/go-github-selfupdate@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}