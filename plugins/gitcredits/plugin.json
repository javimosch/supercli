{
  "name": "gitcredits",
  "version": "0.1.0",
  "description": "Generate contributor credits and statistics for Git repositories",
  "source": "https://github.com/Higangssh/gitcredits",
  "checks": [
    {
      "type": "binary",
      "name": "gitcredits"
    }
  ],
  "install_guidance": {
    "plugin": "gitcredits",
    "binary": "gitcredits",
    "check": "which gitcredits",
    "install_steps": [
      "go install github.com/Higangssh/gitcredits@latest",
      "Verify: gitcredits --version",
      "supercli plugins install ./plugins/gitcredits --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "gitcredits",
      "resource": "self",
      "action": "version",
      "description": "Print gitcredits version",
      "adapter": "process",
      "adapterConfig": {
        "command": "gitcredits",
        "missingDependencyHelp": "Install gitcredits: go install github.com/Higangssh/gitcredits@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "gitcredits",
      "resource": "repo",
      "action": "credits",
      "description": "credits repo via gitcredits",
      "adapter": "process",
      "adapterConfig": {
        "command": "gitcredits",
        "missingDependencyHelp": "Install gitcredits: go install github.com/Higangssh/gitcredits@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "gitcredits",
      "resource": "repo",
      "action": "stats",
      "description": "stats repo via gitcredits",
      "adapter": "process",
      "adapterConfig": {
        "command": "gitcredits",
        "missingDependencyHelp": "Install gitcredits: go install github.com/Higangssh/gitcredits@latest",
        "baseArgs": [
          "--stats"
        ],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "gitcredits",
      "resource": "format",
      "action": "export",
      "description": "export format via gitcredits",
      "adapter": "process",
      "adapterConfig": {
        "command": "gitcredits",
        "missingDependencyHelp": "Install gitcredits: go install github.com/Higangssh/gitcredits@latest",
        "baseArgs": [
          "--format"
        ],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "gitcredits",
      "resource": "_",
      "action": "_",
      "description": "_ _ via gitcredits",
      "adapter": "process",
      "adapterConfig": {
        "command": "gitcredits",
        "missingDependencyHelp": "Install gitcredits: go install github.com/Higangssh/gitcredits@latest",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}