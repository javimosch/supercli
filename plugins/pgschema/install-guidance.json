{
  "plugin": "pgschema",
  "binary": "pgschema",
  "check": "which pgschema",
  "install_steps": [
    "go install github.com/pgplex/pgschema@latest",
    "Verify: pgschema --version",
    "supercli plugins install ./plugins/pgschema --on-conflict replace --json"
  ],
  "note": "Windows is not supported. Use WSL or Linux VM."
}
