{
  "name": "bulloak",
  "version": "0.1.0",
  "description": "Generate tests based on the Branching Tree Technique for smart contract testing",
  "source": "https://github.com/alexfertel/bulloak",
  "checks": [
    {
      "type": "binary",
      "name": "bulloak"
    }
  ],
  "install_guidance": {
    "plugin": "bulloak",
    "binary": "bulloak",
    "check": "which bulloak",
    "install_steps": [
      "cargo install bulloak",
      "Verify: bulloak --version",
      "supercli plugins install ./plugins/bulloak --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "bulloak",
      "resource": "self",
      "action": "version",
      "description": "Print bulloak version",
      "adapter": "process",
      "adapterConfig": {
        "command": "bulloak",
        "missingDependencyHelp": "Install bulloak: cargo install bulloak",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "bulloak",
      "resource": "test",
      "action": "generate",
      "description": "generate test via bulloak",
      "adapter": "process",
      "adapterConfig": {
        "command": "bulloak",
        "missingDependencyHelp": "Install bulloak: cargo install bulloak",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "bulloak",
      "resource": "tree",
      "action": "parse",
      "description": "parse tree via bulloak",
      "adapter": "process",
      "adapterConfig": {
        "command": "bulloak",
        "missingDependencyHelp": "Install bulloak: cargo install bulloak",
        "baseArgs": [
          "--parse"
        ],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "bulloak",
      "resource": "contract",
      "action": "analyze",
      "description": "analyze contract via bulloak",
      "adapter": "process",
      "adapterConfig": {
        "command": "bulloak",
        "missingDependencyHelp": "Install bulloak: cargo install bulloak",
        "baseArgs": [
          "--analyze"
        ],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "bulloak",
      "resource": "config",
      "action": "show",
      "description": "show config via bulloak",
      "adapter": "process",
      "adapterConfig": {
        "command": "bulloak",
        "missingDependencyHelp": "Install bulloak: cargo install bulloak",
        "baseArgs": [
          "--config"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "bulloak",
      "resource": "_",
      "action": "_",
      "description": "_ _ via bulloak",
