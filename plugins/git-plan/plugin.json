{
  "name": "git-plan",
  "version": "0.1.0",
  "description": "Git Plan a better workflow for git with planning and tracking features",
  "source": "https://github.com/rorybyrne/git-plan",
  "checks": [
    {
      "type": "binary",
      "name": "git-plan"
    }
  ],
  "install_guidance": {
    "plugin": "git-plan",
    "binary": "git-plan",
    "check": "which git-plan",
    "install_steps": [
      "pip install git-plan",
      "Verify: git-plan --version",
      "supercli plugins install ./plugins/git-plan --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "git-plan",
      "resource": "self",
      "action": "version",
      "description": "Print git-plan version",
      "adapter": "process",
      "adapterConfig": {
        "command": "git-plan",
        "missingDependencyHelp": "Install git-plan: pip install git-plan",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "git-plan",
      "resource": "plan",
      "action": "create",
      "description": "create plan via git-plan",
      "adapter": "process",
      "adapterConfig": {
        "command": "git-plan",
        "missingDependencyHelp": "Install git-plan: pip install git-plan",
        "baseArgs": [
          "plan"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
