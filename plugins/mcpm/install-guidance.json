{
  "plugin": "mcpm",
  "binary": "mcpm",
  "check": "mcpm --version",
  "install_steps": [
    "curl -sSL https://mcpm.sh/install | bash",
    "Verify: mcpm --version",
    "supercli plugins install ./plugins/mcpm --on-conflict replace --json"
  ],
  "note": "Requires curl. Works on Linux, macOS, and Windows via WSL."
}
