    "plugin": "Twitter-Archive",
    "binary": "twitter-archive",
    "check": "which twitter-archive",
    "install_steps": [
      "pip install twitter-archive",
      "Verify: twitter-archive --version",
      "supercli plugins install ./plugins/Twitter-Archive --on-conflict replace --json"
