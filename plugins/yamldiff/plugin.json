{
  "name": "yamldiff",
  "version": "0.1.0",
  "description": "CLI tool to diff two YAML files with structural awareness",
  "source": "https://github.com/sahilm/yamldiff",
  "checks": [
    {
      "type": "binary",
      "name": "yamldiff"
    }
  ],
  "install_guidance": {
    "plugin": "yamldiff",
    "binary": "yamldiff",
    "check": "which yamldiff",
    "install_steps": [
      "go install github.com/sahilm/yamldiff@latest",
      "Verify: yamldiff --version",
      "supercli plugins install ./plugins/yamldiff --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "yamldiff",
      "resource": "self",
      "action": "version",
      "description": "Print yamldiff version",
      "adapter": "process",
      "adapterConfig": {
        "command": "yamldiff",
        "missingDependencyHelp": "Install yamldiff: go install github.com/sahilm/yamldiff@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "yamldiff",
      "resource": "files",
      "action": "diff",
      "description": "diff files via yamldiff",
      "adapter": "process",
      "adapterConfig": {
        "command": "yamldiff",
        "missingDependencyHelp": "Install yamldiff: go install github.com/sahilm/yamldiff@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "yamldiff",
      "resource": "files",
      "action": "compare",
      "description": "compare files via yamldiff",
      "adapter": "process",
      "adapterConfig": {
        "command": "yamldiff",
        "missingDependencyHelp": "Install yamldiff: go install github.com/sahilm/yamldiff@latest",
        "baseArgs": [
          "--compare"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "yamldiff",
      "resource": "_",
      "action": "_",
      "description": "_ _ via yamldiff",
      "adapter": "process",
      "adapterConfig": {
        "command": "yamldiff",
        "missingDependencyHelp": "Install yamldiff: go install github.com/sahilm/yamldiff@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}