{
  "name": "wgcf",
  "version": "0.1.0",
  "description": "Cross-platform CLI for Cloudflare Warp",
  "source": "https://github.com/ViRb3/wgcf",
  "checks": [
    {
      "type": "binary",
      "name": "wgcf"
    }
  ],
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "wgcf",
      "resource": "account",
      "action": "register",
      "description": "Register new Cloudflare account",
      "adapter": "process",
      "adapterConfig": {
        "command": "wgcf",
        "baseArgs": [
          "register"
        ],
        "passthrough": true
      }
    },
    {
      "namespace": "wgcf",
      "resource": "profile",
      "action": "generate",
      "description": "Generate WireGuard profile",
      "adapter": "process",
      "adapterConfig": {
        "command": "wgcf",
        "baseArgs": [
          "generate"
        ],
        "passthrough": true
      }
    }
  ]
}