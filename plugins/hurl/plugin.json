{
  "name": "hurl",
  "version": "0.1.0",
  "description": "Run and test HTTP requests with plain text. An HTTP testing tool that uses a simple text format for defining requests and assertions. Perfect for API testing, integration testing, and CI/CD.",
  "source": "https://github.com/Orange-OpenSource/hurl",
  "checks": [
    { "type": "binary", "name": "hurl" }
  ],
  "install_guidance": {
    "plugin": "hurl",
    "binary": "hurl",
    "check": "which hurl",
    "install_steps": [
      "brew install hurl",
      "Verify: hurl --version",
      "supercli plugins install ./plugins/hurl --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "hurl",
      "resource": "request",
      "action": "run",
      "description": "Run HTTP request from hurl file",
      "adapter": "process",
      "adapterConfig": {
        "command": "hurl",
        "passthrough": true,
        "missingDependencyHelp": "Install hurl: brew install hurl"
      },
      "args": [
        { "name": "files", "type": "string", "required": true, "description": "Hurl files to run" },
        { "name": "--test", "type": "boolean", "description": "Run in test mode" },
        { "name": "--verbose", "type": "boolean", "description": "Verbose output" },
        { "name": "--output", "type": "string", "description": "Output response body to file" },
        { "name": "--no-output", "type": "boolean", "description": "Suppress response output" },
        { "name": "--report", "type": "string", "description": "Generate report (html, json, junit, tap)" },
        { "name": "--glob", "type": "string", "description": "Glob pattern for files" },
        { "name": "--continue-on-error", "type": "boolean", "description": "Continue on error" }
      ]
    },
    {
      "namespace": "hurl",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to hurl CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "hurl",
        "passthrough": true,
        "missingDependencyHelp": "Install hurl: brew install hurl"
      },
      "args": []
    }
  ]
}
