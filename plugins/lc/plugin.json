{
  "name": "lc",
  "version": "0.1.0",
  "description": "License checker for source code files",
  "source": "https://github.com/boyter/lc",
  "checks": [
    {
      "type": "binary",
      "name": "lc"
    }
  ],
  "install_guidance": {
    "plugin": "lc",
    "binary": "lc",
    "check": "which lc",
    "install_steps": [
      "go install github.com/boyter/lc@latest",
      "Verify: lc --version",
      "supercli plugins install ./plugins/lc --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "lc",
      "resource": "self",
      "action": "version",
      "description": "Print lc version",
      "adapter": "process",
      "adapterConfig": {
        "command": "lc",
        "missingDependencyHelp": "Install lc: go install github.com/boyter/lc@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "lc",
      "resource": "project",
      "action": "analyze",
      "description": "analyze project via lc",
      "adapter": "process",
      "adapterConfig": {
        "command": "lc",
        "missingDependencyHelp": "Install lc: go install github.com/boyter/lc@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "lc",
      "resource": "file",
      "action": "check",
      "description": "check file via lc",
      "adapter": "process",
      "adapterConfig": {
        "command": "lc",
        "missingDependencyHelp": "Install lc: go install github.com/boyter/lc@latest",
        "baseArgs": [
          "--file"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "lc",
      "resource": "format",
      "action": "show",
      "description": "show format via lc",
      "adapter": "process",
      "adapterConfig": {
        "command": "lc",
        "missingDependencyHelp": "Install lc: go install github.com/boyter/lc@latest",
        "baseArgs": [
          "--format"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "lc",
      "resource": "_",
      "action": "_",
      "description": "_ _ via lc",
      "adapter": "process",
      "adapterConfig": {
        "command": "lc",
        "missingDependencyHelp": "Install lc: go install github.com/boyter/lc@latest",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}