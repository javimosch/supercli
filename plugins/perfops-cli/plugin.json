{
  "name": "perfops-cli",
  "version": "0.1.0",
  "description": "Command line tool to interact with servers around the world",
  "source": "https://github.com/ProspectOne/perfops-cli",
  "checks": [
    {
      "type": "binary",
      "name": "perfops"
    }
  ],
  "install_guidance": {
    "plugin": "perfops-cli",
    "binary": "perfops",
    "check": "which perfops",
    "install_steps": [
      "go install github.com/ProspectOne/perfops-cli@latest",
      "Verify: perfops --version",
      "supercli plugins install ./plugins/perfops-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "perfops-cli",
      "resource": "self",
      "action": "version",
      "description": "Print perfops-cli version",
      "adapter": "process",
      "adapterConfig": {
        "command": "perfops",
        "missingDependencyHelp": "Install perfops-cli: go install github.com/ProspectOne/perfops-cli@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "perfops-cli",
      "resource": "ping",
      "action": "run",
      "description": "run ping via perfops",
      "adapter": "process",
      "adapterConfig": {
        "command": "perfops",
        "missingDependencyHelp": "Install perfops-cli: go install github.com/ProspectOne/perfops-cli@latest",
        "baseArgs": [
          "ping"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
