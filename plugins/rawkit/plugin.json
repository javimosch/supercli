{
  "name": "rawkit",
  "version": "0.1.0",
  "description": "Development toolkit and project scaffolding CLI",
  "source": "https://github.com/darcyclarke/rawkit",
  "checks": [
    {
      "type": "binary",
      "name": "rawkit"
    }
  ],
  "install_guidance": {
    "plugin": "rawkit",
    "binary": "rawkit",
    "check": "which rawkit",
    "install_steps": [
      "npm install -g rawkit",
      "Verify: rawkit --version",
      "supercli plugins install ./plugins/rawkit --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "rawkit",
      "resource": "self",
      "action": "version",
      "description": "Print rawkit version",
      "adapter": "process",
      "adapterConfig": {
        "command": "rawkit",
        "missingDependencyHelp": "Install rawkit: npm install -g rawkit",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "rawkit",
      "resource": "project",
      "action": "scaffold",
      "description": "scaffold project via rawkit",
      "adapter": "process",
      "adapterConfig": {
        "command": "rawkit",
        "missingDependencyHelp": "Install rawkit: npm install -g rawkit",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "rawkit",
      "resource": "project",
      "action": "init",
      "description": "init project via rawkit",
      "adapter": "process",
      "adapterConfig": {
        "command": "rawkit",
        "missingDependencyHelp": "Install rawkit: npm install -g rawkit",
        "baseArgs": [
          "init"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "rawkit",
      "resource": "_",
      "action": "_",
      "description": "_ _ via rawkit",
      "adapter": "process",
      "adapterConfig": {
        "command": "rawkit",
        "missingDependencyHelp": "Install rawkit: npm install -g rawkit",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}