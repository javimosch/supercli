{
  "name": "qrc",
  "version": "0.1.0",
  "description": "QR code generator for text terminals with ASCII art and Sixel support",
  "source": "https://github.com/fumiyas/qrc",
  "checks": [
    {
      "type": "binary",
      "name": "qrc"
    }
  ],
  "install_guidance": {
    "plugin": "qrc",
    "binary": "qrc",
    "check": "which qrc",
    "install_steps": [
      "go install github.com/fumiyas/qrc@latest",
      "Verify: qrc --version",
      "supercli plugins install ./plugins/qrc --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "qrc",
      "resource": "self",
      "action": "version",
      "description": "Print qrc version",
      "adapter": "process",
      "adapterConfig": {
        "command": "qrc",
        "missingDependencyHelp": "Install qrc: go install github.com/fumiyas/qrc@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "qrc",
      "resource": "text",
      "action": "encode",
      "description": "encode text via qrc",
      "adapter": "process",
      "adapterConfig": {
        "command": "qrc",
        "missingDependencyHelp": "Install qrc: go install github.com/fumiyas/qrc@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
