{
  "name": "dfir-toolkit",
  "version": "0.1.0",
  "description": "CLI tools for forensic investigation of Windows artifacts",
  "source": "https://github.com/dfir-dd/dfir-toolkit",
  "checks": [
    {
      "type": "binary",
      "name": "dfir-toolkit"
    }
  ],
  "install_guidance": {
    "plugin": "dfir-toolkit",
    "binary": "dfir-toolkit",
    "check": "which dfir-toolkit",
    "install_steps": [
      "cargo install dfir-toolkit",
      "Verify: dfir-toolkit --version",
      "supercli plugins install ./plugins/dfir-toolkit --on-conflict replace --json"
    ]
  },
