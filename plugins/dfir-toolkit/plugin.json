      "action": "version",
      "description": "Print dfir-toolkit version",
      "adapter": "process",
      "adapterConfig": {
        "command": "dfir-toolkit",
        "missingDependencyHelp": "Install dfir-toolkit: cargo install dfir-toolkit",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
