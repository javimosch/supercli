{
  "name": "mbt",
  "version": "0.1.0",
  "description": "The most flexible build tool for monorepo",
  "source": "https://github.com/mbtproject/mbt",
  "checks": [
    {
      "type": "binary",
      "name": "mbt"
    }
  ],
  "install_guidance": {
    "plugin": "mbt",
    "binary": "mbt",
    "check": "which mbt",
    "install_steps": [
      "go install github.com/mbtproject/mbt@latest",
      "Verify: mbt --version",
      "supercli plugins install ./plugins/mbt --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "mbt",
      "resource": "self",
      "action": "version",
      "description": "Print mbt version",
      "adapter": "process",
      "adapterConfig": {
        "command": "mbt",
        "missingDependencyHelp": "Install mbt: go install github.com/mbtproject/mbt@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "mbt",
      "resource": "build",
      "action": "run",
      "description": "run build via mbt",
      "adapter": "process",
      "adapterConfig": {
        "command": "mbt",
        "missingDependencyHelp": "Install mbt: go install github.com/mbtproject/mbt@latest",
        "baseArgs": [
          "build"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "mbt",
      "resource": "discover",
      "action": "run",
      "description": "run discover via mbt",
      "adapter": "process",
      "adapterConfig": {
        "command": "mbt",
        "missingDependencyHelp": "Install mbt: go install github.com/mbtproject/mbt@latest",
        "baseArgs": [
          "discover"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "mbt",
      "resource": "apply",
      "action": "run",
      "description": "run apply via mbt",
      "adapter": "process",
      "adapterConfig": {
        "command": "mbt",
        "missingDependencyHelp": "Install mbt: go install github.com/mbtproject/mbt@latest",
        "baseArgs": [
          "apply"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "mbt",
      "resource": "commit",
      "action": "show",
      "description": "show commit via mbt",
      "adapter": "process",
      "adapterConfig": {
        "command": "mbt",
        "missingDependencyHelp": "Install mbt: go install github.com/mbtproject/mbt@latest",
        "baseArgs": [
          "commit"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "mbt",
      "resource": "_",
      "action": "_",
      "description": "_ _ via mbt",
      "adapter": "process",
      "adapterConfig": {
        "command": "mbt",
        "missingDependencyHelp": "Install mbt: go install github.com/mbtproject/mbt@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}