{
  "name": "nafas",
  "version": "0.1.0",
  "description": "Breathing Gymnastics Application for guided breathing exercises",
  "source": "https://github.com/sepandhaghighi/nafas",
  "checks": [
    {
      "type": "binary",
      "name": "nafas"
    }
  ],
