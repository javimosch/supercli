{
  "name": "is-esm",
  "version": "0.1.0",
  "description": "Check if a package is an ES module",
  "source": "https://github.com/mgechev/is-esm",
  "checks": [
    {
      "type": "binary",
      "name": "is-esm"
    }
  ],
  "install_guidance": {
    "plugin": "is-esm",
    "binary": "is-esm",
    "check": "which is-esm",
    "install_steps": [
      "npm install -g is-esm",
      "Verify: is-esm --version",
      "supercli plugins install ./plugins/is-esm --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "is-esm",
      "resource": "self",
      "action": "version",
      "description": "Print is-esm version",
      "adapter": "process",
      "adapterConfig": {
        "command": "is-esm",
        "missingDependencyHelp": "Install is-esm: npm install -g is-esm",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "is-esm",
      "resource": "package",
      "action": "check",
      "description": "check package via is-esm",
      "adapter": "process",
      "adapterConfig": {
        "command": "is-esm",
        "missingDependencyHelp": "Install is-esm: npm install -g is-esm",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "is-esm",
      "resource": "_",
      "action": "_",
      "description": "_ _ via is-esm",
      "adapter": "process",
      "adapterConfig": {
        "command": "is-esm",
        "missingDependencyHelp": "Install is-esm: npm install -g is-esm",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}