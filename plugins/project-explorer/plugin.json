{
  "name": "project-explorer",
  "version": "0.1.0",
  "description": "Generate project directory tree and documentation",
  "source": "https://github.com/sdras/project-explorer",
  "checks": [
    {
      "type": "binary",
      "name": "project-explorer"
    }
  ],
  "install_guidance": {
    "plugin": "project-explorer",
    "binary": "project-explorer",
    "check": "which project-explorer",
    "install_steps": [
      "npm install -g @sdras/project-explorer",
      "Verify: project-explorer --version",
      "supercli plugins install ./plugins/project-explorer --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "project-explorer",
      "resource": "self",
      "action": "version",
      "description": "Print project-explorer version",
      "adapter": "process",
      "adapterConfig": {
        "command": "project-explorer",
        "missingDependencyHelp": "Install project-explorer: npm install -g @sdras/project-explorer",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "project-explorer",
      "resource": "project",
      "action": "explore",
      "description": "explore project via project-explorer",
      "adapter": "process",
      "adapterConfig": {
        "command": "project-explorer",
        "missingDependencyHelp": "Install project-explorer: npm install -g @sdras/project-explorer",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "project-explorer",
      "resource": "_",
      "action": "_",
      "description": "_ _ via project-explorer",
      "adapter": "process",
      "adapterConfig": {
        "command": "project-explorer",
        "missingDependencyHelp": "Install project-explorer: npm install -g @sdras/project-explorer",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}