{
  "name": "create-component-app",
  "version": "0.1.0",
  "description": "Generate React components from the command line",
  "source": "https://github.com/CVarisco/create-component-app",
  "checks": [
    {
      "type": "binary",
      "name": "create-component-app"
    }
  ],
  "install_guidance": {
    "plugin": "create-component-app",
    "binary": "create-component-app",
    "check": "which create-component-app",
    "install_steps": [
      "npm install -g create-component-app",
      "Verify: create-component-app --version",
      "supercli plugins install ./plugins/create-component-app --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "create-component-app",
      "resource": "self",
      "action": "version",
      "description": "Print create-component-app version",
      "adapter": "process",
      "adapterConfig": {
        "command": "create-component-app",
        "missingDependencyHelp": "Install create-component-app: npm install -g create-component-app",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "create-component-app",
      "resource": "component",
      "action": "generate",
      "description": "generate component via create-component-app",
      "adapter": "process",
      "adapterConfig": {
        "command": "create-component-app",
        "missingDependencyHelp": "Install create-component-app: npm install -g create-component-app",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "create-component-app",
      "resource": "_",
      "action": "_",
      "description": "_ _ via create-component-app",
      "adapter": "process",
      "adapterConfig": {
        "command": "create-component-app",
        "missingDependencyHelp": "Install create-component-app: npm install -g create-component-app",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}