{
  "name": "eureka",
  "version": "0.1.0",
  "description": "CLI tool to input and store your ideas without leaving the terminal",
  "source": "https://github.com/simeg/eureka",
  "checks": [
    {
      "type": "binary",
      "name": "eureka"
    }
  ],
  "install_guidance": {
    "plugin": "eureka",
    "binary": "eureka",
    "check": "which eureka",
    "install_steps": [
      "cargo install eureka",
      "Verify: eureka --version",
      "supercli plugins install ./plugins/eureka --on-conflict replace --json"
    ]
  },
