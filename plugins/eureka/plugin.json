      "description": "Print eureka version",
      "adapter": "process",
      "adapterConfig": {
        "command": "eureka",
        "missingDependencyHelp": "Install eureka: cargo install eureka",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
