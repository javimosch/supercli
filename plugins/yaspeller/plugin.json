{
  "name": "yaspeller",
  "version": "0.1.0",
  "description": "Spell checker for text and Markdown files",
  "source": "https://github.com/hcodes/yaspeller",
  "checks": [
    {
      "type": "binary",
      "name": "yaspeller"
    }
  ],
  "install_guidance": {
    "plugin": "yaspeller",
    "binary": "yaspeller",
    "check": "which yaspeller",
    "install_steps": [
      "npm install -g yaspeller",
      "Verify: yaspeller --version",
      "supercli plugins install ./plugins/yaspeller --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "yaspeller",
      "resource": "self",
      "action": "version",
      "description": "Print yaspeller version",
      "adapter": "process",
      "adapterConfig": {
        "command": "yaspeller",
        "missingDependencyHelp": "Install yaspeller: npm install -g yaspeller",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "yaspeller",
      "resource": "file",
      "action": "check",
      "description": "check file via yaspeller",
      "adapter": "process",
      "adapterConfig": {
        "command": "yaspeller",
        "missingDependencyHelp": "Install yaspeller: npm install -g yaspeller",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "yaspeller",
      "resource": "_",
      "action": "_",
      "description": "_ _ via yaspeller",
      "adapter": "process",
      "adapterConfig": {
        "command": "yaspeller",
        "missingDependencyHelp": "Install yaspeller: npm install -g yaspeller",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}