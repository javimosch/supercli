{
  "name": "flavours",
  "version": "0.1.0",
  "description": "Easy to use base16 scheme manager that integrates with any workflow",
  "source": "https://github.com/Misterio77/flavours",
  "checks": [
    {
      "type": "binary",
      "name": "flavours"
    }
  ],
  "install_guidance": {
    "plugin": "flavours",
    "binary": "flavours",
    "check": "which flavours",
    "install_steps": [
      "cargo install flavours",
      "Verify: flavours --version",
      "supercli plugins install ./plugins/flavours --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "flavours",
      "resource": "self",
      "action": "version",
      "description": "Print flavours version",
      "adapter": "process",
      "adapterConfig": {
        "command": "flavours",
        "missingDependencyHelp": "Install flavours: cargo install flavours",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "flavours",
      "resource": "scheme",
      "action": "apply",
      "description": "apply scheme via flavours",
      "adapter": "process",
      "adapterConfig": {
        "command": "flavours",
        "missingDependencyHelp": "Install flavours: cargo install flavours",
        "baseArgs": [
          "apply"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
