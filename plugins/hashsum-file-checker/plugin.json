{
  "name": "hashsum-file-checker",
  "version": "0.1.0",
  "description": "Calculate file hash checksums",
  "source": "https://github.com/Maxim-Mazurok/nodejs-hashsum-file-checker",
  "checks": [
    { "type": "binary", "name": "hashsum-file-checker" }
  ],
  "install_guidance": {
    "plugin": "hashsum-file-checker",
    "binary": "hashsum-file-checker",
    "check": "which hashsum-file-checker",
    "install_steps": [
      "npm install -g nodejs-hashsum-file-checker",
      "Verify: hashsum-file-checker --help",
      "supercli plugins install ./plugins/hashsum-file-checker --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "hashsum-file-checker",
      "resource": "file",
      "action": "hash",
      "description": "Calculate file hash checksum",
      "adapter": "process",
      "adapterConfig": {
        "command": "hashsum-file-checker",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 120000,
        "missingDependencyHelp": "Install hashsum-file-checker: npm install -g nodejs-hashsum-file-checker"
      },
      "args": [
        { "name": "file", "type": "string", "required": true, "description": "File to hash" },
        { "name": "algorithm", "type": "string", "required": false, "description": "Hash algorithm (md5, sha1, sha256, etc.)" }
      ]
    },
    {
      "namespace": "hashsum-file-checker",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to hashsum-file-checker CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "hashsum-file-checker",
        "passthrough": true,
        "missingDependencyHelp": "Install hashsum-file-checker: npm install -g nodejs-hashsum-file-checker"
      },
      "args": []
    }
  ]
}
