{
  "name": "parrotsay",
  "version": "0.1.0",
  "description": "ASCII art parrot generator for the terminal",
  "source": "https://github.com/matheuss/parrotsay",
  "checks": [
    {
      "type": "binary",
      "name": "parrotsay"
    }
  ],
  "install_guidance": {
    "plugin": "parrotsay",
    "binary": "parrotsay",
    "check": "which parrotsay",
    "install_steps": [
      "npm install -g parrotsay",
      "Verify: parrotsay --version",
      "supercli plugins install ./plugins/parrotsay --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "parrotsay",
      "resource": "self",
      "action": "version",
      "description": "Print parrotsay version",
      "adapter": "process",
      "adapterConfig": {
        "command": "parrotsay",
        "missingDependencyHelp": "Install parrotsay: npm install -g parrotsay",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "parrotsay",
      "resource": "text",
      "action": "display",
      "description": "display text via parrotsay",
      "adapter": "process",
      "adapterConfig": {
        "command": "parrotsay",
        "missingDependencyHelp": "Install parrotsay: npm install -g parrotsay",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "parrotsay",
      "resource": "_",
      "action": "_",
      "description": "_ _ via parrotsay",
      "adapter": "process",
      "adapterConfig": {
        "command": "parrotsay",
        "missingDependencyHelp": "Install parrotsay: npm install -g parrotsay",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}