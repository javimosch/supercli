{
  "name": "rnx-kit",
  "version": "0.1.0",
  "description": "Modern scalable tools for React Native with exceptional developer experience",
  "source": "https://github.com/microsoft/rnx-kit",
  "checks": [
    {
      "type": "binary",
      "name": "rnx"
    }
  ],
  "install_guidance": {
    "plugin": "rnx-kit",
    "binary": "rnx",
    "check": "which rnx",
    "install_steps": [
      "npm install -g @rnx-kit/cli",
      "Verify: rnx --version",
      "supercli plugins install ./plugins/rnx-kit --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "rnx-kit",
      "resource": "self",
      "action": "version",
      "description": "Print rnx-kit version",
      "adapter": "process",
      "adapterConfig": {
        "command": "rnx",
        "missingDependencyHelp": "Install rnx-kit: npm install -g @rnx-kit/cli",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "rnx-kit",
      "resource": "app",
      "action": "create",
      "description": "create app via rnx",
      "adapter": "process",
      "adapterConfig": {
        "command": "rnx",
        "missingDependencyHelp": "Install rnx-kit: npm install -g @rnx-kit/cli",
        "baseArgs": [
          "create"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
