{
  "name": "mermaid-rs-renderer",
  "version": "0.1.0",
  "description": "Fast native Rust Mermaid diagram renderer without browser",
  "source": "https://github.com/1jehuang/mermaid-rs-renderer",
  "checks": [
    {
      "type": "binary",
      "name": "mermaid-rs"
    }
  ],
  "install_guidance": {
    "plugin": "mermaid-rs-renderer",
    "binary": "mermaid-rs",
    "check": "which mermaid-rs",
    "install_steps": [
      "cargo install mermaid-rs-renderer",
      "Verify: mermaid-rs --version",
      "supercli plugins install ./plugins/mermaid-rs-renderer --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "mermaid-rs-renderer",
      "resource": "self",
      "action": "version",
      "description": "Print mermaid-rs-renderer version",
      "adapter": "process",
      "adapterConfig": {
        "command": "mermaid-rs",
        "missingDependencyHelp": "Install mermaid-rs-renderer: cargo install mermaid-rs-renderer",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "mermaid-rs-renderer",
      "resource": "diagram",
      "action": "render",
      "description": "render diagram via mermaid-rs",
      "adapter": "process",
      "adapterConfig": {
        "command": "mermaid-rs",
        "missingDependencyHelp": "Install mermaid-rs-renderer: cargo install mermaid-rs-renderer",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "mermaid-rs-renderer",
      "resource": "file",
