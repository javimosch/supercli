{
  "name": "git-copy-history",
  "version": "0.1.0",
  "description": "Copy commit history between repositories",
  "source": "https://github.com/pfrankov/git-copy-history",
  "checks": [
    {
      "type": "binary",
      "name": "git-copy-history"
    }
  ],
  "install_guidance": {
    "plugin": "git-copy-history",
    "binary": "git-copy-history",
    "check": "which git-copy-history",
    "install_steps": [
      "npm install -g git-copy-history",
      "Verify: git-copy-history --version",
      "supercli plugins install ./plugins/git-copy-history --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "git-copy-history",
      "resource": "self",
      "action": "version",
      "description": "Print git-copy-history version",
      "adapter": "process",
      "adapterConfig": {
        "command": "git-copy-history",
        "missingDependencyHelp": "Install git-copy-history: npm install -g git-copy-history",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "git-copy-history",
      "resource": "repo",
      "action": "copy",
      "description": "copy repo via git-copy-history",
      "adapter": "process",
      "adapterConfig": {
        "command": "git-copy-history",
        "missingDependencyHelp": "Install git-copy-history: npm install -g git-copy-history",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "git-copy-history",
      "resource": "_",
      "action": "_",
      "description": "_ _ via git-copy-history",
      "adapter": "process",
      "adapterConfig": {
        "command": "git-copy-history",
        "missingDependencyHelp": "Install git-copy-history: npm install -g git-copy-history",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}