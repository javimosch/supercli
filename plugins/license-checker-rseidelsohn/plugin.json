{
  "name": "license-checker-rseidelsohn",
  "version": "0.1.0",
  "description": "Check licenses of npm dependencies",
  "source": "https://github.com/RSeidelsohn/license-checker-rseidelsohn",
  "checks": [
    {
      "type": "binary",
      "name": "license-checker"
    }
  ],
  "install_guidance": {
    "plugin": "license-checker-rseidelsohn",
    "binary": "license-checker",
    "check": "which license-checker",
    "install_steps": [
      "npm install -g license-checker-rseidelsohn",
      "Verify: license-checker --version",
      "supercli plugins install ./plugins/license-checker-rseidelsohn --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "license-checker-rseidelsohn",
      "resource": "self",
      "action": "version",
      "description": "Print license-checker-rseidelsohn version",
      "adapter": "process",
      "adapterConfig": {
        "command": "license-checker",
        "missingDependencyHelp": "Install license-checker-rseidelsohn: npm install -g license-checker-rseidelsohn",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "license-checker-rseidelsohn",
      "resource": "deps",
      "action": "check",
      "description": "check deps via license-checker",
      "adapter": "process",
      "adapterConfig": {
        "command": "license-checker",
        "missingDependencyHelp": "Install license-checker-rseidelsohn: npm install -g license-checker-rseidelsohn",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "license-checker-rseidelsohn",
      "resource": "_",
      "action": "_",
      "description": "_ _ via license-checker",
      "adapter": "process",
      "adapterConfig": {
        "command": "license-checker",
        "missingDependencyHelp": "Install license-checker-rseidelsohn: npm install -g license-checker-rseidelsohn",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}