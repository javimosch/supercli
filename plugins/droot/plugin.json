{
  "name": "droot",
  "version": "0.1.0",
  "description": "The super-simple chroot-based application container engine",
  "source": "https://github.com/yuuki/droot",
  "checks": [
    {
      "type": "binary",
      "name": "droot"
    }
  ],
  "install_guidance": {
    "plugin": "droot",
    "binary": "droot",
    "check": "which droot",
    "install_steps": [
      "go install github.com/yuuki/droot@latest",
      "Verify: droot --version",
      "supercli plugins install ./plugins/droot --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "droot",
      "resource": "self",
      "action": "version",
      "description": "Print droot version",
      "adapter": "process",
      "adapterConfig": {
        "command": "droot",
        "missingDependencyHelp": "Install droot: go install github.com/yuuki/droot@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "droot",
      "resource": "image",
      "action": "pull",
      "description": "pull image via droot",
      "adapter": "process",
      "adapterConfig": {
        "command": "droot",
        "missingDependencyHelp": "Install droot: go install github.com/yuuki/droot@latest",
        "baseArgs": [
          "pull"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "droot",
      "resource": "container",
      "action": "run",
      "description": "run container via droot",
      "adapter": "process",
      "adapterConfig": {
        "command": "droot",
        "missingDependencyHelp": "Install droot: go install github.com/yuuki/droot@latest",
        "baseArgs": [
          "run"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "droot",
      "resource": "container",
      "action": "kill",
      "description": "kill container via droot",
      "adapter": "process",
      "adapterConfig": {
        "command": "droot",
        "missingDependencyHelp": "Install droot: go install github.com/yuuki/droot@latest",
        "baseArgs": [
          "kill"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "droot",
      "resource": "container",
      "action": "list",
      "description": "list container via droot",
      "adapter": "process",
      "adapterConfig": {
        "command": "droot",
        "missingDependencyHelp": "Install droot: go install github.com/yuuki/droot@latest",
        "baseArgs": [
          "ps"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "droot",
      "resource": "_",
      "action": "_",
      "description": "_ _ via droot",
      "adapter": "process",
      "adapterConfig": {
        "command": "droot",
        "missingDependencyHelp": "Install droot: go install github.com/yuuki/droot@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}