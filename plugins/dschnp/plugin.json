{
  "name": "dschnp",
  "version": "0.1.0",
  "description": "Custom search engines via CLI with defaultList feature for quick lookups",
  "source": "https://github.com/rushlow/dschnp",
  "checks": [
    {
      "type": "binary",
      "name": "dschnp"
    }
  ],
  "install_guidance": {
    "plugin": "dschnp",
    "binary": "dschnp",
    "check": "which dschnp",
    "install_steps": [
      "npm install -g dschnp",
      "Verify: dschnp --version",
      "supercli plugins install ./plugins/dschnp --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
