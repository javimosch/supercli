      "resource": "self",
      "action": "version",
      "description": "Print dschnp version",
      "adapter": "process",
      "adapterConfig": {
        "command": "dschnp",
        "missingDependencyHelp": "Install dschnp: npm install -g dschnp",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
