{
  "plugin": "opensrc",
  "binary": "opensrc",
  "check": "which opensrc",
  "install_steps": [
    "npm install -g opensrc",
    "Verify: opensrc --version",
    "supercli plugins install ./plugins/opensrc --on-conflict replace --json"
  ],
  "note": "Requires Node.js. Also available via Rust CLI: cargo install opensrc-cli"
}