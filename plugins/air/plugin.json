{
  "name": "air",
  "version": "0.1.0",
  "description": "Live reload for Go apps in development",
  "source": "https://github.com/cosmtrek/air",
  "checks": [
    {
      "type": "binary",
      "name": "air"
    }
  ],
  "install_guidance": {
    "plugin": "air",
    "binary": "air",
    "check": "which air",
    "install_steps": [
      "go install github.com/cosmtrek/air@latest",
      "Verify: air --version",
      "supercli plugins install ./plugins/air --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "air",
      "resource": "self",
      "action": "version",
      "description": "Print air version",
      "adapter": "process",
      "adapterConfig": {
        "command": "air",
        "missingDependencyHelp": "Install air: go install github.com/cosmtrek/air@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "air",
      "resource": "dev",
      "action": "start",
      "description": "start dev via air",
      "adapter": "process",
      "adapterConfig": {
        "command": "air",
        "missingDependencyHelp": "Install air: go install github.com/cosmtrek/air@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "air",
      "resource": "init",
      "action": "init",
      "description": "init init via air",
      "adapter": "process",
      "adapterConfig": {
        "command": "air",
        "missingDependencyHelp": "Install air: go install github.com/cosmtrek/air@latest",
        "baseArgs": [
          "init"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "air",
      "resource": "_",
      "action": "_",
      "description": "_ _ via air",
      "adapter": "process",
      "adapterConfig": {
        "command": "air",
        "missingDependencyHelp": "Install air: go install github.com/cosmtrek/air@latest",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}