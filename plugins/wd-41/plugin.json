{
  "name": "wd-41",
  "version": "0.1.0",
  "description": "Static web server with live-reload for web development",
  "source": "https://github.com/baalimago/wd-41",
  "checks": [
    {
      "type": "binary",
      "name": "wd-41"
    }
  ],
  "install_guidance": {
    "plugin": "wd-41",
    "binary": "wd-41",
    "check": "which wd-41",
    "install_steps": [
      "go install github.com/baalimago/wd-41@latest",
      "Verify: wd-41 --version",
      "supercli plugins install ./plugins/wd-41 --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "wd-41",
      "resource": "self",
      "action": "version",
      "description": "Print wd-41 version",
      "adapter": "process",
      "adapterConfig": {
        "command": "wd-41",
        "missingDependencyHelp": "Install wd-41: go install github.com/baalimago/wd-41@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "wd-41",
      "resource": "serve",
      "action": "start",
      "description": "start serve via wd-41",
      "adapter": "process",
      "adapterConfig": {
        "command": "wd-41",
        "missingDependencyHelp": "Install wd-41: go install github.com/baalimago/wd-41@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "wd-41",
      "resource": "build",
      "action": "run",
      "description": "run build via wd-41",
      "adapter": "process",
      "adapterConfig": {
        "command": "wd-41",
        "missingDependencyHelp": "Install wd-41: go install github.com/baalimago/wd-41@latest",
        "baseArgs": [
          "build"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "wd-41",
      "resource": "watch",
      "action": "start",
      "description": "start watch via wd-41",
      "adapter": "process",
      "adapterConfig": {
        "command": "wd-41",
        "missingDependencyHelp": "Install wd-41: go install github.com/baalimago/wd-41@latest",
        "baseArgs": [
          "watch"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "wd-41",
      "resource": "_",
      "action": "_",
      "description": "_ _ via wd-41",
      "adapter": "process",
      "adapterConfig": {
        "command": "wd-41",
        "missingDependencyHelp": "Install wd-41: go install github.com/baalimago/wd-41@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}