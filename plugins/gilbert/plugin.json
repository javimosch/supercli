{
  "name": "gilbert",
  "version": "0.1.0",
  "description": "Task runner for Go projects with YAML-based configuration",
  "source": "https://github.com/go-gilbert/gilbert",
  "checks": [
    {
      "type": "binary",
      "name": "gilbert"
    }
  ],
  "install_guidance": {
    "plugin": "gilbert",
    "binary": "gilbert",
    "check": "which gilbert",
    "install_steps": [
      "go install github.com/go-gilbert/gilbert@latest",
      "Verify: gilbert --version",
      "supercli plugins install ./plugins/gilbert --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "gilbert",
      "resource": "self",
      "action": "version",
      "description": "Print gilbert version",
      "adapter": "process",
      "adapterConfig": {
        "command": "gilbert",
        "missingDependencyHelp": "Install gilbert: go install github.com/go-gilbert/gilbert@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "gilbert",
      "resource": "task",
      "action": "run",
      "description": "run task via gilbert",
      "adapter": "process",
      "adapterConfig": {
        "command": "gilbert",
        "missingDependencyHelp": "Install gilbert: go install github.com/go-gilbert/gilbert@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "gilbert",
      "resource": "task",
      "action": "list",
      "description": "list task via gilbert",
      "adapter": "process",
      "adapterConfig": {
        "command": "gilbert",
        "missingDependencyHelp": "Install gilbert: go install github.com/go-gilbert/gilbert@latest",
        "baseArgs": [
          "--list"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "gilbert",
      "resource": "init",
      "action": "create",
      "description": "create init via gilbert",
      "adapter": "process",
      "adapterConfig": {
        "command": "gilbert",
        "missingDependencyHelp": "Install gilbert: go install github.com/go-gilbert/gilbert@latest",
        "baseArgs": [
          "init"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "gilbert",
      "resource": "_",
      "action": "_",
      "description": "_ _ via gilbert",
      "adapter": "process",
      "adapterConfig": {
        "command": "gilbert",
        "missingDependencyHelp": "Install gilbert: go install github.com/go-gilbert/gilbert@latest",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}