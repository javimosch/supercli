{
  "name": "gist",
  "version": "0.1.0",
  "description": "Command line tool for creating and managing GitHub Gists",
  "source": "https://github.com/babarot/gist",
  "checks": [
    {
      "type": "binary",
      "name": "gist"
    }
  ],
  "install_guidance": {
    "plugin": "gist",
    "binary": "gist",
    "check": "which gist",
    "install_steps": [
      "go install github.com/babarot/gist@latest",
      "Verify: gist --version",
      "supercli plugins install ./plugins/gist --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "gist",
      "resource": "self",
      "action": "version",
      "description": "Print gist version",
      "adapter": "process",
      "adapterConfig": {
        "command": "gist",
        "missingDependencyHelp": "Install gist: go install github.com/babarot/gist@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "gist",
      "resource": "gist",
      "action": "create",
      "description": "create gist via gist",
      "adapter": "process",
      "adapterConfig": {
        "command": "gist",
        "missingDependencyHelp": "Install gist: go install github.com/babarot/gist@latest",
        "baseArgs": [
          "create"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "gist",
