{
  "name": "md2wechat-skill",
  "version": "0.1.0",
  "description": "Convert Markdown to WeChat article format",
  "source": "https://github.com/geekjourneyx/md2wechat-skill",
  "checks": [
    {
      "type": "binary",
      "name": "md2wechat"
    }
  ],
  "install_guidance": {
    "plugin": "md2wechat-skill",
    "binary": "md2wechat",
    "check": "which md2wechat",
    "install_steps": [
      "go install github.com/geekjourneyx/md2wechat-skill@latest",
      "Verify: md2wechat --version",
      "supercli plugins install ./plugins/md2wechat-skill --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "md2wechat-skill",
      "resource": "self",
      "action": "version",
      "description": "Print md2wechat-skill version",
      "adapter": "process",
      "adapterConfig": {
        "command": "md2wechat",
        "missingDependencyHelp": "Install md2wechat-skill: go install github.com/geekjourneyx/md2wechat-skill@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "md2wechat-skill",
      "resource": "file",
      "action": "convert",
      "description": "convert file via md2wechat",
      "adapter": "process",
      "adapterConfig": {
        "command": "md2wechat",
        "missingDependencyHelp": "Install md2wechat-skill: go install github.com/geekjourneyx/md2wechat-skill@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "md2wechat-skill",
      "resource": "_",
      "action": "_",
      "description": "_ _ via md2wechat",
      "adapter": "process",
      "adapterConfig": {
        "command": "md2wechat",
        "missingDependencyHelp": "Install md2wechat-skill: go install github.com/geekjourneyx/md2wechat-skill@latest",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}