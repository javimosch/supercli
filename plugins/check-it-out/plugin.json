{
  "name": "check-it-out",
  "version": "0.1.0",
  "description": "Command line interface for Git Checkout to see branches available for checkout",
  "source": "https://github.com/jwu910/check-it-out",
  "checks": [
    {
      "type": "binary",
      "name": "cio"
    }
  ],
  "install_guidance": {
    "plugin": "check-it-out",
    "binary": "cio",
    "check": "which cio",
    "install_steps": [
      "npm install -g check-it-out",
      "Verify: cio --version",
      "supercli plugins install ./plugins/check-it-out --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "check-it-out",
      "resource": "self",
      "action": "version",
      "description": "Print check-it-out version",
      "adapter": "process",
      "adapterConfig": {
        "command": "cio",
        "missingDependencyHelp": "Install check-it-out: npm install -g check-it-out",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "check-it-out",
      "resource": "branch",
      "action": "list",
      "description": "list branch via cio",
      "adapter": "process",
      "adapterConfig": {
        "command": "cio",
        "missingDependencyHelp": "Install check-it-out: npm install -g check-it-out",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "check-it-out",
      "resource": "branch",
      "action": "checkout",
      "description": "checkout branch via cio",
      "adapter": "process",
      "adapterConfig": {
        "command": "cio",
        "missingDependencyHelp": "Install check-it-out: npm install -g check-it-out",
        "baseArgs": [
          "--checkout"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "check-it-out",
      "resource": "remote",
      "action": "list",
      "description": "list remote via cio",
      "adapter": "process",
      "adapterConfig": {
        "command": "cio",
        "missingDependencyHelp": "Install check-it-out: npm install -g check-it-out",
        "baseArgs": [
          "--remote"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "check-it-out",
      "resource": "search",
      "action": "run",
      "description": "run search via cio",
      "adapter": "process",
      "adapterConfig": {
        "command": "cio",
        "missingDependencyHelp": "Install check-it-out: npm install -g check-it-out",
        "baseArgs": [
          "--search"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "check-it-out",
      "resource": "config",
      "action": "show",
      "description": "show config via cio",
      "adapter": "process",
      "adapterConfig": {
        "command": "cio",
        "missingDependencyHelp": "Install check-it-out: npm install -g check-it-out",
        "baseArgs": [
          "--config"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "check-it-out",
      "resource": "_",
      "action": "_",
      "description": "_ _ via cio",
      "adapter": "process",
      "adapterConfig": {
        "command": "cio",
        "missingDependencyHelp": "Install check-it-out: npm install -g check-it-out",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}