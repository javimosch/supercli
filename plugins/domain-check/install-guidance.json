{
  "plugin": "domain-check",
  "binary": "domain-check",
  "check": "domain-check --version",
  "install_steps": [
    "cargo install domain-check",
    "domain-check --version",
    "supercli plugins install ./plugins/domain-check --json"
  ],
  "note": "Requires Rust/Cargo installation. Supports 1,200+ TLDs with RDAP primary and WHOIS fallback."
}
