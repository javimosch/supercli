{
  "name": "conftest",
  "version": "0.1.0",
  "description": "Write tests against structured configuration data using OPA",
  "source": "https://github.com/open-policy-agent/conftest",
  "checks": [
    {
      "type": "binary",
      "name": "conftest"
    }
  ],
  "install_guidance": {
    "plugin": "conftest",
    "binary": "conftest",
    "check": "which conftest",
    "install_steps": [
      "brew install conftest",
      "Verify: conftest --version",
      "supercli plugins install ./plugins/conftest --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "conftest",
      "resource": "self",
      "action": "version",
      "description": "Print conftest version",
      "adapter": "process",
      "adapterConfig": {
        "command": "conftest",
        "missingDependencyHelp": "Install conftest: brew install conftest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "conftest",
      "resource": "config",
      "action": "test",
      "description": "test config via conftest",
      "adapter": "process",
      "adapterConfig": {
        "command": "conftest",
        "missingDependencyHelp": "Install conftest: brew install conftest",
        "baseArgs": [
          "test"
        ],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "conftest",
      "resource": "config",
      "action": "verify",
      "description": "verify config via conftest",
      "adapter": "process",
      "adapterConfig": {
        "command": "conftest",
        "missingDependencyHelp": "Install conftest: brew install conftest",
        "baseArgs": [
          "verify"
        ],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "conftest",
      "resource": "_",
      "action": "_",
      "description": "_ _ via conftest",
      "adapter": "process",
      "adapterConfig": {
        "command": "conftest",
        "missingDependencyHelp": "Install conftest: brew install conftest",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}