{
  "name": "tango",
  "version": "0.1.0",
  "description": "Rust microbenchmarking harness based on paired-testing methodology",
  "source": "https://github.com/bazhenov/tango",
  "checks": [
    {
      "type": "binary",
      "name": "tango"
    }
  ],
  "install_guidance": {
    "plugin": "tango",
    "binary": "tango",
    "check": "which tango",
    "install_steps": [
      "cargo install tango",
      "Verify: tango --version",
      "supercli plugins install ./plugins/tango --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "tango",
      "resource": "self",
      "action": "version",
      "description": "Print tango version",
      "adapter": "process",
      "adapterConfig": {
        "command": "tango",
        "missingDependencyHelp": "Install tango: cargo install tango",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "tango",
      "resource": "bench",
      "action": "run",
      "description": "run bench via tango",
      "adapter": "process",
      "adapterConfig": {
        "command": "tango",
        "missingDependencyHelp": "Install tango: cargo install tango",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
