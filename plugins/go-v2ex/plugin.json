{
  "name": "go-v2ex",
  "version": "0.1.0",
  "description": "Command line tool for browsing V2EX community",
  "source": "https://github.com/seth-shi/go-v2ex",
  "checks": [
    {
      "type": "binary",
      "name": "v2ex"
    }
  ],
  "install_guidance": {
    "plugin": "go-v2ex",
    "binary": "v2ex",
    "check": "which v2ex",
    "install_steps": [
      "go install github.com/seth-shi/go-v2ex@latest",
      "Verify: v2ex --version",
      "supercli plugins install ./plugins/go-v2ex --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "go-v2ex",
      "resource": "self",
      "action": "version",
      "description": "Print go-v2ex version",
      "adapter": "process",
      "adapterConfig": {
        "command": "v2ex",
        "missingDependencyHelp": "Install go-v2ex: go install github.com/seth-shi/go-v2ex@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "go-v2ex",
      "resource": "topic",
      "action": "list",
      "description": "list topic via v2ex",
      "adapter": "process",
      "adapterConfig": {
        "command": "v2ex",
        "missingDependencyHelp": "Install go-v2ex: go install github.com/seth-shi/go-v2ex@latest",
        "baseArgs": [
          "list"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "go-v2ex",
      "resource": "node",
      "action": "list",
      "description": "list node via v2ex",
      "adapter": "process",
      "adapterConfig": {
        "command": "v2ex",
        "missingDependencyHelp": "Install go-v2ex: go install github.com/seth-shi/go-v2ex@latest",
        "baseArgs": [
          "node"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "go-v2ex",
      "resource": "topic",
      "action": "show",
      "description": "show topic via v2ex",
      "adapter": "process",
      "adapterConfig": {
        "command": "v2ex",
        "missingDependencyHelp": "Install go-v2ex: go install github.com/seth-shi/go-v2ex@latest",
        "baseArgs": [
          "show"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "go-v2ex",
      "resource": "_",
      "action": "_",
      "description": "_ _ via v2ex",
      "adapter": "process",
      "adapterConfig": {
        "command": "v2ex",
        "missingDependencyHelp": "Install go-v2ex: go install github.com/seth-shi/go-v2ex@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}