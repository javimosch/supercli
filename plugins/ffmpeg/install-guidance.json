{
  "plugin": "ffmpeg",
  "binary": "ffmpeg",
  "check": "which ffmpeg && which ffprobe",
  "install_steps": [
    "macOS: brew install ffmpeg",
    "Ubuntu/Debian: sudo apt install ffmpeg",
    "Windows: choco install ffmpeg (with Chocolatey)",
    "Verify: ffmpeg -version",
    "supercli plugins install ./plugins/ffmpeg --on-conflict replace --json"
  ],
  "note": "Both ffmpeg and ffprobe must be installed. All commands use -y flag to overwrite outputs without prompting."
}
