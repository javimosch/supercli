#!/bin/bash
# FFmpeg video convert wrapper
# Args: input output [codec] [audio_codec] [preset] [crf]
INPUT="$1"
OUTPUT="$2"
CODEC="${3:-libx264}"
AUDIO_CODEC="${4:-aac}"
PRESET="${5:-medium}"
CRF="${6:-23}"
ffmpeg -y -i "$INPUT" -c:v "$CODEC" -c:a "$AUDIO_CODEC" -preset "$PRESET" -crf "$CRF" "$OUTPUT"
