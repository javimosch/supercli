{
  "name": "kt",
  "version": "0.1.0",
  "description": "Apache Kafka CLI tool for producers and consumers",
  "source": "https://github.com/fgeller/kt",
  "checks": [
    {
      "type": "binary",
      "name": "kt"
    }
  ],
  "install_guidance": {
    "plugin": "kt",
    "binary": "kt",
    "check": "which kt",
    "install_steps": [
      "brew install kt",
      "Verify: kt --version",
      "supercli plugins install ./plugins/kt --on-conflict replace --json"
    ]
  },
