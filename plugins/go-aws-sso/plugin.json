{
  "name": "go-aws-sso",
  "version": "0.1.0",
  "description": "AWS SSO credential helper for command line access",
  "source": "https://github.com/theurichde/go-aws-sso",
  "checks": [
    {
      "type": "binary",
      "name": "go-aws-sso"
    }
  ],
  "install_guidance": {
    "plugin": "go-aws-sso",
    "binary": "go-aws-sso",
    "check": "which go-aws-sso",
    "install_steps": [
      "go install github.com/theurichde/go-aws-sso@latest",
      "Verify: go-aws-sso --version",
      "supercli plugins install ./plugins/go-aws-sso --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "go-aws-sso",
      "resource": "self",
      "action": "version",
      "description": "Print go-aws-sso version",
      "adapter": "process",
      "adapterConfig": {
        "command": "go-aws-sso",
        "missingDependencyHelp": "Install go-aws-sso: go install github.com/theurichde/go-aws-sso@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "go-aws-sso",
      "resource": "account",
      "action": "list",
      "description": "list account via go-aws-sso",
      "adapter": "process",
      "adapterConfig": {
        "command": "go-aws-sso",
        "missingDependencyHelp": "Install go-aws-sso: go install github.com/theurichde/go-aws-sso@latest",
        "baseArgs": [
          "list"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "go-aws-sso",
      "resource": "config",
      "action": "setup",
      "description": "setup config via go-aws-sso",
      "adapter": "process",
      "adapterConfig": {
        "command": "go-aws-sso",
        "missingDependencyHelp": "Install go-aws-sso: go install github.com/theurichde/go-aws-sso@latest",
        "baseArgs": [
          "setup"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "go-aws-sso",
      "resource": "login",
      "action": "run",
      "description": "run login via go-aws-sso",
      "adapter": "process",
      "adapterConfig": {
        "command": "go-aws-sso",
        "missingDependencyHelp": "Install go-aws-sso: go install github.com/theurichde/go-aws-sso@latest",
        "baseArgs": [
          "login"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "go-aws-sso",
      "resource": "_",
      "action": "_",
      "description": "_ _ via go-aws-sso",
      "adapter": "process",
      "adapterConfig": {
        "command": "go-aws-sso",
        "missingDependencyHelp": "Install go-aws-sso: go install github.com/theurichde/go-aws-sso@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}