{
  "plugin": "json5",
  "binary": "json5",
  "check": "which json5",
  "install_steps": [
    "brew tap yosuke-furukawa/json5",
    "brew install json5",
    "Verify: json5 -c test.json5",
    "supercli plugins install ./plugins/json5 --on-conflict replace --json"
  ],
  "note": "Alternative: go install github.com/yosuke-furukawa/json5@latest. Package provides json5 command."
}
