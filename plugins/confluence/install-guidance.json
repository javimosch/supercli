{
  "plugin": "confluence",
  "binary": "confluence",
  "check": "which confluence",
  "install_steps": [
    "npm install -g confluence-cli",
    "Verify: confluence --version",
    "supercli plugins install ./plugins/confluence --on-conflict replace --json"
  ],
  "note": "Requires CONFLUENCE_BASE_URL, CONFLUENCE_USER_EMAIL, and CONFLUENCE_API_TOKEN environment variables."
}
