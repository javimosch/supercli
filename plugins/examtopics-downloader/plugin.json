{
  "name": "examtopics-downloader",
  "version": "0.1.0",
  "description": "Download exam content from ExamTopics website",
  "source": "https://github.com/thatonecodes/examtopics-downloader",
  "checks": [
    {
      "type": "binary",
      "name": "examtopics-downloader"
    }
  ],
  "install_guidance": {
    "plugin": "examtopics-downloader",
    "binary": "examtopics-downloader",
    "check": "which examtopics-downloader",
    "install_steps": [
      "go install github.com/thatonecodes/examtopics-downloader@latest",
      "Verify: examtopics-downloader --version",
      "supercli plugins install ./plugins/examtopics-downloader --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "examtopics-downloader",
      "resource": "self",
      "action": "version",
      "description": "Print examtopics-downloader version",
      "adapter": "process",
      "adapterConfig": {
        "command": "examtopics-downloader",
        "missingDependencyHelp": "Install examtopics-downloader: go install github.com/thatonecodes/examtopics-downloader@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "examtopics-downloader",
      "resource": "exam",
      "action": "download",
      "description": "download exam via examtopics-downloader",
      "adapter": "process",
      "adapterConfig": {
        "command": "examtopics-downloader",
        "missingDependencyHelp": "Install examtopics-downloader: go install github.com/thatonecodes/examtopics-downloader@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "examtopics-downloader",
      "resource": "topic",
      "action": "list",
      "description": "list topic via examtopics-downloader",
      "adapter": "process",
      "adapterConfig": {
        "command": "examtopics-downloader",
        "missingDependencyHelp": "Install examtopics-downloader: go install github.com/thatonecodes/examtopics-downloader@latest",
        "baseArgs": [
          "--list"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "examtopics-downloader",
      "resource": "_",
      "action": "_",
      "description": "_ _ via examtopics-downloader",
      "adapter": "process",
      "adapterConfig": {
        "command": "examtopics-downloader",
        "missingDependencyHelp": "Install examtopics-downloader: go install github.com/thatonecodes/examtopics-downloader@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}