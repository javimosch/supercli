{
  "name": "npm",
  "version": "0.1.0",
  "description": "npm CLI plugin for dcli",
  "source": "https://docs.npmjs.com/cli/v10/commands/",
  "checks": [
    {
      "type": "binary",
      "name": "npm"
    }
  ],
  "commands": [
    {
      "namespace": "npm",
      "resource": "cli",
      "action": "version",
      "description": "Show npm CLI version",
      "adapter": "process",
      "adapterConfig": {
        "command": "npm",
        "baseArgs": ["--version"],
        "parseJson": false,
        "missingDependencyHelp": "Please install npm to use this command."
      },
      "args": []
    },
    {
      "namespace": "npm",
      "resource": "_",
      "action": "_",
      "description": "Passthrough command to execute any npm CLI command",
      "adapter": "process",
      "adapterConfig": {
        "command": "npm",
        "passthrough": true,
        "parseJson": true,
        "missingDependencyHelp": "Please install npm to use this command."
      },
      "args": []
    }
  ]
}
