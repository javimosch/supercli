{
  "name": "kubeconform",
  "version": "0.1.0",
  "description": "Fast Kubernetes manifest validation with custom schemas",
  "source": "https://github.com/yannh/kubeconform",
  "checks": [
    {
      "type": "binary",
      "name": "kubeconform"
    }
  ],
  "install_guidance": {
    "plugin": "kubeconform",
    "binary": "kubeconform",
    "check": "which kubeconform",
    "install_steps": [
      "brew install kubeconform",
      "Verify: kubeconform --version",
      "supercli plugins install ./plugins/kubeconform --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "kubeconform",
      "resource": "self",
      "action": "version",
      "description": "Print kubeconform version",
      "adapter": "process",
      "adapterConfig": {
        "command": "kubeconform",
        "missingDependencyHelp": "Install kubeconform: brew install kubeconform",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "kubeconform",
      "resource": "manifest",
      "action": "validate",
      "description": "validate manifest via kubeconform",
      "adapter": "process",
      "adapterConfig": {
        "command": "kubeconform",
        "missingDependencyHelp": "Install kubeconform: brew install kubeconform",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "kubeconform",
      "resource": "_",
      "action": "_",
      "description": "_ _ via kubeconform",
      "adapter": "process",
      "adapterConfig": {
        "command": "kubeconform",
        "missingDependencyHelp": "Install kubeconform: brew install kubeconform",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}