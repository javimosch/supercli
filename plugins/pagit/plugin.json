    {
      "type": "binary",
      "name": "pagit"
    }
  ],
  "install_guidance": {
    "plugin": "pagit",
    "binary": "pagit",
    "check": "which pagit",
    "install_steps": [
      "npm install -g pagit",
      "Verify: pagit --version",
      "supercli plugins install ./plugins/pagit --on-conflict replace --json"
