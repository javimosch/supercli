{
  "name": "hauler",
  "version": "0.1.0",
  "description": "Airgap Swiss Army Knife for content management",
  "source": "https://github.com/hauler-dev/hauler",
  "checks": [
    {
      "type": "binary",
      "name": "hauler"
    }
  ],
  "install_guidance": {
    "plugin": "hauler",
    "binary": "hauler",
    "check": "which hauler",
    "install_steps": [
      "brew install hauler-dev/tap/hauler",
      "Verify: hauler --version",
      "supercli plugins install ./plugins/hauler --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "hauler",
      "resource": "self",
      "action": "version",
      "description": "Print hauler version",
      "adapter": "process",
      "adapterConfig": {
        "command": "hauler",
        "missingDependencyHelp": "Install hauler: brew install hauler-dev/tap/hauler",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "hauler",
      "resource": "store",
      "action": "add",
      "description": "add store via hauler",
      "adapter": "process",
      "adapterConfig": {
        "command": "hauler",
        "missingDependencyHelp": "Install hauler: brew install hauler-dev/tap/hauler",
        "baseArgs": [
          "store",
          "add"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
