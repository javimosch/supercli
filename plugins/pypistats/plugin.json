{
  "name": "pypistats",
  "version": "0.1.0",
  "description": "Command-line interface to PyPI Stats API to get download stats for Python packages",
  "source": "https://github.com/hugovk/pypistats",
  "checks": [
    {
      "type": "binary",
      "name": "pypistats"
    }
  ],
  "install_guidance": {
    "plugin": "pypistats",
    "binary": "pypistats",
    "check": "which pypistats",
    "install_steps": [
      "pip install pypistats",
      "Verify: pypistats --version",
      "supercli plugins install ./plugins/pypistats --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "pypistats",
      "resource": "self",
      "action": "version",
      "description": "Print pypistats version",
      "adapter": "process",
      "adapterConfig": {
        "command": "pypistats",
        "missingDependencyHelp": "Install pypistats: pip install pypistats",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "pypistats",
      "resource": "package",
      "action": "stats",
      "description": "stats package via pypistats",
      "adapter": "process",
      "adapterConfig": {
        "command": "pypistats",
        "missingDependencyHelp": "Install pypistats: pip install pypistats",
        "baseArgs": [
          "stats"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
