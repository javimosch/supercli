{
  "name": "atmos",
  "version": "0.1.0",
  "description": "Universal Tool for DevOps and Cloud Automation. Manage complex cloud infrastructure with Terraform, Helm, and tools using YAML-based configurations.",
  "source": "https://github.com/cloudposse/atmos",
  "checks": [
    { "type": "binary", "name": "atmos" }
  ],
  "install_guidance": {
    "plugin": "atmos",
    "binary": "atmos",
    "check": "which atmos",
    "install_steps": [
      "brew install atmos",
      "Verify: atmos version",
      "supercli plugins install ./plugins/atmos --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "atmos",
      "resource": "stack",
      "action": "deploy",
      "description": "Deploy a stack",
      "adapter": "process",
      "adapterConfig": {
        "command": "atmos",
        "baseArgs": ["terraform", "deploy"],
        "passthrough": true,
        "missingDependencyHelp": "Install atmos: brew install atmos"
      },
      "args": [
        { "name": "component", "type": "string", "description": "Component to deploy" },
        { "name": "--stack", "type": "string", "description": "Stack configuration" },
        { "name": "--dry-run", "type": "boolean", "description": "Show what would be deployed" }
      ]
    },
    {
      "namespace": "atmos",
      "resource": "stack",
      "action": "plan",
      "description": "Plan a stack deployment",
      "adapter": "process",
      "adapterConfig": {
        "command": "atmos",
        "baseArgs": ["terraform", "plan"],
        "passthrough": true,
        "missingDependencyHelp": "Install atmos: brew install atmos"
      },
      "args": [
        { "name": "component", "type": "string", "description": "Component to plan" },
        { "name": "--stack", "type": "string", "description": "Stack configuration" }
      ]
    },
    {
      "namespace": "atmos",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to atmos CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "atmos",
        "passthrough": true,
        "missingDependencyHelp": "Install atmos: brew install atmos"
      },
      "args": []
    }
  ]
}
