{
  "name": "gut",
  "version": "0.1.0",
  "description": "A beginner friendly CLI for git",
  "source": "https://github.com/julien040/gut",
  "checks": [
    {
      "type": "binary",
      "name": "gut"
    }
  ],
  "install_guidance": {
    "plugin": "gut",
    "binary": "gut",
    "check": "which gut",
    "install_steps": [
      "brew install julien040/tap/gut",
      "Verify: gut --version",
      "supercli plugins install ./plugins/gut --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "gut",
      "resource": "self",
      "action": "version",
      "description": "Print gut version",
      "adapter": "process",
      "adapterConfig": {
        "command": "gut",
        "missingDependencyHelp": "Install gut: brew install julien040/tap/gut",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "gut",
      "resource": "repo",
      "action": "init",
      "description": "init repo via gut",
      "adapter": "process",
      "adapterConfig": {
        "command": "gut",
        "missingDependencyHelp": "Install gut: brew install julien040/tap/gut",
        "baseArgs": [
          "init"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "gut",
      "resource": "commit",
      "action": "create",
      "description": "create commit via gut",
      "adapter": "process",
      "adapterConfig": {
        "command": "gut",
        "missingDependencyHelp": "Install gut: brew install julien040/tap/gut",
        "baseArgs": [
          "commit"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "gut",
      "resource": "branch",
      "action": "switch",
      "description": "switch branch via gut",
      "adapter": "process",
      "adapterConfig": {
        "command": "gut",
        "missingDependencyHelp": "Install gut: brew install julien040/tap/gut",
        "baseArgs": [
          "switch"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "gut",
      "resource": "_",
      "action": "_",
      "description": "_ _ via gut",
      "adapter": "process",
      "adapterConfig": {
        "command": "gut",
        "missingDependencyHelp": "Install gut: brew install julien040/tap/gut",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}