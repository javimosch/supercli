{
  "name": "go-replace",
  "version": "0.1.0",
  "description": "Replace in file console utility. Find and replace text patterns in files with multiple modes.",
  "source": "https://github.com/webdevops/go-replace",
  "checks": [
    { "type": "binary", "name": "go-replace" }
  ],
  "install_guidance": {
    "plugin": "go-replace",
    "binary": "go-replace",
    "check": "which go-replace",
    "install_steps": [
      "Download from https://github.com/webdevops/go-replace/releases",
      "Add to PATH",
      "Verify: go-replace --help",
      "supercli plugins install ./plugins/go-replace --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "go-replace",
      "resource": "replace",
      "action": "text",
      "description": "Replace text in files",
      "adapter": "process",
      "adapterConfig": {
        "command": "go-replace",
        "passthrough": true,
        "missingDependencyHelp": "Install go-replace from GitHub releases"
      },
      "args": [
        { "name": "-s", "type": "string", "description": "Search pattern" },
        { "name": "-r", "type": "string", "description": "Replacement text" },
        { "name": "-m", "type": "string", "description": "Mode (replace, line, lineinfile, template)" }
      ]
    },
    {
      "namespace": "go-replace",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to go-replace CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "go-replace",
        "passthrough": true,
        "missingDependencyHelp": "Install go-replace from GitHub releases"
      },
      "args": []
    }
  ]
}
