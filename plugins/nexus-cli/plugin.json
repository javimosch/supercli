{
  "name": "nexus-cli",
  "version": "0.1.0",
  "description": "Nexus CLI for Docker Registry v2 management",
  "source": "https://github.com/mlabouardy/nexus-cli",
  "checks": [
    {
      "type": "binary",
      "name": "nexus"
    }
  ],
  "install_guidance": {
    "plugin": "nexus-cli",
    "binary": "nexus",
    "check": "which nexus",
    "install_steps": [
      "go install github.com/mlabouardy/nexus-cli@latest",
      "Verify: nexus --version",
      "supercli plugins install ./plugins/nexus-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "nexus-cli",
      "resource": "self",
      "action": "version",
      "description": "Print nexus-cli version",
      "adapter": "process",
      "adapterConfig": {
        "command": "nexus",
        "missingDependencyHelp": "Install nexus-cli: go install github.com/mlabouardy/nexus-cli@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "nexus-cli",
      "resource": "image",
      "action": "list",
      "description": "list image via nexus",
      "adapter": "process",
      "adapterConfig": {
        "command": "nexus",
        "missingDependencyHelp": "Install nexus-cli: go install github.com/mlabouardy/nexus-cli@latest",
        "baseArgs": [
          "image",
          "ls"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
