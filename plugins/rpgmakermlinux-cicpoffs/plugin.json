{
  "name": "rpgmakermlinux-cicpoffs",
  "version": "0.1.0",
  "description": "RPG Maker MV/MZ Linux compatibility tool",
  "source": "https://github.com/bakustarver/rpgmakermlinux-cicpoffs",
  "checks": [
    {
      "type": "binary",
      "name": "rpgmakermlinux"
    }
  ],
  "install_guidance": {
    "plugin": "rpgmakermlinux-cicpoffs",
    "binary": "rpgmakermlinux",
    "check": "which rpgmakermlinux",
    "install_steps": [
      "npm install -g rpgmakermlinux-cicpoffs",
      "Verify: rpgmakermlinux --version",
      "supercli plugins install ./plugins/rpgmakermlinux-cicpoffs --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "rpgmakermlinux-cicpoffs",
      "resource": "self",
      "action": "version",
      "description": "Print rpgmakermlinux-cicpoffs version",
      "adapter": "process",
      "adapterConfig": {
        "command": "rpgmakermlinux",
        "missingDependencyHelp": "Install rpgmakermlinux-cicpoffs: npm install -g rpgmakermlinux-cicpoffs",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "rpgmakermlinux-cicpoffs",
      "resource": "game",
      "action": "run",
      "description": "run game via rpgmakermlinux",
      "adapter": "process",
      "adapterConfig": {
        "command": "rpgmakermlinux",
        "missingDependencyHelp": "Install rpgmakermlinux-cicpoffs: npm install -g rpgmakermlinux-cicpoffs",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "rpgmakermlinux-cicpoffs",
      "resource": "_",
      "action": "_",
      "description": "_ _ via rpgmakermlinux",
      "adapter": "process",
      "adapterConfig": {
        "command": "rpgmakermlinux",
        "missingDependencyHelp": "Install rpgmakermlinux-cicpoffs: npm install -g rpgmakermlinux-cicpoffs",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}