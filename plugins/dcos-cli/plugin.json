{
  "name": "dcos-cli",
  "version": "0.1.0",
  "description": "The command line for DC/OS",
  "source": "https://github.com/dcos/dcos-cli",
  "checks": [
    {
      "type": "binary",
      "name": "dcos"
    }
  ],
  "install_guidance": {
    "plugin": "dcos-cli",
    "binary": "dcos",
    "check": "which dcos",
    "install_steps": [
      "brew install dcos-cli",
      "Verify: dcos --version",
      "supercli plugins install ./plugins/dcos-cli --on-conflict replace --json"
    ]
  },
