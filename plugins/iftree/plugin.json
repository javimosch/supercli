{
  "name": "iftree",
  "version": "0.1.0",
  "description": "Display network interfaces as a tree structure",
  "source": "https://github.com/t1anz0ng/iftree",
  "checks": [
    {
      "type": "binary",
      "name": "iftree"
    }
  ],
  "install_guidance": {
    "plugin": "iftree",
    "binary": "iftree",
    "check": "which iftree",
    "install_steps": [
      "go install github.com/t1anz0ng/iftree@latest",
      "Verify: iftree --version",
      "supercli plugins install ./plugins/iftree --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "iftree",
      "resource": "self",
      "action": "version",
      "description": "Print iftree version",
      "adapter": "process",
      "adapterConfig": {
        "command": "iftree",
        "missingDependencyHelp": "Install iftree: go install github.com/t1anz0ng/iftree@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "iftree",
      "resource": "interfaces",
      "action": "show",
      "description": "show interfaces via iftree",
      "adapter": "process",
      "adapterConfig": {
        "command": "iftree",
        "missingDependencyHelp": "Install iftree: go install github.com/t1anz0ng/iftree@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "iftree",
      "resource": "interfaces",
      "action": "tree",
      "description": "tree interfaces via iftree",
      "adapter": "process",
      "adapterConfig": {
        "command": "iftree",
        "missingDependencyHelp": "Install iftree: go install github.com/t1anz0ng/iftree@latest",
        "baseArgs": [
          "--tree"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "iftree",
      "resource": "_",
      "action": "_",
      "description": "_ _ via iftree",
      "adapter": "process",
      "adapterConfig": {
        "command": "iftree",
        "missingDependencyHelp": "Install iftree: go install github.com/t1anz0ng/iftree@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}