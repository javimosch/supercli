{
  "name": "pokevision-cli",
  "version": "0.1.0",
  "description": "CLI tool for Pokemon location tracking",
  "source": "https://github.com/jmshal/pokevision-cli",
  "checks": [
    {
      "type": "binary",
      "name": "pokevision"
    }
  ],
  "install_guidance": {
    "plugin": "pokevision-cli",
    "binary": "pokevision",
    "check": "which pokevision",
    "install_steps": [
      "go install github.com/jmshal/pokevision-cli@latest",
      "Verify: pokevision --version",
      "supercli plugins install ./plugins/pokevision-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "pokevision-cli",
      "resource": "self",
      "action": "version",
      "description": "Print pokevision-cli version",
      "adapter": "process",
      "adapterConfig": {
        "command": "pokevision",
        "missingDependencyHelp": "Install pokevision-cli: go install github.com/jmshal/pokevision-cli@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "pokevision-cli",
      "resource": "location",
      "action": "find",
      "description": "find location via pokevision",
      "adapter": "process",
      "adapterConfig": {
        "command": "pokevision",
        "missingDependencyHelp": "Install pokevision-cli: go install github.com/jmshal/pokevision-cli@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "pokevision-cli",
      "resource": "pokemon",
      "action": "search",
      "description": "search pokemon via pokevision",
      "adapter": "process",
      "adapterConfig": {
        "command": "pokevision",
        "missingDependencyHelp": "Install pokevision-cli: go install github.com/jmshal/pokevision-cli@latest",
        "baseArgs": [
          "--search"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "pokevision-cli",
      "resource": "_",
      "action": "_",
      "description": "_ _ via pokevision",
      "adapter": "process",
      "adapterConfig": {
        "command": "pokevision",
        "missingDependencyHelp": "Install pokevision-cli: go install github.com/jmshal/pokevision-cli@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}