{
  "name": "dosxvpn",
  "version": "0.1.0",
  "description": "Simple macOS VPN client for DigitalOcean Droplets",
  "source": "https://github.com/dan-v/dosxvpn",
  "checks": [
    {
      "type": "binary",
      "name": "dosxvpn"
    }
  ],
  "install_guidance": {
    "plugin": "dosxvpn",
    "binary": "dosxvpn",
    "check": "which dosxvpn",
    "install_steps": [
      "go install github.com/dan-v/dosxvpn@latest",
      "Verify: dosxvpn --version",
      "supercli plugins install ./plugins/dosxvpn --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "dosxvpn",
      "resource": "self",
      "action": "version",
      "description": "Print dosxvpn version",
      "adapter": "process",
      "adapterConfig": {
        "command": "dosxvpn",
        "missingDependencyHelp": "Install dosxvpn: go install github.com/dan-v/dosxvpn@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "dosxvpn",
      "resource": "vpn",
      "action": "connect",
      "description": "connect vpn via dosxvpn",
      "adapter": "process",
      "adapterConfig": {
        "command": "dosxvpn",
        "missingDependencyHelp": "Install dosxvpn: go install github.com/dan-v/dosxvpn@latest",
        "baseArgs": [
          "connect"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
