{
  "name": "nostromo",
  "version": "0.1.0",
  "description": "CLI for building powerful aliases and command shortcuts",
  "source": "https://github.com/pokanop/nostromo",
  "checks": [
    {
      "type": "binary",
      "name": "nostromo"
    }
  ],
  "install_guidance": {
    "plugin": "nostromo",
    "binary": "nostromo",
    "check": "which nostromo",
    "install_steps": [
      "brew install pokanop/tap/nostromo",
      "Verify: nostromo --version",
      "supercli plugins install ./plugins/nostromo --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "nostromo",
      "resource": "self",
      "action": "version",
      "description": "Print nostromo version",
      "adapter": "process",
      "adapterConfig": {
        "command": "nostromo",
        "missingDependencyHelp": "Install nostromo: brew install pokanop/tap/nostromo",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "nostromo",
      "resource": "alias",
      "action": "add",
      "description": "add alias via nostromo",
      "adapter": "process",
      "adapterConfig": {
        "command": "nostromo",
        "missingDependencyHelp": "Install nostromo: brew install pokanop/tap/nostromo",
        "baseArgs": [
          "add"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "nostromo",
      "resource": "alias",
      "action": "list",
      "description": "list alias via nostromo",
      "adapter": "process",
      "adapterConfig": {
        "command": "nostromo",
        "missingDependencyHelp": "Install nostromo: brew install pokanop/tap/nostromo",
        "baseArgs": [
          "list"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "nostromo",
      "resource": "alias",
      "action": "remove",
      "description": "remove alias via nostromo",
      "adapter": "process",
      "adapterConfig": {
        "command": "nostromo",
        "missingDependencyHelp": "Install nostromo: brew install pokanop/tap/nostromo",
        "baseArgs": [
          "remove"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "nostromo",
      "resource": "alias",
      "action": "sync",
      "description": "sync alias via nostromo",
      "adapter": "process",
      "adapterConfig": {
        "command": "nostromo",
        "missingDependencyHelp": "Install nostromo: brew install pokanop/tap/nostromo",
        "baseArgs": [
          "sync"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "nostromo",
      "resource": "_",
      "action": "_",
      "description": "_ _ via nostromo",
      "adapter": "process",
      "adapterConfig": {
        "command": "nostromo",
        "missingDependencyHelp": "Install nostromo: brew install pokanop/tap/nostromo",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}