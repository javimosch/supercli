{
  "name": "realize",
  "version": "0.1.0",
  "description": "Go build system with file watcher, live reload and output streams",
  "source": "https://github.com/oxequa/realize",
  "checks": [
    {
      "type": "binary",
      "name": "realize"
    }
  ],
  "install_guidance": {
    "plugin": "realize",
    "binary": "realize",
    "check": "which realize",
    "install_steps": [
      "go install github.com/oxequa/realize@latest",
      "Verify: realize --version",
      "supercli plugins install ./plugins/realize --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "realize",
      "resource": "self",
      "action": "version",
      "description": "Print realize version",
      "adapter": "process",
      "adapterConfig": {
        "command": "realize",
        "missingDependencyHelp": "Install realize: go install github.com/oxequa/realize@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "realize",
      "resource": "dev",
      "action": "start",
      "description": "start dev via realize",
      "adapter": "process",
      "adapterConfig": {
        "command": "realize",
        "missingDependencyHelp": "Install realize: go install github.com/oxequa/realize@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "realize",
      "resource": "init",
      "action": "init",
      "description": "init init via realize",
      "adapter": "process",
      "adapterConfig": {
        "command": "realize",
        "missingDependencyHelp": "Install realize: go install github.com/oxequa/realize@latest",
        "baseArgs": [
          "init"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "realize",
      "resource": "_",
      "action": "_",
      "description": "_ _ via realize",
      "adapter": "process",
      "adapterConfig": {
        "command": "realize",
        "missingDependencyHelp": "Install realize: go install github.com/oxequa/realize@latest",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}