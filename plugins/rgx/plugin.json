{
  "name": "rgx",
  "version": "0.1.0",
  "description": "regex101 for the terminal - real-time matching, 3 engines, capture groups",
  "source": "https://github.com/brevity1swos/rgx",
  "checks": [
    { "type": "binary", "name": "rgx" }
  ],
  "install_guidance": {
    "plugin": "rgx",
    "binary": "rgx",
    "check": "which rgx",
    "install_steps": [
      "cargo install rgx",
      "Verify: rgx --help",
      "supercli plugins install ./plugins/rgx --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "rgx",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to rgx CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "rgx",
        "cwd": "invoke_cwd",
        "passthrough": true,
        "missingDependencyHelp": "Install rgx: cargo install rgx"
      },
      "args": []
    }
  ]
}
