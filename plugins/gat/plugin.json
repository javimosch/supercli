{
  "name": "gat",
  "version": "0.1.0",
  "description": "Pretty-print files in terminal with syntax highlighting",
  "source": "https://github.com/koki-develop/gat",
  "checks": [
    {
      "type": "binary",
      "name": "gat"
    }
  ],
  "install_guidance": {
    "plugin": "gat",
    "binary": "gat",
    "check": "which gat",
    "install_steps": [
      "brew install gat",
      "Verify: gat --version",
      "supercli plugins install ./plugins/gat --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "gat",
      "resource": "self",
      "action": "version",
      "description": "Print gat version",
      "adapter": "process",
      "adapterConfig": {
        "command": "gat",
        "missingDependencyHelp": "Install gat: brew install gat",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "gat",
      "resource": "file",
      "action": "print",
      "description": "print file via gat",
      "adapter": "process",
      "adapterConfig": {
        "command": "gat",
        "missingDependencyHelp": "Install gat: brew install gat",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "gat",
      "resource": "_",
      "action": "_",
      "description": "_ _ via gat",
      "adapter": "process",
      "adapterConfig": {
        "command": "gat",
        "missingDependencyHelp": "Install gat: brew install gat",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}