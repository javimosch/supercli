{
  "name": "tombi",
  "version": "0.1.0",
  "description": "TOML Toolkit - TOML Formatter / Linter / Language Server. Format and lint TOML configuration files with ease.",
  "source": "https://github.com/tombi-toml/tombi",
  "checks": [
    { "type": "binary", "name": "tombi" }
  ],
  "install_guidance": {
    "plugin": "tombi",
    "binary": "tombi",
    "check": "which tombi",
    "install_steps": [
      "brew install tombi",
      "Verify: tombi --version",
      "supercli plugins install ./plugins/tombi --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "tombi",
      "resource": "toml",
      "action": "format",
      "description": "Format TOML file",
      "adapter": "process",
      "adapterConfig": {
        "command": "tombi",
        "baseArgs": ["fmt"],
        "passthrough": true,
        "missingDependencyHelp": "Install tombi: brew install tombi"
      },
      "args": [
        { "name": "file", "type": "string", "description": "TOML file to format" },
        { "name": "--check", "type": "boolean", "description": "Check without modifying" },
        { "name": "--write", "type": "boolean", "description": "Write changes to file" },
        { "name": "--stdin", "type": "boolean", "description": "Read from stdin" }
      ]
    },
    {
      "namespace": "tombi",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to tombi CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "tombi",
        "passthrough": true,
        "missingDependencyHelp": "Install tombi: brew install tombi"
      },
      "args": []
    }
  ]
}
