{
  "plugin": "ollama",
  "binary": "ollama",
  "check": "ollama --version",
  "install_steps": [
    "curl -fsSL https://ollama.com/install.sh | sh",
    "ollama --version",
    "supercli plugins install ./plugins/ollama --json"
  ],
  "note": "Ollama must be running (ollama serve) for API commands. CLI commands work without the server."
}