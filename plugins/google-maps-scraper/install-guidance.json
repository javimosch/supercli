{
  "plugin": "google-maps-scraper",
  "binary": "python3",
  "check": "python3 --version",
  "install_steps": [
    "pip install playwright pandas",
    "playwright install chromium",
    "Verify: python3 plugins/google-maps-scraper/scraper.py --help",
    "supercli plugins install ./plugins/google-maps-scraper --on-conflict replace --json"
  ],
  "note": "Requires Python 3.8+ and Playwright with Chromium browser. The scraper runs in headless mode by default for automated use."
}
