{
  "name": "google-maps-scraper",
  "version": "0.2.0",
  "description": "Scrape business data from Google Maps including names, addresses, websites, phone numbers, ratings, and reviews using Lightpanda",
  "source": "https://github.com/javimosch/supercli",
  "checks": [
    { "type": "binary", "name": "node" }
  ],
  "install_guidance": {
    "plugin": "google-maps-scraper",
    "binary": "node",
    "check": "node --version",
    "install_steps": [
      "sc lightpanda cli setup",
      "supercli plugins install ./plugins/google-maps-scraper --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "google-maps-scraper",
      "resource": "search",
      "action": "scrape",
      "description": "Scrape Google Maps for business data",
      "adapter": "process",
      "adapterConfig": {
        "command": "node",
        "baseArgs": ["plugins/lightpanda/scripts/lightpanda-wrapper.js", "run"],
        "timeout_ms": 120000,
        "missingDependencyHelp": "Run 'sc lightpanda cli setup' to install Lightpanda runtime dependencies"
      },
      "args": [
        { "name": "file", "type": "string", "required": false, "description": "Path to scraper script (default: plugin_dir/scraper.js)" },
        { "name": "query", "type": "string", "required": true, "description": "Search query for Google Maps (e.g., 'restaurants in Paris')" },
        { "name": "limit", "type": "number", "required": false, "description": "Maximum number of results to scrape (default: 10)" },
        { "name": "timeout-ms", "type": "number", "required": false, "description": "Execution timeout in milliseconds" },
        { "name": "verbose", "type": "boolean", "required": false, "description": "Enable verbose logging" }
      ]
    }
  ]
}
