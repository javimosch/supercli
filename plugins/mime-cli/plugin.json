{
  "name": "mime-cli",
  "version": "0.1.0",
  "description": "Detect MIME types of files",
  "source": "https://www.npmjs.com/package/mime-cli",
  "checks": [
    { "type": "binary", "name": "mime" }
  ],
  "install_guidance": {
    "plugin": "mime-cli",
    "binary": "mime",
    "check": "which mime",
    "install_steps": [
      "npm install -g mime-cli",
      "Verify: mime --help",
      "supercli plugins install ./plugins/mime-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "mime-cli",
      "resource": "file",
      "action": "type",
      "description": "Detect MIME type of file",
      "adapter": "process",
      "adapterConfig": {
        "command": "mime",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 60000,
        "missingDependencyHelp": "Install mime-cli: npm install -g mime-cli"
      },
      "args": [
        { "name": "file", "type": "string", "required": true, "description": "File to check" }
      ]
    },
    {
      "namespace": "mime-cli",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to mime CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "mime",
        "passthrough": true,
        "missingDependencyHelp": "Install mime-cli: npm install -g mime-cli"
      },
      "args": []
    }
  ]
}
