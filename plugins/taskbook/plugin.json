{
  "name": "taskbook",
  "version": "0.1.0",
  "description": "Tasks, boards & notes for the command-line habitat",
  "source": "https://github.com/klaudiosinani/taskbook",
  "checks": [
    {
      "type": "binary",
      "name": "tb"
    }
  ],
  "install_guidance": {
    "plugin": "taskbook",
    "binary": "tb",
    "check": "which tb",
    "install_steps": [
      "npm install -g taskbook",
      "Verify: tb --version",
      "supercli plugins install ./plugins/taskbook --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "taskbook",
      "resource": "self",
      "action": "version",
      "description": "Print taskbook version",
      "adapter": "process",
      "adapterConfig": {
        "command": "tb",
        "missingDependencyHelp": "Install taskbook: npm install -g taskbook",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "taskbook",
      "resource": "task",
      "action": "create",
      "description": "create task via tb",
      "adapter": "process",
      "adapterConfig": {
        "command": "tb",
        "missingDependencyHelp": "Install taskbook: npm install -g taskbook",
        "baseArgs": [
          "--task"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "taskbook",
      "resource": "note",
      "action": "create",
      "description": "create note via tb",
      "adapter": "process",
      "adapterConfig": {
        "command": "tb",
        "missingDependencyHelp": "Install taskbook: npm install -g taskbook",
        "baseArgs": [
          "--note"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "taskbook",
      "resource": "board",
      "action": "show",
      "description": "show board via tb",
      "adapter": "process",
      "adapterConfig": {
        "command": "tb",
        "missingDependencyHelp": "Install taskbook: npm install -g taskbook",
        "baseArgs": [
          "--boards"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "taskbook",
      "resource": "_",
      "action": "_",
      "description": "_ _ via tb",
      "adapter": "process",
      "adapterConfig": {
        "command": "tb",
        "missingDependencyHelp": "Install taskbook: npm install -g taskbook",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}