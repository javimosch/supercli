      "resource": "self",
      "action": "version",
      "description": "Print grpcurl version",
      "adapter": "process",
      "adapterConfig": {
        "command": "grpcurl",
        "missingDependencyHelp": "Install grpcurl: brew install grpcurl",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
