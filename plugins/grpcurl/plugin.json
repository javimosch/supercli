{
  "name": "grpcurl",
  "version": "0.1.0",
  "description": "Command-line tool for interacting with gRPC servers",
  "source": "https://github.com/fullstorydev/grpcurl",
  "checks": [
    {
      "type": "binary",
      "name": "grpcurl"
    }
  ],
  "install_guidance": {
    "plugin": "grpcurl",
    "binary": "grpcurl",
    "check": "which grpcurl",
    "install_steps": [
      "brew install grpcurl",
      "Verify: grpcurl --version",
      "supercli plugins install ./plugins/grpcurl --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
