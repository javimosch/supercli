{
  "plugin": "landrun",
  "binary": "landrun",
  "check": "which landrun",
  "install_steps": [
    "go install github.com/zouuup/landrun/cmd/landrun@latest",
    "Verify: landrun --help",
    "supercli plugins install ./plugins/landrun --on-conflict replace --json"
  ],
  "note": "Linux only. Requires Linux kernel 5.13+ with Landlock enabled. Network restrictions require kernel 6.7+."
}
