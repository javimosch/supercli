{
  "name": "csvtojson",
  "version": "0.1.0",
  "description": "CSV to JSON converter with custom parser support",
  "source": "https://github.com/Keyang/node-csvtojson",
  "checks": [
    { "type": "binary", "name": "csvtojson" }
  ],
  "install_guidance": {
    "plugin": "csvtojson",
    "binary": "csvtojson",
    "check": "which csvtojson",
    "install_steps": [
      "npm install -g csvtojson",
      "Verify: csvtojson",
      "supercli plugins install ./plugins/csvtojson --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "csvtojson",
      "resource": "file",
      "action": "convert",
      "description": "Convert CSV to JSON",
      "adapter": "process",
      "adapterConfig": {
        "command": "csvtojson",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 120000,
        "missingDependencyHelp": "Install csvtojson: npm install -g csvtojson"
      },
      "args": [
        { "name": "input", "type": "string", "required": true, "description": "CSV file path" },
        { "name": "output", "type": "string", "required": false, "description": "Output JSON file path" },
        { "name": "noheader", "type": "boolean", "required": false, "description": "CSV has no header row" },
        { "name": "delimiter", "type": "string", "required": false, "description": "Custom delimiter" }
      ]
    },
    {
      "namespace": "csvtojson",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to csvtojson CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "csvtojson",
        "passthrough": true,
        "missingDependencyHelp": "Install csvtojson: npm install -g csvtojson"
      },
      "args": []
    }
  ]
}
