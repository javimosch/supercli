    },
    {
      "namespace": "windows-folder-remark",
      "resource": "help",
      "action": "show",
      "description": "show help via folder-remark",
      "adapter": "process",
      "adapterConfig": {
        "command": "folder-remark",
        "missingDependencyHelp": "Install windows-folder-remark: pip install windows-folder-remark",
        "baseArgs": [
          "--help"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
