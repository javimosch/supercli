{
  "name": "windows-folder-remark",
  "version": "0.1.0",
  "description": "Lightweight CLI tool to add remarks to Windows folders via Desktop.ini privacy-first",
  "source": "https://github.com/piratf/windows-folder-remark",
  "checks": [
    {
      "type": "binary",
      "name": "folder-remark"
    }
  ],
  "install_guidance": {
    "plugin": "windows-folder-remark",
    "binary": "folder-remark",
    "check": "which folder-remark",
    "install_steps": [
      "pip install windows-folder-remark",
      "Verify: folder-remark --version",
      "supercli plugins install ./plugins/windows-folder-remark --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "windows-folder-remark",
      "resource": "self",
      "action": "version",
      "description": "Print windows-folder-remark version",
      "adapter": "process",
      "adapterConfig": {
        "command": "folder-remark",
        "missingDependencyHelp": "Install windows-folder-remark: pip install windows-folder-remark",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "windows-folder-remark",
      "resource": "folder",
      "action": "add",
      "description": "add folder via folder-remark",
      "adapter": "process",
      "adapterConfig": {
        "command": "folder-remark",
        "missingDependencyHelp": "Install windows-folder-remark: pip install windows-folder-remark",
        "baseArgs": [
          "add"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "windows-folder-remark",
      "resource": "folder",
      "action": "remove",
      "description": "remove folder via folder-remark",
      "adapter": "process",
      "adapterConfig": {
        "command": "folder-remark",
        "missingDependencyHelp": "Install windows-folder-remark: pip install windows-folder-remark",
        "baseArgs": [
          "remove"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "windows-folder-remark",
      "resource": "folder",
      "action": "list",
      "description": "list folder via folder-remark",
      "adapter": "process",
      "adapterConfig": {
        "command": "folder-remark",
        "missingDependencyHelp": "Install windows-folder-remark: pip install windows-folder-remark",
        "baseArgs": [
          "list"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "windows-folder-remark",
      "resource": "remark",
      "action": "show",
      "description": "show remark via folder-remark",
      "adapter": "process",
      "adapterConfig": {
        "command": "folder-remark",
        "missingDependencyHelp": "Install windows-folder-remark: pip install windows-folder-remark",
        "baseArgs": [
          "--show"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "windows-folder-remark",
      "resource": "verbose",
      "action": "set",
      "description": "set verbose via folder-remark",
      "adapter": "process",
      "adapterConfig": {
        "command": "folder-remark",
        "missingDependencyHelp": "Install windows-folder-remark: pip install windows-folder-remark",
        "baseArgs": [
          "--verbose"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
