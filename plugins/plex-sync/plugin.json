{
  "name": "plex-sync",
  "version": "0.1.0",
  "description": "Sync watched status between Plex servers",
  "source": "https://github.com/jacobwgillespie/plex-sync",
  "checks": [
    {
      "type": "binary",
      "name": "plex-sync"
    }
  ],
  "install_guidance": {
    "plugin": "plex-sync",
    "binary": "plex-sync",
    "check": "which plex-sync",
    "install_steps": [
      "npm install -g plex-sync",
      "Verify: plex-sync --version",
      "supercli plugins install ./plugins/plex-sync --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "plex-sync",
      "resource": "self",
      "action": "version",
      "description": "Print plex-sync version",
      "adapter": "process",
      "adapterConfig": {
        "command": "plex-sync",
        "missingDependencyHelp": "Install plex-sync: npm install -g plex-sync",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "plex-sync",
      "resource": "libraries",
      "action": "sync",
      "description": "sync libraries via plex-sync",
      "adapter": "process",
      "adapterConfig": {
        "command": "plex-sync",
        "missingDependencyHelp": "Install plex-sync: npm install -g plex-sync",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "plex-sync",
      "resource": "status",
      "action": "show",
      "description": "show status via plex-sync",
      "adapter": "process",
      "adapterConfig": {
        "command": "plex-sync",
        "missingDependencyHelp": "Install plex-sync: npm install -g plex-sync",
        "baseArgs": [
          "--status"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "plex-sync",
      "resource": "_",
      "action": "_",
      "description": "_ _ via plex-sync",
      "adapter": "process",
      "adapterConfig": {
        "command": "plex-sync",
        "missingDependencyHelp": "Install plex-sync: npm install -g plex-sync",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}