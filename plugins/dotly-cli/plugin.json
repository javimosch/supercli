      "namespace": "dotly-cli",
      "resource": "self",
      "action": "version",
      "description": "Print dotly-cli version",
      "adapter": "process",
      "adapterConfig": {
        "command": "dotly",
        "missingDependencyHelp": "Install dotly-cli: curl -s https://raw.githubusercontent.com/CodelyTV/dotly/master/installer | bash",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
