{
  "name": "dotly-cli",
  "version": "0.1.0",
  "description": "Simplify configuration management from the command line",
  "source": "https://github.com/CodelyTV/dotly",
  "checks": [
    {
      "type": "binary",
      "name": "dotly"
    }
  ],
  "install_guidance": {
    "plugin": "dotly-cli",
    "binary": "dotly",
    "check": "which dotly",
    "install_steps": [
      "curl -s https://raw.githubusercontent.com/CodelyTV/dotly/master/installer | bash",
      "Verify: dotly --version",
      "supercli plugins install ./plugins/dotly-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
