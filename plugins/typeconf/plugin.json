      "resource": "self",
      "action": "version",
      "description": "Print typeconf version",
      "adapter": "process",
      "adapterConfig": {
        "command": "typeconf",
        "missingDependencyHelp": "Install typeconf: npm install -g typeconf",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
