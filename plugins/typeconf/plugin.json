{
  "name": "typeconf",
  "version": "0.1.0",
  "description": "Define feature flags prompts or any experiments right in Typescript",
  "source": "https://github.com/typeconf/typeconf",
  "checks": [
    {
      "type": "binary",
      "name": "typeconf"
    }
  ],
  "install_guidance": {
    "plugin": "typeconf",
    "binary": "typeconf",
    "check": "which typeconf",
    "install_steps": [
      "npm install -g typeconf",
      "Verify: typeconf --version",
      "supercli plugins install ./plugins/typeconf --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
