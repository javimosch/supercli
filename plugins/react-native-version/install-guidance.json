{
  "plugin": "react-native-version",
  "binary": "react-native-version",
  "check": "which react-native-version",
  "install_steps": [
    "npm install -g react-native-version",
    "Verify: react-native-version --version",
    "supercli plugins install ./plugins/react-native-version --on-conflict replace --json"
  ]
}