{
  "name": "react-native-version",
  "version": "0.1.0",
  "description": "Automate React Native versioning",
  "source": "https://github.com/stovmascript/react-native-version",
  "checks": [
    {
      "type": "binary",
      "name": "react-native-version"
    }
  ],
  "install_guidance": {
    "plugin": "react-native-version",
    "binary": "react-native-version",
    "check": "which react-native-version",
    "install_steps": [
      "npm install -g react-native-version",
      "Verify: react-native-version --version",
      "supercli plugins install ./plugins/react-native-version --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "react-native-version",
      "resource": "self",
      "action": "version",
      "description": "Print react-native-version version",
      "adapter": "process",
      "adapterConfig": {
        "command": "react-native-version",
        "missingDependencyHelp": "Install react-native-version: npm install -g react-native-version",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "react-native-version",
      "resource": "version",
      "action": "bump",
      "description": "bump version via react-native-version",
      "adapter": "process",
      "adapterConfig": {
        "command": "react-native-version",
        "missingDependencyHelp": "Install react-native-version: npm install -g react-native-version",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "react-native-version",
      "resource": "_",
      "action": "_",
      "description": "_ _ via react-native-version",
      "adapter": "process",
      "adapterConfig": {
        "command": "react-native-version",
        "missingDependencyHelp": "Install react-native-version: npm install -g react-native-version",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}