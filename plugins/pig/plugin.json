{
  "name": "pig",
  "version": "0.1.0",
  "description": "PostgreSQL extension package manager CLI",
  "source": "https://github.com/pgsty/pig",
  "checks": [
    {
      "type": "binary",
      "name": "pig"
    }
  ],
  "install_guidance": {
    "plugin": "pig",
    "binary": "pig",
    "check": "which pig",
    "install_steps": [
      "brew install pgsty/pig/pig",
      "Verify: pig --version",
      "supercli plugins install ./plugins/pig --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "pig",
      "resource": "self",
      "action": "version",
      "description": "Print pig version",
      "adapter": "process",
      "adapterConfig": {
        "command": "pig",
        "missingDependencyHelp": "Install pig: brew install pgsty/pig/pig",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "pig",
      "resource": "extension",
      "action": "install",
      "description": "install extension via pig",
      "adapter": "process",
      "adapterConfig": {
        "command": "pig",
        "missingDependencyHelp": "Install pig: brew install pgsty/pig/pig",
        "baseArgs": [
          "install"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "pig",
      "resource": "extension",
      "action": "list",
      "description": "list extension via pig",
      "adapter": "process",
      "adapterConfig": {
        "command": "pig",
        "missingDependencyHelp": "Install pig: brew install pgsty/pig/pig",
        "baseArgs": [
          "list"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "pig",
      "resource": "extension",
      "action": "remove",
      "description": "remove extension via pig",
      "adapter": "process",
      "adapterConfig": {
        "command": "pig",
        "missingDependencyHelp": "Install pig: brew install pgsty/pig/pig",
        "baseArgs": [
          "remove"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "pig",
      "resource": "extension",
      "action": "update",
      "description": "update extension via pig",
      "adapter": "process",
      "adapterConfig": {
        "command": "pig",
        "missingDependencyHelp": "Install pig: brew install pgsty/pig/pig",
        "baseArgs": [
          "update"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "pig",
      "resource": "_",
      "action": "_",
      "description": "_ _ via pig",
      "adapter": "process",
      "adapterConfig": {
        "command": "pig",
        "missingDependencyHelp": "Install pig: brew install pgsty/pig/pig",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
