{
  "name": "typeorm-fixtures",
  "version": "0.1.0",
  "description": "Fixtures loader for TypeORM to load test data into your database",
  "source": "https://github.com/RobinCK/typeorm-fixtures",
  "checks": [
    {
      "type": "binary",
      "name": "typeorm-fixtures"
    }
  ],
  "install_guidance": {
    "plugin": "typeorm-fixtures",
    "binary": "typeorm-fixtures",
    "check": "which typeorm-fixtures",
    "install_steps": [
      "npm install -g typeorm-fixtures-cli",
      "Verify: typeorm-fixtures --version",
      "supercli plugins install ./plugins/typeorm-fixtures --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "typeorm-fixtures",
      "resource": "self",
      "action": "version",
      "description": "Print typeorm-fixtures version",
      "adapter": "process",
      "adapterConfig": {
        "command": "typeorm-fixtures",
        "missingDependencyHelp": "Install typeorm-fixtures: npm install -g typeorm-fixtures-cli",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "typeorm-fixtures",
      "resource": "fixtures",
      "action": "load",
