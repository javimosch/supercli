      "adapterConfig": {
        "command": "typeorm-fixtures",
        "missingDependencyHelp": "Install typeorm-fixtures: npm install -g typeorm-fixtures-cli",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
