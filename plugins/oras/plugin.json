        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "oras",
      "resource": "artifact",
      "action": "discover",
      "description": "discover artifact via oras",
      "adapter": "process",
      "adapterConfig": {
        "command": "oras",
        "missingDependencyHelp": "Install oras: brew install oras",
        "baseArgs": [
          "discover"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "oras",
