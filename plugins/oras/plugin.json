{
  "name": "oras",
  "version": "0.1.0",
  "description": "Work with OCI registries from the command line",
  "source": "https://github.com/oras-project/oras",
  "checks": [
    {
      "type": "binary",
      "name": "oras"
    }
  ],
  "install_guidance": {
    "plugin": "oras",
    "binary": "oras",
    "check": "which oras",
    "install_steps": [
      "brew install oras",
      "Verify: oras --version",
      "supercli plugins install ./plugins/oras --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "oras",
      "resource": "self",
      "action": "version",
      "description": "Print oras version",
      "adapter": "process",
      "adapterConfig": {
        "command": "oras",
        "missingDependencyHelp": "Install oras: brew install oras",
        "baseArgs": [
          "version"
        ]
      },
      "args": []
    },
    {
      "namespace": "oras",
      "resource": "artifact",
      "action": "push",
      "description": "push artifact via oras",
      "adapter": "process",
      "adapterConfig": {
        "command": "oras",
        "missingDependencyHelp": "Install oras: brew install oras",
        "baseArgs": [
          "push"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "oras",
      "resource": "artifact",
      "action": "pull",
      "description": "pull artifact via oras",
      "adapter": "process",
      "adapterConfig": {
