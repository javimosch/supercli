{
  "name": "sniffer",
  "version": "0.1.0",
  "description": "A modern alternative network traffic sniffer",
  "source": "https://github.com/chenjiandongx/sniffer",
  "checks": [
    {
      "type": "binary",
      "name": "sniffer"
    }
  ],
  "install_guidance": {
    "plugin": "sniffer",
    "binary": "sniffer",
    "check": "which sniffer",
    "install_steps": [
      "brew install sniffer",
      "Verify: sniffer --version",
      "supercli plugins install ./plugins/sniffer --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "sniffer",
      "resource": "self",
      "action": "version",
      "description": "Print sniffer version",
      "adapter": "process",
      "adapterConfig": {
        "command": "sniffer",
        "missingDependencyHelp": "Install sniffer: brew install sniffer",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "sniffer",
      "resource": "interface",
      "action": "capture",
      "description": "capture interface via sniffer",
      "adapter": "process",
      "adapterConfig": {
        "command": "sniffer",
        "missingDependencyHelp": "Install sniffer: brew install sniffer",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "sniffer",
      "resource": "_",
      "action": "_",
      "description": "_ _ via sniffer",
      "adapter": "process",
      "adapterConfig": {
        "command": "sniffer",
        "missingDependencyHelp": "Install sniffer: brew install sniffer",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}