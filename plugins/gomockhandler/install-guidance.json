{
  "plugin": "gomockhandler",
  "binary": "gomockhandler",
  "check": "which gomockhandler",
  "install_steps": [
    "go install github.com/sanposhiho/gomockhandler@latest",
    "Verify: gomockhandler --version",
    "supercli plugins install ./plugins/gomockhandler --on-conflict replace --json"
  ]
}