{
  "name": "gomockhandler",
  "version": "0.1.0",
  "description": "Manage and generate Go mock implementations",
  "source": "https://github.com/sanposhiho/gomockhandler",
  "checks": [
    {
      "type": "binary",
      "name": "gomockhandler"
    }
  ],
  "install_guidance": {
    "plugin": "gomockhandler",
    "binary": "gomockhandler",
    "check": "which gomockhandler",
    "install_steps": [
      "go install github.com/sanposhiho/gomockhandler@latest",
      "Verify: gomockhandler --version",
      "supercli plugins install ./plugins/gomockhandler --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "gomockhandler",
      "resource": "self",
      "action": "version",
      "description": "Print gomockhandler version",
      "adapter": "process",
      "adapterConfig": {
        "command": "gomockhandler",
        "missingDependencyHelp": "Install gomockhandler: go install github.com/sanposhiho/gomockhandler@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "gomockhandler",
      "resource": "mock",
      "action": "generate",
      "description": "generate mock via gomockhandler",
      "adapter": "process",
      "adapterConfig": {
        "command": "gomockhandler",
        "missingDependencyHelp": "Install gomockhandler: go install github.com/sanposhiho/gomockhandler@latest",
        "baseArgs": [
          "generate"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "gomockhandler",
      "resource": "mock",
      "action": "check",
      "description": "check mock via gomockhandler",
      "adapter": "process",
      "adapterConfig": {
        "command": "gomockhandler",
        "missingDependencyHelp": "Install gomockhandler: go install github.com/sanposhiho/gomockhandler@latest",
        "baseArgs": [
          "check"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "gomockhandler",
      "resource": "mock",
      "action": "list",
      "description": "list mock via gomockhandler",
      "adapter": "process",
      "adapterConfig": {
        "command": "gomockhandler",
        "missingDependencyHelp": "Install gomockhandler: go install github.com/sanposhiho/gomockhandler@latest",
        "baseArgs": [
          "list"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "gomockhandler",
      "resource": "_",
      "action": "_",
      "description": "_ _ via gomockhandler",
      "adapter": "process",
      "adapterConfig": {
        "command": "gomockhandler",
        "missingDependencyHelp": "Install gomockhandler: go install github.com/sanposhiho/gomockhandler@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}