{
  "plugin": "gocloc",
  "binary": "gocloc",
  "check": "which gocloc",
  "install_steps": [
    "go install github.com/hhatto/gocloc/cmd/gocloc@latest",
    "Verify: gocloc --help",
    "supercli plugins install ./plugins/gocloc --on-conflict replace --json"
  ],
  "note": "gocloc provides fast line-of-code counting for multiple languages"
}
