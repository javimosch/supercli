{
  "name": "go-http-cli",
  "version": "0.1.0",
  "description": "A powerful HTTP CLI client written in Go. cURL alternative with profiles, variables, and named requests.",
  "source": "https://github.com/visola/go-http-cli",
  "checks": [
    { "type": "binary", "name": "http" }
  ],
  "install_guidance": {
    "plugin": "go-http-cli",
    "binary": "http",
    "check": "which http",
    "install_steps": [
      "Download from https://github.com/visola/go-http-cli/releases",
      "Unzip and add to PATH",
      "Verify: http --help",
      "supercli plugins install ./plugins/go-http-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "go-http-cli",
      "resource": "request",
      "action": "http",
      "description": "Make HTTP request",
      "adapter": "process",
      "adapterConfig": {
        "command": "http",
        "passthrough": true,
        "missingDependencyHelp": "Install go-http-cli from GitHub releases"
      },
      "args": [
        { "name": "url", "type": "string", "description": "URL to request" },
        { "name": "-X", "type": "string", "description": "HTTP method" },
        { "name": "-H", "type": "string", "description": "HTTP header" },
        { "name": "-d", "type": "string", "description": "Request body data" }
      ]
    },
    {
      "namespace": "go-http-cli",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to http CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "http",
        "passthrough": true,
        "missingDependencyHelp": "Install go-http-cli from GitHub releases"
      },
      "args": []
    }
  ]
}
