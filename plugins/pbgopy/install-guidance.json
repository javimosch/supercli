{
  "plugin": "pbgopy",
  "binary": "pbgopy",
  "check": "which pbgopy",
  "install_steps": [
    "go install github.com/nakabonne/pbgopy@latest",
    "Verify: pbgopy --help",
    "supercli plugins install ./plugins/pbgopy --on-conflict replace --json"
  ],
  "note": "pbgopy provides copy/paste between devices with encryption"
}
