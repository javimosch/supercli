{
  "name": "percollate",
  "version": "0.1.0",
  "description": "Turn web pages into PDF, EPUB, or HTML books",
  "source": "https://github.com/danburzo/percollate",
  "checks": [
    {
      "type": "binary",
      "name": "percollate"
    }
  ],
  "install_guidance": {
    "plugin": "percollate",
    "binary": "percollate",
    "check": "which percollate",
    "install_steps": [
      "npm install -g percollate",
      "Verify: percollate --version",
      "supercli plugins install ./plugins/percollate --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "percollate",
      "resource": "self",
      "action": "version",
      "description": "Print percollate version",
      "adapter": "process",
      "adapterConfig": {
        "command": "percollate",
        "missingDependencyHelp": "Install percollate: npm install -g percollate",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "percollate",
      "resource": "page",
      "action": "convert",
      "description": "convert page via percollate",
      "adapter": "process",
      "adapterConfig": {
        "command": "percollate",
        "missingDependencyHelp": "Install percollate: npm install -g percollate",
        "baseArgs": [
          "pdf"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "percollate",
      "resource": "_",
      "action": "_",
      "description": "_ _ via percollate",
      "adapter": "process",
      "adapterConfig": {
        "command": "percollate",
        "missingDependencyHelp": "Install percollate: npm install -g percollate",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}