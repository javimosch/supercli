{
  "plugin": "timetrace",
  "binary": "timetrace",
  "check": "which timetrace",
  "install_steps": [
    "brew install timetrace",
    "Verify: timetrace --version",
    "supercli plugins install ./plugins/timetrace --on-conflict replace --json"
  ],
  "note": "timetrace provides simple time tracking for working hours"
}
