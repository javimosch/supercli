{
  "name": "rimage",
  "version": "0.1.0",
  "description": "Image encoder CLI tool inspired by squoosh with multiple format support (AVIF, JPEG, PNG, WebP, etc.)",
  "source": "https://github.com/vlad-salone/rimage",
  "checks": [
    { "type": "binary", "name": "rimage" }
  ],
  "install_guidance": {
    "plugin": "rimage",
    "binary": "rimage",
    "check": "which rimage",
    "install_steps": [
      "cargo install rimage",
      "Verify: rimage --version",
      "supercli plugins install ./plugins/rimage --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "rimage",
      "resource": "self",
      "action": "version",
      "description": "Print rimage version",
      "adapter": "process",
      "adapterConfig": {
        "command": "rimage",
        "baseArgs": ["--version"],
        "missingDependencyHelp": "Install rimage: cargo install rimage"
      },
      "args": []
    },
    {
      "namespace": "rimage",
      "resource": "encode",
      "action": "avif",
      "description": "Encode images into AVIF format",
      "adapter": "process",
      "adapterConfig": {
        "command": "rimage",
        "baseArgs": ["avif"],
        "cwd": "invoke_cwd",
        "passthrough": true,
        "timeout_ms": 60000,
        "missingDependencyHelp": "Install rimage"
      },
      "args": []
    },
    {
      "namespace": "rimage",
      "resource": "encode",
      "action": "jpeg",
      "description": "Encode images into JPEG format",
      "adapter": "process",
      "adapterConfig": {
        "command": "rimage",
        "baseArgs": ["jpeg"],
        "cwd": "invoke_cwd",
        "passthrough": true,
        "timeout_ms": 60000,
        "missingDependencyHelp": "Install rimage"
      },
      "args": []
    },
    {
      "namespace": "rimage",
      "resource": "encode",
      "action": "mozjpeg",
      "description": "Encode images into JPEG format using MozJpeg codec",
      "adapter": "process",
      "adapterConfig": {
        "command": "rimage",
        "baseArgs": ["mozjpeg"],
        "cwd": "invoke_cwd",
        "passthrough": true,
        "timeout_ms": 60000,
        "missingDependencyHelp": "Install rimage"
      },
      "args": []
    },
    {
      "namespace": "rimage",
      "resource": "encode",
      "action": "png",
      "description": "Encode images into PNG format",
      "adapter": "process",
      "adapterConfig": {
        "command": "rimage",
        "baseArgs": ["png"],
        "cwd": "invoke_cwd",
        "passthrough": true,
        "timeout_ms": 60000,
        "missingDependencyHelp": "Install rimage"
      },
      "args": []
    },
    {
      "namespace": "rimage",
      "resource": "encode",
      "action": "webp",
      "description": "Encode images into WebP format",
      "adapter": "process",
      "adapterConfig": {
        "command": "rimage",
        "baseArgs": ["webp"],
        "cwd": "invoke_cwd",
        "passthrough": true,
        "timeout_ms": 60000,
        "missingDependencyHelp": "Install rimage"
      },
      "args": []
    },
    {
      "namespace": "rimage",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to rimage CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "rimage",
        "cwd": "invoke_cwd",
        "passthrough": true,
        "missingDependencyHelp": "Install rimage"
      },
      "args": []
    }
  ]
}
