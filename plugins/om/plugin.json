{
  "name": "om",
  "version": "0.1.0",
  "description": "Pivotal Operations Manager command line tool",
  "source": "https://github.com/pivotal-cf/om",
  "checks": [
    {
      "type": "binary",
      "name": "om"
    }
  ],
  "install_guidance": {
    "plugin": "om",
    "binary": "om",
    "check": "which om",
    "install_steps": [
      "go install github.com/pivotal-cf/om@latest",
      "Verify: om --version",
      "supercli plugins install ./plugins/om --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "om",
      "resource": "self",
      "action": "version",
      "description": "Print om version",
      "adapter": "process",
      "adapterConfig": {
        "command": "om",
        "missingDependencyHelp": "Install om: go install github.com/pivotal-cf/om@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "om",
      "resource": "product",
      "action": "list",
      "description": "list product via om",
      "adapter": "process",
      "adapterConfig": {
        "command": "om",
        "missingDependencyHelp": "Install om: go install github.com/pivotal-cf/om@latest",
        "baseArgs": [
          "products"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
