{
  "name": "bundown",
  "version": "0.1.0",
  "description": "Fast all-in-one Markdown runtime and bundler built on Bun",
  "source": "https://github.com/rysana-ai/bundown",
  "checks": [
    {
      "type": "binary",
      "name": "bundown"
    }
  ],
  "install_guidance": {
    "plugin": "bundown",
    "binary": "bundown",
    "check": "which bundown",
    "install_steps": [
      "npm install -g bundown",
      "Verify: bundown --version",
      "supercli plugins install ./plugins/bundown --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
