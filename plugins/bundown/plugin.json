      "resource": "self",
      "action": "version",
      "description": "Print bundown version",
      "adapter": "process",
      "adapterConfig": {
        "command": "bundown",
        "missingDependencyHelp": "Install bundown: npm install -g bundown",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "bundown",
      "resource": "markdown",
      "action": "run",
      "description": "run markdown via bundown",
      "adapter": "process",
      "adapterConfig": {
        "command": "bundown",
        "missingDependencyHelp": "Install bundown: npm install -g bundown",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
