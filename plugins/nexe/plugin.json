{
  "name": "nexe",
  "version": "0.1.0",
  "description": "Create a single executable out of your node.js apps",
  "source": "https://github.com/nexe/nexe",
  "checks": [
    {
      "type": "binary",
      "name": "nexe"
    }
  ],
  "install_guidance": {
    "plugin": "nexe",
    "binary": "nexe",
    "check": "which nexe",
    "install_steps": [
      "npm install -g nexe",
      "Verify: nexe --version",
      "supercli plugins install ./plugins/nexe --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "nexe",
      "resource": "self",
      "action": "version",
      "description": "Print nexe version",
      "adapter": "process",
      "adapterConfig": {
        "command": "nexe",
        "missingDependencyHelp": "Install nexe: npm install -g nexe",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "nexe",
      "resource": "build",
      "action": "compile",
      "description": "compile build via nexe",
      "adapter": "process",
      "adapterConfig": {
        "command": "nexe",
        "missingDependencyHelp": "Install nexe: npm install -g nexe",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "nexe",
      "resource": "_",
      "action": "_",
      "description": "_ _ via nexe",
      "adapter": "process",
      "adapterConfig": {
        "command": "nexe",
        "missingDependencyHelp": "Install nexe: npm install -g nexe",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}