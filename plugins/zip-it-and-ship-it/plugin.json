{
  "name": "zip-it-and-ship-it",
  "version": "0.1.0",
  "description": "Create deployable function bundles for Netlify and AWS Lambda",
  "source": "https://github.com/netlify/zip-it-and-ship-it",
  "checks": [
    {
      "type": "binary",
      "name": "zip-it-and-ship-it"
    }
  ],
  "install_guidance": {
    "plugin": "zip-it-and-ship-it",
    "binary": "zip-it-and-ship-it",
    "check": "which zip-it-and-ship-it",
    "install_steps": [
      "npm install -g @netlify/zip-it-and-ship-it",
      "Verify: zip-it-and-ship-it --version",
      "supercli plugins install ./plugins/zip-it-and-ship-it --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "zip-it-and-ship-it",
      "resource": "self",
      "action": "version",
      "description": "Print zip-it-and-ship-it version",
      "adapter": "process",
      "adapterConfig": {
        "command": "zip-it-and-ship-it",
        "missingDependencyHelp": "Install zip-it-and-ship-it: npm install -g @netlify/zip-it-and-ship-it",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "zip-it-and-ship-it",
      "resource": "functions",
      "action": "bundle",
      "description": "bundle functions via zip-it-and-ship-it",
      "adapter": "process",
      "adapterConfig": {
        "command": "zip-it-and-ship-it",
        "missingDependencyHelp": "Install zip-it-and-ship-it: npm install -g @netlify/zip-it-and-ship-it",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "zip-it-and-ship-it",
      "resource": "functions",
      "action": "list",
      "description": "list functions via zip-it-and-ship-it",
      "adapter": "process",
      "adapterConfig": {
        "command": "zip-it-and-ship-it",
        "missingDependencyHelp": "Install zip-it-and-ship-it: npm install -g @netlify/zip-it-and-ship-it",
        "baseArgs": [
          "--list"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "zip-it-and-ship-it",
      "resource": "_",
      "action": "_",
      "description": "_ _ via zip-it-and-ship-it",
      "adapter": "process",
      "adapterConfig": {
        "command": "zip-it-and-ship-it",
        "missingDependencyHelp": "Install zip-it-and-ship-it: npm install -g @netlify/zip-it-and-ship-it",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}