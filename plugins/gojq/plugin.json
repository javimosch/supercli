{
  "name": "gojq",
  "version": "0.1.0",
  "description": "Pure Go implementation of jq. Process and query JSON data with jq-compatible syntax.",
  "source": "https://github.com/itchyny/gojq",
  "checks": [
    { "type": "binary", "name": "gojq" }
  ],
  "install_guidance": {
    "plugin": "gojq",
    "binary": "gojq",
    "check": "which gojq",
    "install_steps": [
      "brew install gojq",
      "Verify: gojq --version",
      "supercli plugins install ./plugins/gojq --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "gojq",
      "resource": "query",
      "action": "json",
      "description": "Query JSON with jq syntax",
      "adapter": "process",
      "adapterConfig": {
        "command": "gojq",
        "passthrough": true,
        "missingDependencyHelp": "Install gojq: brew install gojq"
      },
      "args": [
        { "name": "query", "type": "string", "description": "jq query string" }
      ]
    },
    {
      "namespace": "gojq",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to gojq CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "gojq",
        "passthrough": true,
        "missingDependencyHelp": "Install gojq: brew install gojq"
      },
      "args": []
    }
  ]
}
