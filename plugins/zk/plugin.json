{
  "name": "zk",
  "version": "0.1.0",
  "description": "Plain text note-taking assistant",
  "source": "https://github.com/zk-org/zk",
  "checks": [
    {
      "type": "binary",
      "name": "zk"
    }
  ],
  "install_guidance": {
    "plugin": "zk",
    "binary": "zk",
    "check": "which zk",
    "install_steps": [
      "brew install zk",
      "Verify: zk --version",
      "supercli plugins install ./plugins/zk --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "zk",
      "resource": "self",
      "action": "version",
      "description": "Print zk version",
      "adapter": "process",
      "adapterConfig": {
        "command": "zk",
        "missingDependencyHelp": "Install zk: brew install zk",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "zk",
      "resource": "note",
      "action": "create",
      "description": "create note via zk",
      "adapter": "process",
      "adapterConfig": {
        "command": "zk",
        "missingDependencyHelp": "Install zk: brew install zk",
        "baseArgs": [
          "new"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "zk",
      "resource": "note",
      "action": "list",
      "description": "list note via zk",
      "adapter": "process",
      "adapterConfig": {
        "command": "zk",
        "missingDependencyHelp": "Install zk: brew install zk",
        "baseArgs": [
          "list"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "zk",
      "resource": "note",
      "action": "search",
      "description": "search note via zk",
      "adapter": "process",
      "adapterConfig": {
        "command": "zk",
        "missingDependencyHelp": "Install zk: brew install zk",
        "baseArgs": [
          "index",
          "query"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "zk",
      "resource": "_",
      "action": "_",
      "description": "_ _ via zk",
      "adapter": "process",
      "adapterConfig": {
        "command": "zk",
        "missingDependencyHelp": "Install zk: brew install zk",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}