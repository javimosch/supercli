{
  "plugin": "x",
  "binary": "x",
  "check": "which x",
  "install_steps": [
    "Download from: https://github.com/devhindo/x/releases/latest",
    "Extract tarball: tar -xzf x_Linux_x86_64.tar.gz",
    "Add to PATH: export PATH=$PATH:/path/to/x",
    "Authenticate: x auth (opens browser)",
    "Verify: x auth -v",
    "supercli plugins install ./plugins/x --on-conflict replace --json"
  ],
  "note": "Auth requires browser-based OAuth. Run 'x auth' on a machine with browser access to authorize."
}