{
  "plugin": "terraform-module-versions",
  "binary": "terraform-module-versions",
  "check": "which terraform-module-versions",
  "install_steps": [
    "go install github.com/keilerkonzept/terraform-module-versions@latest",
    "Verify: terraform-module-versions --version",
    "supercli plugins install ./plugins/terraform-module-versions --on-conflict replace --json"
  ]
}