{
  "name": "terraform-module-versions",
  "version": "0.1.0",
  "description": "CLI tool that checks Terraform code for module updates",
  "source": "https://github.com/keilerkonzept/terraform-module-versions",
  "checks": [
    {
      "type": "binary",
      "name": "terraform-module-versions"
    }
  ],
  "install_guidance": {
    "plugin": "terraform-module-versions",
    "binary": "terraform-module-versions",
    "check": "which terraform-module-versions",
    "install_steps": [
      "go install github.com/keilerkonzept/terraform-module-versions@latest",
      "Verify: terraform-module-versions --version",
      "supercli plugins install ./plugins/terraform-module-versions --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "terraform-module-versions",
      "resource": "self",
      "action": "version",
      "description": "Print terraform-module-versions version",
      "adapter": "process",
      "adapterConfig": {
        "command": "terraform-module-versions",
        "missingDependencyHelp": "Install terraform-module-versions: go install github.com/keilerkonzept/terraform-module-versions@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "terraform-module-versions",
      "resource": "code",
      "action": "check",
      "description": "check code via terraform-module-versions",
      "adapter": "process",
      "adapterConfig": {
        "command": "terraform-module-versions",
        "missingDependencyHelp": "Install terraform-module-versions: go install github.com/keilerkonzept/terraform-module-versions@latest",
        "baseArgs": [
          "check"
        ],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "terraform-module-versions",
      "resource": "module",
      "action": "list",
      "description": "list module via terraform-module-versions",
      "adapter": "process",
      "adapterConfig": {
        "command": "terraform-module-versions",
        "missingDependencyHelp": "Install terraform-module-versions: go install github.com/keilerkonzept/terraform-module-versions@latest",
        "baseArgs": [
          "list"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "terraform-module-versions",
      "resource": "update",
      "action": "check",
      "description": "check update via terraform-module-versions",
      "adapter": "process",
      "adapterConfig": {
        "command": "terraform-module-versions",
        "missingDependencyHelp": "Install terraform-module-versions: go install github.com/keilerkonzept/terraform-module-versions@latest",
        "baseArgs": [
          "update-check"
        ],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "terraform-module-versions",
      "resource": "_",
      "action": "_",
      "description": "_ _ via terraform-module-versions",
      "adapter": "process",
      "adapterConfig": {
        "command": "terraform-module-versions",
        "missingDependencyHelp": "Install terraform-module-versions: go install github.com/keilerkonzept/terraform-module-versions@latest",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}