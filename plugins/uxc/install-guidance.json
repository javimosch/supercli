{
  "plugin": "uxc",
  "binary": "uxc",
  "check": "which uxc",
  "install_steps": [
    "brew install holon-run/tap/uxc",
    "Verify: uxc --version",
    "supercli plugins install ./plugins/uxc --on-conflict replace --json"
  ],
  "note": "Also: curl -fsSL https://raw.githubusercontent.com/holon-run/uxc/main/scripts/install.sh | bash"
}
