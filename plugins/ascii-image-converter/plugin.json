{
  "name": "ascii-image-converter",
  "version": "0.1.0",
  "description": "Convert images into ASCII art",
  "source": "https://github.com/TheZoraiz/ascii-image-converter",
  "checks": [
    {
      "type": "binary",
      "name": "ascii-image-converter"
    }
  ],
  "install_guidance": {
    "plugin": "ascii-image-converter",
    "binary": "ascii-image-converter",
    "check": "which ascii-image-converter",
    "install_steps": [
      "go install github.com/TheZoraiz/ascii-image-converter@latest",
      "Verify: ascii-image-converter --version",
      "supercli plugins install ./plugins/ascii-image-converter --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "ascii-image-converter",
      "resource": "self",
      "action": "version",
      "description": "Print ascii-image-converter version",
      "adapter": "process",
      "adapterConfig": {
        "command": "ascii-image-converter",
        "missingDependencyHelp": "Install ascii-image-converter: go install github.com/TheZoraiz/ascii-image-converter@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "ascii-image-converter",
      "resource": "image",
      "action": "convert",
      "description": "convert image via ascii-image-converter",
      "adapter": "process",
      "adapterConfig": {
        "command": "ascii-image-converter",
        "missingDependencyHelp": "Install ascii-image-converter: go install github.com/TheZoraiz/ascii-image-converter@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "ascii-image-converter",
      "resource": "_",
      "action": "_",
      "description": "_ _ via ascii-image-converter",
      "adapter": "process",
      "adapterConfig": {
        "command": "ascii-image-converter",
        "missingDependencyHelp": "Install ascii-image-converter: go install github.com/TheZoraiz/ascii-image-converter@latest",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}