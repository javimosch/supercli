{
  "name": "mermaid-cli",
  "version": "0.1.0",
  "description": "Command line tool for the Mermaid diagramming language",
  "source": "https://github.com/mermaid-js/mermaid-cli",
  "checks": [
    {
      "type": "binary",
      "name": "mmdc"
    }
  ],
  "install_guidance": {
    "plugin": "mermaid-cli",
    "binary": "mmdc",
    "check": "which mmdc",
    "install_steps": [
      "npm install -g @mermaid-js/mermaid-cli",
      "Verify: mmdc --version",
      "supercli plugins install ./plugins/mermaid-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "mermaid-cli",
      "resource": "self",
      "action": "version",
      "description": "Print mermaid-cli version",
      "adapter": "process",
      "adapterConfig": {
        "command": "mmdc",
        "missingDependencyHelp": "Install mermaid-cli: npm install -g @mermaid-js/mermaid-cli",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "mermaid-cli",
      "resource": "file",
      "action": "render",
      "description": "render file via mmdc",
      "adapter": "process",
      "adapterConfig": {
        "command": "mmdc",
        "missingDependencyHelp": "Install mermaid-cli: npm install -g @mermaid-js/mermaid-cli",
        "baseArgs": [
          "-i"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "mermaid-cli",
      "resource": "_",
      "action": "_",
      "description": "_ _ via mmdc",
      "adapter": "process",
      "adapterConfig": {
        "command": "mmdc",
        "missingDependencyHelp": "Install mermaid-cli: npm install -g @mermaid-js/mermaid-cli",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}