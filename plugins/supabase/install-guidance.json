{
  "plugin": "supabase",
  "binary": "supabase",
  "check": "supabase --version",
  "install_steps": [
    "npm install -g supabase",
    "supabase --version",
    "supercli plugins install ./plugins/supabase --on-conflict replace --json"
  ],
  "note": "Run 'supabase login' before remote operations. Use 'supabase start' for local development."
}