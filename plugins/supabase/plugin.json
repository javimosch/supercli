{
  "name": "supabase",
  "version": "0.1.0",
  "description": "Supabase CLI plugin for dcli",
  "source": "https://supabase.com/docs/reference/cli/introduction",
  "checks": [
    {
      "type": "binary",
      "name": "supabase"
    }
  ],
  "commands": [
    {
      "namespace": "supabase",
      "resource": "projects",
      "action": "list",
      "description": "List Supabase projects for the authenticated account",
      "adapter": "process",
      "adapterConfig": {
        "command": "supabase",
        "baseArgs": ["projects", "list", "--output", "json"],
        "parseJson": true,
        "missingDependencyHelp": "Please install the Supabase CLI to use this command."
      },
      "args": []
    },
    {
      "namespace": "supabase",
      "resource": "_",
      "action": "_",
      "description": "Passthrough command to execute any Supabase CLI command",
      "adapter": "process",
      "adapterConfig": {
        "command": "supabase",
        "passthrough": true,
        "parseJson": true,
        "missingDependencyHelp": "Please install the Supabase CLI to use this command."
      },
      "args": []
    }
  ]
}
