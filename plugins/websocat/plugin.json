{
  "name": "websocat",
  "version": "0.1.0",
  "description": "Command-line client for WebSockets, like netcat or curl for ws://. Connect, send, and receive WebSocket messages from the terminal with advanced socat-like functions.",
  "source": "https://github.com/vi/websocat",
  "checks": [
    { "type": "binary", "name": "websocat" }
  ],
  "install_guidance": {
    "plugin": "websocat",
    "binary": "websocat",
    "check": "which websocat",
    "install_steps": [
      "brew install websocat",
      "Verify: websocat --version",
      "supercli plugins install ./plugins/websocat --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "websocat",
      "resource": "websocket",
      "action": "connect",
      "description": "Connect to WebSocket server",
      "adapter": "process",
      "adapterConfig": {
        "command": "websocat",
        "passthrough": true,
        "missingDependencyHelp": "Install websocat: brew install websocat"
      },
      "args": [
        { "name": "url", "type": "string", "description": "WebSocket URL" },
        { "name": "--text", "type": "boolean", "description": "Text mode" },
        { "name": "--ping-interval", "type": "integer", "description": "Ping interval in seconds" },
        { "name": "--protocol", "type": "string", "description": "WebSocket protocol" },
        { "name": "--header", "type": "string", "description": "HTTP header" }
      ]
    },
    {
      "namespace": "websocat",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to websocat CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "websocat",
        "passthrough": true,
        "missingDependencyHelp": "Install websocat: brew install websocat"
      },
      "args": []
    }
  ]
}
