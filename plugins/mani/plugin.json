{
  "name": "mani",
  "version": "0.1.0",
  "description": "CLI tool to help you manage multiple repositories",
  "source": "https://github.com/alajmo/mani",
  "checks": [
    {
      "type": "binary",
      "name": "mani"
    }
  ],
  "install_guidance": {
    "plugin": "mani",
    "binary": "mani",
    "check": "which mani",
    "install_steps": [
      "brew install mani",
      "Verify: mani --version",
      "supercli plugins install ./plugins/mani --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "mani",
      "resource": "self",
      "action": "version",
      "description": "Print mani version",
      "adapter": "process",
      "adapterConfig": {
        "command": "mani",
        "missingDependencyHelp": "Install mani: brew install mani",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "mani",
      "resource": "project",
      "action": "list",
      "description": "list project via mani",
      "adapter": "process",
      "adapterConfig": {
        "command": "mani",
        "missingDependencyHelp": "Install mani: brew install mani",
        "baseArgs": [
          "list"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "mani",
      "resource": "run",
      "action": "exec",
      "description": "exec run via mani",
      "adapter": "process",
      "adapterConfig": {
        "command": "mani",
        "missingDependencyHelp": "Install mani: brew install mani",
        "baseArgs": [
          "run"
        ],
        "passthrough": true,
        "timeout_ms": 120000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "mani",
      "resource": "_",
      "action": "_",
      "description": "_ _ via mani",
      "adapter": "process",
      "adapterConfig": {
        "command": "mani",
        "missingDependencyHelp": "Install mani: brew install mani",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}