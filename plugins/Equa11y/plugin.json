{
  "name": "Equa11y",
  "version": "0.1.0",
  "description": "Stream-lined command line tool for running accessibility testing with axe-core and puppeteer",
  "source": "https://github.com/oslabs-beta/Equa11y",
  "checks": [
    {
      "type": "binary",
      "name": "equa11y"
    }
  ],
  "install_guidance": {
    "plugin": "Equa11y",
    "binary": "equa11y",
    "check": "which equa11y",
    "install_steps": [
      "npm install -g equa11y",
      "Verify: equa11y --version",
      "supercli plugins install ./plugins/Equa11y --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "Equa11y",
      "resource": "self",
      "action": "version",
      "description": "Print Equa11y version",
      "adapter": "process",
      "adapterConfig": {
        "command": "equa11y",
        "missingDependencyHelp": "Install Equa11y: npm install -g equa11y",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "Equa11y",
      "resource": "site",
      "action": "test",
      "description": "test site via equa11y",
      "adapter": "process",
      "adapterConfig": {
        "command": "equa11y",
        "missingDependencyHelp": "Install Equa11y: npm install -g equa11y",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
