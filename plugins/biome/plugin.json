{
  "name": "biome",
  "version": "0.1.0",
  "description": "A toolchain for web projects with formatter and linter",
  "source": "https://github.com/biomejs/biome",
  "checks": [
    {
      "type": "binary",
      "name": "biome"
    }
  ],
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "biome",
      "resource": "format",
      "action": "run",
      "description": "Format files",
      "adapter": "process",
      "adapterConfig": {
        "command": "biome",
        "baseArgs": [
          "format"
        ],
        "passthrough": true
      },
      "args": [
        {
          "name": "files",
          "type": "string",
          "required": true,
          "description": "Files to format"
        }
      ]
    },
    {
      "namespace": "biome",
      "resource": "lint",
      "action": "run",
      "description": "Lint files",
      "adapter": "process",
      "adapterConfig": {
        "command": "biome",
        "baseArgs": [
          "lint"
        ],
        "passthrough": true
      },
      "args": [
        {
          "name": "files",
          "type": "string",
          "required": true,
          "description": "Files to lint"
        }
      ]
    },
    {
      "namespace": "biome",
      "resource": "check",
      "action": "run",
      "description": "Run format and lint checks",
      "adapter": "process",
      "adapterConfig": {
        "command": "biome",
        "baseArgs": [
          "check"
        ],
        "passthrough": true
      },
      "args": [
        {
          "name": "files",
          "type": "string",
          "required": true,
          "description": "Files to check"
        }
      ]
    }
  ]
}