{
  "name": "crane",
  "version": "0.1.0",
  "description": "Tool for interacting with remote container registries",
  "source": "https://github.com/google/go-containerregistry",
  "checks": [
    {
      "type": "binary",
      "name": "crane"
    }
  ],
  "install_guidance": {
    "plugin": "crane",
    "binary": "crane",
    "check": "which crane",
    "install_steps": [
      "brew install crane",
      "Verify: crane --version",
      "supercli plugins install ./plugins/crane --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "crane",
      "resource": "self",
      "action": "version",
      "description": "Print crane version",
      "adapter": "process",
      "adapterConfig": {
        "command": "crane",
        "missingDependencyHelp": "Install crane: brew install crane",
        "baseArgs": [
          "version"
        ]
      },
      "args": []
    },
    {
      "namespace": "crane",
      "resource": "image",
      "action": "pull",
      "description": "pull image via crane",
      "adapter": "process",
      "adapterConfig": {
        "command": "crane",
        "missingDependencyHelp": "Install crane: brew install crane",
        "baseArgs": [
          "pull"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "crane",
      "resource": "image",
      "action": "push",
      "description": "push image via crane",
      "adapter": "process",
      "adapterConfig": {
        "command": "crane",
        "missingDependencyHelp": "Install crane: brew install crane",
        "baseArgs": [
          "push"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "crane",
      "resource": "image",
      "action": "ls",
      "description": "ls image via crane",
      "adapter": "process",
      "adapterConfig": {
        "command": "crane",
        "missingDependencyHelp": "Install crane: brew install crane",
        "baseArgs": [
          "ls"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "crane",
      "resource": "image",
      "action": "digest",
      "description": "digest image via crane",
      "adapter": "process",
      "adapterConfig": {
        "command": "crane",
        "missingDependencyHelp": "Install crane: brew install crane",
        "baseArgs": [
          "digest"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "crane",
      "resource": "_",
      "action": "_",
      "description": "_ _ via crane",
      "adapter": "process",
      "adapterConfig": {
        "command": "crane",
        "missingDependencyHelp": "Install crane: brew install crane",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}