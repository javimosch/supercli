{
  "name": "ggc",
  "version": "0.1.0",
  "description": "Modern Git CLI tool with simplified traditional commands and an interactive fuzzy-picker UI. Streamlines common git operations with intuitive syntax.",
  "source": "https://github.com/bmf-san/ggc",
  "checks": [
    { "type": "binary", "name": "ggc" }
  ],
  "install_guidance": {
    "plugin": "ggc",
    "binary": "ggc",
    "check": "which ggc",
    "install_steps": [
      "curl -sSL https://raw.githubusercontent.com/bmf-san/ggc/main/install.sh | bash",
      "Verify: ggc --version",
      "supercli plugins install ./plugins/ggc --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "ggc",
      "resource": "self",
      "action": "version",
      "description": "Print ggc version",
      "adapter": "process",
      "adapterConfig": {
        "command": "ggc",
        "baseArgs": ["--version"],
        "missingDependencyHelp": "Install ggc: curl -sSL https://raw.githubusercontent.com/bmf-san/ggc/main/install.sh | bash or brew install ggc"
      },
      "args": []
    },
    {
      "namespace": "ggc",
      "resource": "repo",
      "action": "status",
      "description": "Show git status in simplified format",
      "adapter": "process",
      "adapterConfig": {
        "command": "ggc",
        "baseArgs": ["status"],
        "passthrough": true,
        "cwd": "invoke_cwd",
        "missingDependencyHelp": "Install ggc: curl -sSL https://raw.githubusercontent.com/bmf-san/ggc/main/install.sh | bash or brew install ggc"
      },
      "args": []
    },
    {
      "namespace": "ggc",
      "resource": "repo",
      "action": "add",
      "description": "Stage files for commit",
      "adapter": "process",
      "adapterConfig": {
        "command": "ggc",
        "baseArgs": ["add"],
        "passthrough": true,
        "cwd": "invoke_cwd",
        "missingDependencyHelp": "Install ggc: curl -sSL https://raw.githubusercontent.com/bmf-san/ggc/main/install.sh | bash or brew install ggc"
      },
      "args": [
        { "name": "files", "type": "string", "description": "Files or patterns to stage (default: .)" }
      ]
    },
    {
      "namespace": "ggc",
      "resource": "repo",
      "action": "commit",
      "description": "Commit staged changes",
      "adapter": "process",
      "adapterConfig": {
        "command": "ggc",
        "baseArgs": ["commit"],
        "passthrough": true,
        "cwd": "invoke_cwd",
        "missingDependencyHelp": "Install ggc: curl -sSL https://raw.githubusercontent.com/bmf-san/ggc/main/install.sh | bash or brew install ggc"
      },
      "args": [
        { "name": "message", "type": "string", "required": true, "description": "Commit message" }
      ]
    },
    {
      "namespace": "ggc",
      "resource": "repo",
      "action": "log",
      "description": "Show simplified git log",
      "adapter": "process",
      "adapterConfig": {
        "command": "ggc",
        "baseArgs": ["log"],
        "passthrough": true,
        "cwd": "invoke_cwd",
        "missingDependencyHelp": "Install ggc: curl -sSL https://raw.githubusercontent.com/bmf-san/ggc/main/install.sh | bash or brew install ggc"
      },
      "args": [
        { "name": "args", "type": "string", "description": "Additional log options (e.g. simple)" }
      ]
    },
    {
      "namespace": "ggc",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to ggc CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "ggc",
        "passthrough": true,
        "cwd": "invoke_cwd",
        "missingDependencyHelp": "Install ggc: curl -sSL https://raw.githubusercontent.com/bmf-san/ggc/main/install.sh | bash or brew install ggc"
      },
      "args": []
    }
  ]
}
