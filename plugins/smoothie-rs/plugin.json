{
  "name": "smoothie-rs",
  "version": "0.1.0",
  "description": "Add motion blur to videos with granular configuration",
  "source": "https://github.com/couleur-tweak-tips/smoothie-rs",
  "checks": [
    {
      "type": "binary",
      "name": "smoothie"
    }
  ],
  "install_guidance": {
    "plugin": "smoothie-rs",
    "binary": "smoothie",
    "check": "which smoothie",
    "install_steps": [
      "cargo install smoothie-rs",
      "Verify: smoothie --version",
      "supercli plugins install ./plugins/smoothie-rs --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "smoothie-rs",
      "resource": "self",
      "action": "version",
      "description": "Print smoothie-rs version",
      "adapter": "process",
      "adapterConfig": {
        "command": "smoothie",
        "missingDependencyHelp": "Install smoothie-rs: cargo install smoothie-rs",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "smoothie-rs",
      "resource": "video",
      "action": "blur",
      "description": "blur video via smoothie",
      "adapter": "process",
      "adapterConfig": {
        "command": "smoothie",
        "missingDependencyHelp": "Install smoothie-rs: cargo install smoothie-rs",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "smoothie-rs",
      "resource": "config",
      "action": "show",
      "description": "show config via smoothie",
      "adapter": "process",
      "adapterConfig": {
        "command": "smoothie",
        "missingDependencyHelp": "Install smoothie-rs: cargo install smoothie-rs",
        "baseArgs": [
          "--config"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "smoothie-rs",
      "resource": "preset",
      "action": "list",
      "description": "list preset via smoothie",
      "adapter": "process",
      "adapterConfig": {
        "command": "smoothie",
        "missingDependencyHelp": "Install smoothie-rs: cargo install smoothie-rs",
        "baseArgs": [
          "--list-presets"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "smoothie-rs",
      "resource": "preset",
      "action": "apply",
      "description": "apply preset via smoothie",
      "adapter": "process",
      "adapterConfig": {
        "command": "smoothie",
        "missingDependencyHelp": "Install smoothie-rs: cargo install smoothie-rs",
        "baseArgs": [
          "--preset"
        ],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "smoothie-rs",
      "resource": "_",
      "action": "_",
      "description": "_ _ via smoothie",
      "adapter": "process",
      "adapterConfig": {
        "command": "smoothie",
        "missingDependencyHelp": "Install smoothie-rs: cargo install smoothie-rs",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}