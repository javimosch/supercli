{
  "name": "localias",
  "version": "0.1.0",
  "description": "Manage local development aliases and hostnames",
  "source": "https://github.com/peterldowns/localias",
  "checks": [
    {
      "type": "binary",
      "name": "localias"
    }
  ],
  "install_guidance": {
    "plugin": "localias",
    "binary": "localias",
    "check": "which localias",
    "install_steps": [
      "go install github.com/peterldowns/localias@latest",
      "Verify: localias --version",
      "supercli plugins install ./plugins/localias --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "localias",
      "resource": "self",
      "action": "version",
      "description": "Print localias version",
      "adapter": "process",
      "adapterConfig": {
        "command": "localias",
        "missingDependencyHelp": "Install localias: go install github.com/peterldowns/localias@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "localias",
      "resource": "alias",
      "action": "list",
      "description": "list alias via localias",
      "adapter": "process",
      "adapterConfig": {
        "command": "localias",
        "missingDependencyHelp": "Install localias: go install github.com/peterldowns/localias@latest",
        "baseArgs": [
          "list"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "localias",
      "resource": "alias",
      "action": "add",
      "description": "add alias via localias",
      "adapter": "process",
      "adapterConfig": {
        "command": "localias",
        "missingDependencyHelp": "Install localias: go install github.com/peterldowns/localias@latest",
        "baseArgs": [
          "add"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "localias",
      "resource": "_",
      "action": "_",
      "description": "_ _ via localias",
      "adapter": "process",
      "adapterConfig": {
        "command": "localias",
        "missingDependencyHelp": "Install localias: go install github.com/peterldowns/localias@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}