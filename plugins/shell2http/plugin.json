{
  "name": "shell2http",
  "version": "0.1.0",
  "description": "Executing shell commands via HTTP server. Expose any shell command as an HTTP endpoint for easy integration and automation.",
  "source": "https://github.com/msoap/shell2http",
  "checks": [
    { "type": "binary", "name": "shell2http" }
  ],
  "install_guidance": {
    "plugin": "shell2http",
    "binary": "shell2http",
    "check": "which shell2http",
    "install_steps": [
      "brew install shell2http",
      "Verify: shell2http --version",
      "supercli plugins install ./plugins/shell2http --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "shell2http",
      "resource": "server",
      "action": "start",
      "description": "Start HTTP server for shell commands",
      "adapter": "process",
      "adapterConfig": {
        "command": "shell2http",
        "baseArgs": [],
        "passthrough": true,
        "missingDependencyHelp": "Install shell2http: brew install shell2http"
      },
      "args": [
        { "name": "--port", "type": "integer", "description": "Server port" },
        { "name": "--host", "type": "string", "description": "Server host" },
        { "name": "--timeout", "type": "integer", "description": "Command timeout in seconds" },
        { "name": "--no-index", "type": "boolean", "description": "Disable index page" }
      ]
    },
    {
      "namespace": "shell2http",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to shell2http CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "shell2http",
        "passthrough": true,
        "missingDependencyHelp": "Install shell2http: brew install shell2http"
      },
      "args": []
    }
  ]
}
