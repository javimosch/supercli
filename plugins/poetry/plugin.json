{
  "name": "poetry",
  "version": "0.1.0",
  "description": "Poetry CLI plugin for dcli",
  "source": "https://python-poetry.org/docs/cli/",
  "checks": [
    {
      "type": "binary",
      "name": "poetry"
    }
  ],
  "commands": [
    {
      "namespace": "poetry",
      "resource": "cli",
      "action": "version",
      "description": "Show Poetry CLI version",
      "adapter": "process",
      "adapterConfig": {
        "command": "poetry",
        "baseArgs": ["--version"],
        "parseJson": false,
        "missingDependencyHelp": "Please install Poetry to use this command."
      },
      "args": []
    },
    {
      "namespace": "poetry",
      "resource": "_",
      "action": "_",
      "description": "Passthrough command to execute any Poetry CLI command",
      "adapter": "process",
      "adapterConfig": {
        "command": "poetry",
        "passthrough": true,
        "parseJson": true,
        "missingDependencyHelp": "Please install Poetry to use this command."
      },
      "args": []
    }
  ]
}
