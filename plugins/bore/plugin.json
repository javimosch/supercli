{
  "name": "bore",
  "version": "0.1.0",
  "description": "Simple CLI tool for making tunnels to localhost",
  "source": "https://github.com/ekzhang/bore",
  "checks": [
    {
      "type": "binary",
      "name": "bore"
    }
  ],
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "bore",
      "resource": "local",
      "action": "expose",
      "description": "Expose local port to remote server",
      "adapter": "process",
      "adapterConfig": {
        "command": "bore",
        "baseArgs": [
          "local"
        ],
        "passthrough": true
      },
      "args": [
        {
          "name": "port",
          "type": "integer",
          "required": true,
          "description": "Local port to expose"
        },
        {
          "name": "--to",
          "type": "string",
          "description": "Bore server address"
        }
      ]
    },
    {
      "namespace": "bore",
      "resource": "server",
      "action": "start",
      "description": "Start bore server",
      "adapter": "process",
      "adapterConfig": {
        "command": "bore",
        "baseArgs": [
          "server"
        ],
        "passthrough": true
      },
      "args": [
        {
          "name": "--min-port",
          "type": "integer",
          "description": "Minimum accepted port"
        }
      ]
    }
  ]
}