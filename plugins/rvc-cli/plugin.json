      "namespace": "rvc-cli",
      "resource": "self",
      "action": "version",
      "description": "Print rvc-cli version",
      "adapter": "process",
      "adapterConfig": {
        "command": "rvc-cli",
        "missingDependencyHelp": "Install rvc-cli: pip install rvc-cli",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "rvc-cli",
      "resource": "voice",
      "action": "clone",
      "description": "clone voice via rvc-cli",
      "adapter": "process",
      "adapterConfig": {
        "command": "rvc-cli",
        "missingDependencyHelp": "Install rvc-cli: pip install rvc-cli",
        "baseArgs": [
          "clone"
        ],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
