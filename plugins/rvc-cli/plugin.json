{
  "name": "rvc-cli",
  "version": "0.1.0",
  "description": "RVC and UVR tools for voice cloning easily and free",
  "source": "https://github.com/blaisewf/rvc-cli",
  "checks": [
    {
      "type": "binary",
      "name": "rvc-cli"
    }
  ],
  "install_guidance": {
    "plugin": "rvc-cli",
    "binary": "rvc-cli",
    "check": "which rvc-cli",
    "install_steps": [
      "pip install rvc-cli",
      "Verify: rvc-cli --version",
      "supercli plugins install ./plugins/rvc-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
