{
  "name": "graphqlviz",
  "version": "0.1.0",
  "description": "Visualize GraphQL schemas as Graphviz graphs",
  "source": "https://github.com/sheerun/graphqlviz",
  "checks": [
    {
      "type": "binary",
      "name": "graphqlviz"
    }
  ],
  "install_guidance": {
    "plugin": "graphqlviz",
    "binary": "graphqlviz",
    "check": "which graphqlviz",
    "install_steps": [
      "npm install -g graphqlviz",
      "Verify: graphqlviz --version",
      "supercli plugins install ./plugins/graphqlviz --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "graphqlviz",
      "resource": "self",
      "action": "version",
      "description": "Print graphqlviz version",
      "adapter": "process",
      "adapterConfig": {
        "command": "graphqlviz",
        "missingDependencyHelp": "Install graphqlviz: npm install -g graphqlviz",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "graphqlviz",
      "resource": "schema",
      "action": "visualize",
      "description": "visualize schema via graphqlviz",
      "adapter": "process",
      "adapterConfig": {
        "command": "graphqlviz",
        "missingDependencyHelp": "Install graphqlviz: npm install -g graphqlviz",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "graphqlviz",
      "resource": "_",
      "action": "_",
      "description": "_ _ via graphqlviz",
      "adapter": "process",
      "adapterConfig": {
        "command": "graphqlviz",
        "missingDependencyHelp": "Install graphqlviz: npm install -g graphqlviz",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}