{
  "name": "vfox",
  "version": "0.1.0",
  "description": "Cross-platform and extendable version manager with support for Java, Node.js, Golang, Python, Flutter, .NET and more. Manage multiple runtime versions easily.",
  "source": "https://github.com/version-fox/vfox",
  "checks": [
    { "type": "binary", "name": "vfox" }
  ],
  "install_guidance": {
    "plugin": "vfox",
    "binary": "vfox",
    "check": "which vfox",
    "install_steps": [
      "brew install vfox",
      "Verify: vfox --version",
      "supercli plugins install ./plugins/vfox --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "vfox",
      "resource": "version",
      "action": "install",
      "description": "Install runtime version",
      "adapter": "process",
      "adapterConfig": {
        "command": "vfox",
        "passthrough": true,
        "missingDependencyHelp": "Install vfox: brew install vfox"
      },
      "args": [
        { "name": "runtime", "type": "string", "description": "Runtime name (java, node, golang, python)" },
        { "name": "version", "type": "string", "description": "Version to install" },
        { "name": "--global", "type": "boolean", "description": "Install globally" }
      ]
    },
    {
      "namespace": "vfox",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to vfox CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "vfox",
        "passthrough": true,
        "missingDependencyHelp": "Install vfox: brew install vfox"
      },
      "args": []
    }
  ]
}
