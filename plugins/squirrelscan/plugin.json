{
  "name": "squirrelscan",
  "version": "0.2.0",
  "description": "SquirrelScan Docker plugin with structured CLI wrappers and passthrough",
  "source": "https://docs.squirrelscan.com/cli",
  "checks": [{ "type": "binary", "name": "node" }, { "type": "binary", "name": "docker" }],
  "install_guidance": { "plugin": "squirrelscan", "binary": "docker", "check": "docker --version", "install_steps": ["docker --version", "supercli plugins install squirrelscan", "supercli squirrel audit https://example.com -C quick"], "note": "Builds a pinned local Docker image on first run; subsequent runs reuse image layers and cache volumes." },
  "learn": { "file": "skills/quickstart/SKILL.md" },
  "post_install": { "script": "scripts/post-install.js", "runtime": "node", "timeout_ms": 15000 },
  "post_uninstall": { "script": "scripts/post-uninstall.js", "runtime": "node", "timeout_ms": 15000 },
  "commands": [
    {
      "namespace": "squirrel",
      "resource": "audit",
      "action": "run",
      "description": "Run website audit (crawl and analyze)",
      "adapter": "process",
      "adapterConfig": {
        "command": "node",
        "cwd": "plugin_dir",
        "baseArgs": ["scripts/run-squirrel.js", "audit"],
        "positionalArgs": ["url"],
        "parseJson": false,
        "timeout_ms": 180000,
        "missingDependencyHelp": "Install Docker and run: docker --version"
      },
      "args": [
        { "name": "url", "type": "string", "required": true },
        { "name": "max-pages", "type": "integer", "required": false },
        { "name": "coverage", "type": "string", "required": false },
        { "name": "format", "type": "string", "required": false },
        { "name": "output", "type": "string", "required": false },
        { "name": "refresh", "type": "boolean", "required": false },
        { "name": "resume", "type": "boolean", "required": false },
        { "name": "verbose", "type": "boolean", "required": false },
        { "name": "debug", "type": "boolean", "required": false },
        { "name": "trace", "type": "boolean", "required": false },
        { "name": "project-name", "type": "string", "required": false },
        { "name": "publish", "type": "boolean", "required": false },
        { "name": "visibility", "type": "string", "required": false },
        { "name": "config-file", "type": "string", "required": false }
      ]
    },
