{
  "name": "domain-cli",
  "version": "0.1.0",
  "description": "CLI tool for WHOIS and domain information lookup",
  "source": "https://github.com/WeiChiaChang/domain-cli",
  "checks": [
    {
      "type": "binary",
      "name": "domain"
    }
  ],
  "install_guidance": {
    "plugin": "domain-cli",
    "binary": "domain",
    "check": "which domain",
    "install_steps": [
      "npm install -g domain-cli",
      "Verify: domain --version",
      "supercli plugins install ./plugins/domain-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "domain-cli",
      "resource": "self",
      "action": "version",
      "description": "Print domain-cli version",
      "adapter": "process",
      "adapterConfig": {
        "command": "domain",
        "missingDependencyHelp": "Install domain-cli: npm install -g domain-cli",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "domain-cli",
      "resource": "domain",
      "action": "lookup",
      "description": "lookup domain via domain",
      "adapter": "process",
      "adapterConfig": {
        "command": "domain",
        "missingDependencyHelp": "Install domain-cli: npm install -g domain-cli",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "domain-cli",
      "resource": "_",
      "action": "_",
      "description": "_ _ via domain",
      "adapter": "process",
      "adapterConfig": {
        "command": "domain",
        "missingDependencyHelp": "Install domain-cli: npm install -g domain-cli",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}