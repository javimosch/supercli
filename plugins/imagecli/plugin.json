  "install_guidance": {
    "plugin": "imagecli",
    "binary": "imagecli",
    "check": "which imagecli",
    "install_steps": [
      "cargo install imagecli",
      "Verify: imagecli --version",
      "supercli plugins install ./plugins/imagecli --on-conflict replace --json"
