{
  "plugin": "diesel-guard",
  "binary": "diesel-guard",
  "check": "which diesel-guard",
  "install_steps": [
    "cargo install diesel-guard",
    "Verify: diesel-guard --version",
    "supercli plugins install ./plugins/diesel-guard --on-conflict replace --json"
  ],
  "note": "Also available via Homebrew: brew install ayarotsky/tap/diesel-guard"
}
