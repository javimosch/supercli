{
  "name": "diesel-guard",
  "version": "0.1.0",
  "description": "Linter for dangerous Postgres migration patterns in Diesel and SQLx — prevents downtime",
  "source": "https://github.com/ayarotsky/diesel-guard",
  "checks": [
    { "type": "binary", "name": "diesel-guard" }
  ],
  "install_guidance": {
    "plugin": "diesel-guard",
    "binary": "diesel-guard",
    "check": "which diesel-guard",
    "install_steps": [
      "cargo install diesel-guard",
      "Verify: diesel-guard --version",
      "supercli plugins install ./plugins/diesel-guard --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "diesel-guard",
      "resource": "self",
      "action": "version",
      "description": "Print diesel-guard version",
      "adapter": "process",
      "adapterConfig": {
        "command": "diesel-guard",
        "baseArgs": ["--version"],
        "missingDependencyHelp": "Install diesel-guard: cargo install diesel-guard"
      },
      "args": []
    },
    {
      "namespace": "diesel-guard",
      "resource": "migration",
      "action": "check",
      "description": "Check migrations for unsafe patterns",
      "adapter": "process",
      "adapterConfig": {
        "command": "diesel-guard",
        "baseArgs": ["check"],
        "passthrough": true,
        "timeout_ms": 30000,
        "missingDependencyHelp": "Install diesel-guard"
      },
      "args": []
    },
    {
      "namespace": "diesel-guard",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to diesel-guard CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "diesel-guard",
        "passthrough": true,
        "missingDependencyHelp": "Install diesel-guard"
      },
      "args": []
    }
  ]
}
