{
  "name": "filesize-cli",
  "version": "0.1.0",
  "description": "Calculate and display file sizes",
  "source": "https://www.npmjs.com/package/filesize-cli",
  "checks": [
    { "type": "binary", "name": "filesize" }
  ],
  "install_guidance": {
    "plugin": "filesize-cli",
    "binary": "filesize",
    "check": "which filesize",
    "install_steps": [
      "npm install -g filesize-cli",
      "Verify: filesize --help",
      "supercli plugins install ./plugins/filesize-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "filesize-cli",
      "resource": "file",
      "action": "size",
      "description": "Get file size",
      "adapter": "process",
      "adapterConfig": {
        "command": "filesize",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 60000,
        "missingDependencyHelp": "Install filesize-cli: npm install -g filesize-cli"
      },
      "args": [
        { "name": "file", "type": "string", "required": true, "description": "File to check" },
        { "name": "human", "type": "boolean", "required": false, "description": "Human readable format" }
      ]
    },
    {
      "namespace": "filesize-cli",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to filesize CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "filesize",
        "passthrough": true,
        "missingDependencyHelp": "Install filesize-cli: npm install -g filesize-cli"
      },
      "args": []
    }
  ]
}
