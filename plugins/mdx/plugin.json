{
  "name": "mdx",
  "version": "0.1.0",
  "description": "Markdown processing and transformation tool",
  "source": "https://github.com/arimatakao/mdx",
  "checks": [
    {
      "type": "binary",
      "name": "mdx"
    }
  ],
  "install_guidance": {
    "plugin": "mdx",
    "binary": "mdx",
    "check": "which mdx",
    "install_steps": [
      "go install github.com/arimatakao/mdx@latest",
      "Verify: mdx --version",
      "supercli plugins install ./plugins/mdx --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "mdx",
      "resource": "self",
      "action": "version",
      "description": "Print mdx version",
      "adapter": "process",
      "adapterConfig": {
        "command": "mdx",
        "missingDependencyHelp": "Install mdx: go install github.com/arimatakao/mdx@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "mdx",
      "resource": "file",
      "action": "process",
      "description": "process file via mdx",
      "adapter": "process",
      "adapterConfig": {
        "command": "mdx",
        "missingDependencyHelp": "Install mdx: go install github.com/arimatakao/mdx@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "mdx",
      "resource": "_",
      "action": "_",
      "description": "_ _ via mdx",
      "adapter": "process",
      "adapterConfig": {
        "command": "mdx",
        "missingDependencyHelp": "Install mdx: go install github.com/arimatakao/mdx@latest",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}