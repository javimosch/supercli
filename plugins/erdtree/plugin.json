{
  "name": "erdtree",
  "version": "0.1.0",
  "description": "A modern, multi-threaded file tree visualizer and disk usage analyzer. A prettier and faster tree command with icons, colors, and disk usage information.",
  "source": "https://github.com/solidiquis/erdtree",
  "checks": [
    { "type": "binary", "name": "erdtree" }
  ],
  "install_guidance": {
    "plugin": "erdtree",
    "binary": "erdtree",
    "check": "which erdtree",
    "install_steps": [
      "brew install erdtree",
      "Verify: erdtree --version",
      "supercli plugins install ./plugins/erdtree --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "erdtree",
      "resource": "tree",
      "action": "show",
      "description": "Display file tree with disk usage",
      "adapter": "process",
      "adapterConfig": {
        "command": "erdtree",
        "passthrough": true,
        "missingDependencyHelp": "Install erdtree: brew install erdtree"
      },
      "args": [
        { "name": "path", "type": "string", "description": "Directory path" },
        { "name": "--level", "type": "integer", "description": "Maximum depth level" },
        { "name": "--human-readable", "type": "boolean", "description": "Human-readable sizes" },
        { "name": "--icons", "type": "boolean", "description": "Show file icons" },
        { "name": "--prune", "type": "boolean", "description": "Prune empty directories" }
      ]
    },
    {
      "namespace": "erdtree",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to erdtree CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "erdtree",
        "passthrough": true,
        "missingDependencyHelp": "Install erdtree: brew install erdtree"
      },
      "args": []
    }
  ]
}
