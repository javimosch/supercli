{
  "name": "tsk",
  "version": "0.1.0",
  "description": "Simple todo list manager for the terminal",
  "source": "https://github.com/kakengloh/tsk",
  "checks": [
    {
      "type": "binary",
      "name": "tsk"
    }
  ],
  "install_guidance": {
    "plugin": "tsk",
    "binary": "tsk",
    "check": "which tsk",
    "install_steps": [
      "go install github.com/kakengloh/tsk@latest",
      "Verify: tsk --version",
      "supercli plugins install ./plugins/tsk --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "tsk",
      "resource": "self",
      "action": "version",
      "description": "Print tsk version",
      "adapter": "process",
      "adapterConfig": {
        "command": "tsk",
        "missingDependencyHelp": "Install tsk: go install github.com/kakengloh/tsk@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "tsk",
      "resource": "task",
      "action": "add",
      "description": "add task via tsk",
      "adapter": "process",
      "adapterConfig": {
        "command": "tsk",
        "missingDependencyHelp": "Install tsk: go install github.com/kakengloh/tsk@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "tsk",
      "resource": "task",
      "action": "list",
      "description": "list task via tsk",
      "adapter": "process",
      "adapterConfig": {
        "command": "tsk",
        "missingDependencyHelp": "Install tsk: go install github.com/kakengloh/tsk@latest",
        "baseArgs": [
          "list"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "tsk",
      "resource": "task",
      "action": "done",
      "description": "done task via tsk",
      "adapter": "process",
      "adapterConfig": {
        "command": "tsk",
        "missingDependencyHelp": "Install tsk: go install github.com/kakengloh/tsk@latest",
        "baseArgs": [
          "done"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "tsk",
      "resource": "_",
      "action": "_",
      "description": "_ _ via tsk",
      "adapter": "process",
      "adapterConfig": {
        "command": "tsk",
        "missingDependencyHelp": "Install tsk: go install github.com/kakengloh/tsk@latest",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}