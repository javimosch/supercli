{
  "name": "yatas",
  "version": "0.1.0",
  "description": "Audit AWS and GCP infrastructure for misconfiguration and security issues",
  "source": "https://github.com/padok-team/yatas",
  "checks": [
    {
      "type": "binary",
      "name": "yatas"
    }
  ],
  "install_guidance": {
    "plugin": "yatas",
    "binary": "yatas",
    "check": "which yatas",
    "install_steps": [
      "go install github.com/padok-team/yatas@latest",
      "Verify: yatas --version",
      "supercli plugins install ./plugins/yatas --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
