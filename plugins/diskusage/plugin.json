{
  "name": "diskusage",
  "version": "0.1.0",
  "description": "Show disk usage in terminal with visual charts",
  "source": "https://github.com/chenquan/diskusage",
  "checks": [
    {
      "type": "binary",
      "name": "diskusage"
    }
  ],
  "install_guidance": {
    "plugin": "diskusage",
    "binary": "diskusage",
    "check": "which diskusage",
    "install_steps": [
      "go install github.com/chenquan/diskusage@latest",
      "Verify: diskusage --version",
      "supercli plugins install ./plugins/diskusage --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "diskusage",
      "resource": "self",
      "action": "version",
      "description": "Print diskusage version",
      "adapter": "process",
      "adapterConfig": {
        "command": "diskusage",
        "missingDependencyHelp": "Install diskusage: go install github.com/chenquan/diskusage@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "diskusage",
      "resource": "path",
      "action": "analyze",
      "description": "analyze path via diskusage",
      "adapter": "process",
      "adapterConfig": {
        "command": "diskusage",
        "missingDependencyHelp": "Install diskusage: go install github.com/chenquan/diskusage@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "diskusage",
      "resource": "tree",
      "action": "show",
      "description": "show tree via diskusage",
      "adapter": "process",
      "adapterConfig": {
        "command": "diskusage",
        "missingDependencyHelp": "Install diskusage: go install github.com/chenquan/diskusage@latest",
        "baseArgs": [
          "--tree"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "diskusage",
      "resource": "_",
      "action": "_",
      "description": "_ _ via diskusage",
      "adapter": "process",
      "adapterConfig": {
        "command": "diskusage",
        "missingDependencyHelp": "Install diskusage: go install github.com/chenquan/diskusage@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}