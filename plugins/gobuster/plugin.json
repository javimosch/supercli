{
  "name": "gobuster",
  "version": "0.1.0",
  "description": "Directory/File, DNS and VHost busting tool written in Go",
  "source": "https://github.com/OJ/gobuster",
  "checks": [
    {
      "type": "binary",
      "name": "gobuster"
    }
  ],
  "install_guidance": {
    "plugin": "gobuster",
    "binary": "gobuster",
    "check": "which gobuster",
    "install_steps": [
      "go install github.com/OJ/gobuster/v3@latest",
      "Verify: gobuster --version",
      "supercli plugins install ./plugins/gobuster --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "gobuster",
      "resource": "self",
      "action": "version",
      "description": "Print gobuster version",
      "adapter": "process",
      "adapterConfig": {
        "command": "gobuster",
        "missingDependencyHelp": "Install gobuster: go install github.com/OJ/gobuster/v3@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "gobuster",
      "resource": "dir",
      "action": "scan",
      "description": "scan dir via gobuster",
      "adapter": "process",
      "adapterConfig": {
        "command": "gobuster",
        "missingDependencyHelp": "Install gobuster: go install github.com/OJ/gobuster/v3@latest",
        "baseArgs": [
          "dir"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "gobuster",
      "resource": "dns",
      "action": "scan",
      "description": "scan dns via gobuster",
      "adapter": "process",
      "adapterConfig": {
        "command": "gobuster",
        "missingDependencyHelp": "Install gobuster: go install github.com/OJ/gobuster/v3@latest",
        "baseArgs": [
          "dns"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "gobuster",
      "resource": "vhost",
      "action": "scan",
      "description": "scan vhost via gobuster",
      "adapter": "process",
      "adapterConfig": {
        "command": "gobuster",
        "missingDependencyHelp": "Install gobuster: go install github.com/OJ/gobuster/v3@latest",
        "baseArgs": [
          "vhost"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "gobuster",
      "resource": "_",
      "action": "_",
      "description": "_ _ via gobuster",
      "adapter": "process",
      "adapterConfig": {
        "command": "gobuster",
        "missingDependencyHelp": "Install gobuster: go install github.com/OJ/gobuster/v3@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}