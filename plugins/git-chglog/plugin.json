{
  "name": "git-chglog",
  "version": "0.1.0",
  "description": "Changelog generator from git history",
  "source": "https://github.com/git-chglog/git-chglog",
  "checks": [
    {
      "type": "binary",
      "name": "git-chglog"
    }
  ],
  "install_guidance": {
    "plugin": "git-chglog",
    "binary": "git-chglog",
    "check": "which git-chglog",
    "install_steps": [
      "go install github.com/git-chglog/git-chglog/cmd/git-chglog@latest",
      "Verify: git-chglog --version",
      "supercli plugins install ./plugins/git-chglog --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "git-chglog",
      "resource": "self",
      "action": "version",
      "description": "Print git-chglog version",
      "adapter": "process",
      "adapterConfig": {
        "command": "git-chglog",
        "missingDependencyHelp": "Install git-chglog: go install github.com/git-chglog/git-chglog/cmd/git-chglog@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "git-chglog",
      "resource": "changelog",
      "action": "generate",
      "description": "generate changelog via git-chglog",
      "adapter": "process",
      "adapterConfig": {
        "command": "git-chglog",
        "missingDependencyHelp": "Install git-chglog: go install github.com/git-chglog/git-chglog/cmd/git-chglog@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "git-chglog",
      "resource": "_",
      "action": "_",
      "description": "_ _ via git-chglog",
      "adapter": "process",
      "adapterConfig": {
        "command": "git-chglog",
        "missingDependencyHelp": "Install git-chglog: go install github.com/git-chglog/git-chglog/cmd/git-chglog@latest",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}