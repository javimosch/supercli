{
  "name": "tldr",
  "version": "0.1.0",
  "description": "Simplified and community-driven man pages",
  "source": "https://github.com/tldr-pages/tldr-node-client",
  "checks": [
    {
      "type": "binary",
      "name": "tldr"
    }
  ],
  "install_guidance": {
    "plugin": "tldr",
    "binary": "tldr",
    "check": "which tldr",
    "install_steps": [
      "npm install -g tldr",
      "Verify: tldr --version",
      "supercli plugins install ./plugins/tldr --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "tldr",
      "resource": "self",
      "action": "version",
      "description": "Print tldr version",
      "adapter": "process",
      "adapterConfig": {
        "command": "tldr",
        "missingDependencyHelp": "Install tldr: npm install -g tldr",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "tldr",
      "resource": "page",
      "action": "show",
      "description": "show page via tldr",
      "adapter": "process",
      "adapterConfig": {
        "command": "tldr",
        "missingDependencyHelp": "Install tldr: npm install -g tldr",
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "tldr",
      "resource": "_",
      "action": "_",
      "description": "_ _ via tldr",
      "adapter": "process",
      "adapterConfig": {
        "command": "tldr",
        "missingDependencyHelp": "Install tldr: npm install -g tldr",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}