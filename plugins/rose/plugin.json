{
  "name": "rose",
  "version": "0.1.0",
  "description": "Command line tool for managing and viewing rose projects",
  "source": "https://github.com/rose-pine/rose",
  "checks": [
    {
      "type": "binary",
      "name": "rose"
    }
  ],
  "install_guidance": {
    "plugin": "rose",
    "binary": "rose",
    "check": "which rose",
    "install_steps": [
      "go install github.com/rose-pine/rose@latest",
      "Verify: rose --version",
      "supercli plugins install ./plugins/rose --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "rose",
      "resource": "self",
      "action": "version",
      "description": "Print rose version",
      "adapter": "process",
      "adapterConfig": {
        "command": "rose",
        "missingDependencyHelp": "Install rose: go install github.com/rose-pine/rose@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "rose",
      "resource": "theme",
      "action": "apply",
      "description": "apply theme via rose",
      "adapter": "process",
      "adapterConfig": {
        "command": "rose",
        "missingDependencyHelp": "Install rose: go install github.com/rose-pine/rose@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "rose",
      "resource": "theme",
      "action": "list",
      "description": "list theme via rose",
      "adapter": "process",
      "adapterConfig": {
        "command": "rose",
        "missingDependencyHelp": "Install rose: go install github.com/rose-pine/rose@latest",
        "baseArgs": [
          "--list"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "rose",
      "resource": "_",
      "action": "_",
      "description": "_ _ via rose",
      "adapter": "process",
      "adapterConfig": {
        "command": "rose",
        "missingDependencyHelp": "Install rose: go install github.com/rose-pine/rose@latest",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}