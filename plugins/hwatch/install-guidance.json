{
  "plugin": "hwatch",
  "binary": "hwatch",
  "check": "which hwatch",
  "install_steps": [
    "cargo install hwatch",
    "Verify: hwatch --version",
    "supercli plugins install ./plugins/hwatch --on-conflict replace --json"
  ],
  "note": "Also available via: brew, pacman, nix. Use --batch flag for headless mode."
}
