{
  "name": "hygen",
  "version": "0.1.0",
  "description": "Fast, scalable code generator that lives in your project",
  "source": "https://github.com/jondot/hygen",
  "checks": [
    {
      "type": "binary",
      "name": "hygen"
    }
  ],
  "install_guidance": {
    "plugin": "hygen",
    "binary": "hygen",
    "check": "which hygen",
    "install_steps": [
      "npm install -g hygen",
      "Verify: hygen --version",
      "supercli plugins install ./plugins/hygen --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "hygen",
      "resource": "self",
      "action": "version",
      "description": "Print hygen version",
      "adapter": "process",
      "adapterConfig": {
        "command": "hygen",
        "missingDependencyHelp": "Install hygen: npm install -g hygen",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "hygen",
      "resource": "generator",
      "action": "run",
      "description": "run generator via hygen",
      "adapter": "process",
      "adapterConfig": {
        "command": "hygen",
        "missingDependencyHelp": "Install hygen: npm install -g hygen",
        "baseArgs": [
          "generator"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "hygen",
      "resource": "_",
      "action": "_",
      "description": "_ _ via hygen",
      "adapter": "process",
      "adapterConfig": {
        "command": "hygen",
        "missingDependencyHelp": "Install hygen: npm install -g hygen",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}