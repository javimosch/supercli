{
  "name": "fil",
  "version": "0.1.0",
  "description": "Fast and simple file search tool",
  "source": "https://github.com/file-go/fil",
  "checks": [
    {
      "type": "binary",
      "name": "fil"
    }
  ],
  "install_guidance": {
    "plugin": "fil",
    "binary": "fil",
    "check": "which fil",
    "install_steps": [
      "go install github.com/file-go/fil@latest",
      "Verify: fil --version",
      "supercli plugins install ./plugins/fil --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "fil",
      "resource": "self",
      "action": "version",
      "description": "Print fil version",
      "adapter": "process",
      "adapterConfig": {
        "command": "fil",
        "missingDependencyHelp": "Install fil: go install github.com/file-go/fil@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "fil",
      "resource": "file",
      "action": "find",
      "description": "find file via fil",
      "adapter": "process",
      "adapterConfig": {
        "command": "fil",
        "missingDependencyHelp": "Install fil: go install github.com/file-go/fil@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "fil",
      "resource": "directory",
      "action": "list",
      "description": "list directory via fil",
      "adapter": "process",
      "adapterConfig": {
        "command": "fil",
        "missingDependencyHelp": "Install fil: go install github.com/file-go/fil@latest",
        "baseArgs": [
          "--list"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "fil",
      "resource": "_",
      "action": "_",
      "description": "_ _ via fil",
      "adapter": "process",
      "adapterConfig": {
        "command": "fil",
        "missingDependencyHelp": "Install fil: go install github.com/file-go/fil@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}