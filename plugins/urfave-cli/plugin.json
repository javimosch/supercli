{
  "name": "urfave-cli",
  "version": "0.1.0",
  "description": "A command-line interface framework for Go. Build powerful CLI applications with flags, subcommands, and help text generation.",
  "source": "https://github.com/urfave/cli",
  "checks": [
    { "type": "binary", "name": "urfave-cli" }
  ],
  "install_guidance": {
    "plugin": "urfave-cli",
    "binary": "urfave-cli",
    "check": "which urfave-cli",
    "install_steps": [
      "brew install urfave-cli",
      "Verify: urfave-cli --version",
      "supercli plugins install ./plugins/urfave-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "urfave-cli",
      "resource": "project",
      "action": "init",
      "description": "Initialize new CLI project",
      "adapter": "process",
      "adapterConfig": {
        "command": "urfave-cli",
        "baseArgs": ["init"],
        "passthrough": true,
        "missingDependencyHelp": "Install urfave-cli: brew install urfave-cli"
      },
      "args": [
        { "name": "name", "type": "string", "description": "Project name" },
        { "name": "--module", "type": "string", "description": "Go module name" }
      ]
    },
    {
      "namespace": "urfave-cli",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to urfave-cli CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "urfave-cli",
        "passthrough": true,
        "missingDependencyHelp": "Install urfave-cli: brew install urfave-cli"
      },
      "args": []
    }
  ]
}
