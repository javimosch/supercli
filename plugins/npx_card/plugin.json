{
  "name": "npx_card",
  "version": "0.1.0",
  "description": "Display your npm card in terminal",
  "source": "https://github.com/anmol098/npx_card",
  "checks": [
    {
      "type": "binary",
      "name": "npx-card"
    }
  ],
  "install_guidance": {
    "plugin": "npx_card",
    "binary": "npx-card",
    "check": "which npx-card",
    "install_steps": [
      "npx anmol098",
      "Verify: npx-card --version",
      "supercli plugins install ./plugins/npx_card --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "npx_card",
      "resource": "self",
      "action": "version",
      "description": "Print npx_card version",
      "adapter": "process",
      "adapterConfig": {
        "command": "npx-card",
        "missingDependencyHelp": "Install npx_card: npx anmol098",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "npx_card",
      "resource": "card",
      "action": "display",
      "description": "display card via npx-card",
      "adapter": "process",
      "adapterConfig": {
        "command": "npx-card",
        "missingDependencyHelp": "Install npx_card: npx anmol098",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "npx_card",
      "resource": "_",
      "action": "_",
      "description": "_ _ via npx-card",
      "adapter": "process",
      "adapterConfig": {
        "command": "npx-card",
        "missingDependencyHelp": "Install npx_card: npx anmol098",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}