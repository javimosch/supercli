{
  "name": "skaffold",
  "version": "0.1.0",
  "description": "Easy and Repeatable Kubernetes Development",
  "source": "https://github.com/GoogleContainerTools/skaffold",
  "checks": [
    {
      "type": "binary",
      "name": "skaffold"
    }
  ],
  "install_guidance": {
    "plugin": "skaffold",
    "binary": "skaffold",
    "check": "which skaffold",
    "install_steps": [
      "brew install skaffold",
      "Verify: skaffold --version",
      "supercli plugins install ./plugins/skaffold --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "skaffold",
      "resource": "self",
      "action": "version",
      "description": "Print skaffold version",
      "adapter": "process",
      "adapterConfig": {
        "command": "skaffold",
        "missingDependencyHelp": "Install skaffold: brew install skaffold",
        "baseArgs": [
          "version"
        ]
      },
      "args": []
    },
    {
      "namespace": "skaffold",
      "resource": "dev",
      "action": "run",
      "description": "run dev via skaffold",
      "adapter": "process",
      "adapterConfig": {
        "command": "skaffold",
        "missingDependencyHelp": "Install skaffold: brew install skaffold",
        "baseArgs": [
          "dev"
        ],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "skaffold",
      "resource": "build",
      "action": "run",
      "description": "run build via skaffold",
      "adapter": "process",
      "adapterConfig": {
        "command": "skaffold",
        "missingDependencyHelp": "Install skaffold: brew install skaffold",
        "baseArgs": [
          "build"
        ],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "skaffold",
      "resource": "_",
      "action": "_",
      "description": "_ _ via skaffold",
      "adapter": "process",
      "adapterConfig": {
        "command": "skaffold",
        "missingDependencyHelp": "Install skaffold: brew install skaffold",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}