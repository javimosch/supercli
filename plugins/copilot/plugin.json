{
  "name": "copilot",
  "version": "0.1.0",
  "description": "GitHub Copilot CLI plugin with programmatic wrappers and passthrough",
  "source": "https://docs.github.com/copilot/how-tos/copilot-cli/cli-getting-started",
  "checks": [
    { "type": "binary", "name": "copilot" }
  ],
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "copilot",
      "resource": "cli",
      "action": "version",
      "description": "Show installed Copilot CLI version",
      "adapter": "process",
      "adapterConfig": {
        "command": "copilot",
        "baseArgs": ["--version"],
        "parseJson": false,
        "missingDependencyHelp": "Install with: npm install -g @github/copilot"
      },
      "args": []
    },
    {
      "namespace": "copilot",
      "resource": "task",
      "action": "ask",
      "description": "Run a programmatic Copilot prompt and return text-only response",
      "adapter": "process",
      "adapterConfig": {
        "command": "copilot",
        "baseArgs": [],
        "parseJson": false,
        "timeout_ms": 180000,
        "missingDependencyHelp": "Install with: npm install -g @github/copilot"
      },
      "args": [
        { "name": "prompt", "type": "string", "required": true, "description": "Prompt to run in programmatic mode" },
        { "name": "model", "type": "string", "required": false, "description": "Model id (optional)" }
      ]
    },
    {
      "namespace": "copilot",
      "resource": "task",
      "action": "ask-json",
      "description": "Run a programmatic Copilot prompt with non-stream text output",
      "adapter": "process",
      "adapterConfig": {
        "command": "copilot",
        "baseArgs": ["--stream", "off"],
        "parseJson": false,
        "timeout_ms": 180000,
        "missingDependencyHelp": "Install with: npm install -g @github/copilot"
      },
      "args": [
        { "name": "prompt", "type": "string", "required": true, "description": "Prompt to run in programmatic mode" },
        { "name": "model", "type": "string", "required": false, "description": "Model id (optional)" },
        { "name": "agent", "type": "string", "required": false, "description": "Custom agent to use" }
      ]
    },
    {
      "namespace": "copilot",
      "resource": "_",
      "action": "_",
      "description": "Passthrough command to execute any Copilot CLI command",
      "adapter": "process",
      "adapterConfig": {
        "command": "copilot",
        "passthrough": true,
        "parseJson": true,
        "timeout_ms": 180000,
        "missingDependencyHelp": "Install with: npm install -g @github/copilot"
      },
      "args": []
    }
  ]
}
