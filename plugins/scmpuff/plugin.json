{
  "name": "scmpuff",
  "version": "0.1.0",
  "description": "Numeric file selection shortcuts for common git commands",
  "source": "https://github.com/mroth/scmpuff",
  "checks": [
    {
      "type": "binary",
      "name": "scmpuff"
    }
  ],
  "install_guidance": {
    "plugin": "scmpuff",
    "binary": "scmpuff",
    "check": "which scmpuff",
    "install_steps": [
      "brew install scmpuff",
      "Verify: scmpuff --version",
      "supercli plugins install ./plugins/scmpuff --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "scmpuff",
      "resource": "self",
      "action": "version",
      "description": "Print scmpuff version",
      "adapter": "process",
      "adapterConfig": {
        "command": "scmpuff",
        "missingDependencyHelp": "Install scmpuff: brew install scmpuff",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "scmpuff",
      "resource": "status",
      "action": "show",
      "description": "show status via scmpuff",
      "adapter": "process",
      "adapterConfig": {
        "command": "scmpuff",
        "missingDependencyHelp": "Install scmpuff: brew install scmpuff",
        "baseArgs": [
          "status"
        ],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "scmpuff",
      "resource": "cmd",
      "action": "exec",
      "description": "exec cmd via scmpuff",
      "adapter": "process",
      "adapterConfig": {
        "command": "scmpuff",
        "missingDependencyHelp": "Install scmpuff: brew install scmpuff",
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "scmpuff",
      "resource": "_",
      "action": "_",
      "description": "_ _ via scmpuff",
      "adapter": "process",
      "adapterConfig": {
        "command": "scmpuff",
        "missingDependencyHelp": "Install scmpuff: brew install scmpuff",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}