{
  "name": "js-yaml",
  "version": "0.1.0",
  "description": "JavaScript YAML parser and dumper. Parse YAML files to JSON and dump JSON to YAML with CLI support.",
  "source": "https://github.com/nodeca/js-yaml",
  "checks": [
    { "type": "binary", "name": "js-yaml" }
  ],
  "install_guidance": {
    "plugin": "js-yaml",
    "binary": "js-yaml",
    "check": "which js-yaml",
    "install_steps": [
      "npm install -g js-yaml",
      "Verify: js-yaml --version",
      "supercli plugins install ./plugins/js-yaml --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "js-yaml",
      "resource": "parse",
      "action": "yaml",
      "description": "Parse YAML file",
      "adapter": "process",
      "adapterConfig": {
        "command": "js-yaml",
        "passthrough": true,
        "missingDependencyHelp": "Install js-yaml: npm install -g js-yaml"
      },
      "args": [
        { "name": "file", "type": "string", "description": "YAML file to parse" },
        { "name": "-c", "type": "boolean", "description": "Compact mode" }
      ]
    },
    {
      "namespace": "js-yaml",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to js-yaml CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "js-yaml",
        "passthrough": true,
        "missingDependencyHelp": "Install js-yaml: npm install -g js-yaml"
      },
      "args": []
    }
  ]
}
