{
  "plugin": "pv-migrate",
  "binary": "pv-migrate",
  "check": "which pv-migrate",
  "install_steps": [
    "brew install pv-migrate",
    "Verify: pv-migrate --version",
    "supercli plugins install ./plugins/pv-migrate --on-conflict replace --json"
  ],
  "note": "Also available via: direct binary download from GitHub releases, krew (kubectl plugin), or go install."
}
