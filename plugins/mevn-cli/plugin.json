{
  "name": "mevn-cli",
  "version": "0.1.0",
  "description": "CLI tool for the MEVN stack (MongoDB Express Vue Node)",
  "source": "https://github.com/madlabsinc/mevn-cli",
  "checks": [
    {
      "type": "binary",
      "name": "mevn"
    }
  ],
  "install_guidance": {
    "plugin": "mevn-cli",
    "binary": "mevn",
    "check": "which mevn",
    "install_steps": [
      "npm install -g mevn-cli",
      "Verify: mevn --version",
      "supercli plugins install ./plugins/mevn-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "mevn-cli",
      "resource": "self",
      "action": "version",
      "description": "Print mevn-cli version",
      "adapter": "process",
      "adapterConfig": {
        "command": "mevn",
        "missingDependencyHelp": "Install mevn-cli: npm install -g mevn-cli",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "mevn-cli",
      "resource": "project",
      "action": "init",
      "description": "init project via mevn",
      "adapter": "process",
      "adapterConfig": {
        "command": "mevn",
        "missingDependencyHelp": "Install mevn-cli: npm install -g mevn-cli",
        "baseArgs": [
          "init"
        ],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "mevn-cli",
      "resource": "server",
      "action": "create",
      "description": "create server via mevn",
      "adapter": "process",
      "adapterConfig": {
        "command": "mevn",
        "missingDependencyHelp": "Install mevn-cli: npm install -g mevn-cli",
        "baseArgs": [
          "create"
        ],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "mevn-cli",
      "resource": "component",
      "action": "generate",
      "description": "generate component via mevn",
      "adapter": "process",
      "adapterConfig": {
        "command": "mevn",
        "missingDependencyHelp": "Install mevn-cli: npm install -g mevn-cli",
        "baseArgs": [
          "generate"
        ],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "mevn-cli",
      "resource": "_",
      "action": "_",
      "description": "_ _ via mevn",
      "adapter": "process",
      "adapterConfig": {
        "command": "mevn",
        "missingDependencyHelp": "Install mevn-cli: npm install -g mevn-cli",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}