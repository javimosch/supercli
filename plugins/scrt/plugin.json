{
  "name": "scrt",
  "version": "0.1.0",
  "description": "Password manager and secret store CLI tool",
  "source": "https://github.com/loderunner/scrt",
  "checks": [
    {
      "type": "binary",
      "name": "scrt"
    }
  ],
  "install_guidance": {
    "plugin": "scrt",
    "binary": "scrt",
    "check": "which scrt",
    "install_steps": [
      "brew install scrt",
      "Verify: scrt --version",
      "supercli plugins install ./plugins/scrt --on-conflict replace --json"
    ]
  },
