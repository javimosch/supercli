      "description": "Print scrt version",
      "adapter": "process",
      "adapterConfig": {
        "command": "scrt",
        "missingDependencyHelp": "Install scrt: brew install scrt",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
