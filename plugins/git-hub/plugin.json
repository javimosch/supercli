{
  "name": "git-hub",
  "version": "0.1.0",
  "description": "Git command line interface to GitHub for managing repositories and issues",
  "source": "https://github.com/sociomantic-tsunami/git-hub",
  "checks": [
    {
      "type": "binary",
      "name": "git-hub"
    }
  ],
  "install_guidance": {
    "plugin": "git-hub",
    "binary": "git-hub",
    "check": "which git-hub",
    "install_steps": [
      "pip install git-hub",
      "Verify: git-hub --version",
      "supercli plugins install ./plugins/git-hub --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
