      "action": "version",
      "description": "Print git-hub version",
      "adapter": "process",
      "adapterConfig": {
        "command": "git-hub",
        "missingDependencyHelp": "Install git-hub: pip install git-hub",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
