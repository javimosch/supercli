{
  "name": "airflowctl",
  "version": "0.1.0",
  "description": "CLI tool to streamline getting started with Apache Airflow and managing multiple Airflow projects",
  "source": "https://github.com/kaxil/airflowctl",
  "checks": [
    {
      "type": "binary",
      "name": "airflowctl"
    }
  ],
  "install_guidance": {
    "plugin": "airflowctl",
    "binary": "airflowctl",
    "check": "which airflowctl",
    "install_steps": [
      "pip install airflowctl",
      "Verify: airflowctl --version",
      "supercli plugins install ./plugins/airflowctl --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
