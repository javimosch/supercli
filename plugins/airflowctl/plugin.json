      "resource": "self",
      "action": "version",
      "description": "Print airflowctl version",
      "adapter": "process",
      "adapterConfig": {
        "command": "airflowctl",
        "missingDependencyHelp": "Install airflowctl: pip install airflowctl",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "airflowctl",
      "resource": "project",
      "action": "create",
      "description": "create project via airflowctl",
      "adapter": "process",
      "adapterConfig": {
        "command": "airflowctl",
        "missingDependencyHelp": "Install airflowctl: pip install airflowctl",
        "baseArgs": [
          "create"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
