{
  "name": "bitcoin-chart-cli",
  "version": "0.1.0",
  "description": "Display Bitcoin price charts in the terminal",
  "source": "https://github.com/madnight/bitcoin-chart-cli",
  "checks": [
    {
      "type": "binary",
      "name": "bitcoin-chart"
    }
  ],
  "install_guidance": {
    "plugin": "bitcoin-chart-cli",
    "binary": "bitcoin-chart",
    "check": "which bitcoin-chart",
    "install_steps": [
      "npm install -g bitcoin-chart-cli",
      "Verify: bitcoin-chart --version",
      "supercli plugins install ./plugins/bitcoin-chart-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "bitcoin-chart-cli",
      "resource": "self",
      "action": "version",
      "description": "Print bitcoin-chart-cli version",
      "adapter": "process",
      "adapterConfig": {
        "command": "bitcoin-chart",
        "missingDependencyHelp": "Install bitcoin-chart-cli: npm install -g bitcoin-chart-cli",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "bitcoin-chart-cli",
      "resource": "price",
      "action": "show",
      "description": "show price via bitcoin-chart",
      "adapter": "process",
      "adapterConfig": {
        "command": "bitcoin-chart",
        "missingDependencyHelp": "Install bitcoin-chart-cli: npm install -g bitcoin-chart-cli",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "bitcoin-chart-cli",
      "resource": "_",
      "action": "_",
      "description": "_ _ via bitcoin-chart",
      "adapter": "process",
      "adapterConfig": {
        "command": "bitcoin-chart",
        "missingDependencyHelp": "Install bitcoin-chart-cli: npm install -g bitcoin-chart-cli",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}