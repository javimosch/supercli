{
  "name": "context-mode",
  "version": "0.1.0",
  "description": "Context window optimization for AI coding agents. Sandboxes tool output with up to 98% reduction across 12 platforms. Includes sandbox tools (ctx_search, ctx_index, ctx_execute) and meta-tools (ctx_stats, ctx_doctor, ctx_insight).",
  "source": "https://github.com/mksglu/context-mode",
  "checks": [
    { "type": "binary", "name": "context-mode" }
  ],
  "install_guidance": {
    "plugin": "context-mode",
    "binary": "context-mode",
    "check": "which context-mode",
    "install_steps": [
      "npm install -g context-mode",
      "Verify: context-mode --version",
      "supercli plugins install ./plugins/context-mode --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "context-mode",
      "resource": "self",
      "action": "version",
      "description": "Print context-mode version",
      "adapter": "process",
      "adapterConfig": {
        "command": "context-mode",
        "baseArgs": ["--version"],
        "missingDependencyHelp": "Install context-mode: npm install -g context-mode"
      },
      "args": []
    },
    {
      "namespace": "context-mode",
      "resource": "ctx",
      "action": "doctor",
      "description": "Validate context-mode installation and runtimes",
      "adapter": "process",
      "adapterConfig": {
        "command": "context-mode",
        "baseArgs": ["ctx-doctor"],
        "passthrough": true,
        "missingDependencyHelp": "Install context-mode: npm install -g context-mode"
      },
      "args": []
    },
    {
      "namespace": "context-mode",
      "resource": "ctx",
      "action": "stats",
      "description": "Show context-mode statistics",
      "adapter": "process",
      "adapterConfig": {
        "command": "context-mode",
        "baseArgs": ["ctx-stats"],
        "passthrough": true,
        "missingDependencyHelp": "Install context-mode: npm install -g context-mode"
      },
      "args": []
    },
    {
      "namespace": "context-mode",
      "resource": "ctx",
      "action": "search",
      "description": "Search the knowledge base",
      "adapter": "process",
      "adapterConfig": {
        "command": "context-mode",
        "baseArgs": ["ctx_search"],
        "passthrough": true,
        "missingDependencyHelp": "Install context-mode: npm install -g context-mode"
      },
      "args": [
        { "name": "query", "type": "string", "required": true, "description": "Search query" }
      ]
    },
    {
      "namespace": "context-mode",
      "resource": "ctx",
      "action": "index",
      "description": "Index files or content into the knowledge base",
      "adapter": "process",
      "adapterConfig": {
        "command": "context-mode",
        "baseArgs": ["ctx_index"],
        "passthrough": true,
        "missingDependencyHelp": "Install context-mode: npm install -g context-mode"
      },
      "args": [
        { "name": "files", "type": "string", "required": true, "description": "Files or directories to index" }
      ]
    },
    {
      "namespace": "context-mode",
      "resource": "ctx",
      "action": "execute",
      "description": "Execute a command within the sandbox",
      "adapter": "process",
      "adapterConfig": {
        "command": "context-mode",
        "baseArgs": ["ctx_execute"],
        "passthrough": true,
        "missingDependencyHelp": "Install context-mode: npm install -g context-mode"
      },
      "args": [
        { "name": "command", "type": "string", "required": true, "description": "Command to execute in sandbox" }
      ]
    },
    {
      "namespace": "context-mode",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to context-mode CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "context-mode",
        "passthrough": true,
        "missingDependencyHelp": "Install context-mode: npm install -g context-mode"
      },
      "args": []
    }
  ]
}
