{
  "name": "context-mode",
  "version": "0.1.0",
  "description": "Context window optimization for AI coding agents. Auto-registers as MCP server. Includes knowledge base via SKILL.md.",
  "source": "https://github.com/mksglu/context-mode",
  "checks": [
    { "type": "binary", "name": "context-mode" }
  ],
  "server_resources": {
    "mcp": [
      {
        "name": "context-mode",
        "command": "context-mode",
        "args": [],
        "stateful": true
      }
    ]
  },
  "install_guidance": {
    "plugin": "context-mode",
    "binary": "context-mode",
    "check": "which context-mode",
    "install_steps": [
      "npm install -g context-mode",
      "supercli plugins install ./plugins/context-mode --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "post_install": {
    "script": "scripts/post-install.js",
    "runtime": "node",
    "timeout_ms": 15000
  },
  "post_uninstall": {
    "script": "scripts/post-uninstall.js",
    "runtime": "node",
    "timeout_ms": 15000
  },
  "commands": []
}
