{
  "plugin": "ship-safe",
  "binary": "ship-safe",
  "check": "which ship-safe",
  "install_steps": [
    "npm install -g ship-safe",
    "Verify: ship-safe --version",
    "supercli plugins install ./plugins/ship-safe --on-conflict replace --json"
  ],
  "note": "Requires Node.js 18+ for the CLI. Run 'ship-safe doctor' to verify environment setup."
}
