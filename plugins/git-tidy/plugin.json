{
  "name": "git-tidy",
  "version": "0.1.0",
  "description": "Tidy up stale git branches",
  "source": "https://github.com/drewwyatt/git-tidy",
  "checks": [
    { "type": "binary", "name": "git-tidy" }
  ],
  "install_guidance": {
    "plugin": "git-tidy",
    "binary": "git-tidy",
    "check": "which git-tidy",
    "install_steps": [
      "cargo install git-tidy",
      "Verify: git-tidy --help",
      "supercli plugins install ./plugins/git-tidy --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "git-tidy",
      "resource": "tidy",
      "action": "branches",
      "description": "Tidy up stale git branches",
      "adapter": "process",
      "adapterConfig": {
        "command": "git-tidy",
        "cwd": "invoke_cwd",
        "timeout_ms": 60000,
        "missingDependencyHelp": "Install git-tidy: cargo install git-tidy"
      },
      "args": []
    },
    {
      "namespace": "git-tidy",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to git-tidy CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "git-tidy",
        "cwd": "invoke_cwd",
        "passthrough": true,
        "missingDependencyHelp": "Install git-tidy: cargo install git-tidy"
      },
      "args": []
    }
  ]
}
