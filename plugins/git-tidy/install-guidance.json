{
  "plugin": "git-tidy",
  "binary": "git-tidy",
  "check": "which git-tidy",
  "install_steps": [
    "cargo install git-tidy",
    "Verify: git-tidy --help",
    "supercli plugins install ./plugins/git-tidy --on-conflict replace --json"
  ],
  "note": "git-tidy provides stale git branch cleanup"
}
