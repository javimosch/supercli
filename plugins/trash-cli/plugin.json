{
  "name": "trash-cli",
  "version": "0.1.0",
  "description": "Move files and folders to the trash",
  "source": "https://github.com/sindresorhus/trash-cli",
  "checks": [
    {
      "type": "binary",
      "name": "trash"
    }
  ],
  "install_guidance": {
    "plugin": "trash-cli",
    "binary": "trash",
    "check": "which trash",
    "install_steps": [
      "npm install -g trash-cli",
      "Verify: trash --version",
      "supercli plugins install ./plugins/trash-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "trash-cli",
      "resource": "self",
      "action": "version",
      "description": "Print trash-cli version",
      "adapter": "process",
      "adapterConfig": {
        "command": "trash",
        "missingDependencyHelp": "Install trash-cli: npm install -g trash-cli",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "trash-cli",
      "resource": "file",
      "action": "trash",
      "description": "trash file via trash",
      "adapter": "process",
      "adapterConfig": {
        "command": "trash",
        "missingDependencyHelp": "Install trash-cli: npm install -g trash-cli",
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "trash-cli",
      "resource": "_",
      "action": "_",
      "description": "_ _ via trash",
      "adapter": "process",
      "adapterConfig": {
        "command": "trash",
        "missingDependencyHelp": "Install trash-cli: npm install -g trash-cli",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}