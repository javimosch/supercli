{
  "name": "dry",
  "version": "0.1.0",
  "description": "A Docker manager for the terminal. Monitor and manage Docker containers, images, networks, and volumes from a terminal-based interface.",
  "source": "https://github.com/moncho/dry",
  "checks": [
    { "type": "binary", "name": "dry" }
  ],
  "install_guidance": {
    "plugin": "dry",
    "binary": "dry",
    "check": "which dry",
    "install_steps": [
      "brew install dry",
      "Verify: dry --version",
      "supercli plugins install ./plugins/dry --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "dry",
      "resource": "docker",
      "action": "monitor",
      "description": "Monitor Docker containers and resources",
      "adapter": "process",
      "adapterConfig": {
        "command": "dry",
        "baseArgs": [],
        "passthrough": true,
        "missingDependencyHelp": "Install dry: brew install dry"
      },
      "args": [
        { "name": "--host", "type": "string", "description": "Docker daemon host" }
      ]
    },
    {
      "namespace": "dry",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to dry CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "dry",
        "passthrough": true,
        "missingDependencyHelp": "Install dry: brew install dry"
      },
      "args": []
    }
  ]
}
