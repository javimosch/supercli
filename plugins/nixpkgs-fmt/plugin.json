{
  "name": "nixpkgs-fmt",
  "version": "0.1.0",
  "description": "Nix code formatter for nixpkgs. Format Nix expressions and configurations according to nixpkgs style guidelines.",
  "source": "https://github.com/nix-community/nixpkgs-fmt",
  "checks": [
    { "type": "binary", "name": "nixpkgs-fmt" }
  ],
  "install_guidance": {
    "plugin": "nixpkgs-fmt",
    "binary": "nixpkgs-fmt",
    "check": "which nixpkgs-fmt",
    "install_steps": [
      "brew install nixpkgs-fmt",
      "Verify: nixpkgs-fmt --version",
      "supercli plugins install ./plugins/nixpkgs-fmt --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "nixpkgs-fmt",
      "resource": "nix",
      "action": "format",
      "description": "Format Nix code",
      "adapter": "process",
      "adapterConfig": {
        "command": "nixpkgs-fmt",
        "passthrough": true,
        "missingDependencyHelp": "Install nixpkgs-fmt: brew install nixpkgs-fmt"
      },
      "args": [
        { "name": "file", "type": "string", "description": "Nix file to format" },
        { "name": "--check", "type": "boolean", "description": "Check without modifying" },
        { "name": "--write", "type": "boolean", "description": "Write changes to file" },
        { "name": "--verify", "type": "boolean", "description": "Verify formatting" }
      ]
    },
    {
      "namespace": "nixpkgs-fmt",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to nixpkgs-fmt CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "nixpkgs-fmt",
        "passthrough": true,
        "missingDependencyHelp": "Install nixpkgs-fmt: brew install nixpkgs-fmt"
      },
      "args": []
    }
  ]
}
