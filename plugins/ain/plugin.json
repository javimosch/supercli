{
  "name": "ain",
  "version": "0.1.0",
  "description": "HTTP API client for the terminal",
  "source": "https://github.com/jonaslu/ain",
  "checks": [
    {
      "type": "binary",
      "name": "ain"
    }
  ],
  "install_guidance": {
    "plugin": "ain",
    "binary": "ain",
    "check": "which ain",
    "install_steps": [
      "brew install ain",
      "Verify: ain --version",
      "supercli plugins install ./plugins/ain --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "ain",
      "resource": "self",
      "action": "version",
      "description": "Print ain version",
      "adapter": "process",
      "adapterConfig": {
        "command": "ain",
        "missingDependencyHelp": "Install ain: brew install ain",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "ain",
      "resource": "request",
      "action": "execute",
      "description": "execute request via ain",
      "adapter": "process",
      "adapterConfig": {
        "command": "ain",
        "missingDependencyHelp": "Install ain: brew install ain",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "ain",
      "resource": "_",
      "action": "_",
      "description": "_ _ via ain",
      "adapter": "process",
      "adapterConfig": {
        "command": "ain",
        "missingDependencyHelp": "Install ain: brew install ain",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}