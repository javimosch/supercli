{
  "name": "dnspyre",
  "version": "0.1.0",
  "description": "CLI tool for a high QPS DNS benchmark",
  "source": "https://github.com/Tantalor93/dnspyre",
  "checks": [
    {
      "type": "binary",
      "name": "dnspyre"
    }
  ],
  "install_guidance": {
    "plugin": "dnspyre",
    "binary": "dnspyre",
    "check": "which dnspyre",
    "install_steps": [
      "brew install dnspyre",
      "Verify: dnspyre --version",
      "supercli plugins install ./plugins/dnspyre --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "dnspyre",
      "resource": "self",
      "action": "version",
      "description": "Print dnspyre version",
      "adapter": "process",
      "adapterConfig": {
        "command": "dnspyre",
        "missingDependencyHelp": "Install dnspyre: brew install dnspyre",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "dnspyre",
      "resource": "server",
      "action": "benchmark",
      "description": "benchmark server via dnspyre",
      "adapter": "process",
      "adapterConfig": {
        "command": "dnspyre",
        "missingDependencyHelp": "Install dnspyre: brew install dnspyre",
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "dnspyre",
      "resource": "_",
      "action": "_",
      "description": "_ _ via dnspyre",
      "adapter": "process",
      "adapterConfig": {
        "command": "dnspyre",
        "missingDependencyHelp": "Install dnspyre: brew install dnspyre",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}