{
  "plugin": "wstunnel",
  "binary": "wstunnel",
  "check": "which wstunnel",
  "install_steps": [
    "Download from https://github.com/erebe/wstunnel/releases",
    "Extract and add to PATH",
    "Verify: wstunnel --version",
    "supercli plugins install ./plugins/wstunnel --on-conflict replace --json"
  ],
  "note": "Also available via Docker: docker pull ghcr.io/erebe/wstunnel:latest"
}