{
  "name": "quarto",
  "version": "0.1.0",
  "description": "Open-source scientific and technical publishing system",
  "source": "https://github.com/quarto-dev/quarto-cli",
  "checks": [
    {
      "type": "binary",
      "name": "quarto"
    }
  ],
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "quarto",
      "resource": "document",
      "action": "render",
      "description": "Render document",
      "adapter": "process",
      "adapterConfig": {
        "command": "quarto",
        "baseArgs": [
          "render"
        ],
        "passthrough": true
      },
      "args": [
        {
          "name": "file",
          "type": "string",
          "required": true,
          "description": "File to render"
        }
      ]
    },
    {
      "namespace": "quarto",
      "resource": "preview",
      "action": "document",
      "description": "Preview document",
      "adapter": "process",
      "adapterConfig": {
        "command": "quarto",
        "baseArgs": [
          "preview"
        ],
        "passthrough": true
      },
      "args": [
        {
          "name": "file",
          "type": "string",
          "required": true,
          "description": "File to preview"
        }
      ]
    }
  ]
}