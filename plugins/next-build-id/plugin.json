{
  "name": "next-build-id",
  "version": "0.1.0",
  "description": "Generate unique build IDs for Next.js applications",
  "source": "https://github.com/nexdrew/next-build-id",
  "checks": [
    {
      "type": "binary",
      "name": "next-build-id"
    }
  ],
  "install_guidance": {
    "plugin": "next-build-id",
    "binary": "next-build-id",
    "check": "which next-build-id",
    "install_steps": [
      "npm install -g next-build-id",
      "Verify: next-build-id --version",
      "supercli plugins install ./plugins/next-build-id --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "next-build-id",
      "resource": "self",
      "action": "version",
      "description": "Print next-build-id version",
      "adapter": "process",
      "adapterConfig": {
        "command": "next-build-id",
        "missingDependencyHelp": "Install next-build-id: npm install -g next-build-id",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "next-build-id",
      "resource": "build",
      "action": "generate",
      "description": "generate build via next-build-id",
      "adapter": "process",
      "adapterConfig": {
        "command": "next-build-id",
        "missingDependencyHelp": "Install next-build-id: npm install -g next-build-id",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "next-build-id",
      "resource": "_",
      "action": "_",
      "description": "_ _ via next-build-id",
      "adapter": "process",
      "adapterConfig": {
        "command": "next-build-id",
        "missingDependencyHelp": "Install next-build-id: npm install -g next-build-id",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}