{
  "name": "TokenTracker",
  "version": "0.1.0",
  "description": "Track and display cryptocurrency token prices",
  "source": "https://github.com/mm7894215/TokenTracker",
  "checks": [
    {
      "type": "binary",
      "name": "tokentracker"
    }
  ],
  "install_guidance": {
    "plugin": "TokenTracker",
    "binary": "tokentracker",
    "check": "which tokentracker",
    "install_steps": [
      "npm install -g tokentracker",
      "Verify: tokentracker --version",
      "supercli plugins install ./plugins/TokenTracker --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "TokenTracker",
      "resource": "self",
      "action": "version",
      "description": "Print TokenTracker version",
      "adapter": "process",
      "adapterConfig": {
        "command": "tokentracker",
        "missingDependencyHelp": "Install TokenTracker: npm install -g tokentracker",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "TokenTracker",
      "resource": "token",
      "action": "track",
      "description": "track token via tokentracker",
      "adapter": "process",
      "adapterConfig": {
        "command": "tokentracker",
        "missingDependencyHelp": "Install TokenTracker: npm install -g tokentracker",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "TokenTracker",
      "resource": "market",
      "action": "list",
      "description": "list market via tokentracker",
      "adapter": "process",
      "adapterConfig": {
        "command": "tokentracker",
        "missingDependencyHelp": "Install TokenTracker: npm install -g tokentracker",
        "baseArgs": [
          "--list"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "TokenTracker",
      "resource": "_",
      "action": "_",
      "description": "_ _ via tokentracker",
      "adapter": "process",
      "adapterConfig": {
        "command": "tokentracker",
        "missingDependencyHelp": "Install TokenTracker: npm install -g tokentracker",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}