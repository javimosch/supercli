{
  "name": "puml-for-markdown",
  "version": "0.1.0",
  "description": "Generate PlantUML diagrams for Markdown files",
  "source": "https://github.com/danielyaa5/puml-for-markdown",
  "checks": [
    {
      "type": "binary",
      "name": "puml-for-markdown"
    }
  ],
  "install_guidance": {
    "plugin": "puml-for-markdown",
    "binary": "puml-for-markdown",
    "check": "which puml-for-markdown",
    "install_steps": [
      "npm install -g puml-for-markdown",
      "Verify: puml-for-markdown --version",
      "supercli plugins install ./plugins/puml-for-markdown --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "puml-for-markdown",
      "resource": "self",
      "action": "version",
      "description": "Print puml-for-markdown version",
      "adapter": "process",
      "adapterConfig": {
        "command": "puml-for-markdown",
        "missingDependencyHelp": "Install puml-for-markdown: npm install -g puml-for-markdown",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "puml-for-markdown",
      "resource": "file",
      "action": "generate",
      "description": "generate file via puml-for-markdown",
      "adapter": "process",
      "adapterConfig": {
        "command": "puml-for-markdown",
        "missingDependencyHelp": "Install puml-for-markdown: npm install -g puml-for-markdown",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "puml-for-markdown",
      "resource": "_",
      "action": "_",
      "description": "_ _ via puml-for-markdown",
      "adapter": "process",
      "adapterConfig": {
        "command": "puml-for-markdown",
        "missingDependencyHelp": "Install puml-for-markdown: npm install -g puml-for-markdown",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}