{
  "name": "gitmoji-cli",
  "version": "0.1.0",
  "description": "Interactive CLI for using emojis on commits",
  "source": "https://github.com/carloscuesta/gitmoji-cli",
  "checks": [
    {
      "type": "binary",
      "name": "gitmoji"
    }
  ],
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "gitmoji",
      "resource": "commit",
      "action": "interactive",
      "description": "Interactive commit with emoji",
      "adapter": "process",
      "adapterConfig": {
        "command": "gitmoji",
        "passthrough": true
      },
      "args": [
        {
          "name": "--commit",
          "type": "boolean",
          "description": "Commit changes"
        }
      ]
    },
    {
      "namespace": "gitmoji",
      "resource": "list",
      "action": "show",
      "description": "List all gitmojis",
      "adapter": "process",
      "adapterConfig": {
        "command": "gitmoji",
        "baseArgs": [
          "-l"
        ],
        "passthrough": true
      }
    }
  ]
}