{
  "plugin": "gitmoji-cli",
  "binary": "gitmoji",
  "check": "which gitmoji",
  "install_steps": [
    "npm install -g gitmoji-cli",
    "Verify: gitmoji --version",
    "supercli plugins install ./plugins/gitmoji-cli --on-conflict replace --json"
  ],
  "note": "Source: https://github.com/carloscuesta/gitmoji-cli (4,826 stars). Written in nodejs."
}