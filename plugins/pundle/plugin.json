{
  "name": "pundle",
  "version": "0.1.0",
  "description": "Fast JavaScript bundler with hot reload",
  "source": "https://github.com/steelbrain/pundle",
  "checks": [
    {
      "type": "binary",
      "name": "pundle"
    }
  ],
  "install_guidance": {
    "plugin": "pundle",
    "binary": "pundle",
    "check": "which pundle",
    "install_steps": [
      "npm install -g pundle",
      "Verify: pundle --version",
      "supercli plugins install ./plugins/pundle --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "pundle",
      "resource": "self",
      "action": "version",
      "description": "Print pundle version",
      "adapter": "process",
      "adapterConfig": {
        "command": "pundle",
        "missingDependencyHelp": "Install pundle: npm install -g pundle",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "pundle",
      "resource": "bundle",
      "action": "build",
      "description": "build bundle via pundle",
      "adapter": "process",
      "adapterConfig": {
        "command": "pundle",
        "missingDependencyHelp": "Install pundle: npm install -g pundle",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "pundle",
      "resource": "_",
      "action": "_",
      "description": "_ _ via pundle",
      "adapter": "process",
      "adapterConfig": {
        "command": "pundle",
        "missingDependencyHelp": "Install pundle: npm install -g pundle",
        "passthrough": true,
        "cwd": "invoke_cwd"
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}