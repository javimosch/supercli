{
  "name": "reflex",
  "version": "0.1.0",
  "description": "Run a command when files change",
  "source": "https://github.com/cespare/reflex",
  "checks": [
    {
      "type": "binary",
      "name": "reflex"
    }
  ],
  "install_guidance": {
    "plugin": "reflex",
    "binary": "reflex",
    "check": "which reflex",
    "install_steps": [
      "brew install reflex",
      "Verify: reflex --version",
      "supercli plugins install ./plugins/reflex --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "reflex",
      "resource": "self",
      "action": "version",
      "description": "Print reflex version",
      "adapter": "process",
      "adapterConfig": {
        "command": "reflex",
        "missingDependencyHelp": "Install reflex: brew install reflex",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "reflex",
      "resource": "watch",
      "action": "start",
      "description": "start watch via reflex",
      "adapter": "process",
      "adapterConfig": {
        "command": "reflex",
        "missingDependencyHelp": "Install reflex: brew install reflex",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "reflex",
      "resource": "_",
      "action": "_",
      "description": "_ _ via reflex",
      "adapter": "process",
      "adapterConfig": {
        "command": "reflex",
        "missingDependencyHelp": "Install reflex: brew install reflex",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}