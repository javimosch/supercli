{
  "name": "git-labelmaker",
  "version": "0.1.0",
  "description": "CLI tool for creating and editing GitHub labels",
  "source": "https://github.com/himynameisdave/git-labelmaker",
  "checks": [
    {
      "type": "binary",
      "name": "git-labelmaker"
    }
  ],
  "install_guidance": {
    "plugin": "git-labelmaker",
    "binary": "git-labelmaker",
    "check": "which git-labelmaker",
    "install_steps": [
      "npm install -g git-labelmaker",
      "Verify: git-labelmaker --version",
      "supercli plugins install ./plugins/git-labelmaker --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "git-labelmaker",
      "resource": "self",
      "action": "version",
      "description": "Print git-labelmaker version",
      "adapter": "process",
      "adapterConfig": {
        "command": "git-labelmaker",
        "missingDependencyHelp": "Install git-labelmaker: npm install -g git-labelmaker",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "git-labelmaker",
      "resource": "label",
      "action": "create",
      "description": "create label via git-labelmaker",
      "adapter": "process",
      "adapterConfig": {
        "command": "git-labelmaker",
        "missingDependencyHelp": "Install git-labelmaker: npm install -g git-labelmaker",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "git-labelmaker",
      "resource": "label",
      "action": "edit",
      "description": "edit label via git-labelmaker",
      "adapter": "process",
      "adapterConfig": {
        "command": "git-labelmaker",
        "missingDependencyHelp": "Install git-labelmaker: npm install -g git-labelmaker",
        "baseArgs": [
          "edit"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "git-labelmaker",
      "resource": "_",
      "action": "_",
      "description": "_ _ via git-labelmaker",
      "adapter": "process",
      "adapterConfig": {
        "command": "git-labelmaker",
        "missingDependencyHelp": "Install git-labelmaker: npm install -g git-labelmaker",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}