{
  "name": "cleed",
  "version": "0.1.0",
  "description": "Feed reader for the command line",
  "source": "https://github.com/radulucut/cleed",
  "checks": [
    {
      "type": "binary",
      "name": "cleed"
    }
  ],
  "install_guidance": {
    "plugin": "cleed",
    "binary": "cleed",
    "check": "which cleed",
    "install_steps": [
      "go install github.com/radulucut/cleed@latest",
      "Verify: cleed --version",
      "supercli plugins install ./plugins/cleed --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "cleed",
      "resource": "self",
      "action": "version",
      "description": "Print cleed version",
      "adapter": "process",
      "adapterConfig": {
        "command": "cleed",
        "missingDependencyHelp": "Install cleed: go install github.com/radulucut/cleed@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "cleed",
      "resource": "feed",
      "action": "read",
      "description": "read feed via cleed",
      "adapter": "process",
      "adapterConfig": {
        "command": "cleed",
        "missingDependencyHelp": "Install cleed: go install github.com/radulucut/cleed@latest",
        "baseArgs": [],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "cleed",
      "resource": "feed",
      "action": "list",
      "description": "list feed via cleed",
      "adapter": "process",
      "adapterConfig": {
        "command": "cleed",
        "missingDependencyHelp": "Install cleed: go install github.com/radulucut/cleed@latest",
        "baseArgs": [
          "--list"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "cleed",
      "resource": "feed",
      "action": "add",
      "description": "add feed via cleed",
      "adapter": "process",
      "adapterConfig": {
        "command": "cleed",
        "missingDependencyHelp": "Install cleed: go install github.com/radulucut/cleed@latest",
        "baseArgs": [
          "--add"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
