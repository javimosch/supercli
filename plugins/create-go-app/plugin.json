{
  "name": "create-go-app",
  "version": "0.1.0",
  "description": "A complete and self-contained solution for developers to create production-ready projects with backend (Go), frontend, and deploy automation by running only one CLI command.",
  "source": "https://github.com/create-go-app/cli",
  "checks": [
    { "type": "binary", "name": "create-go-app" }
  ],
  "install_guidance": {
    "plugin": "create-go-app",
    "binary": "create-go-app",
    "check": "which create-go-app",
    "install_steps": [
      "brew install create-go-app",
      "Verify: create-go-app --version",
      "supercli plugins install ./plugins/create-go-app --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "create-go-app",
      "resource": "project",
      "action": "create",
      "description": "Create new Go application",
      "adapter": "process",
      "adapterConfig": {
        "command": "create-go-app",
        "baseArgs": ["create"],
        "passthrough": true,
        "missingDependencyHelp": "Install create-go-app: brew install create-go-app"
      },
      "args": [
        { "name": "name", "type": "string", "description": "Project name" },
        { "name": "--template", "type": "string", "description": "Template to use" },
        { "name": "--framework", "type": "string", "description": "Backend framework" }
      ]
    },
    {
      "namespace": "create-go-app",
      "resource": "_",
      "action": "_",
      "description": "Passthrough to create-go-app CLI",
      "adapter": "process",
      "adapterConfig": {
        "command": "create-go-app",
        "passthrough": true,
        "missingDependencyHelp": "Install create-go-app: brew install create-go-app"
      },
      "args": []
    }
  ]
}
