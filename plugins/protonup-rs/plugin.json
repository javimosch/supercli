{
  "name": "protonup-rs",
  "version": "0.1.0",
  "description": "Automate installation and update of Linux Gaming Compatibility tools",
  "source": "https://github.com/auyer/Protonup-rs",
  "checks": [
    {
      "type": "binary",
      "name": "protonup-rs"
    }
  ],
  "install_guidance": {
    "plugin": "protonup-rs",
    "binary": "protonup-rs",
    "check": "which protonup-rs",
    "install_steps": [
      "cargo install protonup-rs",
      "Verify: protonup-rs --version",
      "supercli plugins install ./plugins/protonup-rs --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "protonup-rs",
      "resource": "self",
      "action": "version",
      "description": "Print protonup-rs version",
      "adapter": "process",
      "adapterConfig": {
        "command": "protonup-rs",
        "missingDependencyHelp": "Install protonup-rs: cargo install protonup-rs",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "protonup-rs",
      "resource": "proton",
      "action": "install",
      "description": "install proton via protonup-rs",
      "adapter": "process",
      "adapterConfig": {
        "command": "protonup-rs",
        "missingDependencyHelp": "Install protonup-rs: cargo install protonup-rs",
        "baseArgs": [
          "install"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "protonup-rs",
      "resource": "proton",
