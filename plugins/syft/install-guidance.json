{
  "plugin": "syft",
  "binary": "syft",
  "check": "which syft",
  "install_steps": [
    "curl -sSfL https://get.anchore.io/syft | sudo sh -s -- -b /usr/local/bin",
    "Verify: syft --version",
    "supercli plugins install ./plugins/syft --on-conflict replace --json"
  ],
  "note": "Also available via: Homebrew, Docker, Scoop, Chocolatey, Nix, MacPorts."
}
