{
  "name": "maestro-cli",
  "version": "0.1.0",
  "description": "Command-line tool to play songs or any audio in the terminal",
  "source": "https://github.com/PrajwalVandana/maestro-cli",
  "checks": [
    {
      "type": "binary",
      "name": "maestro"
    }
  ],
  "install_guidance": {
    "plugin": "maestro-cli",
    "binary": "maestro",
    "check": "which maestro",
    "install_steps": [
      "pip install maestro-cli",
      "Verify: maestro --version",
      "supercli plugins install ./plugins/maestro-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "maestro-cli",
      "resource": "self",
      "action": "version",
      "description": "Print maestro-cli version",
      "adapter": "process",
      "adapterConfig": {
        "command": "maestro",
        "missingDependencyHelp": "Install maestro-cli: pip install maestro-cli",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "maestro-cli",
      "resource": "audio",
      "action": "play",
      "description": "play audio via maestro",
      "adapter": "process",
      "adapterConfig": {
        "command": "maestro",
        "missingDependencyHelp": "Install maestro-cli: pip install maestro-cli",
        "baseArgs": [
          "play"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "maestro-cli",
      "resource": "audio",
      "action": "pause",
      "description": "pause audio via maestro",
      "adapter": "process",
      "adapterConfig": {
        "command": "maestro",
        "missingDependencyHelp": "Install maestro-cli: pip install maestro-cli",
        "baseArgs": [
          "pause"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "maestro-cli",
      "resource": "audio",
      "action": "stop",
      "description": "stop audio via maestro",
      "adapter": "process",
      "adapterConfig": {
        "command": "maestro",
        "missingDependencyHelp": "Install maestro-cli: pip install maestro-cli",
        "baseArgs": [
          "stop"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "maestro-cli",
      "resource": "audio",
      "action": "list",
      "description": "list audio via maestro",
      "adapter": "process",
      "adapterConfig": {
        "command": "maestro",
        "missingDependencyHelp": "Install maestro-cli: pip install maestro-cli",
        "baseArgs": [
          "list"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "maestro-cli",
      "resource": "volume",
      "action": "set",
      "description": "set volume via maestro",
