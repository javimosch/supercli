  "install_guidance": {
    "plugin": "ascii_py",
    "binary": "ascii-py",
    "check": "which ascii-py",
    "install_steps": [
      "pip install ascii_py",
      "Verify: ascii-py --version",
      "supercli plugins install ./plugins/ascii_py --on-conflict replace --json"
