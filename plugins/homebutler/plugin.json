{
  "name": "homebutler",
  "version": "0.1.0",
  "description": "Home automation and device management CLI",
  "source": "https://github.com/Higangssh/homebutler",
  "checks": [
    {
      "type": "binary",
      "name": "homebutler"
    }
  ],
  "install_guidance": {
    "plugin": "homebutler",
    "binary": "homebutler",
    "check": "which homebutler",
    "install_steps": [
      "go install github.com/Higangssh/homebutler@latest",
      "Verify: homebutler --version",
      "supercli plugins install ./plugins/homebutler --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "homebutler",
      "resource": "self",
      "action": "version",
      "description": "Print homebutler version",
      "adapter": "process",
      "adapterConfig": {
        "command": "homebutler",
        "missingDependencyHelp": "Install homebutler: go install github.com/Higangssh/homebutler@latest",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "homebutler",
      "resource": "device",
      "action": "list",
      "description": "list device via homebutler",
      "adapter": "process",
      "adapterConfig": {
        "command": "homebutler",
        "missingDependencyHelp": "Install homebutler: go install github.com/Higangssh/homebutler@latest",
        "baseArgs": [
          "list"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "homebutler",
      "resource": "device",
      "action": "control",
      "description": "control device via homebutler",
      "adapter": "process",
      "adapterConfig": {
        "command": "homebutler",
        "missingDependencyHelp": "Install homebutler: go install github.com/Higangssh/homebutler@latest",
        "baseArgs": [
          "control"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "homebutler",
      "resource": "scene",
      "action": "run",
      "description": "run scene via homebutler",
      "adapter": "process",
      "adapterConfig": {
        "command": "homebutler",
        "missingDependencyHelp": "Install homebutler: go install github.com/Higangssh/homebutler@latest",
        "baseArgs": [
          "scene"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "homebutler",
      "resource": "_",
      "action": "_",
      "description": "_ _ via homebutler",
      "adapter": "process",
      "adapterConfig": {
        "command": "homebutler",
        "missingDependencyHelp": "Install homebutler: go install github.com/Higangssh/homebutler@latest",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}