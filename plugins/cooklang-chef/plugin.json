{
  "name": "cooklang-chef",
  "version": "0.1.0",
  "description": "CLI to manage and organize Cooklang recipes",
  "source": "https://github.com/Zheoni/cooklang-chef",
  "checks": [
    {
      "type": "binary",
      "name": "chef"
    }
  ],
  "install_guidance": {
    "plugin": "cooklang-chef",
    "binary": "chef",
    "check": "which chef",
    "install_steps": [
      "cargo install cooklang-chef",
      "Verify: chef --version",
      "supercli plugins install ./plugins/cooklang-chef --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "cooklang-chef",
      "resource": "self",
      "action": "version",
      "description": "Print cooklang-chef version",
      "adapter": "process",
      "adapterConfig": {
        "command": "chef",
        "missingDependencyHelp": "Install cooklang-chef: cargo install cooklang-chef",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "cooklang-chef",
      "resource": "recipe",
      "action": "list",
      "description": "list recipe via chef",
      "adapter": "process",
      "adapterConfig": {
        "command": "chef",
        "missingDependencyHelp": "Install cooklang-chef: cargo install cooklang-chef",
        "baseArgs": [
          "list"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
