{
  "name": "humble-cli",
  "version": "0.1.0",
  "description": "Command line tool for Humble Bundle purchases and downloads",
  "source": "https://github.com/smbl64/humble-cli",
  "checks": [
    {
      "type": "binary",
      "name": "humble"
    }
  ],
  "install_guidance": {
    "plugin": "humble-cli",
    "binary": "humble",
    "check": "which humble",
    "install_steps": [
      "cargo install humble-cli",
      "Verify: humble --version",
      "supercli plugins install ./plugins/humble-cli --on-conflict replace --json"
    ]
  },
  "learn": {
    "file": "skills/quickstart/SKILL.md"
  },
  "commands": [
    {
      "namespace": "humble-cli",
      "resource": "self",
      "action": "version",
      "description": "Print humble-cli version",
      "adapter": "process",
      "adapterConfig": {
        "command": "humble",
        "missingDependencyHelp": "Install humble-cli: cargo install humble-cli",
        "baseArgs": [
          "--version"
        ]
      },
      "args": []
    },
    {
      "namespace": "humble-cli",
      "resource": "library",
      "action": "list",
      "description": "list library via humble",
      "adapter": "process",
      "adapterConfig": {
        "command": "humble",
        "missingDependencyHelp": "Install humble-cli: cargo install humble-cli",
        "baseArgs": [
          "list"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "humble-cli",
      "resource": "bundle",
      "action": "show",
      "description": "show bundle via humble",
      "adapter": "process",
      "adapterConfig": {
        "command": "humble",
        "missingDependencyHelp": "Install humble-cli: cargo install humble-cli",
        "baseArgs": [
          "show"
        ],
        "passthrough": true,
        "timeout_ms": 30000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "humble-cli",
      "resource": "bundle",
      "action": "download",
      "description": "download bundle via humble",
      "adapter": "process",
      "adapterConfig": {
        "command": "humble",
        "missingDependencyHelp": "Install humble-cli: cargo install humble-cli",
        "baseArgs": [
          "download"
        ],
        "passthrough": true,
        "timeout_ms": 300000
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    },
    {
      "namespace": "humble-cli",
      "resource": "_",
      "action": "_",
      "description": "_ _ via humble",
      "adapter": "process",
      "adapterConfig": {
        "command": "humble",
        "missingDependencyHelp": "Install humble-cli: cargo install humble-cli",
        "passthrough": true
      },
      "args": [
        {
          "name": "args",
          "type": "string",
          "required": false,
          "description": "Additional arguments"
        }
      ]
    }
  ]
}