<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SUPERCLI — Command Control Plane</title>
  <link href="https://cdn.jsdelivr.net/npm/daisyui@4.12.2/dist/full.min.css" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/vue@3/dist/vue.global.prod.js"></script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Newsreader:wght@400;500;600&family=Geist:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap');
    
    body {
      font-family: 'Geist', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background-color: #FBFBFA;
      color: #111111;
      line-height: 1.6;
      min-height: 100vh;
    }
    
    .editorial-heading {
      font-family: 'Newsreader', serif;
      font-weight: 500;
      letter-spacing: -0.02em;
    }
    
    .mono-text {
      font-family: 'JetBrains Mono', monospace;
    }
    
    .nav-active {
      background-color: #F7F6F3;
      color: #111111;
    }
    
    .bento-card {
      background: white;
      border: 1px solid #EAEAEA;
      border-radius: 0.5rem;
      transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    }
    
    .bento-card:hover {
      border-color: #111111;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
    }
    
    .btn {
      border: 1px solid #EAEAEA;
      background: white;
      color: #111111;
      padding: 0.5rem 1rem;
      border-radius: 0.375rem;
      font-weight: 500;
      transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    }
    
    .btn:hover {
      border-color: #111111;
      background: #F7F6F3;
    }
    
    .btn-primary {
      background: #111111;
      color: white;
      border-color: #111111;
    }
    
    .btn-primary:hover {
      background: #333333;
    }
    
    .badge {
      display: inline-block;
      padding: 0.25rem 0.5rem;
      font-size: 0.75rem;
      border-radius: 9999px;
      background: #F7F6F3;
      color: #787774;
    }
    
    .badge-outline {
      background: transparent;
      border: 1px solid #EAEAEA;
    }
  </style>
</head>
<body>

  <div class="flex min-h-screen">
    <!-- Sidebar navigation -->
    <aside class="w-64 bg-white border-r border-[#EAEAEA] p-6">
      <div class="mb-8">
        <h1 class="text-xl font-bold editorial-heading">SUPERCLI</h1>
        <p class="text-sm text-[#787774]">Command Control Plane</p>
      </div>
      <nav class="space-y-2">
        <a href="/api/plugins" class="block px-4 py-2 rounded-lg hover:bg-[#F7F6F3] transition-colors <%= req.path?.startsWith('/api/plugins') ? 'bg-[#F7F6F3]' : '' %>">
          Plugins
        </a>
        <a href="/api/settings" class="block px-4 py-2 rounded-lg hover:bg-[#F7F6F3] transition-colors <%= req.path === '/api/settings' ? 'bg-[#F7F6F3]' : '' %>">
          Settings
        </a>
        <a href="/api/api-keys" class="block px-4 py-2 rounded-lg hover:bg-[#F7F6F3] transition-colors <%= req.path === '/api/api-keys' ? 'bg-[#F7F6F3]' : '' %>">
          API Keys
        </a>
        <a href="/api/commands" class="block px-4 py-2 rounded-lg hover:bg-[#F7F6F3] transition-colors <%= req.path === '/api/commands' ? 'bg-[#F7F6F3]' : '' %>">
          Commands
        </a>
        <a href="/api/jobs" class="block px-4 py-2 rounded-lg hover:bg-[#F7F6F3] transition-colors <%= req.path === '/api/jobs' ? 'bg-[#F7F6F3]' : '' %>">
          Jobs
        </a>
        <a href="/api/clients" class="block px-4 py-2 rounded-lg hover:bg-[#F7F6F3] transition-colors <%= req.path === '/api/clients' ? 'bg-[#F7F6F3]' : '' %>">
          Clients
        </a>
        <a href="/api/adapters" class="block px-4 py-2 rounded-lg hover:bg-[#F7F6F3] transition-colors <%= req.path === '/api/adapters' ? 'bg-[#F7F6F3]' : '' %>">
          Adapters
        </a>
        <a href="/api/specs" class="block px-4 py-2 rounded-lg hover:bg-[#F7F6F3] transition-colors <%= req.path === '/api/specs' ? 'bg-[#F7F6F3]' : '' %>">
          OpenAPI Specs
        </a>
        <a href="/api/mcp" class="block px-4 py-2 rounded-lg hover:bg-[#F7F6F3] transition-colors <%= req.path === '/api/mcp' ? 'bg-[#F7F6F3]' : '' %>">
          MCP Servers
        </a>
      </nav>
    </aside>

    <!-- Main content -->
    <main class="flex-1 p-8 bg-[#FBFBFA]">
      <%- body %>
    </main>
  </div>

  <script src="/static/app.js"></script>
</body>
</html>
