# Storage Configuration
# Set to "true" to use MongoDB, otherwise uses local JSON files
DCLI_USE_MONGO=false
DCLI_STORAGE_DIR=./dcli_storage

# MongoDB connection (only used if DCLI_USE_MONGO=true)
MONGO_URL=mongodb://127.0.0.1:27017
DCLI_DB=dcli

# Server port
PORT=3000

# CLI server URL (used by CLI runtime)
DCLI_SERVER=http://127.0.0.1:3000
